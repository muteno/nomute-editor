  const copyB = document.createElement('button'); copyB.type = 'button'; copyB.className = 'iobtn iobtn-edge iobtn-copy iobtn-hide';   // 복사 = 내용 있을 때만 붙여넣기 좌측(108)에 별도 노출(운영자 260627)
  copyB.innerHTML = COPY_SVG; copyB.setAttribute('aria-label', '복사'); copyB.title = '복사'; wrap.appendChild(copyB);
  const eraser = document.createElement('button'); eraser.type = 'button'; eraser.className = 'iobtn iobtn-edge iobtn-erase';   // 지우개 = 최우측(44) · 칩 비움→~10초 되돌리기(textarea attachCopyPaste 동작 통일·운영자 260628)
  eraser.innerHTML = ERASE_SVG; eraser.setAttribute('aria-label', '입력 지우기'); eraser.title = '입력 지우기'; wrap.appendChild(eraser);
  let undoTimer = null, undoLines = null;
  const exitUndo = () => { if (undoTimer) { clearTimeout(undoTimer); undoTimer = null; } eraser.classList.remove('iobtn-undo'); eraser.innerHTML = ERASE_SVG; eraser.setAttribute('aria-label', '입력 지우기'); eraser.title = '입력 지우기'; if (cardIo) cardIo(); };
  const setIcon = (b, svg, key) => { if (b._icon !== key) { b.innerHTML = svg; b._icon = key; } };   // 동일 아이콘 재대입 안 함 = 칩 편집마다 SVG 재생성(번쩍) 차단(운영자 260628)
  cardIo = () => {   // 붙여넣기 항상 붙여넣기 / 복사는 내용 있을 때만(붙여넣기 유지) / 지우개 = 빈칸 dim
    const filled = buildEmphText().trim().length > 0;
    if (!btn.classList.contains('ok')) { setIcon(btn, PASTE_SVG, 'paste'); btn.dataset.mode = 'paste'; btn.setAttribute('aria-label', '붙여넣기'); btn.title = '붙여넣기'; }
    if (!copyB.classList.contains('ok')) { setIcon(copyB, COPY_SVG, 'copy'); copyB.classList.toggle('iobtn-hide', !filled); }
    if (!eraser.classList.contains('iobtn-undo')) eraser.classList.toggle('iobtn-off', !filled);   // 되돌리기 모드면 유지(흰 픽토·내용 무관 노출)
  };
  copyB.onclick = ev => { ev.preventDefault(); clipCopy(buildEmphText(), copyB, cardIo); };   // 복사 전용
  btn.onclick = async ev => {   // 붙여넣기 전용(기존: 칩 교체)
    ev.preventDefault();
    const t = await clipPasteText(); if (t) { edLines = parseEmphLines(t); if (!edLines.length) edLines = [[]]; renderEditChips(); } cardIo();   // readText→폴백 공용(통일 기틀) · 문자수/줄수 조건은 parseEmphLines(MAX_LINES)·renderEditChips가 보장
  };
  eraser.onclick = ev => {   // 지우개 = 칩 전부 비움 → ~10초 되돌리기(직전 칩 구조 복원·textarea 지우개와 동작 통일)
    ev.preventDefault();
    if (eraser.classList.contains('iobtn-undo')) { if (undoLines) { edLines = undoLines; if (!edLines.length) edLines = [[]]; renderEditChips(); } exitUndo(); return; }   // 되돌리기 = 직전 칩 복원
    if (buildEmphText().trim().length === 0) return;   // 빈칸 = 지울 것 없음
    try { undoLines = JSON.parse(JSON.stringify(edLines)); } catch { undoLines = null; }   // 지운 칩 구조 보관(텍스트 roundtrip 아닌 원본 = 무손실 복원)
    edLines = [[]]; renderEditChips();   // 비움(renderEditChips가 cardIo 호출 → 아래서 undo 상태로 덮음)
    eraser.classList.remove('iobtn-off'); eraser.classList.add('iobtn-undo'); eraser.innerHTML = UNDO_SVG; eraser.setAttribute('aria-label', '되돌리기'); eraser.title = '되돌리기 (직전 입력 복원)';
    if (undoTimer) clearTimeout(undoTimer); undoTimer = setTimeout(exitUndo, ERASE_UNDO_MS);
  };
  cardIo();
})();
// ---- 실시간 자간(tracking) 추정 — 워크플로 measure+sweep의 브라우저판 (글자폭 = PIL 실측 상수) ----
const TRK = {
  post:  { H: 70, S: 17, N: 48, fs: 76, limit: 920, start: 0,  floor: -45 },
  reels: { H: 72, S: 18, N: 48, fs: 78, limit: 844, start: -1, floor: -30 },
};
function lineWidthPx(text, tr, cfg) {   // ΣbbW + tp*(len-1) + 5 (한글 monospace · 약간 보수적)
  const plain = text.replace(/\*/g, '');
  let s = 0; for (const ch of plain) s += /[가-힣ㄱ-ㅎㅏ-ㅣ]/.test(ch) ? cfg.H : ch === ' ' ? cfg.S : cfg.N;
  return s + (tr / 1000 * cfg.fs) * Math.max(plain.length - 1, 0) + 5;
}
function estTracking(lines, fmt) {   // 전 줄이 마진 안에 드는 전역 tr (워크플로 fit_tracking 동일 로직)
  const cfg = TRK[fmt];
  const widest = tr => Math.max(0, ...lines.map(l => lineWidthPx(l, tr, cfg)));
  if (widest(cfg.start) <= cfg.limit) return { tr: cfg.start, swept: false, over: false };
  for (let x = cfg.start; x >= cfg.floor; x--) if (widest(x) <= cfg.limit) return { tr: x, swept: true, over: false };
  return { tr: cfg.floor, swept: true, over: true };
}
function updateTrkHint(taId, hintId, fmt) {   // 자간 줄어들기 시작하면 그때부터 '자간 -N' · 한도 초과 빨강
  const el = $('#' + hintId); if (!el) return;
  const lines = ($('#' + taId).value || '').split('\n').map(s => s.trim()).filter(Boolean);
  const r = lines.length ? estTracking(lines, fmt) : null;
  if (!r || (!r.swept && !r.over)) { el.textContent = ''; el.classList.remove('on', 'over'); return; }   // 여유 = 숨김 (base 클래스 trk·cmtrk 보존 = classList 토글)
  if (r.over) { el.innerHTML = WARN_SVG + ` 자간 ${TRK[fmt].floor}로도 초과 — 축약 필요`; el.classList.remove('on'); el.classList.add('over'); }
  else { el.textContent = `· 자간 ${r.tr} 적용`; el.classList.remove('over'); el.classList.add('on'); }
}
$('#lines').addEventListener('input', () => updateTrkHint('lines', 'linesTrk', 'post'));
// 릴스 자막(cLines) 자간 안내 = updateComboTrk(아래)에서 처리

// ---- 릴스 헤더(부제/제목) 실시간 자간 — reels2 _fit_tr 추정(getlength 기준 · AVAIL 960) ----
const HDR = {
  sub:   { H: 60.72, S: 14.98, N: 38.94, fs: 66, avail: 960, floor: -45 },
  title: { H: 82.80, S: 20.44, N: 53.09, fs: 90, avail: 960, floor: -45 },
};
function estHeaderTr(text, cfg) {   // reels2 _fit_tr(0→-45) 추정
  if (!text) return { tr: 0, over: false };
  const w = tr => { let s = 0; for (const ch of text) s += /[가-힣ㄱ-ㅎㅏ-ㅣ]/.test(ch) ? cfg.H : ch === ' ' ? cfg.S : cfg.N; return s + (tr / 1000 * cfg.fs) * Math.max(text.length - 1, 0); };
  if (w(0) <= cfg.avail) return { tr: 0, over: false };
  for (let x = -1; x >= cfg.floor; x--) if (w(x) <= cfg.avail) return { tr: x, over: false };
  return { tr: cfg.floor, over: true };
}
function renderHdrTrk(elSel, subSel, titleSel) {   // 헤더(부제/제목) reels2 자간 추정 → elSel 표시(헤더 탭·기본 탭 공용) · classList 토글로 base 클래스(cmtrk 등) 보존
  const el = $(elSel); if (!el) return;
  const s = estHeaderTr($(subSel).value.trim(), HDR.sub), t = estHeaderTr($(titleSel).value.trim(), HDR.title);
  const parts = [];
  if (s.over) parts.push('부제 축약필요'); else if (s.tr < 0) parts.push(`부제 자간${s.tr} 적용`);
  if (t.over) parts.push('제목 축약필요'); else if (t.tr < 0) parts.push(`제목 자간${t.tr} 적용`);
  el.textContent = parts.length ? '· ' + parts.join(' · ') : '';
  el.classList.remove('on', 'over');
  if (s.over || t.over) el.classList.add('over'); else if (parts.length) el.classList.add('on');
}
function headerActive() { return !!(($('#cSub') && $('#cSub').value.trim()) || ($('#cTitle') && $('#cTitle').value.trim())); }
function effOvFmt() { return headerActive() ? 'reels' : ovFmt; }   // 헤더 입력 중 = 흰칸(9:16)과 짝 → 오버레이 릴스 강제
function renderOvFmt() {   // • 오버레이 포맷 토글 표시(포스트=시안 / 릴스=레몬 · 헤더 중엔 릴스 고정·dim)
  const t = $('#ovFmtTog'); if (!t) return; const f = effOvFmt(), hl = headerActive();
  t.textContent = f === 'post' ? '포스트' : '릴스';
  t.classList.toggle('post', f === 'post'); t.classList.toggle('reels', f === 'reels'); t.classList.toggle('forced', hl);
  t.setAttribute('aria-label', '오버레이 포맷 ' + t.textContent + (hl ? ' (헤더 입력 중 고정)' : ' (탭=전환)'));   // SR 현재값(분신술8)
}
function updateComboTrk() {   // 썸네일 단일 폼 = 헤더(부제/제목) 자간 + 오버레이 자간(포맷별 한도: 포스트 −45 / 릴스 −30) (운영자 260624)
  renderHdrTrk('#cHdrTrk', '#cSub', '#cTitle');
  renderOvFmt();
  updateTrkHint('cLines', 'cLinesTrk', effOvFmt());   // 포맷에 맞는 자간 한도 실시간 적용(전환 시 초과구간 빨강)
}
$('#cSub').addEventListener('input', updateComboTrk);
$('#cTitle').addEventListener('input', updateComboTrk);
$('#cLines').addEventListener('input', updateComboTrk);
// • 오버레이 포맷 토글(포스트↔릴스) — 헤더 입력 중엔 릴스 강제라 토글 무시. 클릭 시 자간 한도 즉시 전환(전환 = 가능해야 하므로 초과구간 빨강 표시).
(function () {
  const t = $('#ovFmtTog'); if (!t) return;
  const tog = () => { if (headerActive()) return; ovFmt = (ovFmt === 'post') ? 'reels' : 'post'; updateComboTrk(); };
  t.addEventListener('click', tog);
  t.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); tog(); } });
})();

// ---- 발사 ----
function jobLabel() {
  if (APP === '1') return '포스트';
  if (APP === '2') return '릴스';
  if (APP === '3') return '저작권';
  if (APP === '5') return '카드뉴스';
  return '제작';
}
// 제작 = 동시 가능. 누를 때마다 잡 생성 → 로그에 쌓고 각자 폴링(백엔드는 id별 동시처리 안전). #go 비활성 안 함.
let _goLock = false;   // 더블탭 오발사만 방지(짧은 디바운스) — 큐잉 자체는 막지 않음
// 축약 = 기본 4종(정본·절대규칙5·불변) + 사용자 커스텀 쌍(축약 토글 롱프레스 등록·localStorage). 리터럴 치환(split/join = 정규식 이스케이프 불요).
const ABBR_BUILTIN = [['...', '⋯'], ['•', '·'], ['이,', '李,'], ['윤,', '尹,']];   // 정본 4종 — 절대규칙(불변)
const ABBR_STANDALONE = new Set(['이,', '윤,']);   // 성씨(이/윤) = '단독'일 때만 변환 — 앞 글자가 한글 음절이면 이름 일부라 보존(예 "윤가이,"→李 변환 안 함 · 260627)
const ABBR_KEY = 'nomute_thumb_abbr';   // 사용자 커스텀 [{from,to},…]
function abbrCustom() { try { const a = JSON.parse(localStorage.getItem(ABBR_KEY) || '[]'); return Array.isArray(a) ? a.filter(p => p && p.from) : []; } catch { return []; } }
const _abbrEsc = s => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
function abbrStandalone(s, from, to) {   // 앞이 문장 시작·공백·기호(=한글 음절 아님)일 때만 치환. lookbehind 미사용(구형 사파리 호환) → 경계 1글자 보존+안정화 루프(연속 "이,이," 대응)
  const re = new RegExp('(^|[^가-힣])' + _abbrEsc(from), 'g'), rep = '$1' + to;
  let prev; do { prev = s; s = s.replace(re, rep); } while (s !== prev);
  return s;
}
function abbr(s) {
  let out = String(s);
  for (const [from, to] of ABBR_BUILTIN) out = ABBR_STANDALONE.has(from) ? abbrStandalone(out, from, to) : out.split(from).join(to);   // 성씨는 단독만·나머지(…·•)는 리터럴
  for (const p of abbrCustom()) out = out.split(String(p.from)).join(String(p.to == null ? '' : p.to));   // 커스텀(앞뒤 글자까지 from에 넣어 스코프)
  return out;
}
// 잡 1건 생성 → 로그 → 디스패치 → 폴링(비동기·독립). 동시 다발(경고문 듀얼포맷 등) 가능.
// 전송 상태머신: 누르면 '전송 중…'+초록 풀필 → ✓ 체크 그려짐(시안1 스트로크) → '전송됨' → 원복.
function goFire(yellow) {   // yellow=맞춤법 교정 적용 생성 → 게이지·체크 노랑(게이지바 동작은 동일)
  const gb = document.getElementById('go'); if (!gb) return;
  if (!gb.dataset.label) gb.dataset.label = gb.textContent;        // 원래 라벨 보존(재진입 시 덮어쓰기 방지)
  clearTimeout(gb._fT1); clearTimeout(gb._fT2); clearTimeout(gb._fT3); clearTimeout(gb._errT);
  gb.classList.remove('firing', 'okdone', 'checking', 'err', 'warn', 'shake', 'spelling', 'fy', 'spell-arm'); void gb.offsetWidth;    // 리플로우 = 게이지 재시작
  gb.classList.add('firing'); if (yellow) gb.classList.add('fy'); gb.textContent = '전송 중…'; gb.setAttribute('aria-busy', 'true');
  gb._fT1 = setTimeout(() => {                                     // 게이지 완료 → ✓ 체크가 그려짐(시안1)
    gb.classList.remove('firing'); gb.classList.add('okdone', 'checking');   // 'fy'는 유지(노랑 체크)
    gb.innerHTML = '<svg class="gck" viewBox="0 0 24 24" role="img" aria-label="전송됨"><path d="M5 13l4 4L19 7"/></svg>';
    gb.removeAttribute('aria-busy');
    gb._fT2 = setTimeout(() => {                                   // 체크 후 → '전송됨'(이미지 완료 아님 = 진행은 작업카드가 표시)
      gb.classList.remove('checking'); gb.textContent = '전송됨';
      gb._fT3 = setTimeout(() => { gb.classList.remove('okdone', 'fy'); gb.textContent = gb.dataset.label || '이미지 제작'; }, 850);
    }, 560);
  }, 900);
}
function dispatchJob(endpoint, payload, label, src) {
  // 제작 조건 스냅샷(문구·설정)을 서버에도 보존 → 기기 간 '수정' 복원(api/thumb→워크플로 _src.json→build-viewer→thumb-hist.json). 썸네일(/api/thumb)만(카드 /api/compose는 별도 파이프 = 미적용). 이미지 b64는 미동봉(snapForm이 이미 제외·IDB만).
  // 서버 보존본 = imgName(원본 파일명=공개 레포 신규 노출 차단)·imgKey(타 기기서 무의미한 로컬 IDB 키) 제거. imgUsed는 유지(빗금 참고본 분기용). 로컬 src(localStorage)는 원본 유지 = 같은 기기 복원 무손실. (분신술 평의회 3·9·10)
  if (endpoint === '/api/thumb' && src && payload && !payload.src) { const { imgKey, imgName, ...rest } = src; payload.src = rest; }
  goFire(_spellApplied);   // 전송 피드백 = 실제 전송 시점에만(검증 통과·재발사 포함) · 맞춤법 적용 시 노랑 게이지
  clearRestored();   // 새 제작 = 복원된 최근 결과 고스트 치움(새 결과가 맨 위·운영자 260622)
  const job = { n: ++JOBSEQ, label, t0: Date.now(), outs: [], done: [], status: 'run', msg: '', endpoint, payload, src };   // endpoint·payload 보관 = 실패 시 같은 설정 재발사 · src = 제작 조건 스냅샷(수정 복원·운영자 260624)
  JOBS.unshift(job); renderJob(job);
  (async () => {
    try {
      const res = await fetch(endpoint, { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(payload) });
      const j = await res.json();
      if (!res.ok || j.error) { job.status = 'err'; job.msg = (j.error || ('서버 ' + res.status)); renderJob(job); return; }
      job.outs = j.outs || (j.out ? [{ path: j.out, label: '' }] : []);
      job.thid = j.id || thIdOf((job.outs[0] || {}).path) || '';   // 작업 id = 알림 #done=<id> 랜딩 매칭키(api/thumb 반환 id, 없으면 출력경로서 추출)
      job.done = job.outs.map(() => false);
      if (!job.outs.length) { job.status = 'err'; job.msg = '출력 경로 없음'; renderJob(job); return; }
      pollJob(job);
    } catch (e) { job.status = 'err'; job.msg = '요청 실패: ' + e.message; renderJob(job); }
  })();
}
// 한 번의 '제작'이 여러 발사(헤더+자막 · 저작권+안내문)면 → 하나의 잡으로 병합 = 같은 큐 카드에 변형별 개별 다운로드(.jvar-dl) + 전체 다운로드(.jsave) 동시(운영자 260625). 단일 발사면 dispatchJob 그대로(라벨·변형·전체 불변 = 회귀 0).
function dispatchBatch(items, batchLabel, src) {
  if (!items || !items.length) return;
  if (items.length === 1) { dispatchJob(items[0].endpoint, items[0].payload, items[0].label, src); return; }   // 단일 = 기존 경로(원래 라벨·변형·전체 그대로)
  goFire(_spellApplied); clearRestored();
  const job = { n: ++JOBSEQ, label: batchLabel, t0: Date.now(), outs: [], done: [], status: 'run', msg: '', batch: items, src };   // batch = 실패 시 같은 묶음 재발사용
  JOBS.unshift(job); renderJob(job);
  (async () => {
    const groups = await Promise.all(items.map(async it => {
      const payload = it.payload;
      if (it.endpoint === '/api/thumb' && src && payload && !payload.src) { const { imgKey, imgName, ...rest } = src; payload.src = rest; }   // dispatchJob과 동일 src 주입(기기간 '수정' 복원)
      try {
        const res = await fetch(it.endpoint, { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(payload) });
        const j = await res.json();
        if (!res.ok || j.error) return { err: (it.tag || it.label) + ': ' + (j.error || ('서버 ' + res.status)) };
        const outs = j.outs || (j.out ? [{ path: j.out, label: '' }] : []);
        if (!outs.length) return { err: (it.tag || it.label) + ': 출력 경로 없음' };
        return { id: j.id, outs: outs.map(o => ({ path: o.path, label: it.tag + (o.label ? ' ' + o.label : '') })) };   // 변형 라벨에 역할 태그(헤더/자막/저작권/안내문) 접두 = 한 카드서 구분(헤더 흰칸·자막 OPA60 …)
      } catch (e) { return { err: (it.tag || it.label) + ': 요청 실패 ' + e.message }; }
    }));
    const okGroups = groups.filter(g => g && g.outs);
    const errs = groups.filter(g => g && g.err).map(g => g.err);
    job.outs = okGroups.flatMap(g => g.outs);
    job.thid = (groups.find(g => g && g.id) || {}).id || thIdOf((job.outs[0] || {}).path) || '';
    job.done = job.outs.map(() => false);
    if (!job.outs.length) { job.status = 'err'; job.msg = errs.join(' · ') || '출력 경로 없음'; renderJob(job); return; }   // 전부 실패 = 잡 실패(재시도 버튼=배치 재발사)
    if (errs.length) job.partErr = errs.join(' · ');   // 일부만 실패 = 성공분은 폴링·진행, 행에 '일부 실패' 표식
    pollJob(job);   // 전 변형 outs 확정 후 1회 폴링(인덱스 고정 = 도착순 무관 1번부터 노출)
  })();
}
// ── 맞춤법 자동교정 — 제작(글자 카운트/검증) 전에 부산대 검사기로 자유 텍스트 교정(비-LLM·토큰 0) ──
// 대상 = 자유 입력 텍스트 필드만(이름·연도·프리셋·카드 토큰에디터 제외). *별표 강조*는 프록시에서 개수 보존.
function spellTargets() {
  if (APP === '1') return [$('#lines')];
  if (APP === '2') return [$('#cSub'), $('#cTitle'), $('#cLines')];   // 릴스 단일 폼 = 부제·제목·자막
  if (APP === '3' && guideMode) return [$('#warnLines')];   // 저작권 탭의 안내문(ON일 때만) = 자유 텍스트 맞춤법 대상
  return [];   // 3(안내문 OFF) = 이름/연도(고정) · 5 = 카드(토큰 에디터, 후속)
}
// 맞춤법 검사기 건강상태 → localStorage(같은 출처라 index.html 프로필이 읽어 노란 링/메시지 표시·정본 키).
function setSHC(healthy, reason) {
  try { localStorage.setItem('nomute_shc', JSON.stringify({ healthy: !!healthy, ts: Date.now(), reason: reason || '' })); } catch {}
}
function clearSpellReview() {   // 리뷰 폐기 — 칩 숨김·버튼 노랑 해제(앱전환·텍스트편집·생성 시)
  _spellReview = null;
  const c = $('#spellChips'); if (c) { c.hidden = true; c.innerHTML = ''; }
  const gb = $('#go'); if (gb) gb.classList.remove('spell-arm');
}
const spellAnyLit = () => !!(_spellReview && _spellReview.fields.some(f => f.corrections.some(c => c.lit)));
const chipLabel = s => { let x = String(s).replace(/^\*+|\*+$/g, '').trim() || String(s); return x.length > 16 ? x.slice(0, 15) + '…' : x; };   // 칩 표시 = 별표 떼고 길면 줄임
function paintGoReview() {   // 리뷰 중 버튼: 점등 있으면 노랑(재확인) / 다 풀면 초록(맞춤법 안 함)
  const gb = $('#go'); if (!gb) return;
  const lit = spellAnyLit();
  gb.classList.toggle('spell-arm', lit);
  gb.textContent = lit ? '재확인 → 제작' : '이미지 제작 (맞춤법 안 함)';
}
function renderSpellChips() {   // 버튼 아래 칩 = 바뀐 단어만(점등=적용). 탭하면 개별 토글.
  const c = $('#spellChips'); if (!c) return;
  c.innerHTML = ''; let any = false;
  if (_spellReview) _spellReview.fields.forEach(f => f.corrections.forEach(cr => {
    any = true;
    const el = document.createElement('button'); el.type = 'button';
    el.className = 'spchip' + (cr.lit ? ' on' : ''); el.textContent = chipLabel(cr.to);
    el.addEventListener('click', () => { cr.lit = !cr.lit; el.classList.toggle('on', cr.lit); paintGoReview(); });
    c.appendChild(el);
  }));
  c.hidden = !any;
}
// 운영자 교정 사전 — 네이버 맞춤법이 *못 잡는* '둘 다 정상 단어인데 문맥상 틀린' 혼동어(LLM 없이·무료·비차단). [틀린말, 맞는말].
// 네이버는 사전에 있는 단어(예: 선거구 '획정')는 오타로 안 봄 → 운영자가 자주 틀리는 쌍만 큐레이션해 제안 칩으로 띄움(개별 해제 가능). 자주 틀리는 거 생기면 여기에 줄 추가.
const CONFUSE_PAIRS = [
  ['획정', '확정'],   // "32강 탈락 획정→확정" — 둘 다 정상단어라 네이버 미검출(운영자 260628). 시드(이후엔 자가학습으로 누적)
];
// ── 자가학습 교정(A안 + 누적 · 운영자 260628) — 입력칸에서 '한 단어'를 비슷한 단어로 직접 고치면 그 쌍을 기억(localStorage) → 다음부터 자동 제안 칩.
//    오타교정 형태(같은 음절수 · 자모거리 1~2)만 학습 = 본인이 실제 교정한 것만 → 오탐 0. 비-LLM·무과금.
const _LEARN_KEY = 'nomute_spell_learned', _LEARN_CAP = 400, _SPELL_FIELDS = ['lines', 'cSub', 'cTitle', 'cLines', 'warnLines'];
function loadLearned() { try { const o = JSON.parse(localStorage.getItem(_LEARN_KEY) || '{}'); return (o && typeof o === 'object') ? o : {}; } catch { return {}; } }
function saveLearned(m) { try { const e = Object.entries(m); localStorage.setItem(_LEARN_KEY, JSON.stringify(e.length > _LEARN_CAP ? Object.fromEntries(e.slice(e.length - _LEARN_CAP)) : m)); } catch {} }
function spellPairs() { const L = loadLearned(); return CONFUSE_PAIRS.concat(Object.keys(L).map(k => [k, L[k]])); }   // 시드 + 학습 누적
function _jamo(s) { const out = []; for (const ch of s) { const o = ch.charCodeAt(0) - 0xAC00; out.push((o >= 0 && o < 11172) ? [Math.floor(o / 588), Math.floor((o % 588) / 28), o % 28] : [ch]); } return out; }
function _jamoDist(a, b) { if (a.length !== b.length) return 9; const ja = _jamo(a), jb = _jamo(b); let d = 0; for (let i = 0; i < ja.length; i++) { const x = ja[i], y = jb[i]; if (x.length !== 3 || y.length !== 3) { if (x[0] !== y[0]) d += 2; } else { for (let k = 0; k < 3; k++) if (x[k] !== y[k]) d++; } } return d; }
function _learnFromEdit(before, after) {   // before→after = '한 단어만 같은음절수로 자모 1~2 바뀜'이면 오타교정으로 보고 학습
  if (before == null || before === after) return;
  const A = before.match(/[가-힣]{2,}/g) || [], B = after.match(/[가-힣]{2,}/g) || [];
  if (!A.length || A.length !== B.length) return;            // 토큰 수 다름 = 단순 단어교체 아님(새 입력·증감)
  let bad = null, good = null, n = 0;
  for (let i = 0; i < A.length; i++) if (A[i] !== B[i]) { bad = A[i]; good = B[i]; if (++n > 1) return; }   // 정확히 한 단어만 변경
  if (!bad || bad.length !== good.length || bad.length < 2) return;   // 같은 음절수 치환만(조사·활용 변화 제외)
  const jd = _jamoDist(bad, good); if (jd === 0 || jd > 2) return;    // 자모거리 1~2 = 오타교정 형태(전혀 다른 단어 교체 제외)
  const m = loadLearned(); if (m[bad] === good) return; m[bad] = good; saveLearned(m);
  try { const st = $('#status'); if (st) { st.classList.add('ok'); st.classList.remove('err'); st.textContent = '맞춤법 기억: ‘' + bad + '’ → ‘' + good + '’'; setTimeout(() => { if (st.textContent.indexOf('맞춤법 기억') === 0) { st.textContent = ''; st.classList.remove('ok'); } }, 2600); } } catch {}
}
// 포커스 진입 = 스냅 / 떠날 때 = 비교해 학습(제작 버튼 탭도 입력칸 blur라 잡힘)
document.addEventListener('focusin', e => { const el = e.target; if (el && _SPELL_FIELDS.indexOf(el.id) >= 0) el._spSnap = el.value; }, true);
document.addEventListener('focusout', e => { const el = e.target; if (el && _SPELL_FIELDS.indexOf(el.id) >= 0) { _learnFromEdit(el._spSnap, el.value); el._spSnap = el.value; } }, true);
async function runSpellCheck() {   // 1차 누름 = 검사 → _spellReview 구성. 교정 있으면 true(리뷰 진입), 없으면 false(바로 생성). (네이버 + 운영자 교정사전 병합)
  const els = spellTargets().filter(Boolean);
  els.forEach(el => { if (el._spSnap != null && el._spSnap !== el.value) { _learnFromEdit(el._spSnap, el.value); el._spSnap = el.value; } });   // blur 없이 제작 눌러도 교정 학습(안전망)
  const texts = els.map(el => el.value || '');
  if (!texts.some(t => t.trim())) return false;
  const gb = $('#go');
  if (gb) { if (!gb.dataset.label) gb.dataset.label = gb.textContent; gb.classList.add('spelling'); gb.setAttribute('aria-busy', 'true'); gb.textContent = '맞춤법 확인 중…'; }
  let res;
  try {
    const ctrl = new AbortController(); const to = setTimeout(() => ctrl.abort(), 12000);
    try { const r = await fetch('/api/spellcheck', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ texts }), signal: ctrl.signal }); if (r.ok) res = await r.json(); } finally { clearTimeout(to); }
  } catch {}   // 미도달=모호 → 무보정 생성(건강 안 건드림)
  finally { if (gb) { gb.classList.remove('spelling'); gb.removeAttribute('aria-busy'); gb.textContent = gb.dataset.label || '이미지 제작'; } }
  // 네이버 결과 유효성 — 없거나 실패해도 아래 운영자 교정사전은 돈다(비차단)
  const naverOk = !!(res && res.ok && Array.isArray(res.corrected));
  if (res && res.ok === false) setSHC(false, res.error || 'backend');   // 검사기 명시 실패 = 불건강(노란 링)
  else if (naverOk) setSHC(true);
  const fields = [];
  els.forEach((el, i) => {
    const orig = texts[i]; if (!orig) return;
    let corrected = orig; const corrs = [];
    if (naverOk) {
      const nc = (typeof res.corrected[i] === 'string') ? res.corrected[i] : orig;
      const corr = (res.corrections && res.corrections[i]) || [];
      if (corr.length) { corr.forEach(c => corrs.push({ from: c.from, to: c.to, lit: true })); corrected = nc; }
      else if (nc !== orig) { corrs.push({ from: orig, to: nc, lit: true }); corrected = nc; }   // 쌍 못 뽑았지만 교정됨 → 통째 칩(조용한 유실 방지)
    }
    // 운영자 교정사전(시드 + 자가학습 누적) — 네이버가 못 잡는 '정상단어 혼동'(획정→확정 등). 이미 같은 from 있으면 스킵(중복 칩 방지).
    for (const [bad, good] of spellPairs()) {
      if (orig.includes(bad) && !corrs.some(c => c.from === bad)) { corrs.push({ from: bad, to: good, lit: true }); corrected = corrected.split(bad).join(good); }
    }
    if (corrs.length) fields.push({ el, original: orig, corrected, corrections: corrs });
  });
  if (!fields.length) return false;   // 진짜 오타 0(원본=교정) → 리뷰 없이 바로 생성
  _spellReview = { fields };
  return true;
}
function applySpellReview() {   // 2차 누름 = 점등된 교정만 적용. _spellApplied=적용 여부(게이지 색).
  _spellApplied = false;
  if (!_spellReview) return;
  _applyingSpell = true;
  _spellReview.fields.forEach(f => {
    const lits = f.corrections.filter(c => c.lit);
    let val;
    if (!lits.length) val = f.original;                                   // 다 해제 = 원문(맞춤법 안 함)
    else if (lits.length === f.corrections.length) val = f.corrected;     // 다 점등 = 통째 교정(정확)
    else { val = f.original; lits.forEach(c => { val = val.replace(c.from, c.to); }); }   // 일부 = 순차 치환(첫 일치)
    if (lits.length) _spellApplied = true;
    if (val !== f.el.value) { f.el.value = val; f.el.dispatchEvent(new Event('input', { bubbles: true })); }   // 자간 트래커·줄 클램프 갱신
  });
  _applyingSpell = false;
  clearSpellReview();
}
$('#go').onclick = async () => {
  if (_goLock) return; _goLock = true;   // 맞춤법 await 동안 잠금 유지(더블탭 = 중복 교정·디스패치 차단) → finally서 해제
  try {
  // firing(전송 상태머신)은 실제 전송 시점(dispatchJob)에서만 — 검증 실패 시 헛발사 방지
  const status = $('#status'); status.classList.remove('err'); status.textContent = '';
  // 맞춤법 리뷰 게이트(대상 앱만) — 1차=검사→칩 점등(생성 안 함) / 2차=점등분 적용 후 아래 생성. (운영자 260623)
  _spellApplied = false;
  if (spellTargets().length) {
    if (_spellReview) { applySpellReview(); }   // 2차 — 점등 교정 적용(텍스트 갱신) 후 생성으로 진행
    else { const found = await runSpellCheck(); if (found) { renderSpellChips(); paintGoReview(); return; } }   // 1차 — 오타 있으면 리뷰 진입(생성 보류)
  }
  const SRC = snapForm();   // 제작 조건 스냅샷(탭·모드·텍스트·OPA·토글) → 이력 동봉 → 나중에 '수정'으로 작성기 복원(운영자 260624)
  if (APP === '5') {   // 카드뉴스 = /api/compose (축약 미적용)
    if (!IMG.b64) return errStatus('이미지를 선택해주세요');
    if (edAnyOver()) return errStatus('빨간 글자 = 한 줄 한도(한글 18자) 초과 — 줄이거나 + 로 새 줄');
    const clines = buildEmphText().split('\n').map(s => s.trim()).filter(Boolean);
    if (!clines.length) return errStatus('텍스트를 넣어주세요');
    dispatchJob('/api/compose', { imageB64: IMG.b64, name: IMG.name, lines: clines }, '카드뉴스', SRC);
    return;
  }
  if (APP === '3') {   // 저작권(ON일 때) + 안내문(guideMode 선택 시) — 단일 포맷(cpFmt·기본 릴스) 공유 · 채운 것만 발사 (260624)
    const fmt = cpFmt, FL = { post: '포스트', reels: '릴스' };
    const guideLines = guideMode ? ($('#warnLines').value || '').split('\n').map(s => s.trim()).filter(Boolean) : [];
    if (!copyOn && !guideLines.length) return errStatus('저작권을 켜거나 안내문을 골라줘');   // 둘 다 OFF = 만들 게 없음
    if (copyOn && !getName()) return errStatus('이름을 넣어주세요');   // 이름 필수 — 빈 채 발사 차단(백엔드 실패 방지·제작 버튼에 메시지+흔들림 · 운영자 260622)
    const items = [];
    if (copyOn) items.push({ endpoint: '/api/thumb', payload: { app: '3', params: { fmt, year: getYear(), name: getName(), platform: getPlatform() } }, label: '저작권 (' + FL[fmt] + ')', tag: '저작권' });
    if (guideLines.length) items.push({ endpoint: '/api/thumb', payload: { app: '4', params: { fmt, lines: guideLines } }, label: '안내문 (' + FL[fmt] + ')', tag: '안내문' });
    // 저작권+안내문 둘 다면 한 잡으로 병합 · 하나면 기존 단일 경로(운영자 260625)
    dispatchBatch(items, '저작권·안내문 (' + FL[fmt] + ')', SRC);
    return;
  }
  if (APP === '2') {   // 릴스 단일 폼 — 채운 섹션만 발사(B·운영자 260624): 헤더(부제+제목)→흰칸 / 자막→오버레이(OPA60[+30]) / 둘 다→동시. 백엔드(흰칸/오버레이 모드) 불변.
    let csub = $('#cSub').value.trim(), ctitle = $('#cTitle').value.trim();
    let clines = normEmph($('#cLines').value).split('\n').map(s => s.trim()).filter(Boolean);   // 강조 정규화(**·줄걸침 → 줄별 *…*)·260625
    const hasHeader = !!(csub && ctitle), partHeader = !!(csub || ctitle), hasOverlay = clines.length > 0;
    if (partHeader && !hasHeader) return errStatus(csub ? '제목을 넣어주세요' : '부제를 넣어주세요');   // 헤더 시작했으면 둘 다 필요(반쪽 헤더=흰칸 백엔드 불가)
    if (!hasHeader && !hasOverlay) return errStatus('헤더(부제·제목) 또는 자막을 넣어주세요');
    if (hasOverlay && !clines.some(l => /\*[^*]+\*/.test(l))) return errStatus('강조를 넣어주세요', 'warn');   // 자막 강조(*별표*) 필수 — 정규화 후 줄별 검사(**·줄걸침 인식·260625)
    if ($('#abbr').checked) { csub = abbr(csub); ctitle = abbr(ctitle); clines = clines.map(abbr); }   // 축약 = 포스트·릴스 공통
    const items = [];
    if (hasHeader) items.push({ endpoint: '/api/thumb', payload: { app: '2', params: { mode: 'header', sub: csub, title: ctitle, bothBg: $('#cBg').checked } }, label: '릴스 헤더', tag: '헤더' });   // 흰칸(배경 ON = +nobg)
    if (hasOverlay) {
      // 오버레이 포맷 = effOvFmt(헤더 있으면 릴스 강제 / 없으면 토글값). 포스트=4:5(app1/fmt:post) · 릴스=9:16(app2/overlay). 이미지·OPA·축약 공용.
      const f = effOvFmt();
      const ovp = f === 'post'
        ? { app: '1', params: { fmt: 'post', lines: clines, opas: getComboOpas() } }
        : { app: '2', params: { mode: 'overlay', lines: clines, opas: getComboOpas() } };
      if (CIMG.b64) { ovp.imageB64 = CIMG.b64; ovp.name = CIMG.name; }
      items.push({ endpoint: '/api/thumb', payload: ovp, label: f === 'post' ? '포스트' : '릴스 자막', tag: '자막' });
    }
    // 헤더+자막 둘 다면 한 잡으로 병합(같은 큐 카드 · 변형별 개별 + 전체 다운로드) · 하나면 기존 단일 경로(운영자 260625)
    dispatchBatch(items, hasHeader && hasOverlay ? '릴스 헤더·자막' : '릴스', SRC);
    return;
  }
  // /1 포스트 = /api/thumb (릴스·저작권·경고문·카드는 위에서 처리·return)
  const params = buildParams();
  if (APP === '1' && Array.isArray(params.lines)) params.lines = normEmph($('#lines').value).split('\n').map(s => s.trim()).filter(Boolean);   // 강조 정규화(**·줄걸침 → 줄별 *…*)·백엔드 불변·260625
  if (APP === '1' && !(Array.isArray(params.lines) && params.lines.length)) return errStatus('텍스트를 넣어주세요');   // 포스트 = 텍스트 필수 — 빈 채 발사 차단 + 제작 버튼 흔들림(운영자 260622)
  if (APP === '1' && $('#abbr').checked && Array.isArray(params.lines)) params.lines = params.lines.map(abbr);   // 축약 = 포스트(정본 화이트리스트)
  if (APP === '1' && !params.lines.some(l => /\*[^*]+\*/.test(l))) return errStatus('강조를 넣어주세요', 'warn');   // 강조(*별표*) 필수 — 정규화 후 줄별 검사·앰버 버튼 흔들림(운영자 260622·260625)
  const payload = { app: APP, params };
  if (APP === '1' && PIMG.b64) { payload.imageB64 = PIMG.b64; payload.name = PIMG.name; }       // 포스트 배경 = 옵션(슬롯·PIMG)
  dispatchJob('/api/thumb', payload, jobLabel(), SRC);
  } finally { _goLock = false; }   // 동기 종료(검증 return·디스패치) 직후 해제 = 연속 제작 큐잉은 그대로 허용
};
function errStatus(m, cls) {   // 전송 막힘 = 메시지를 버튼 *안에* 액티브로 띄우며 흔들고 1.7s 뒤 원복(운영자 260622). cls 기본 'err'(빨강·미입력) / 'warn'(앰버·강조 누락)
  cls = cls || 'err';
  const s = $('#status'); s.textContent = ''; s.classList.remove('err', 'ok');   // 버튼 밑 별도 메시지 폐지 — 버튼 안에 표시(맞춤법 ok 잔존 클래스도 정리)
  const g = document.getElementById('go'); if (!g) return;
  if (!g.dataset.label) g.dataset.label = g.textContent;        // 원래 라벨 보존(재진입 시 덮어쓰기 방지)
  clearTimeout(g._fT1); clearTimeout(g._fT2); clearTimeout(g._fT3); clearTimeout(g._errT);
  g.classList.remove('firing', 'okdone', 'checking', 'err', 'warn', 'fy', 'spell-arm', 'spelling'); g.removeAttribute('aria-busy');
  g.textContent = m; g.setAttribute('aria-live', 'assertive');  // 메시지 = 버튼 안에
  g.classList.add(cls); g.classList.remove('shake'); void g.offsetWidth; g.classList.add('shake');
  g._errT = setTimeout(() => { g.classList.remove('err', 'warn', 'shake'); g.textContent = g.dataset.label || '이미지 제작'; }, 1700); }

// 다운로드 버튼 표준 클릭효과 = ✓ 팝 + 링 리플(.dlbtn 전 앱 공통 · 위임·캡처 · 운영자 260622)
document.addEventListener('click', e => {
  const b = e.target.closest('.dlbtn'); if (!b) return;
  const o = document.createElement('span'); o.className = 'dl-ack';
  o.innerHTML = '<span class="dl-ring"></span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>';
  if (getComputedStyle(b).position === 'static') b.style.position = 'relative';
  b.appendChild(o); setTimeout(() => o.remove(), 700);
}, true);

// 맞춤법 대상 입력 편집 시 진행 중이던 리뷰 폐기(stale 교정 적용 방지) — 프로그램 적용(applySpellReview) 중엔 무시
['#lines', '#warnLines', '#cSub', '#cTitle', '#cLines'].forEach(id => { const el = $(id); if (el) el.addEventListener('input', () => { if (!_applyingSpell && _spellReview) clearSpellReview(); }); });
selApp('2');   // 기본 탭 = 썸네일(포스트 통합·260624)
renderHist();        // 로컬(이 기기) 즉시 표시
// 자동 맨 위 복원 폐지(운영자 260624) — 평소엔 결과 비움(폼+이력만), 완성 알림 #done=<id> 탭 때만 그 결과를 맨 위로(maybeOpenHist→restoreById)
idbPrune(Date.now() - THUMB_HMS);   // 보관 이미지(IDB) 12h 경과분 정리(이력 보관과 동기 · 운영자 260624)
maybeOpenHist();     // #done=<id>(제작완료 알림) 진입이면 그 결과를 맨 위 큰 결과로 복원·랜딩(서버 병합 후 loadServerHist서 재확인)
loadServerHist();    // 전 기기 제작분(thumb-hist.json) 병합 — 기기간 공유
</script>
<script src="cscroll.js"></script>

<!-- 빠른 메뉴 FAB (우하단·오른엄지) — 중앙 토글 → 9시·10:30·12시 아치 와이프. 2번=컨텍스트 / 3번=이미지 / 4번=도구전환. 운영자 260621. -->
<style>
  #rfab { position:fixed; right:18px; bottom:34%; z-index:70; width:0; height:0; }   /* 위치 = 우측 엄지존. bottom 30%→34% 조금 위로(운영자 260621) */
  /* 코어 = 뉴스 요약 '수정' 연필 FAB(.rev-fab) 외형 계승 — 글래스(반투명+blur+초록 테두리+글로우)·초록 아이콘(운영자 260622) */
  #rfab .rc { position:absolute; right:0; bottom:0; width:54px; height:54px; border-radius:50%; cursor:pointer;
    background:rgba(0,0,0,.34); color:var(--accent); border:1px solid rgba(var(--accent-rgb),.4); display:grid; place-items:center;
    backdrop-filter:blur(14px) saturate(1.3); -webkit-backdrop-filter:blur(14px) saturate(1.3);
    box-shadow:0 10px 26px rgba(0,0,0,.45), inset 0 1px 0 rgba(255,255,255,.12);
    transition:transform .25s; -webkit-tap-highlight-color:transparent; }
  #rfab.open .rc { transform:rotate(135deg); }
  #rfab .rc svg { width:26px; height:26px; stroke:currentColor; stroke-width:2.6; fill:none; stroke-linecap:round; }
  /* 세부 버튼도 코어와 동일 글래스 계승(.rev-fab 외형) — 글로우만 작게(운영자 260622) */
  #rfab .ro { position:absolute; right:7px; bottom:7px; border-radius:50%; cursor:pointer; color:var(--accent);
    background:rgba(0,0,0,.34); border:1px solid rgba(var(--accent-rgb),.4); backdrop-filter:blur(14px) saturate(1.3); -webkit-backdrop-filter:blur(14px) saturate(1.3);
    display:grid; place-items:center; box-shadow:0 6px 16px rgba(0,0,0,.45), inset 0 1px 0 rgba(255,255,255,.1);
    opacity:0; transform:translate(0,0) scale(.3); pointer-events:none;
    transition:transform .32s cubic-bezier(.2,.9,.3,1.25), opacity .22s; -webkit-tap-highlight-color:transparent; }
  #rfab .ro svg { width:19px; height:19px; stroke:currentColor; stroke-width:2; fill:none; stroke-linecap:round; stroke-linejoin:round; }
  #rfab.open .ro { opacity:1; pointer-events:auto; }
  #rfab .ro.off { opacity:.32 !important; pointer-events:none; }
  #rfab .ro[hidden] { display:none; }   /* ⚠️ hidden 봉합 — 위 #rfab .ro{display:grid}(명시도 1,1,0)가 UA [hidden]{display:none}(0,1,0)을 이겨 무력화 → 첨부 시 rfab3↔rfabGen 대체가 시각적으로 안 먹고 *겹쳐 렌더*되던 critical(평의회 260628). #rfab .ro[hidden] 명시도 1,2,0 > 1,1,0이라 !important 불요·ly 통일 */
  #rfab2, #rfab3, #rfab4, #rfabGen { width:35px; height:35px; }   /* 네비 3버튼 크기 = 12시(옛 #rfab4) 35px로 통일(운영자 260628) · rfabGen(▶ 제작)도 동일 */
  /* 빠른메뉴 코어(+) 바로 위·가운데 정렬 글래스 '-' = 창(편집기) 최소화(엄지존 · iframe→부모 minimizeTool · 코어 글래스 계승) · 빠른메뉴 펼치면 서브버튼과 겹치니 반대 촤르륵으로 사라짐 · 운영자 260627 */
  #rfab .rmin { position:absolute; right:13px; bottom:62px; width:28px; height:28px; border-radius:50%; cursor:pointer; color:var(--accent);
    background:rgba(0,0,0,.34); border:0; display:grid; place-items:center;
    backdrop-filter:blur(14px) saturate(1.3); -webkit-backdrop-filter:blur(14px) saturate(1.3);
    transition:transform .32s cubic-bezier(.2,.9,.3,1.25), opacity .22s; -webkit-tap-highlight-color:transparent; }   /* 촤르륵 = 세부버튼(.ro) 스프링 커브 · 테두리·box-shadow(주변부 음영) 제거(운영자 260628) */
  #rfab .rmin svg { width:15px; height:15px; stroke:currentColor; stroke-width:2.6; fill:none; stroke-linecap:round; transition:transform .14s cubic-bezier(.2,.9,.3,1.25); }
  #rfab .rmin:active svg { transform:scale(var(--press-pico,.55)); }   /* 누름 = 버튼 아닌 픽토그램이 축소 = '최소화(창 작아짐)' 표현(운영자 260628) */
  #rfab.open .rmin { opacity:0; transform:translateY(8px) scale(.3); pointer-events:none; }   /* 빠른메뉴 펼침 = 반대 촤르륵으로 스프링 아웃(.ro resting과 동일 scale.3 · 서브버튼 겹침 방지) */
  @media (prefers-reduced-motion:reduce){ #rfab .rmin{ transition:opacity .15s; } #rfab.open .rmin{ transform:none; } #rfab .rmin:active svg{ transition:transform .09s; } }
  /* 픽토그램 중심을 코어 중심 기준 반경 63.5px(=현 12시 간격) 원에 정확히 9시·10:30·12시 배치. 35px .ro 안착중심이 코어보다 (+2.5,+2.5)라 그만큼 보정(운영자 260628). */
  #rfab.open #rfab2 { transform:translate(-66px,-2.5px) scale(1); transition-delay:0s; }        /* 9시 = (-63.5, 0) */
  #rfab.open #rfab3 { transform:translate(-47.4px,-47.4px) scale(1); transition-delay:.06s; }   /* 10:30 = 45°·동일 반경 63.5 */
  #rfab.open #rfabGen { transform:translate(-47.4px,-47.4px) scale(1); transition-delay:.06s; }   /* ▶ 제작 = 이미지선택(rfab3)과 *같은 자리*(10:30) — 사진 첨부 시 이미지선택 버튼을 대체(둘 중 하나만·ly lyFileFab↔lyGenFab 패턴·운영자 260628) */
  #rfab.open #rfab4 { transform:translate(-2.5px,-66px) scale(1); transition-delay:.12s; }      /* 12시 = (0, -63.5)·수직 정렬(드리프트 -2.5 보정) */
  @media (hover:hover) and (pointer:fine) { #rfab { display:none; } }   /* PC(마우스) = 엄지 빠른메뉴 불필요 → 숨김(.cartrack PC 분기와 동일 컨벤션·운영자 260620) */
  @media (prefers-reduced-motion:reduce){ #rfab .rc, #rfab .ro { transition:opacity .15s; } }
</style>
<button id="histRemote" type="button" aria-label="이전 제작 접기"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 15l-6-6-6 6"/></svg>접기</button>
<div id="rfab" aria-label="빠른 메뉴">
  <button class="ro" id="rfab2" type="button" title="전환/이동"><svg viewBox="0 0 24 24"><path d="M7 10l5-5 5 5M7 14l5 5 5-5"/></svg></button>
  <button class="ro" id="rfab3" type="button" title="이미지 선택"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="9.5" r="1.5"/><path d="M21 16l-5-5L5 20"/></svg></button>
  <button class="ro" id="rfabGen" type="button" title="이미지 제작" hidden><svg viewBox="0 0 24 24"><path d="M5 3l14 9-14 9z"/></svg></button>
  <button class="ro" id="rfab4" type="button" title="도구 전환"><svg viewBox="0 0 24 24"><path d="M4 8h13l-3-3M20 16H7l3 3"/></svg></button>
  <button class="rc" id="rfabCore" type="button" aria-label="빠른 메뉴 열기"><svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg></button>
  <button class="rmin" id="rfabMin" type="button" aria-label="최소화" title="최소화 (창 접기)"><svg viewBox="0 0 24 24"><path d="M6 12h12"/></svg></button>
</div>
<script>
(function(){
  var rfab = document.getElementById('rfab'); if (!rfab) return;
  var core = document.getElementById('rfabCore'), b2 = document.getElementById('rfab2'),
      b3 = document.getElementById('rfab3'), b4 = document.getElementById('rfab4'), gen = document.getElementById('rfabGen');
  function imgInput(){ if (APP === '1') return document.getElementById('pFile');
                       if (APP === '2') return document.getElementById('cFile');
                       if (APP === '5') return document.getElementById('file'); return null; }   // 카드뉴스(5) 이미지 선택 = #file/#fileLab 배선(운영자 260628 — FAB 이미지 선택 안먹힘 봉합)
  function curSlot(){ if (APP === '1') return document.getElementById('pImgSlot');   // 첨부 상태 슬롯(.has) = 모드별(포스트 배경·릴스 자막·카드뉴스 #fileLab)
                      if (APP === '2') return document.getElementById('cImgSlot');
                      if (APP === '5') return document.getElementById('fileLab'); return null; }
  function refresh(){   // 이미지 없는 모드(저작권/경고문 = curSlot null) = rfab3 비활성 / 사진 첨부(슬롯 .has) 시 = rfab3(이미지선택) → rfabGen(▶ 제작) 대체(둘 중 하나만·ly lyFileFab↔lyGenFab 패턴·운영자 260628)
    var s = curSlot(), imgMode = !!s;
    var refonly = !!(s && (s.classList.contains('refonly') || s.querySelector('.refonly')));   // 참고본 = 슬롯(APP1/2)·자식 .fileprev(APP5 #fileLab) 어느 쪽이든
    var attached = !!(s && s.classList.contains('has') && !refonly);   // ⚠️ curSlot(라벨·슬롯=영속) 기준 — imgInput(#file)은 카드뉴스 첨부 시 innerHTML 교체로 id 소실 → null이라 못 씀(운영자 버그 #2 근원). refonly(참고본=실데이터 없음·재선택 필요)는 미첨부 취급 → 이미지선택 유지(평의회 E2·ly .has=실파일 정합)
    b3.classList.toggle('off', !imgMode);
    if (gen) { var swap = attached; b3.hidden = swap; gen.hidden = !swap; }   // 첨부됨 = 이미지선택 숨김·▶제작 표시 / 아니면 역(재선택은 슬롯 X/휴지통으로 비운 뒤 복귀)
  }
  window._rfabSyncGen = refresh;   // 외부 호출용(보존)
  ['fileLab','pImgSlot','cImgSlot'].forEach(function(id){ var el = document.getElementById(id); if (el) { try { new MutationObserver(refresh).observe(el, { attributes:true, attributeFilter:['class'] }); } catch(_){} } });   // 첨부/삭제로 슬롯 .has 토글되면 즉시 rfab3(이미지선택)↔rfabGen(▶제작) 대체(6핸들러 개별 훅 대신 단일 관찰자·운영자 260628)
  core.addEventListener('click', function(e){ e.stopPropagation(); rfab.classList.toggle('open'); refresh(); });
  var rmin = document.getElementById('rfabMin');   // '-' = 창 최소화(iframe→부모 minimizeTool, 동일 출처)
  if (rmin) { if (window.parent === window) { rmin.style.display = 'none'; }   // 단독 열기(모달 아님) = 최소화 무의미 → 숨김
    else rmin.addEventListener('click', function(e){ e.stopPropagation(); try { if (parent.minimizeTool) parent.minimizeTool(); } catch (_) {} }); }
  var _rfabKeep = false;   // 세부버튼이 트리거한 합성 click(.click())이 document로 버블 → 메뉴가 닫히던 것 차단(운영자 260621: 전환해도 세부버튼 유지)
  function keepFab(){ _rfabKeep = true; setTimeout(function(){ _rfabKeep = false; }, 0); }
  document.addEventListener('click', function(e){ if (!rfab.contains(e.target) && !_rfabKeep) rfab.classList.remove('open'); });
  function cyc(sel, filt){ var bs = [].slice.call(document.querySelectorAll(sel)); if (filt) bs = bs.filter(filt);
    if (!bs.length) return; var i = bs.findIndex(function(b){ return b.classList.contains('on'); });
    bs[(i + 1 + bs.length) % bs.length].click(); }                 // 기존 버튼 .click() 재사용 = 핸들러 그대로
  b2.addEventListener('click', function(e){ e.stopPropagation(); keepFab();
    if (APP === '2') { var c = document.getElementById('cSub'); if (c) { c.scrollIntoView({ behavior: 'smooth', block: 'center' }); try { c.focus(); } catch (_) {} } }   // 릴스 = 단일 폼(모드 순환 폐지) → 첫 입력칸으로
    else if (APP === '3') { var c3 = document.getElementById('cphName'); if (c3) { c3.scrollIntoView({ behavior: 'smooth', block: 'center' }); try { c3.focus(); } catch (_) {} } }   // 저작권 = 이름 부분으로(탭=수정 · 플랫폼은 팝업 픽토그램)
    else if (APP === '5') { var box = document.getElementById('cardBox'); if (box) box.scrollIntoView({ behavior: 'smooth', block: 'center' });
           var eds = document.querySelectorAll('#edChips .ed-empty'), ed = eds.length ? eds[eds.length - 1] : null;   // #cardBox는 포커스 불가 wrapper → 실제 입력 = 칩 에디터 끝 .ed-empty(contenteditable) 잡고 캐럿 끝(운영자 260628)
           if (ed) { try { ed.focus(); var sel = window.getSelection(), r = document.createRange(); r.selectNodeContents(ed); r.collapse(false); sel.removeAllRanges(); sel.addRange(r); } catch (_) {} } }
    else { var t = document.getElementById('lines');
           if (t) { t.scrollIntoView({ behavior: 'smooth', block: 'center' }); try { t.focus(); } catch (_) {} } }  // 포스트 = 입력칸으로
  });
  b3.addEventListener('click', function(e){ e.stopPropagation(); keepFab();
    var slot = APP === '1' ? document.getElementById('pImgSlot') : APP === '2' ? document.getElementById('cImgSlot') : APP === '5' ? document.getElementById('fileLab') : null;
    if (slot) slot.scrollIntoView({ behavior: 'smooth', block: 'center' });   // 사진 첨부 = 첨부 위치(이미지 슬롯)로 이동(운영자 260626)
    if (APP === '5') { var fi = slot && slot.querySelector('input[type=file]'); if (fi) fi.click(); }   // 카드뉴스 = #fileLab 내부 input 직접 클릭(applyImg/reset로 id 교체돼도 영속·운영자 260628 버그#2 봉합)
    else { var f = imgInput(); if (f) f.click(); } });
  if (gen) gen.addEventListener('click', function(e){ e.stopPropagation(); keepFab(); var g = document.getElementById('go'); if (g) g.click(); });   // ▶ = 이미지 제작 트리거(ly lyGenFab→#go 패턴·운영자 260628)
  b4.addEventListener('click', function(e){ e.stopPropagation(); keepFab(); var o = ['2','3','5'], i = o.indexOf(APP); selApp(o[(i + 1) % o.length]); refresh();
    window.scrollTo({ top: 0, behavior: 'smooth' }); });   // 도구 전환 = 맨 위로(새 탭 처음부터 보이게 · 카드뉴스 포함 · 운영자 260626)
  document.querySelectorAll('.tab').forEach(function(t){ t.addEventListener('click', function(){ setTimeout(refresh, 0); }); });
  refresh();
})();
</script>
<script>
/* 이전 제작 리모트 접기 — 펼쳐지고(.hist.open) 헤더가 위로 지나가면 하단 중앙 '접기' 등장 → 탭=접기+헤더로 스크롤(스크롤 업 불필요·운영자 260626) */
(function () {
  var rm = document.getElementById('histRemote'), hist = document.getElementById('hist'), hd = document.getElementById('histH');
  if (!rm || !hist || !hd) return;
  function sync() { var open = hist.classList.contains('open'); var past = hd.getBoundingClientRect().bottom < 36; rm.classList.toggle('show', !!(open && past)); }
  window.addEventListener('scroll', sync, { passive: true });
  window.addEventListener('resize', sync);
  rm.addEventListener('click', function () {
    var b = document.getElementById('histBody');
    if (b && !b.hidden) { b.hidden = true; hd.setAttribute('aria-expanded', 'false'); hist.classList.remove('open'); }
    hd.scrollIntoView({ behavior: 'smooth', block: 'start' }); sync();
  });
  sync();
})();
</script>
</body>
</html>
