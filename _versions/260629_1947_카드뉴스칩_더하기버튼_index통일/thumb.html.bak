}
// 완성 알림 탭(#done=<id>) → 그 결과를 맨 위 큰 결과(캐러셀)로 띄워 바로 보이게 (운영자 260624). 성공 시 true.
function restoreById(id) {
  if (!id) return false;
  if (RESTORED && [...RESTORED_URLS].some(u => thIdOf(u) === id)) return true;   // 이미 그 id 복원됨(재진입) = 그대로
  const pick = findResultById(id);
  if (!pick) return false;                                      // 아직 없음(빌드·배포 랙) → 호출측이 재시도
  if (RESTORED) {                                               // 다른 게 복원돼 있으면 치우고 교체
    RESTORED = false; RESTORED_URLS.clear();
    const r = document.getElementById('job-R'); if (r) r.remove();
    CARSLIDES.length = 0; const tr = $('#cartrack'); if (tr) tr.innerHTML = '';
  }
  return doRestore(pick);
}
$('#histH').addEventListener('click', () => { const b = $('#histBody'), open = b.hidden; b.hidden = !open; $('#histH').setAttribute('aria-expanded', String(open)); $('#hist').classList.toggle('open', open);
  if (open) requestAnimationFrame(() => $('#hist').scrollIntoView({ behavior: 'smooth', block: 'start' }));   // 펼침 = 이전 제작을 상단 헤더 라인까지 자동 이징 스크롤 → 최근 항목 노출(운영자 260626)
  else window.scrollTo({ top: 0, behavior: 'smooth' });   // 접음 = 상단 폼으로 복귀(첨부 상태)
});
window.addEventListener('hashchange', () => maybeOpenHist());   // 이미 열린 탭을 알림이 #done 으로 이동시켜도(해시만 바뀜) 펼치게 · ()=래핑 = Event가 tries 인자로 새 안 들어가게(재시도 무력화 차단)
// 기록 지우기 = 인라인 재확인→확인(네이티브 팝업 폐지). 1차=재확인(arm·3s 타임아웃) → 2차=게이지 채우며 실행(운영자 260622).
let _histArm = false, _histArmT = null;
function resetHistClr() { const b = $('#histClr'); if (!b) return; _histArm = false; clearTimeout(_histArmT); b.classList.remove('arm', 'firing'); b.textContent = '기록 지우기'; }
$('#histClr').addEventListener('click', () => {
  const b = $('#histClr');
  if (!_histArm) { _histArm = true; b.classList.add('arm'); b.textContent = '재확인'; clearTimeout(_histArmT); _histArmT = setTimeout(resetHistClr, 3000); return; }   // 1차 = 재확인(3s 내 재클릭 없으면 원복)
  clearTimeout(_histArmT); _histArm = false; b.classList.remove('arm'); b.classList.add('firing'); b.textContent = '지우는 중';   // 2차 = 게이지 채우며 실행
  setTimeout(() => {   // 게이지(.46s) 다 찬 뒤 실제 삭제 + 렌더(섹션 비워짐)
    try { localStorage.setItem(THUMB_HCLEAR_KEY, String(Date.now())); } catch {}   // 서버(전 기기) 병합분도 이 시점 이전 숨김 = '지워도 남던' 버그 해소
    localStorage.removeItem(THUMB_HKEY); try { localStorage.removeItem(THUMB_LAST_KEY); } catch {}
    idbClear();   // 보관 이미지(IDB)도 함께 비움
    resetHistClr(); clearRestored(); renderHist();
  }, 480);
});
$('#cartrack').addEventListener('scroll', carUpdate, { passive: true });
// PC: 마우스로 잡아끌어 좌우 넘김(터치는 네이티브 스와이프) — 뉴스 카드피드(.feedtrack) 패턴 계승. 드래그 후 클릭(다운로드) 억제.
(() => {
  const track = $('#cartrack');
  track.addEventListener('mousedown', e => {
    if (e.button !== 0 || e.target.closest('.imgdl,.carnav')) return;   // 다운로드·화살표 위에선 드래그 안 함
    const sl = track.scrollLeft, x0 = e.clientX; let moved = false;
    track.classList.add('dragging');
    const mv = ev => { track.scrollLeft = sl - (ev.clientX - x0); if (Math.abs(ev.clientX - x0) > 4) moved = true; };
    const up = () => {
      window.removeEventListener('mousemove', mv); window.removeEventListener('mouseup', up);
      track.classList.remove('dragging'); track._dragged = moved;
      const w = track.clientWidth || 1; track.scrollTo({ left: Math.round(track.scrollLeft / w) * w, behavior: 'smooth' });   // 가장 가까운 변형으로 스냅
    };
    window.addEventListener('mousemove', mv); window.addEventListener('mouseup', up); e.preventDefault();
  });
  track.addEventListener('click', e => { if (track._dragged) { e.stopPropagation(); e.preventDefault(); track._dragged = false; } }, true);   // 드래그 직후 클릭 억제
})();
// 전체 다운로드은 캐러셀 오버레이서 잡(결과) 행 우측 인라인으로 이동(renderJob의 .jsave · 잡별 = index .fi-saveall 패턴)
// 1초 벽시계 티커 — 진행 중 잡의 표시 초를 실제 시간과 일치(5s 폴과 분리·260619)
setInterval(() => { JOBS.forEach(j => { if (j.status !== 'done' && j.status !== 'err') renderJob(j); }); }, 1000);
// 실패 기록 12h 자동 정리 — 오래된 실패 잡은 목록에서 제거(이전 제작 12h 보관과 동일·운영자 260622)
function pruneOldFails() { const cut = Date.now() - THUMB_HMS; for (let i = JOBS.length - 1; i >= 0; i--) { const j = JOBS[i]; if (j.status === 'err' && (j.t0 || 0) < cut) { const r = document.getElementById('job-' + j.n); if (r) r.remove(); JOBS.splice(i, 1); } } }
pruneOldFails(); setInterval(pruneOldFails, 60000);

// ==== 카드뉴스(/5) 칩 에디터 (인라인) — 어절칩·줄=행·강조·한도 빨강. 뷰어 카드편집기 포팅(입출력=칩↔compose) ====
let edLines = [], PENDING_FOCUS = null, PENDING_EDIT = null, _edRendering = false;
const MAX_LINES = 4, EDLINE_HANGUL = 18, EDLINE_WIDTH = 19.5, EDLINE_SOFT = 14;
const edHangul = s => (s.match(/[가-힣]/g) || []).length;
const edWidth = s => { let w = 0; for (const ch of s) w += /[가-힣ㄱ-ㅎㅏ-ㅣ‘-‟…　-〿＀-￯]/.test(ch) ? 1 : 0.5; return w; };
const esc = s => s.replace(/[&<>"]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
function parseEmphLines(s) {
  const arr = [...s]; const plain = []; const ce = []; let on = false;
  for (let p = 0; p < arr.length; p++) {
    if (arr[p] === '*') { on = !on; continue; }
    plain.push(arr[p]); ce.push(on);
  }
  const lines = [[]]; let cur = lines[0]; let i = 0;
  while (i < plain.length) {
    const ch = plain[i];
    if (ch === '\n') { cur = []; lines.push(cur); i++; continue; }
    if (ch === ' ' || ch === '\t') { i++; continue; }
    let j = i, text = ''; const em = []; let allOn = true, allOff = true;
    while (j < plain.length && plain[j] !== ' ' && plain[j] !== '\t' && plain[j] !== '\n') {
      em.push(ce[j]); if (ce[j]) allOff = false; else allOn = false; text += plain[j]; j++;
    }
    if (allOn) cur.push({ text, on: true });
    else if (allOff) cur.push({ text, on: false });
    else cur.push({ text, on: false, em });
    i = j;
  }
  return lines.slice(0, MAX_LINES);
}
function edMarkWarn() {
  for (const line of edLines) {
    let w = 0, hg = 0, over = false;
    line.forEach((wd, k) => {
      if (k) w += 0.5;
      const wasOver = over; let from = -1;
      const chars = [...wd.text];
      for (let ci = 0; ci < chars.length; ci++) {
        w += edWidth(chars[ci]); hg += edHangul(chars[ci]);
        if (!over && (w > EDLINE_WIDTH || hg > EDLINE_HANGUL)) { over = true; from = ci; }
      }
      if (wasOver) { wd._over = true; wd._overFrom = 0; }
      else if (over) { wd._over = true; wd._overFrom = from >= 0 ? from : 0; }
      else { wd._over = false; wd._overFrom = -1; }
    });
    let tw = 0; line.forEach((wd, k) => { if (k) tw += 0.5; tw += edWidth(wd.text); });
    const warn = tw > EDLINE_SOFT;
    line.forEach(wd => { wd._warn = warn && !wd._over; });
  }
}
function edAnyOver() {
  for (const line of edLines) {
    let w = 0, hg = 0;
    for (let k = 0; k < line.length; k++) {
      if (k) w += 0.5;
      for (const ch of line[k].text) { w += edWidth(ch); hg += edHangul(ch); if (w > EDLINE_WIDTH || hg > EDLINE_HANGUL) return true; }
    }
  }
