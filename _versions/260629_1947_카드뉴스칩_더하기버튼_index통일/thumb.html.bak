    };
    eraser.onclick = ev => {
      ev.preventDefault();
      if (eraser.classList.contains('iobtn-undo')) {   // 되돌리기 모드 = 직전 입력 복원
        prog = true; el.value = undoVal; el.dispatchEvent(new Event('input', { bubbles: true })); prog = false;
        try { el.focus(); } catch {} exitUndo(); return;
      }
      if (!(el.value || '').length) return;   // 빈칸 = 지울 것 없음(평소 dim·무동작)
      undoVal = el.value;   // 지운 내용 보관(복원용)
      prog = true; el.value = ''; el.dispatchEvent(new Event('input', { bubbles: true })); prog = false;   // 비움 → input(자간/맞춤법 동반 갱신)
      try { el.focus(); } catch {}
      eraser.classList.remove('iobtn-off'); eraser.classList.add('iobtn-undo');   // 지움 직후 ~10초 = 되돌리기(흰 픽토그램·내용 없어도 노출)
      eraser.innerHTML = UNDO_SVG; eraser.setAttribute('aria-label', '되돌리기'); eraser.title = '되돌리기 (직전 입력 복원)';
      if (undoTimer) clearTimeout(undoTimer); undoTimer = setTimeout(exitUndo, ERASE_UNDO_MS);
    };
    el.addEventListener('input', () => { if (!prog && undoTimer) exitUndo(); });   // 사용자가 직접 입력/붙여넣기 = 새 내용 우선 → 되돌리기 창 즉시 종료
    wrap.appendChild(eraser);
  }
  btn.onclick = async ev => {
    ev.preventDefault();
