    const t = await clipPasteText(); if (t) { el.value = t; el.dispatchEvent(new Event('input', { bubbles: true })); } refresh();   // 붙여넣기(readText→폴백·교체) · clipPasteText 공용(통일 기틀)
  };
  el.addEventListener('input', refresh); refresh();
