['lines', 'warnLines', 'cSub', 'cTitle', 'cLines'].forEach(id => { const el = $('#' + id); if (el) attachCopyPaste(el, true); });   // covrow textarea(lines·cLines)도 클립 부착 — wrap이 covta 승계로 flex 유지(슬롯 호환·260624) · warnLines(안내문/경고문) 포함 전부 붙여넣기+복사+지우개 3종 통일(운영자 260628)
// covrow: 이미지 슬롯(.covimg) 높이 = 텍스트칸(textarea) 높이로 동기화 — 수동 리사이즈 포함(stretch만으론 어긋난다는 운영자 실측 · 260624). textarea(클립 wrap 안)를 ResizeObserver로 추적해 형제 .covimg에 명시 height 부여.
(function () {
  if (typeof ResizeObserver === 'undefined') return;
  document.querySelectorAll('.covrow').forEach(row => {
    const ta = row.querySelector('textarea'), img = row.querySelector('.covimg');
    if (!ta || !img) return;
    const sync = () => { if (ta.offsetHeight) img.style.height = ta.offsetHeight + 'px'; };   // offsetHeight=border-box → 동일 높이 · 0(탭 숨김)이면 스킵(보일 때 RO가 재동기)
    new ResizeObserver(sync).observe(ta); sync();
  });
})();
let cardIo = null;   // 카드 에디터 copy/paste 아이콘 갱신자 — 정의는 칩 에디터(edLines/buildEmphText) 뒤에서(TDZ 회피)

// ---- 입력 → params ----
// 강조(*) 정규화 — 별표 run(`*`·`**`…)을 단일 강조 토글로 보고, 줄바꿈을 넘는 강조는 줄 끝에서 닫고 다음 줄에서 다시 연다.
// 왜: 렌더러(nomute_overlay.parse)가 *줄 단위*로 `*…*`를 파싱 → 한 줄 안에서 닫히지 않으면 별표가 리터럴로 그려짐(깨짐). 그래서 `**볼드**`나 줄 걸친 강조가
// "강조를 넣어주세요"로 막히던 것을 프론트 변환만으로 해소(백엔드 흰=고정·nomute_*.py 불변 = 렌더 회귀 0). 운영자 260625.
function normEmph(text) {
  let out = '', on = false;
  for (const p of String(text == null ? '' : text).split(/(\*+|\n)/)) {
    if (!p) continue;
    if (/^\*+$/.test(p)) { out += '*'; on = !on; }       // 별표 run = 강조 토글(개수 무관)
    else if (p === '\n') { out += on ? '*\n*' : '\n'; }   // 강조 중 줄바꿈 = 줄 끝서 닫고 다음 줄서 재개
    else out += p;
  }
  return on ? out + '*' : out;                            // 안 닫힌 강조 마감
}
function buildParams() {
  const linesArr = ($('#lines').value || '').split('\n').map(s => s.trim()).filter(Boolean);
  if (APP === '1') return { fmt: 'post', lines: linesArr, opas: getOpas() };   // /1 = post · 선택된 OPA들 각각 1장(다중)
  // APP === '2' 릴스 · APP === '3' 저작권+안내문 = go.onclick에서 직접 발사(buildParams 미사용)
}

// ==== 수정(편집) = 제작 조건 보존 → 이전 제작에서 작성기로 복원 (운영자 260624) ====
// 발사 시점의 폼 설정(탭·모드·포맷·텍스트·OPA·토글·프리셋)을 압축 스냅샷으로 떠서 이력 항목에 동봉(localStorage 가벼움).
// 이미지 b64는 localStorage 쿼터 못 담아 IndexedDB(이 기기 대용량)에 보관 → 수정 시 원본 이미지 그대로 복원(운영자 260624).
// (업로드 원본 uploads/는 Pages 미서빙[viewer/만] → URL 재호출 불가 = IDB가 정답 · 타 기기 이력은 이 기기 IDB에 없어 이미지 제외.)
const IDB_NAME = 'nomute_thumb_img', IDB_STORE = 'imgs';
function idbOpen() { return new Promise((res, rej) => { let r; try { r = indexedDB.open(IDB_NAME, 1); } catch (e) { return rej(e); } r.onupgradeneeded = () => { const db = r.result; if (!db.objectStoreNames.contains(IDB_STORE)) db.createObjectStore(IDB_STORE); }; r.onsuccess = () => res(r.result); r.onerror = () => rej(r.error); }); }
async function idbPut(key, b64) { try { const db = await idbOpen(); await new Promise((res, rej) => { const tx = db.transaction(IDB_STORE, 'readwrite'); tx.objectStore(IDB_STORE).put({ b64, ts: Date.now() }, key); tx.oncomplete = () => res(); tx.onerror = () => rej(tx.error); }); return true; } catch { return false; } }
async function idbGet(key) { try { const db = await idbOpen(); return await new Promise(res => { const tx = db.transaction(IDB_STORE, 'readonly'); const rq = tx.objectStore(IDB_STORE).get(key); rq.onsuccess = () => res(rq.result || null); rq.onerror = () => res(null); }); } catch { return null; } }
function idbPrune(cut) { idbOpen().then(db => { const tx = db.transaction(IDB_STORE, 'readwrite'); const st = tx.objectStore(IDB_STORE); const rq = st.openCursor(); rq.onsuccess = e => { const c = e.target.result; if (!c) return; if (!c.value || (c.value.ts || 0) < cut) st.delete(c.key); c.continue(); }; }).catch(() => {}); }   // 12h 경과분 정리(이력 보관과 동기)
function idbClear() { idbOpen().then(db => { db.transaction(IDB_STORE, 'readwrite').objectStore(IDB_STORE).clear(); }).catch(() => {}); }
function snapForm() {
  const s = { app: APP, fmt: FMT, abbr: $('#abbr').checked, cBg: $('#cBg').checked, opa1: cOpa1on, opa2: cOpa2on, opa2v: cOpa2val };
  let img = null;   // 이 제작에 쓰인 원본 이미지(b64·name) — 있으면 IDB 보관 후 스냅샷엔 키만
  if (APP === '1') { s.lines = $('#lines').value; s.opas = getOpas(); if (PIMG.b64) img = { b64: PIMG.b64, name: PIMG.name }; }
  else if (APP === '2') { s.cSub = $('#cSub').value; s.cTitle = $('#cTitle').value; s.cLines = $('#cLines').value; s.ovFmt = ovFmt; if (CIMG.b64) img = { b64: CIMG.b64, name: CIMG.name }; }
  else if (APP === '3') {
    s.cyear = getYear(); s.cname = getName();
    s.plat = $('#cphPlat').dataset.plat; s.cplat = $('#cplat').value;
    s.cpFmt = cpFmt; s.copyOn = copyOn; s.guideMode = guideMode; s.warnLines = $('#warnLines').value;
  } else if (APP === '5') { try { s.edLines = JSON.parse(JSON.stringify(edLines)); } catch {} if (IMG.b64) img = { b64: IMG.b64, name: IMG.name }; }
  if (img) { s.imgUsed = true; s.imgName = img.name || ''; s.imgKey = 'img_' + Date.now() + '_' + Math.random().toString(36).slice(2, 8); idbPut(s.imgKey, img.b64); }   // b64=IDB, 스냅샷엔 키만(localStorage 가벼움 유지)
  return s;
}
function restoreOpaSeg(segSel, numEl, customBtn, vals) {   // 점등 OPA 복원 — 프리셋 버튼은 vals에 든 값만 켜고, 프리셋에 없는 값은 직접입력칸으로
  const presets = [];
  document.querySelectorAll(segSel + ' button').forEach(b => { if (b.dataset.opa !== 'custom') presets.push(parseInt(b.dataset.opa, 10)); });
  document.querySelectorAll(segSel + ' button').forEach(b => { if (b.dataset.opa !== 'custom') b.classList.toggle('on', vals.includes(parseInt(b.dataset.opa, 10))); });
  const extra = vals.find(v => !presets.includes(v));
  if (extra != null) { if (numEl) numEl.value = String(extra); if (customBtn) customBtn.classList.add('on'); }
  else { if (numEl) numEl.value = ''; if (customBtn) customBtn.classList.remove('on'); }
}
function importHint(msg, ok) {   // 복원 알림 = 버튼 아래 #status에 잠깐(accent) — 비차단
  const s = $('#status'); if (!s) return;
  s.classList.remove('err'); s.classList.toggle('ok', ok !== false); s.textContent = msg;
  clearTimeout(s._hT); s._hT = setTimeout(() => { s.textContent = ''; s.classList.remove('ok'); }, 3200);
}
function importToEditor(src, compUrl) {   // compUrl = 이 제작의 합성본 URL(이미지 원본 없을 때 빗금 참고본으로 슬롯에 표시)
  if (!src) return;
  if (src.app === '1') src = Object.assign({}, src, { app: '2', cLines: src.lines || '', ovFmt: 'post' });   // 레거시 포스트 → 썸네일 텍스트(포스트 포맷)로 복원(260624 통합)
  if (src.app === '4') src = Object.assign({}, src, { app: '3', _wasWarn: true });   // 레거시 경고문 → 저작권+안내문 통합 탭(아래 app3 분기가 warnLit/warnLines 흡수·260624)
  selApp(src.app);                                           // 탭 전환(핵심) + 박스 토글
  if (src.fmt) FMT = src.fmt;                                // (app1/2 레거시 FMT 보존 — fmtSeg UI는 폐지)
  $('#abbr').checked = !!src.abbr;
  if (src.app === '1') {
    $('#lines').value = src.lines || ''; $('#lines').dispatchEvent(new Event('input', { bubbles: true }));   // 복원도 입력 인식 → 클립버튼·자간 갱신(운영자 260626)
    if (src.opas && src.opas.length) restoreOpaSeg('#opaSeg', $('#opaNum'), $('#opaCustom'), src.opas);
    if ($('#pImgSlot')._reset) $('#pImgSlot')._reset();
    updateTrkHint('lines', 'linesTrk', 'post');
  } else if (src.app === '2') {
    // 단일 폼 복원 — 레거시(rmode header/overlay) 이력도 부제/제목/자막으로 매핑(12h 전환기 우아 복원)
    $('#cSub').value = src.cSub || src.sub || '';
    $('#cTitle').value = src.cTitle || src.title || '';
    $('#cLines').value = src.cLines || src.rLines || '';
    ['#cSub', '#cTitle', '#cLines'].forEach(s => $(s).dispatchEvent(new Event('input', { bubbles: true })));   // 복원도 '입력'으로 인식 → 클립버튼(지우개 dim 해제·붙여넣기→복사)·자간 안내 갱신(운영자 260626 — 수정 후 지우개 먹통 버그)
    $('#cBg').checked = !!(src.cBg || src.rBg);
    if (typeof src.opa1 === 'boolean') { cOpa1on = src.opa1; cOpa2on = !!src.opa2; cOpa2val = src.opa2v || 30; }
    else { cOpa1on = true; cOpa2on = !!src.cOpa30 || (Array.isArray(src.reelsOpas) && src.reelsOpas.includes(30)); cOpa2val = 30; }   // 레거시(전 cOpa30/reelsOpas)
    ovFmt = (src.ovFmt === 'reels') ? 'reels' : 'post';   // 오버레이 포맷 복원(없으면 포스트)
    if ($('#cImgSlot')._reset) $('#cImgSlot')._reset();
    updateComboTrk();
  } else if (src.app === '3' || src.app === '4') {
    // 저작권+안내문 통합 복원 — 레거시 app3(cyear/cySuf/platSel/fmts)·app4(warnLit/warnLines)도 우아 흡수
    // 연도: 신본 cyear(자유·전체) 우선, 레거시 cySuf(끝자리)는 '202'+suf로 복원
    setYear(src.cyear != null ? src.cyear : (src.cySuf != null ? '202' + src.cySuf : '2026'));
    setName(src.cname || '');
    const plat = src.plat || src.platSel || 'instagram', custom = plat === 'custom';
    $('#cphPlat').dataset.plat = plat; $('#cphPlat').textContent = custom ? '직접' : plat;
    $('#cplat').classList.toggle('none', !custom); if (custom) $('#cplat').value = src.cplat || '';
    // 저작권 ON/OFF: 신본 copyOn(없으면 ON · 레거시 경고문만이면 OFF로 = 안내문만 만든 것)
    copyOn = (src.copyOn != null) ? !!src.copyOn : !src._wasWarn;
    // 포맷: 신본 cpFmt 우선, 레거시 fmts 배열은 첫 항목(없으면 릴스 기본)
    cpFmt = src.cpFmt || ((Array.isArray(src.fmts) && src.fmts.length === 1) ? src.fmts[0] : 'reels');
    // 안내문: 신본 guideMode 우선, 레거시 warnLit(배열)은 첫 항목으로 매핑(없으면 텍스트 있으면 free)
    guideMode = src.guideMode || (Array.isArray(src.warnLit) && src.warnLit.length ? src.warnLit[0] : (src._wasWarn && src.warnLines ? 'free' : ''));
    $('#warnLines').value = src.warnLines || ''; $('#warnLines').dispatchEvent(new Event('input', { bubbles: true }));
    syncCpFmt(); syncCopyTog(); syncGuide();
  } else if (src.app === '5') {
    if (src.edLines) { try { edLines = JSON.parse(JSON.stringify(src.edLines)); } catch {} if (!edLines.length) edLines = [[]]; renderEditChips(); }
    if ($('#fileLab')._reset) $('#fileLab')._reset();
  }
  updateGoSpec();
  window.scrollTo({ top: 0, behavior: 'smooth' });
  // 이미지 복원 — IDB(이 기기)에서 원본 b64 꺼내 해당 위젯에 그대로. 키 없거나(타 기기·구버전)·만료면:
  //   합성본 URL 있으면 → 빗금 참고본으로 슬롯에 표시(원본 아님 = 재렌더 시 다시 선택해야 교체) · 없으면 재선택 안내.
  const noImg = () => { if (src.imgUsed && compUrl) { setImportRef(src, compUrl); importHint('설정 복원됨 · 이미지는 합성본(빗금)=참고용 · 다시 선택하면 교체'); } else importHint(src.imgUsed ? '설정 복원됨 · 이미지/배경만 다시 선택해주세요' : '설정 복원됨'); };
  if (src.imgKey) {
    idbGet(src.imgKey).then(rec => {
      if (rec && rec.b64) { setImportImg(src, rec.b64, src.imgName); importHint('설정·이미지 복원됨'); }
      else noImg();
    }).catch(noImg);
  } else noImg();
}
function setImportImg(src, b64, name) {   // 복원 이미지 → 앱·모드별 위젯에 주입(파일선택과 동일 렌더)
  if (src.app === '1') { if ($('#pImgSlot')._set) $('#pImgSlot')._set(b64, name); }
  else if (src.app === '5') { if ($('#fileLab')._set) $('#fileLab')._set(b64, name); }
  else if (src.app === '2') { if ($('#cImgSlot')._set) $('#cImgSlot')._set(b64, name); }   // 릴스 자막 슬롯(레거시 overlay 이미지도 여기로)
}
function setImportRef(src, url) {   // 원본 없음(타 기기) → 합성본을 '빗금 참고본'으로 슬롯에 표시. store는 안 채움(재렌더 시 다시 선택해야 이미지 들어감 = 빗금이 그 신호 · 운영자 260624)
  const w = src.app === '1' ? $('#pImgSlot') : src.app === '2' ? $('#cImgSlot') : src.app === '5' ? $('#fileLab') : null;
  if (w && w._setRef) w._setRef(url);
}

// ==== 대기열(JOBS) + 캐러셀 — 제작 동시 가능: 누른 게 다 로그에 쌓이고 각자 폴링, 완성분은 캐러셀에 한 장씩 ====
const JOBS = [];           // 제작 건 누적
let JOBSEQ = 0;
const CARSLIDES = [];      // 완성 이미지(캐러셀 슬라이드)

function renderJob(job) {   // 잡 로그 행 갱신(없으면 생성, 최신이 위)
  let row = document.getElementById('job-' + job.n);
  if (!row) { row = document.createElement('div'); row.id = 'job-' + job.n; row.className = 'job'; $('#jobs').prepend(row); }
  if (job.thid) row.dataset.thid = job.thid;   // 알림 #done=<id> → 이 잡 행으로 핀포인트 랜딩(세션 내 미리로드 시)
  row.className = 'job' + (job.status === 'done' ? ' done' : '') + (job.status === 'err' ? ' err' : '');
  if (job.status === 'done' && !job._restored && !job._saved && (job.saves || []).length) { job._saved = true; saveLastResult(job); }   // 완료 = 최근 제작 스냅샷 저장(다음에 열면 맨 위 복원·운영자 260622)
  const sec = Math.round((Date.now() - job.t0) / 1000);
  const tot = job.outs.length || '?';
  const dn = job.done.filter(Boolean).length;
  let ic, tx;   // 상태 = SVG 픽토그램 + 글자(이모지 폐지·수직중앙 · 운영자 260622)
  if (job.status === 'err') { ic = WARN_SVG; tx = '실패'; }   // 실패 = 간결히 '실패'만(부가 설명[사유]은 행 tooltip으로 · 운영자 260622)
  else if (job.status === 'done') { ic = CHECK_SVG; tx = '완료 · ' + tot + '장' + (job._restored ? ' · ' + histTime(job.t0) : ' (' + sec + 's)') + (job.partErr ? ' · 일부 실패' : ''); }   // 복원 결과 = 경과초 대신 제작시각(운영자 260622) · 배치 일부 실패면 표식(사유=행 tooltip)
  else if (job._queued) { ic = SPIN_SVG; tx = '큐 대기·지연 ' + sec + 's · ' + dn + '/' + tot + '장'; }   // 러너 배정 대기(GitHub 혼잡) — 실패 아님·뜨면 자동 표시(운영자 260625)
  else { ic = SPIN_SVG; tx = '제작 중 ' + sec + 's · ' + dn + '/' + tot + '장'; }
  row.innerHTML = '';
  const lab = document.createElement('span'); lab.className = 'jlab'; lab.textContent = job.label + (job._restored ? '' : ' #' + job.n);
  const labs = (job.outs || []).map(o => o && o.label).filter(Boolean);
  // 단일 변형도 인라인(· OPA60)이 아니라 아래 [1] 행으로 = n개와 동일 포맷(운영자 260626)
  const stsp = document.createElement('span'); stsp.className = 'jst'; stsp.innerHTML = ic + '<span>' + esc(tx) + '</span>';
  row.append(lab, stsp);
  if (job.partErr && job.status === 'done') row.title = job.partErr;   // 배치 일부 실패 = 사유 tooltip(성공분은 정상 표시)
  let svRow = null;   // 전체 다운로드 버튼 — 변형목록과 같은 띠(우측)에 둘지 아래 배치에서 결정(운영자 260626)
  if (job.status === 'done' && (job.saves || []).length) {   // 완료 = 이 잡 결과 '전체'(전체 다운로드) 버튼
    svRow = document.createElement('div'); svRow.className = 'jsave-row';
    const sv = document.createElement('button'); sv.type = 'button'; sv.className = 'jsave dlbtn'; sv.title = '이 결과 전체 다운로드';
    sv.innerHTML = DLSEQ_IC + '<span class="jslbl">전체</span>';
    sv.onclick = () => jSaveSeq(job);
    if (job._dlSt) { sv.classList.add(job._dlSt.cls); sv.style.setProperty('--p', job._dlSt.p); const _l = sv.querySelector('.jslbl'); if (_l) _l.textContent = job._dlSt.txt; if (job._dlSt.cls === 'dlseq-busy') sv.style.pointerEvents = 'none'; }   // 다운 진행 중 재렌더돼도 상태 복원(✓ 유지·운영자 260623)
    svRow.appendChild(sv);   // append는 아래 배치에서(변형 있으면 같은 띠 우측·없으면 단독 우측)
  }
  if (job.status === 'err' && ((job.payload && job.endpoint) || (job.batch && job.batch.length))) {   // 실패 = 같은 설정 재발사(단일=payload·배치=batch · 운영자 260620 아이디어 3·260625)
    const rt = document.createElement('button'); rt.type = 'button'; rt.className = 'jretry'; rt.title = '같은 설정으로 다시 제작';
    rt.innerHTML = RETRY_SVG + '<span>재시도</span>';
    rt.onclick = () => { rt.disabled = true; if (job.batch && job.batch.length) dispatchBatch(job.batch, job.label, job.src); else dispatchJob(job.endpoint, job.payload, job.label, job.src); };
    row.append(rt);
  }
  if (job.status === 'err') {   // 실패 = 우측 휴지통(삭제) · 세로중앙(.job align-items:center) · 사유는 행 tooltip
    row.title = job.msg || '';
    const del = document.createElement('button'); del.type = 'button'; del.className = 'jdel'; del.title = '이 실패 기록 삭제'; del.setAttribute('aria-label', '삭제');
    del.innerHTML = TRASH_SVG;
    del.onclick = () => { const i = JOBS.indexOf(job); if (i >= 0) JOBS.splice(i, 1); row.remove(); };
    row.append(del);
  }
  // 출력 변형 목록 = [i] 라벨 + 개별 다운로드 (1개도 줄바꿔 [1]로 = n개와 동일 포맷·운영자 260626)
  let vs = null;
  if (labs.length >= 1) {
    vs = document.createElement('div'); vs.className = 'jvars'; vs.setAttribute('aria-label', '출력 변형');   // 스크린리더 — 변형 목록 맥락 부여
    (job.outs || []).forEach((o, i) => {   // 각 변형 = 클릭(그 변형 캐러셀로 점프) + 개별 다운로드(이미지 나온 변형만 · 운영자 260620 아이디어 1·2)
      if (!(o && o.label)) return;
      const d = document.createElement('span'); d.className = 'jvar';
      const tx = document.createElement('span'); tx.className = 'jvar-tx'; tx.textContent = '[' + (i + 1) + '] ' + o.label;
      d.appendChild(tx);
      if (o._slide != null) {   // 이미지 도착한 변형만 활성(점프·개별 다운로드)
        d.classList.add('on');
        tx.title = '이 변형으로 이동'; tx.onclick = () => carJump(o._slide);
        const dl = document.createElement('a'); dl.className = 'jvar-dl dlbtn'; dl.href = o._url;
        dl.setAttribute('aria-label', '이 변형 다운로드'); dl.title = '이 변형만 다운로드'; dl.innerHTML = DOWNLOAD_SVG;
        dl.addEventListener('click', e => { e.preventDefault(); e.stopPropagation(); dlBlob(o._url, o._dlname); });   // R2=blob 다운로드·점프와 분리
        d.appendChild(dl);
      }
      vs.appendChild(d);
    });
  }
  // 배치: 변형(좌) + 전체(우)를 한 띠에 = 전체 줄 좌측 공백 활용(1개/n개 동일 · 운영자 260626) · 변형 없으면 전체만 단독(우)
  if (vs && svRow) { const grid = document.createElement('div'); grid.className = 'jgrid'; grid.append(vs, svRow); row.append(grid); }
  else { if (svRow) row.append(svRow); if (vs) row.append(vs); }
}
function pollJob(job) {   // 각 잡 독립 폴링 — 완성 슬롯은 캐러셀에 추가. 2단 타임아웃(150s='큐 대기' 안내·720s=실패) + 포그라운드 복귀 재킥(아래 visibilitychange/focus). 운영자 260618·260625(옛 180s 단일은 러너 큐 지연·모바일 백그라운드 정지를 '실패'로 오판→릴스 막힘).
  const SOFT_S = 150, HARD_S = 720;   // 2단 타임아웃 — GitHub Actions 러너 큐 대기(실측 ~6분)를 견딤: 150s 후 '큐 대기' 안내(폴 느리게)·720s(12분)에야 실패. 옛 180s는 큐 지연을 렌더실패로 오판→릴스 막힘(운영자 260625).
  const tick = () => {
    if (job._timer) { clearTimeout(job._timer); job._timer = null; }   // 재킥(포그라운드 복귀) 시 중복 타이머 방지
    if (job.done.every(Boolean)) { job.status = 'done'; renderJob(job); return; }
    const _el = Math.round((Date.now() - job.t0) / 1000);
    if (_el > HARD_S) { job.status = 'err'; job.msg = '시간 초과(12분) — 러너 큐 혼잡/렌더 실패 가능, 다시 시도'; renderJob(job); return; }
    job._queued = _el > SOFT_S;   // 큐 대기 구간 = renderJob이 '큐 대기·지연'으로 표시(실패 아님)
    renderJob(job);
    job.outs.forEach((o, i) => {
      if (job.done[i]) return;
      const url = o.path + '?t=' + Date.now();
      const img = new Image();
      img.onload = () => {
        if (job.done[i]) return; job.done[i] = true;
        // 변형 순서(0,1,2…)대로만 캐러셀에 추가 = 로드 완료 순서 무관 '1번부터' 노출. 먼저 로드된 뒷 변형은 앞 변형 도착까지 버퍼 대기.
        (job._ready || (job._ready = {}))[i] = [url, dlStamp(job.t0) + '_' + dlSlug(job.label) + '_' + pad3(job.n) + (o.label ? '_' + o.label : '') + '.' + (o.path.split('.').pop() || 'png'), job.label + ' #' + job.n, job, o.label ? ' · ' + o.label : '', o];
        if (job._next == null) job._next = 0;
        while (job._ready[job._next]) { carAppend(...job._ready[job._next]); delete job._ready[job._next]; job._next++; }
        if (job.done.every(Boolean)) job.status = 'done';   // 마지막 장 로드 즉시 완료 표시(5s tick 안 기다림)
        renderJob(job);
      };
      img.src = url;   // 아직 없으면 무시 → 다음 tick 재시도
    });
    job._timer = setTimeout(tick, job._queued ? 12000 : 5000);   // 큐 대기 구간은 폴 간격↑(요청·부하↓) · 핸들 보관(재킥 시 취소)
  };
  job._tick = tick;   // 포그라운드 복귀(visibilitychange/focus)서 외부 재킥용
  tick();
}
// 모바일 백그라운드(탭 비활성·화면 끔)서 setTimeout 폴링이 얼면 잡이 '제작 중'에 영구 고정 → 포그라운드 복귀 시 미완료 잡 즉시 재킥(얼었던 폴링 깨워 R2 200 바로 잡음 · 운영자 260625). thumb엔 이 핸들러가 없던 게 '영구 0/1장'의 직접 원인(index.html 속보 폴링엔 있었음).
document.addEventListener('visibilitychange', () => { if (document.hidden) return; JOBS.forEach(j => { if (j.status === 'run' && j._tick) j._tick(); }); });
window.addEventListener('focus', () => { JOBS.forEach(j => { if (j.status === 'run' && j._tick) j._tick(); }); });
function dlStamp(ts) {   // 다운로드 파일명 시각 프리픽스 yymmdd_hhmm — 제작(job.t0) 기준. 시스템 전 다운로드 일관(index.html dlStamp과 동일 포맷).
  const n = new Date(ts || Date.now()), p = x => String(x).padStart(2, '0');
  return `${String(n.getFullYear()).slice(2)}${p(n.getMonth() + 1)}${p(n.getDate())}_${p(n.getHours())}${p(n.getMinutes())}`;
}
// ── 통일 라벨 (잡헤더·캐러셀 캡션·파일명 공용) ──
const pad3 = n => String(n).padStart(3, '0');   // 잡번호 3자리(005) — 파일명 통일
// 파일명용 라벨 슬러그 — 한글 유지, '#' 제거(파일시스템 인식 문제)·공백/괄호/·/금지문자 → '_' 정리
const dlSlug = s => String(s || '').replace(/#/g, '').replace(/[·()/\\:*?"<>|]/g, ' ').replace(/\s+/g, '_').replace(/_+/g, '_').replace(/^_|_$/g, '');
function dlBlob(url, name) {   // 다운로드 — R2(교차출처)는 같은-출처 프록시(api/dl)가 Content-Disposition: attachment로 강제 저장(전 플랫폼·CORS 무관·iOS 인라인 회피·?t= 캐시버스트 보존). 비R2(같은출처)는 download 속성으로 직접.
  const a = document.createElement('a');
  a.href = /\/\/pub-[0-9a-fA-F]+\.r2\.dev\//.test(url) ? ('api/dl?u=' + encodeURIComponent(url) + '&n=' + encodeURIComponent(name || 'thumb.png')) : url;
  a.download = name || 'thumb.png';
  document.body.appendChild(a); a.click(); a.remove();
}
function carAppend(url, dlname, cap, job, varStr, o, restore) {   // 완성 이미지 1장 캐러셀 추가(나온 순서). o=변형 객체. restore=true=복원(이전제작 재기록 안 함·운영자 260622)
  const slideIdx = CARSLIDES.length;   // push 전 = 이 슬라이드의 전역 인덱스(변형줄 클릭 점프용)
  CARSLIDES.push({ url, dlname });
  if (!restore) histAdd({ url, dlname, cap, varStr: varStr || '', ts: Date.now(), src: job && job.src });   // 12h 보관(창 닫아도 '이전 제작'서 다시 보기 · 운영자 260621) · src=제작 조건(수정 복원) · 복원 시엔 재기록 X(중복 방지)
  if (o) { o._slide = slideIdx; o._url = url; o._dlname = dlname; }   // 변형 i ↔ 슬라이드·다운로드 매핑(로드 순서 무관 = o 객체에 직접 박음 · 운영자 260620)
  if (job) (job.saves || (job.saves = [])).push({ url, dlname, cap, varStr: varStr || '' });   // 잡별 '전체 다운로드'용 + 최근제작 복원용(cap/varStr 포함)
  $('#carwrap').hidden = false; $('#carbar').hidden = false;   // 바(전체 다운로드·N/N장)는 대기열 위에 노출
  const track = $('#cartrack');
  const slide = document.createElement('div'); slide.className = 'carslide'; slide.dataset.slide = slideIdx;
  slide.innerHTML = '<img src="' + url + '"><span class="cap"></span>';   // 다운로드 = 슬라이드 밖 고정 오버레이(#carDl)로 이관 → 스와이프해도 안 흔들림(뷰어 .feed-ui 패턴·마진 통일 · 운영자 260622)
  const capEl = slide.querySelector('.cap'); capEl.textContent = cap;
  if (varStr) { const v = document.createElement('span'); v.className = 'cap-var'; v.textContent = varStr; capEl.appendChild(v); }   // OPA 변형 = 일반체(제목과 분리)
  track.appendChild(slide);
  carUpdate();
  track.scrollTo({ left: track.scrollWidth, behavior: 'smooth' });   // 새로 나온 장으로 이동
}
function carUpdate() {
  const track = $('#cartrack'), n = CARSLIDES.length;
  const idx = Math.round(track.scrollLeft / (track.clientWidth || 1));
  $('#carcount').textContent = n ? (Math.min(idx + 1, n) + ' / ' + n + '장') : '';
  $('#carPrev').disabled = idx <= 0; $('#carNext').disabled = idx >= n - 1;
  const dl = $('#carDl'), cur = n ? CARSLIDES[Math.min(Math.max(idx, 0), n - 1)] : null;   // 고정 다운로드 = 현재 슬라이드 타겟(스와이프 추적 · 뷰어 오버레이 패턴)
  if (dl) { dl.hidden = !n; if (cur) { if (!dl.innerHTML) dl.innerHTML = DOWNLOAD_SVG; dl.href = cur.url; dl.onclick = e => { e.preventDefault(); dlBlob(cur.url, cur.dlname); }; } }
}
function carJump(slideIdx) {   // 변형줄 클릭 → 해당 변형 슬라이드로 캐러셀 이동(운영자 260620 아이디어 1)
  const track = $('#cartrack');
  const slide = track.querySelector('.carslide[data-slide="' + slideIdx + '"]');
  if (slide) { $('#carwrap').hidden = false; track.scrollTo({ left: slide.offsetLeft, behavior: 'smooth' }); }
}
$('#carPrev').onclick = () => { const t = $('#cartrack'); t.scrollBy({ left: -t.clientWidth, behavior: 'smooth' }); };
$('#carNext').onclick = () => { const t = $('#cartrack'); t.scrollBy({ left: t.clientWidth, behavior: 'smooth' }); };

// ── 이전 제작 보관(12시간) — 완성 이미지(원격 URL·가벼움)를 localStorage에 쌓아 창 닫아도 다시 보기. 이 기기 한정. ──
const THUMB_HKEY = 'nomute_thumb_hist', THUMB_HMS = 12 * 3600e3, THUMB_HMAX = 240;   // 12시간 보관 · 최대 240장(초과 시 오래된 것 제거)
const THUMB_HCLEAR_KEY = 'nomute_thumb_hist_cleared';   // '기록 지우기' 시점(epoch) — 이 이전 제작분은 로컬·서버(전 기기) 모두 숨김(지워도 서버분 남던 버그 해소·운영자 260622)
function histClearedCut() { try { return +localStorage.getItem(THUMB_HCLEAR_KEY) || 0; } catch { return 0; } }
const THUMB_LAST_KEY = 'nomute_thumb_last';   // 가장 최근 제작 1건 = 창 닫아도 맨 위 '결과'로 복원(전체 다운+캐러셀 · 이 기기 · 운영자 260622)
// 기기간 공유: build-viewer가 thumb_out/(전 기기 커밋 이미지) 스캔해 만든 thumb-hist.json을 읽어 로컬과 병합(운영자 260621).
const baseUrl = u => String(u || '').split('?')[0];   // ?t= 캐시버스트 제거 = 중복판정 키
const thIdOf = u => { const m = String(u || '').match(/thumb_out\/([^/?#]+)/); return m ? m[1] : ''; };   // 결과/이력 url(thumb_out/<id>/file)서 작업 id 추출 = 알림 #done=<id> 매칭키
const scrollMid = el => { if (!el) return; requestAnimationFrame(() => { try { const y = el.getBoundingClientRect().top + window.pageYOffset - Math.round((window.innerHeight || 700) * 0.18); window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' }); } catch (_) { try { el.scrollIntoView(); } catch (_) {} } }); };   // 중상단(상단서 18%) 랜딩 · rAF=레이아웃 정착 후 측정(이미지 리플로우 뒤 정확)
const flashEl = el => { if (!el) return; el.classList.add('thfocus'); setTimeout(() => el.classList.remove('thfocus'), 2200); };   // 착지 항목 잠깐 강조 = '해당 작업' 식별
let SRV_HIST = [];
async function loadServerHist() {
  try { const r = await fetch('thumb-hist.json?_=' + Date.now()); if (r.ok) { const d = await r.json(); if (Array.isArray(d)) SRV_HIST = d; } } catch { /* 없으면 로컬만 */ }
  renderHist();
  maybeOpenHist();   // 제작완료 알림(#done=<id>)로 들어왔으면 서버 병합 후 그 결과를 맨 위로(restoreById)
}
// 제작완료 푸시 탭 → /thumb.html#done 진입 시 '이전 제작'을 펼치고 그 위치로 스크롤(완성 결과가 바로 보이게).
let _histRetry = false, _histTimer = 0;   // 단일 재시도 사다리 가드 — 진입점 다중(init·loadServerHist·hashchange)이라도 중복 fetch 0(평의회 FIX-1)
function maybeOpenHist(tries = 0) {
  if (!/\bdone\b/.test(location.hash)) return;
  const wantId = (location.hash.match(/done=([\w-]+)/) || [])[1] || '';   // #done=<id> = 그 작업 핀포인트(없으면 레거시 = 결과 블록)
  const hist = $('#hist');
  if (hist && !hist.hidden) { const b = $('#histBody'); if (b && b.hidden) { b.hidden = false; $('#histH').setAttribute('aria-expanded', 'true'); hist.classList.add('open'); } }   // 이력 펼침(타깃이 이력 항목일 수 있어 노출)
  const land = el => { _histRetry = false; if (_histTimer) { clearTimeout(_histTimer); _histTimer = 0; } try { history.replaceState(null, '', location.pathname + location.search); } catch (_) {} scrollMid(el); };   // 착지 = #done 제거 + 재시도 종료(재호출·새로고침 시 재스크롤·고아타이머 방지)
  if (wantId) {   // 완성 알림(#done=<id>) → 그 결과를 맨 위 큰 결과(캐러셀)로 띄우고 거기로 랜딩(바로 보이게)
    if (restoreById(wantId)) { const cw = $('#carwrap'); land(cw); flashEl(cw); return; }   // 그 id 결과를 맨 위에 복원
    const tgt = document.querySelector('[data-thid="' + wantId + '"]');   // 폴백 = 진행 중 잡 로그행 등(wantId=[\w-]+ 캡처라 선택자 안전)
    if (tgt) { land(tgt); flashEl(tgt); return; }
    if (tries < 15) {   // 콜드스타트 = 이력(thumb-hist.json) 빌드·배포 랙(~30~90s) → 재fetch+재렌더 후 재시도(요약 ?a= 백오프 · 15회≈104s로 90s 꼬리 커버 · 평의회 FIX-3)
      if (!_histRetry) {   // 단일 사다리만 가동(다른 진입점은 즉시 querySelector만 · 재시도는 한 줄로)
        _histRetry = true;
        _histTimer = setTimeout(async () => {
          _histTimer = 0; _histRetry = false;
          try {
            const sig = (typeof AbortSignal !== 'undefined' && AbortSignal.timeout) ? AbortSignal.timeout(6000) : null;   // 멈춘 요청 영구대기 차단(미지원 브라우저는 타임아웃 없이 정상 fetch · 평의회 FIX-2)
            const r = await fetch('thumb-hist.json?_=' + Date.now(), sig ? { signal: sig } : undefined);
            if (r.ok) { const d = await r.json(); if (Array.isArray(d)) SRV_HIST = d; }
          } catch (_) {}
          renderHist(); maybeOpenHist(tries + 1);
        }, Math.min(2500 + tries * 1200, 8000));
      }
      return;   // 사다리 가동/대기 중 — 폴백 안 감(#done 유지)
    }
    // 끝내 못 찾음(배포 지연 초과) → 안내 + 폴백(평의회 FIX-4)
    const s = $('#status'); if (s) { s.classList.remove('err'); s.textContent = '결과 준비 중 — 잠시 후 새로고침'; }
  }
  // 레거시 #done(id 없음) 또는 끝내 미발견 → 방금 만든 결과 블록(없으면 이력) 중상단
  const cb = $('#carbar');
  const fb = (cb && !cb.hidden) ? cb : (($('#jobs') && $('#jobs').firstElementChild) || (hist && !hist.hidden ? hist : null));
  land(fb);
}
function histLoad() { try { const a = JSON.parse(localStorage.getItem(THUMB_HKEY) || '[]'); return Array.isArray(a) ? a : []; } catch { return []; } }
function histSave(a) { try { localStorage.setItem(THUMB_HKEY, JSON.stringify(a)); } catch {} }
function histPrune(a) { const cut = Date.now() - THUMB_HMS; return a.filter(e => e && e.ts && e.ts >= cut); }
function histAdd(e) { let a = histPrune(histLoad()); a.push(e); while (a.length > THUMB_HMAX) a.shift(); histSave(a); renderHist(); }
function histTime(ts) { const d = new Date(ts); let h = d.getHours(); const m = d.getMinutes(); const ap = h < 12 ? '오전' : '오후'; h = h % 12 || 12;
  const now = new Date(); const dayDiff = Math.round((new Date(now.getFullYear(), now.getMonth(), now.getDate()) - new Date(d.getFullYear(), d.getMonth(), d.getDate())) / 86400000);
  const pre = dayDiff === 0 ? '오늘 ' : dayDiff === 1 ? '어제 ' : '';   // 12h 보관이라 날짜 넘어가면 오전/오후만으론 헷갈림 → 오늘/어제 접두(운영자 260621)
  return pre + ap + ' ' + h + ':' + String(m).padStart(2, '0'); }   // 제작 시각 = 오늘/어제 오전/오후 H:MM(운영자 260621)
function renderHist() {
  const local = histPrune(histLoad()); histSave(local);   // 로컬 만료분(12h↑) 정리
  const seen = new Set(local.map(e => baseUrl(e.url)));
  const cut = Date.now() - THUMB_HMS;
  const clr = histClearedCut();   // 기록 지우기 시점 — 로컬·서버 모두 이 이전은 숨김
  const srv = (SRV_HIST || []).filter(e => e && e.url && e.ts >= cut && !seen.has(baseUrl(e.url)));   // 타 기기 제작분(로컬 중복 제외)
  let a = local.concat(srv).filter(e => (e.ts || 0) > clr).sort((x, y) => (y.ts || 0) - (x.ts || 0));   // 로컬+서버 병합 · 지운 시점 이후만 · 최신 먼저
  if (RESTORED_URLS.size) a = a.filter(e => !RESTORED_URLS.has(baseUrl(e.url)));   // 맨 위로 복원된 최근 제작은 '이전(previous) 제작'서 제외 = 위에만(운영자 260622)
  const hist = $('#hist'); if (!hist) return;
  if (!a.length) { hist.hidden = true; return; }
  hist.hidden = false; $('#histCnt').textContent = '(' + a.length + ')';
  const grid = $('#histGrid'); grid.innerHTML = '';
  a.forEach(e => {   // 최신 먼저(이미 정렬됨)
    const it = document.createElement('div'); it.className = 'hist-it'; it.dataset.thid = thIdOf(e.url);   // 작업 id 태그 = 알림 #done=<id> → 이 이력 항목으로 핀포인트(콜드스타트 주경로)
    const hd = document.createElement('div'); hd.className = 'hist-hd'; hd.textContent = histTime(e.ts);   // 제작 시각(오전/오후 H:MM·흰색·이미지 위)
    const th = document.createElement('div'); th.className = 'hist-thumb';
    const dl = document.createElement('a'); dl.className = 'imgdl dlbtn'; dl.href = e.url;
    dl.setAttribute('aria-label', '다운로드'); dl.innerHTML = DOWNLOAD_SVG; dl.addEventListener('click', ev => { ev.preventDefault(); ev.stopPropagation(); dlBlob(e.url, e.dlname || 'thumb.png'); });
    const img = document.createElement('img'); img.loading = 'lazy'; img.alt = ''; img.src = e.url; img.onerror = () => it.remove();   // 백엔드서 사라진 이미지는 슬롯 자동 제거
    const cap = document.createElement('span'); cap.className = 'hist-cap'; cap.textContent = e.cap || '';
    if (e.varStr) { const v = document.createElement('span'); v.className = 'hist-cap-v'; v.textContent = e.varStr; cap.appendChild(v); }
    th.append(dl, img, cap);
    if (e.src) {   // 수정(편집) = 이 설정으로 작성기 복원. 이제 서버 이력(타 기기 제작분)도 _src.json→src 동봉 → 기기 달라도 버튼 표시(운영자 260624). 이미지 원본 없으면 합성본 빗금 참고본으로 대체.
      const ed = document.createElement('button'); ed.type = 'button'; ed.className = 'imgedit'; ed.title = '이 설정으로 수정'; ed.setAttribute('aria-label', '수정');
      ed.innerHTML = EDIT_SVG;
      ed.addEventListener('click', ev => { ev.preventDefault(); ev.stopPropagation(); importToEditor(e.src, e.url); });
      th.appendChild(ed);
    }
    it.append(hd, th); grid.appendChild(it);
  });
}
// ── 가장 최근 제작 1건 = 창 닫아도 맨 위 '결과'로 복원 (전체 다운+캐러셀 · 이 기기 · 운영자 260622) ──
let RESTORED = false, RESTORED_TS = 0; const RESTORED_URLS = new Set();   // 맨 위에 복원된 최근 제작 url·ts(이전 제작서 제외·cross-device 최신비교용)
function saveLastResult(job) {   // 잡 완료 시 최근 제작 스냅샷 저장(URL은 캐시버스트 제거)
  try { if (!job || !(job.saves || []).length) return;
    localStorage.setItem(THUMB_LAST_KEY, JSON.stringify({ label: job.label, ts: job.t0, src: job.src,
      items: job.saves.map(s => ({ url: baseUrl(s.url), dlname: s.dlname, cap: s.cap || '', varStr: s.varStr || '' })) })); } catch {}
}
function clearRestored() {   // 새 제작 발사 = 복원 고스트 치우고 새 결과로(복원분은 '이전 제작'으로 되돌림)
  if (!RESTORED) return; RESTORED = false; RESTORED_URLS.clear();
  const r = document.getElementById('job-R'); if (r) r.remove();
  CARSLIDES.length = 0; const tr = $('#cartrack'); if (tr) tr.innerHTML = '';
  $('#carwrap').hidden = true; $('#carbar').hidden = true; carUpdate(); renderHist();
}
// 로컬 마지막 제작(THUMB_LAST_KEY) — 만료/빈값이면 null
function localLastResult() {
  let rec; try { rec = JSON.parse(localStorage.getItem(THUMB_LAST_KEY) || 'null'); } catch {}
  if (!rec || !Array.isArray(rec.items) || !rec.items.length) return null;
  if (Date.now() - (rec.ts || 0) > THUMB_HMS) { try { localStorage.removeItem(THUMB_LAST_KEY); } catch {} return null; }   // 12h 만료
  return rec;
}
function doRestore(pick) {   // pick(items/ts/label[/src])을 맨 위 결과(캐러셀)로 복원
  if (!pick || !Array.isArray(pick.items) || !pick.items.length) return false;
  const rjob = { n: 'R', label: pick.label || '제작', t0: pick.ts, status: 'done', _restored: true, _saved: true, src: pick.src,
    outs: pick.items.map(it => ({ label: (it.varStr || '').replace(/^\s*·\s*/, '') })), done: pick.items.map(() => true), saves: [] };
  pick.items.forEach((it, i) => { RESTORED_URLS.add(baseUrl(it.url)); carAppend(it.url, it.dlname, it.cap || pick.label || '', rjob, it.varStr || '', rjob.outs[i], true); });
  RESTORED = true; RESTORED_TS = pick.ts || 0; renderJob(rjob); renderHist();   // 맨 위 결과 + 이전 제작서 제외
  return true;
}
// 특정 작업 id(완성 알림 #done=<id>)의 결과 찾기 — 로컬 마지막이 그 id면 그걸로(src 보유=수정가능), 아니면 서버(thumb-hist.json) 같은 id 그룹.
function findResultById(id) {
  const loc = localLastResult();
  if (loc && Array.isArray(loc.items) && loc.items.some(it => thIdOf(it.url) === id)) return loc;   // 이 기기서 만든 거면 src까지
  if (Array.isArray(SRV_HIST)) {
    const arr = SRV_HIST.filter(e => e && e.url && thIdOf(e.url) === id);
    if (arr.length) {
      const sorted = arr.slice().sort((a, b) => String(a.dlname || '').localeCompare(String(b.dlname || '')));
      return { ts: Math.max(...arr.map(e => e.ts || 0)), label: sorted[0].cap || '제작', items: sorted.map(e => ({ url: e.url, dlname: e.dlname, cap: e.cap || '', varStr: e.varStr || '' })) };
