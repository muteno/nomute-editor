function buildEmphText() {
  const charEm = (wd, ci) => wd.em ? !!wd.em[ci] : wd.on;
  return edLines.map(line => {
    const words = line.filter(wd => wd.text !== '');
    const seq = [];
    words.forEach((wd, k) => {
      const chars = [...wd.text];
      if (k) {
        const prev = words[k - 1], pc = [...prev.text];
        seq.push({ c: ' ', e: charEm(prev, pc.length - 1) && charEm(wd, 0) });
      }
