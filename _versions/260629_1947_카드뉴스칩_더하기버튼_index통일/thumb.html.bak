<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>오버레이 생성기</title>
<link rel="stylesheet" href="tokens.css">   <!-- 공유 구조토큰(§🎨 STAGE3·index :root 파생·색 제외). 인라인 :root가 팔레트 오버라이드 -->
<style>
  :root { --bg:#0b0d0c;   /* 노뮤트 문서/보고서와 통일(거의-검정 평면)·운영자 260624 */ --pan:#16171a; --line:#2a2c31; --fg:#e9eaec; --mut:#8b8f98; --hist-accent:#c24bf5; --hist-rgb:194,75,245;
          --accent:#0FFD02; --accent-rgb:15,253,2; --accent-dim:rgba(var(--accent-rgb),.13); --on-accent:#062108; --line2:#2a2c31;
          --amber:#ff9614; --amber-rgb:255,150,20;
          --warn:#ffd24a; --warn-rgb:255,210,74; --arm:#ffd93d; --arm-rgb:255,217,61; --on-arm:#1a1205;
          --press-pico:.55; --press-xs:.82; --press-s:.85; --press-m:.9; --press-l:.95; }   /* 눌림 scale 사다리(index 통일·운영자 260628·분신술10) — 픽토온리는 :active svg에만. 의미색(앰버=강조누락 / 노랑warn·arm=맞춤법 교정) · index.html SSOT 값 복사(§🎨) */
  @media (prefers-reduced-motion:reduce){ :root{ --press-pico:1; --press-xs:1; --press-s:1; --press-m:1; --press-l:1; } }   /* 눌림 토큰 전역 무효화(index 통일·분신술10) */
  * { box-sizing:border-box; -webkit-tap-highlight-color:transparent; }   /* 모바일 기본 하늘색 탭 하이라이트 블록 제거 = 뉴스요약(index) 전역 계승 · 운영자 260626 */
  /* 스크롤바 = 뉴스 요약(index.html)과 통일 — 반투명 검정(중립·거의 안보임 · 운영자 260626: 초록·완전숨김 폐기→index 그대로) */
  /* ⚠️ 실제 화면에 보이는 스크롤바는 아래 네이티브가 아니라 cscroll.js 커스텀 오버레이다(cscroll이 네이티브를 display:none로 죽이고 자기 thumb를 그림). 색 바꾸려면 viewer/cscroll.js를 고쳐라 — 이 네이티브 규칙만 만지면 안 바뀜(260626 고질 교훈·검증 5인). */
  html { scrollbar-width:thin; scrollbar-color:rgba(0,0,0,.45) transparent; }
  ::-webkit-scrollbar { width:10px; height:10px; }
  ::-webkit-scrollbar-track { background:transparent; }
  ::-webkit-scrollbar-thumb { background:rgba(0,0,0,.42); border-radius:999px;
    border:2px solid var(--bg); background-clip:padding-box; }
  ::-webkit-scrollbar-thumb:hover { background:rgba(0,0,0,.6); background-clip:padding-box; }
  body { margin:0; background:var(--bg); color:var(--fg); font:15px/1.6 -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif; }
  /* 배경 = 뷰어 글래스모피즘 배경 이식(동일): 다크 실크(feed_bg) + 딥블랙 스크림(.58) + 상단 accent 점등. 기존 글래스 패널(.panel/.tab/.seg 등)이 이 위에서 제대로 비침(전엔 평면 검정이라 글래스가 죽어 보였음) · 글로우 없음 · 운영자 260625(롤백=이 ::before 제거). */
  body::before { content:''; position:fixed; inset:0; z-index:-1; pointer-events:none;
    filter:brightness(1.2) saturate(1.05);   /* 실크 밝힘 = 투명 패널 뒤로 실크가 보여 '진짜 투명'해 보임(딥블랙이라 .10 패널도 솔리드처럼 보이던 것 해소·운영자 260626) */
    background:
      radial-gradient(125% 70% at 50% -8%, rgba(var(--accent-rgb),.10), transparent 55%),
      linear-gradient(rgba(0,0,0,.4), rgba(0,0,0,.4)),
      url(assets/brand/feed_bg.png) center/cover no-repeat, var(--bg); }
  .wrap { max-width:600px; margin:0 auto; padding:18px 16px 70px; }
  h1 { font-size:18px; margin:6px 0 18px; }
  h1 b { color:var(--accent); }
  /* 상단 3탭 = 글자만(박스·배경·테두리·blur 제거 · 글자 눌러 전환 · 중앙 모음 = '안으로 들이고' · index.html .chip 패턴 계승 · 운영자 260626) */
  .tabs { display:flex; justify-content:center; gap:44px; margin-bottom:26px; }   /* 글자 탭 간격 넓힘(22→44 · 미관 · 운영자 260626) · mb 16→26 = 이미지 3탭 첫 소머리 블릿을 영상(ly/k) 첫 블릿과 동일 화면선(실측 187px)으로 통일(첫 블릿 시작라인 §📐 · 운영자 260629) */
  .tab { padding:4px 2px; background:none; border:none; box-shadow:none; border-radius:0; cursor:pointer; font-weight:600; font-size:13px; color:var(--mut); transition:color .15s; -webkit-tap-highlight-color:transparent; }
  .tab svg { width:14px; height:14px; vertical-align:-2px; margin-right:5px; }   /* 글자 앞 픽토그램(currentColor = 활성 강조색·비활성 회색 · 운영자 260626) */
  .tab:hover { color:var(--fg); }
  .tab small { display:block; color:var(--mut); font-weight:400; font-size:11px; margin-top:2px; }
  .tab.on { color:var(--accent); font-weight:800; text-shadow:0 0 11px rgba(var(--accent-rgb),.55); }
  .tab.on small { color:#bfeeb6; }
  @media (min-width:520px){ .tabs{ gap:0; } .tab{ flex:1; text-align:center; } }   /* PC(넓은 모달) = 3탭 등폭 분배 → 간격 균일·고르게 벌어짐(모바일은 기존 center+gap 유지) · 운영자 260627 */
  .panel { background:transparent; border:0; border-radius:0; padding:0; box-shadow:none; }   /* 겉면 프레임 제거 = 뉴스 요약 페이지(index .nm-wrap) 계승 — 섹션·입력칸이 배경 글래스 위에 바로 흐름(외곽 라인 불필요·운영자 260626). 깊이는 입력칸 자체 글래스가 담당(§🎨 테두리보다 글래스). */
  label { display:block; font-size:var(--fs-label); color:var(--mut); margin:14px 0 8px; }   /* 소제목 위아래 마진 통일·확보(운영자 260617). .fl=소머리(흰색800+형광블릿) / 무클래스·.chk·.file=비소머리(회색 유지) */
  label.fl { font-weight:var(--fw-x); color:var(--fg); }   /* 소머리 = 흰색(--fg)·800(--fw-x) = 뉴스 .cref-lbl 표준 형광통일(운영자 260629) */
  label.fl::before { content:'• '; color:var(--accent); font-weight:var(--fw-b); }   /* 블릿 = 형광(--accent)·700(--fw-b) · 뉴스 정본 content:'• '(블록·공백) 동일 */
  input[type=text], input[type=number], textarea, select {
    width:100%; padding:12px; background:rgba(14,15,17,.55); border:1px solid var(--line); border-radius:var(--r-s); color:var(--fg); font:inherit; font-size:90%;   /* 반투명 = 패널의 블러된 실크가 입력칸에도 은은히 비침(피드 동일 결) · 글자 가독 위해 .55 · 운영자 260625 · 입력 글자 90%(이 화면 한정·운영자 260626) */
  }
  input:focus, textarea:focus, select:focus { border-color:rgba(var(--accent-rgb),.35); box-shadow:0 0 0 3px rgba(var(--accent-rgb),.08); outline:none; }
  input::placeholder, textarea::placeholder { color:var(--mut); }
  textarea { min-height:96px; resize:none; }   /* 리사이즈 핸들 제거(운영자 260629 · 전역) */
  .row { display:flex; gap:8px; }
  .row > * { flex:1; }
  .hint { font-size:12px; color:var(--mut); margin-top:5px; }
  .hint b { color:var(--accent); }
  .seg { display:flex; gap:6px; }
  .seg button { flex:1; padding:8px; background:linear-gradient(165deg, rgba(34,56,41,.42), rgba(14,26,18,.52)); backdrop-filter:blur(10px) saturate(1.2); -webkit-backdrop-filter:blur(10px) saturate(1.2); border:1px solid rgba(255,255,255,.09); border-radius:var(--r-s); color:var(--fg); cursor:pointer; box-shadow:inset 0 1px 0 rgba(255,255,255,.07); transition:border-color .15s, background .15s; }
  .seg button.on { border-color:rgba(var(--accent-rgb),.5); color:var(--accent); background:linear-gradient(165deg, rgba(var(--accent-rgb),.16), rgba(var(--accent-rgb),.05)); box-shadow:inset 0 1px 0 rgba(255,255,255,.1); }
  .seg button.fixed { cursor:default; }   /* 60·30 = 항상 출력(고정 표시) — 누름 동작 없음 */
  /* 직접입력 = 버튼 자체가 입력창 (선택 시 라벨 숨고 안에 커서) */
  #opaCustom { padding:0; overflow:hidden; }
  #opaCustom .lab { display:block; padding:8px 2px; }
  /* ID 스코프 = .lab과 대칭(특정성 0,1,1 전역 input[type=text] 패딩/테두리에 안 짐) → 입력 모드에서도 버튼 높이 라벨과 동일 */
  #opaCustom .opa-in { display:none; box-sizing:border-box; width:100%; padding:8px 2px; border:none; background:transparent; color:var(--accent); text-align:center; font:inherit; outline:none; }
  #opaCustom.on .lab { display:none; }
  #opaCustom.on .opa-in { display:block; }
  /* (구) 플랫폼 .pseg/.pbtn·경고문 .wseg = /3 통합으로 폐지(260624) — 플랫폼은 .platpop 픽토그램 팝업으로 대체 */
  /* 실시간 자간(tracking) 표시 — 줄어들기 시작하면 노랑, 한도 초과 빨강 */
  .trk { font-size:12px; font-weight:800; }
  .trk.on { color:#ffd84d; }
  .trk.over { color:#ff7a7a; }
  /* ── 기본(통합) 모드 — 섹션머리(•) + 부제 흰색/제목 강조색 + 자막 2/3 + 이미지 슬롯 1/3 ── */
  .csec { display:flex; align-items:center; gap:6px; font-size:var(--fs-label); font-weight:var(--fw-x); color:var(--fg); margin:16px 0 9px; }   /* 소머리 텍스트 = 흰색(--fg)·800(--fw-x) = 뉴스 .cref-lbl 표준 형광통일(운영자 260629) · '• 헤더'↔배경 = align-items center 수직중앙 */
  .csec::before { content:'•'; color:var(--accent); font-weight:var(--fw-b); }   /* 블릿 = 형광(--accent)·700(--fw-b) · 인라인 '• '→::before 분리(텍스트 흰색·블릿 형광) · flex라 gap:6px가 간격(블록 .fl은 content:'• ' 공백 = 뉴스 정본) */
  .csec-d { font-size:12px; font-weight:400; color:var(--mut); }
  .csec-chk { margin:0 0 0 auto; font-size:12.5px; font-weight:400; }   /* 배경 체크 = '• 헤더' 행 우측(margin-left auto)·별도 행 제거 */
  .csec-chk .cbox { width:17px; height:17px; }   /* 글자 높이로 축소 = '• 헤더'↔배경 정렬 기준 일치 */
  .csec-chk .ackm { width:11px; height:11px; }
  /* ── 머리(.csec)↔첫 박스 간격 = 단일값(9px)으로 통일: 헤더·오버레이·옵션 동일 (운영자 260624) ──
     원인: 간격이 섹션마다 다른 규칙에서 나옴 — 헤더=#rCombo .cf{margin-top}(그런데 이 마진이 클립버튼
     wrap '안'에서 새서 ① 헤더 간격 과대 ② 입력칸이 8px 밀려 클립버튼이 테두리서 뜸) · 오버레이=.covrow{margin-top:8}
     · 옵션=.gospec{margin-top:16}. 셋이 별개라 한쪽 고쳐도 안 따라오고 마진상쇄(flex vs block)까지 겹쳐 계속 틀어짐.
     해결: .csec 아래마진=0 + 첫 박스 margin-top=9 단일소스 → 위 0 + 9 = 정확히 9px(상쇄 무관) · 입력칸이 wrap에 밀착돼 클립버튼 라인 정렬. */
  #rCombo .csec, #rOptHead { margin-bottom:0; }
  #rCombo > .iowrap, #rCombo > .covrow { margin-top:9px; }   /* #goSpec은 박스화돼 아래 #goSpec 규칙에서 margin 직접(9px) — 같은 단일값 */
  #rCombo .cf-sub { color:#fff; }        /* 부제 입력 = 흰색(결과물 흰색 미러) */
  #rCombo .cf-title { color:var(--accent); }   /* 제목 입력 = 강조색(결과물 초록 미러) */
  #rCombo .cf-title::placeholder { color:var(--accent); opacity:.5; }   /* 제목 예시도 강조색(부제 예시는 전역 mut) */
  .covrow { display:flex; gap:8px; align-items:stretch; margin-top:8px; }
  .covta { flex:2 1 0; min-width:0; }                      /* 자막 = 2/3(텍스트 짧음) */
  .covrow textarea { min-height:104px; }                   /* 자막 텍스트칸 = 3줄(콘텐츠 96px) 스크롤 없이 들어가게 +헤드룸(전역 96 → 104·운영자 260625). 슬롯도 ResizeObserver로 동기 */
  /* 이미지 슬롯 = 전경(플레이트) 완전 제거 → 픽토그램만(강조색) · 배경·테두리·blur 없음 · '이미지' 라벨 제거(운영자 260626) */
  .covimg { flex:1 1 0; min-width:0; position:relative; display:flex; flex-direction:column; align-items:flex-end; justify-content:flex-start; gap:3px;
    min-height:104px; border:none; border-radius:var(--r-s); color:var(--accent); cursor:pointer; overflow:hidden;
    background:transparent; transition:background .15s; -webkit-tap-highlight-color:transparent; }
  .covimg .covimg-ic { margin:12px 16px 0 0; }   /* 빈 슬롯 픽토그램 = 슬롯 상단·우측(빠른메뉴 +/− 네비 세로열과 정렬 · 슬롯 우변·네비 둘 다 뷰포트 우측 고정이라 폭 무관 유지 · 운영자 260627). .has/.refonly = 자식 전부 absolute라 무영향 */
  @media (hover:hover) and (pointer:fine) { .covimg:hover { background:rgba(255,255,255,.04); } .covimg.has:hover { background:var(--bg); } }   /* hover 배경 = 마우스에서만. 터치는 파일창 열고 취소 후 :hover가 고착돼 슬롯이 전경색으로 칠해지던 버그 차단(상황 따라 안 바뀜 · #rfab PC숨김과 동일 컨벤션 · 운영자 260627) */
  .covimg:active { transform:scale(var(--press-l,.97)); }                 /* 큰 면 = 1에 근접(§🎨 누름 scale 계승) */
  .covimg.has { cursor:default; background:var(--bg); }
  .covimg .covimg-ic svg { width:26px; height:26px; display:block; }
  .covimg .covimg-t { display:none; }   /* '이미지' 라벨 제거 */
  .covimg img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block; }
  .covimg .covimg-x { position:absolute; top:6px; right:6px; width:30px; height:30px; display:grid; place-items:center; padding:0;
    color:var(--accent); background:rgba(0,0,0,.20); border:0; border-radius:var(--r-s); cursor:pointer; z-index:2;
    filter:drop-shadow(0 1px 3px rgba(0,0,0,.6)); -webkit-tap-highlight-color:transparent; transition:transform .12s, background .15s; }   /* .fileprev .filerm 계승 */
  .covimg .covimg-x:active { transform:scale(var(--press-xs,.82)); background:rgba(0,0,0,.32); }
  .covimg .covimg-x svg { width:15px; height:15px; display:block; }
  .covimg .covimg-kb { position:absolute; bottom:0; left:0; right:0; background:rgba(0,0,0,.55); color:var(--fg); font-size:9px; text-align:center; padding:1px 0; z-index:2; }   /* .askimg-kb 계승 */
  /* 모바일 = 이미지 슬롯 너비 75%(33%→25%·확보분 텍스트로) → 이미지 옆 둘 때 우측 넘침 방지(운영자 260624). 입력 글자크기는 100%(옛 85% 복귀). 데스크톱은 불변. */
  @media (max-width:480px) {
    .covta { flex:3 1 0; }   /* 텍스트 67%→75% · 이미지 슬롯(.covimg flex:1) 33%→25% (입력 글자 90%(이 화면·260626) · 슬롯 축소로 우측 넘침 해소·운영자 260624) */
  }
  .file { display:block; padding:12px; border:1px dashed transparent; border-radius:var(--r-s); text-align:center; color:var(--accent); cursor:pointer; background:transparent; transition:color .18s, border-color .18s, background .18s, transform .12s ease; }   /* 빈 상태 = 플레이트 없는 사진 픽토그램만(ly .file 통일·운영자 260628) */
  .file svg { width:26px; height:26px; display:block; transition:transform .14s cubic-bezier(.2,.9,.3,1.25); }   /* 파일/사진 픽토그램(빈 상태·ly 47 계승) */
  .file:active { background:transparent; }   /* 누름 = 박스 전체 칠하기 금지(ly .file:active 통일) → PC 파일창(별창) 열림 중 배경/테두리 노출 차단 = .picking 폐지(운영자 260628) */
  .file:active svg { transform:scale(var(--press-xs,.8)); }   /* 누름 = 픽토그램만 축소(박스 전체 X·ly 계승) */
  .file.has { color:var(--accent); border-color:var(--accent); border-style:solid; }
  /* 미리보기 = 4:5 컴팩트(업로드 보통 1080×1350) · 파일명은 칸 안 차지 말고 우하단 50% 반투명 오버레이(우측정렬) */
  .fileprev { position:relative; display:inline-block; margin-top:8px; max-width:100%; }
  .fileprev img { display:block; aspect-ratio:4/5; height:230px; max-width:100%; width:auto; object-fit:cover; border-radius:7px; }
  .fileprev .fn { position:absolute; right:0; bottom:0; max-width:100%; box-sizing:border-box; margin:0;
    background:rgba(0,0,0,.5); color:#fff; font-size:10.5px; line-height:1.3; padding:3px 8px; border-radius:7px 0 7px 0;
    text-align:right; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; backdrop-filter:blur(3px); -webkit-backdrop-filter:blur(3px); }
  /* 업로드 이미지 삭제(휴지통) = 다운로드 버튼(.imgdl) 결 계승 — 이미지 위라 플레이트 검정 20%(아이콘 그린 유지·.imgdl/.imgedit과 통일 · 운영자 260624) */
  .fileprev .filerm { position:absolute; top:8px; right:8px; width:34px; height:34px; display:grid; place-items:center; padding:0; color:var(--accent); background:rgba(0,0,0,.20); border:0; border-radius:10px; cursor:pointer; z-index:2; filter:drop-shadow(0 1px 3px rgba(0,0,0,.6)); -webkit-tap-highlight-color:transparent; transition:transform .12s, background .15s, color .15s; }
  .fileprev .filerm:hover { background:rgba(0,0,0,.24); }
  .fileprev .filerm:active { transform:scale(var(--press-xs,.82)); background:rgba(0,0,0,.32); }
  .fileprev .filerm svg { display:block; width:15px; height:15px; }
  /* 합성본 빗금 참고본(원본 없음·타 기기 수정) — 대각 빗금 = '원본 아님, 재선택하면 교체' 신호(운영자 260624) */
  .refhatch { position:absolute; inset:0; z-index:1; pointer-events:none; border-radius:inherit;   /* 대각 빗금 = 밝은 줄(검정 .38) + 어두운 이미지용 흰 줄(흰 .12) 2톤 → 어떤 배경에도 보임 */
    background:repeating-linear-gradient(45deg, rgba(0,0,0,.38) 0 6px, rgba(255,255,255,.12) 6px 9px, rgba(0,0,0,0) 9px 16px); }
  .refbadge { position:absolute; left:6px; bottom:6px; z-index:2; pointer-events:none; font-size:9px; font-weight:600;
    color:var(--fg); background:rgba(0,0,0,.62); padding:2px 6px; border-radius:6px; letter-spacing:.02em; }
  .fileprev.refonly .refhatch { border-radius:7px; }
  /* 생성 버튼 = 카드 '카드 이미지 생성'(.mkbtn)과 통일 = 글래스 고스트(accent-dim+테두리+네온 글자·pill·하단 게이지 · 운영자 260621) */
  .go { width:100%; margin-top:16px; padding:14px; background:rgba(255,255,255,.05); color:var(--accent); border:1px solid var(--line); border-radius:999px; font-weight:800; font-size:14px; font-family:inherit; cursor:pointer; position:relative; overflow:hidden; transition:transform .12s ease, background .15s ease, border-color .15s ease; }
  /* .go:hover 제거 — 메인 버튼(index .mkbtn) 계승: hover 전경 fill 없음·:active만 피드백(운영자 260629 "마우스 올리면 버튼 전경 뜸" 차단 + 터치 stuck-hover 동시 차단) */
  .go:active { transform:scale(.955); background:rgba(var(--accent-rgb),.08); border-color:rgba(var(--accent-rgb),.35); }
  .go:disabled { opacity:.5; cursor:default; transform:none; }
  .go.shake { animation:edshake .42s; }   /* 내용 미입력 등 전송 막힘 = 좌우 흔들림(edshake 재사용·운영자 260622) */
  @media (prefers-reduced-motion:reduce) { .go.shake { animation:none; } }
  .go.err { background:rgba(255,77,77,.14); color:#ff7a7a; border-color:#ff5d5d; }   /* 미입력 메시지를 버튼 안에 빨강 액티브로 표시(.ed-chip.reject 빨강 계승 · 운영자 260622) */
  .go.warn { background:rgba(var(--amber-rgb),.16); color:var(--amber); border-color:var(--amber); }   /* 강조(*별표*) 누락 = 앰버 액티브(빨강 미입력과 색만 구분 · 진행 불가 · 운영자 260622) */
  .go.firing { color:var(--on-accent); pointer-events:none; opacity:1;
    background:linear-gradient(var(--accent),var(--accent)) left/0% 100% no-repeat, linear-gradient(var(--accent-dim),var(--accent-dim));
    animation:goFill .72s linear forwards; }   /* 누르면 버튼 전체를 초록이 좌→우로 채움(구성도 .send.is-fire 정본·260622) */
  @keyframes goFill { from { background-size:0% 100%, 100% 100%; } to { background-size:100% 100%, 100% 100%; } }   /* 0%(퍼센트)+명시 from = 부드러운 보간(0 길이면 끝에서 툭 튐) */
  @media (prefers-reduced-motion:reduce) { .go.firing { animation-duration:.2s; } }
  .go.okdone { background:var(--accent); color:var(--on-accent); border-color:var(--accent); }   /* 전송됨 = 초록 채움(.iobtn.ok 계승 · 완료비트) */
  .go.checking { display:grid; place-items:center; }   /* 체크 그리는 동안 SVG 중앙정렬 */
  .go .gck { width:26px; height:26px; }
  .go .gck path { fill:none; stroke:var(--on-accent); stroke-width:2.7; stroke-linecap:round; stroke-linejoin:round; stroke-dasharray:24; stroke-dashoffset:24; animation:goTick .38s .04s ease forwards; }   /* 시안1 = 스트로크 드로우(완료 체크) */
  @keyframes goTick { to { stroke-dashoffset:0; } }
  @media (prefers-reduced-motion:reduce) { .go .gck path { animation:none; stroke-dashoffset:0; } }
  .go.spelling { animation:goSpell 1s ease-in-out infinite; }   /* 맞춤법 확인 중 = 부정형 펄스(게이지 아님 — 소요시간 불확정) */
  @keyframes goSpell { 0%,100% { opacity:.6; } 50% { opacity:1; } }
  @media (prefers-reduced-motion:reduce) { .go.spelling { animation:none; opacity:.8; } }
  /* 맞춤법 교정 = 노랑 재확인(리뷰) + 노랑 게이지/체크(게이지바 유지, 색만 노랑) */
  .go.spell-arm { background:rgba(var(--arm-rgb),.16); color:var(--arm); border-color:rgba(var(--arm-rgb),.55); }
  .go.firing.fy { background:linear-gradient(var(--warn),var(--warn)) left/0% 100% no-repeat, linear-gradient(rgba(var(--warn-rgb),.16),rgba(var(--warn-rgb),.16)); }
  .go.okdone.fy { background:var(--warn); color:var(--on-arm); border-color:var(--warn); }
  .go.okdone.fy .gck path { stroke:var(--on-arm); }
  /* 축약 = 제작 버튼 안 좌측 오버레이(별도 행 제거·행 절약 · /1·/2만 표시) — 버튼 형제라 클릭 충돌 0·textContent 상태머신 무영향 */
  .gowrap { position:relative; }
  .go-abbr { position:absolute; left:calc(100% / 5); top:50%; transform:translate(-50%, -50%); z-index:2; margin:0; gap:6px; font-size:14px; font-weight:600; line-height:1; color:var(--accent); -webkit-tap-highlight-color:transparent; }   /* 배경 없음·버튼 가로 1/5·수직 중앙·글자크기=버튼 텍스트(14px) */
  .go-abbr .cbox, .go-abbr .ackm { flex:none; }   /* 체크박스 찌그러짐 방지 */
  .go-abbr .cbox { width:14px; height:14px; border-radius:5px; }   /* 축약 글자(14px) 높이와 동일·수직중앙 */
  .go-abbr .ackm { width:10px; height:10px; }
  /* 첨부(이미지 슬롯) + 제작 버튼 한 행 = ly .filerow 통일(빈 상태 한 행·높이 절약 / 이미지 선택 시 미리보기 전체폭 펼침 · 운영자 260628) */
  .makerow { display:flex; flex-wrap:wrap; gap:10px; align-items:stretch; margin-top:9px; }   /* margin-top:9px = 형제(.iowrap·.covrow·#goSpec) 단일 리듬 합류(분신술7·260628) */
  .makerow > #imgBox:not(.none) { flex:1.4 1 0; min-width:0; margin:0; display:flex; }   /* 빈 슬롯 = 좌측 넓게(ly 비율) · :not(.none) = 썸네일/저작권 탭(app2·3 imgBox.none)서 노출 버그 차단(specificity 110이 .none 10 이기던 것·260628) */
  .makerow > #imgBox .file { width:100%; box-sizing:border-box; margin:0; min-height:100%; display:flex; align-items:center; justify-content:center; white-space:nowrap; }
  .makerow > .gowrap { flex:1 1 0; min-width:140px; }   /* 제작 버튼 = 우측 짧게 */
  .makerow > .gowrap .go { margin-top:0; }
  .makerow > #imgBox:not(.none):has(.file.has) { flex-basis:100%; }   /* 이미지 선택 → 슬롯 전체폭, 버튼 다음 줄 전폭(미리보기 펼침) */
  /* 붙여넣기 폴백 모달 = readText 막힌 환경(모바일 칩)에서 '길게 눌러 붙여넣기' (통일 기틀·운영자 260628) · dialog=top-layer */
  .pastefb { border:none; outline:none; background:transparent; max-width:100vw; max-height:100dvh; width:auto; padding:0; margin:auto; }
  .pastefb::backdrop { background:rgba(0,0,0,.55); -webkit-backdrop-filter:blur(4px); backdrop-filter:blur(4px); }
  .pastefb-box { width:min(360px,90vw); background:linear-gradient(165deg,#14160f,#0c0f0c); border:1px solid var(--line); border-radius:var(--r-l); padding:16px; display:flex; flex-direction:column; gap:12px; box-shadow:0 16px 48px rgba(0,0,0,.55); }
  .pastefb-msg { font-size:13px; color:#cfd2d7; line-height:1.5; } .pastefb-msg b { color:var(--accent); }
  .pastefb-ta { width:100%; box-sizing:border-box; min-height:90px; resize:none; padding:10px 12px; border:1px solid var(--line); border-radius:10px; background:rgba(255,255,255,.05); color:#e8eaed; font:inherit; font-size:14px; }
  .pastefb-ta:focus { border-color:rgba(var(--accent-rgb),.4); outline:none; }
  .pastefb-row { display:flex; gap:8px; justify-content:flex-end; }
  .pastefb-btn { padding:8px 16px; border-radius:999px; border:1px solid var(--line); background:rgba(255,255,255,.05); color:#cfd2d7; font:inherit; font-size:13px; font-weight:700; cursor:pointer; }
  .pastefb-ok { color:var(--accent); border-color:rgba(var(--accent-rgb),.4); background:rgba(var(--accent-rgb),.1); }
  /* 제작 직전 결과물 명세(통합 모드 — 체크 많아 한눈 요약) · 블릿 말머리·좌측정렬 · 활성=노랑/비활성=회색 */
  .gospec { margin:16px 2px 0; font-size:12.5px; color:var(--mut); text-align:left; line-height:1.8; }
  /* 옵션줄 = 검정 배경 패널로 돋보이게(운영자 260624) */
  #goSpec { margin:9px 0 0; padding:10px 13px; background:rgba(0,0,0,.32); border:1px solid var(--line); border-radius:var(--r-m); }   /* 옵션줄 = 검정 패널 · 머리↔박스 간격 9px(헤더·오버레이와 통일·운영자 260624) */
  /* • 오버레이 포맷 토글 — 포스트=시안 / 릴스=레몬(운영자 260624) */
  .csec .ovsep { color:var(--mut); font-weight:400; margin:0 5px; }
  .csec .ovfmt { cursor:pointer; font-weight:800; -webkit-tap-highlight-color:transparent; -webkit-user-select:none; user-select:none; padding:3px 5px; transition:color .15s, transform .1s; }   /* 패딩 = 폰 탭 영역 확보(도형 없이 · 분신술8) */
  .csec .ovfmt.post { color:#1fd6ee; }    /* 포스트 = 시안 */
  .csec .ovfmt.reels { color:#e7ff2e; }   /* 릴스 = 레몬 */
  .csec .ovfmt.forced { opacity:.65; cursor:default; }   /* 헤더 입력 중 = 릴스 고정 */
  .csec .ovfmt:active { transform:scale(var(--press-m,.92)); }   /* 눌림 피드백(.onoff·옛 .cpfmt와 일관 · 분신술8) */
  .gospec .gs-bul { color:var(--mut); font-weight:700; margin-right:4px; }
  .gospec .gs-lbl { color:var(--mut); font-weight:700; }   /* 라벨(헤더/오버레이/축약) = mut 통일(운영자 260624) */
  .gospec .gs-v { color:var(--mut); }
  .gospec .gs-v.on { color:var(--accent); font-weight:700; }   /* 활성값 = 네온그린 강조(노랑→accent 통일·운영자 260624) */
  /* goSpec 컨트롤 — OPA(휠/드래그)·기본/축약(클릭 토글). 조절 중 mut·픽스 강조 */
  .gospec .gs-opa { cursor:ns-resize; color:var(--accent); font-weight:700; font-variant-numeric:tabular-nums; padding:0 2px; touch-action:none; -webkit-tap-highlight-color:transparent; transition:color .25s ease; }
  .gospec .gs-opa.opa-adjusting { color:var(--mut); }
  /* 릴스 자막 보조 OPA(+30) — OFF=일반색 클릭추가 / ON=accent(.gs-v.on)·스크롤 조절 */
  #gsOpa2 { font-variant-numeric:tabular-nums; -webkit-tap-highlight-color:transparent; }
  #gsOpa2.on { cursor:ns-resize; touch-action:none; }
  #gsOpa2.opa-adjusting { color:var(--mut); }
  /* 보조 OPA −/+ 탭 스테퍼(모바일 드래그 보완 = ±5·운영자 260624) — ON일 때만 노출 · 큰 탭 타깃 · .gospec 접두=.gs-v(mut) 이김 */
  .gospec .gsop-step { color:var(--accent); font-weight:800; padding:0 7px; cursor:pointer; -webkit-tap-highlight-color:transparent; user-select:none; -webkit-user-select:none; }
  .gospec .gsop-step:active { opacity:.55; }
  .gospec .gs-tog { cursor:pointer; -webkit-tap-highlight-color:transparent; transition:color .2s ease; padding:0 1px; -webkit-user-select:none; user-select:none; -webkit-touch-callout:none; }   /* user-select:none = 축약 롱프레스 시 텍스트 선택/콜아웃 방지 */
  .gospec .gs-tog:active { opacity:.65; }
  #goSpec { font-size:11.25px; white-space:nowrap; }   /* 기본(combo) 명세 = 현재의 90% + 한 줄(모바일 · []·/ 제거 · 운영자 260624) */
  .cmtrk { display:block; margin:6px 2px 0; }            /* 통합 모드 자간 안내(부제/제목·자막) = 입력 아래 별도 줄 */
  .cmtrk:empty { display:none; }                          /* 초과 없으면 숨김(빈 줄 방지) */
  /* ── /3 저작권+안내문 통합 (260624) ── */
  /* 포맷 = 단일 토글(포스트↔릴스 · 한 번에 하나만 · 썸네일 #ovFmtTog와 동일 패턴 · 도형 없음 · 운영자 260624) → .csec .ovfmt 계승(시안/레몬) */
  /* ON/OFF 토글 — 도형(알약) 없이 텍스트만(운영자 260624) · 저작권(기본 ON) · 안내문(기본 OFF, 켜지면 종류명 표시) · ON=네온그린 */
  .csec .onoff { cursor:pointer; font-weight:800; font-size:12px; letter-spacing:.03em; color:var(--mut); padding:3px 5px; -webkit-tap-highlight-color:transparent; -webkit-user-select:none; user-select:none; transition:color .15s, transform .1s; }   /* 패딩 = 폰 탭 영역(도형 없이 · 분신술8) */
  .csec .onoff.on { color:var(--accent); }
  .csec .onoff:active { transform:scale(var(--press-m,.92)); }
  .csec.gsec { position:relative; }   /* 안내문 팝업(.gpop) 기준 */
  /* 저작권 = 자연스러운 한 문장. 정적(.cph-st) + 탭 수정(연도·이름=.cph-ed) + 플랫폼(.cph-plat) · 'all rights…'는 편집화면만 줄바꿈 */
  .cphline { position:relative; display:flex; flex-wrap:wrap; align-items:baseline; margin-top:11px; font-size:14px; color:var(--fg); line-height:2; transition:opacity .15s; }
  .cphline.off { opacity:.4; }   /* 저작권 OFF = 흐리게(제작에서 빠짐 신호) */
  .cphline .cph-st { color:var(--fg); white-space:pre; }   /* ⓒ·.·(·) 등 정적 텍스트 */
  .cph-br { flex-basis:100%; height:0; }   /* 편집화면에서 'all rights reserved.'를 다음 줄로(출력엔 영향 0 — 발사는 year/name/platform 파라미터) */
  /* 수정 가능한 부분 = 문구 속 점선 밑줄 affordance(플랫폼 .cph-plat 톤 계승) → 탭=커서·바로 편집 */
  .cph-ed { color:var(--accent); font-weight:600; cursor:text; padding:0 3px; min-width:1.1em; outline:none;
    border-bottom:1px dashed rgba(var(--accent-rgb),.45); -webkit-tap-highlight-color:transparent; transition:color .15s, border-color .15s, background .15s; }
  .cph-ed:hover { border-bottom-color:var(--accent); }
  .cph-ed:focus { border-bottom-style:solid; border-bottom-color:var(--accent); background:rgba(var(--accent-rgb),.08); border-radius:4px; }
  .cph-ed:empty::before { content:attr(data-ph); color:var(--mut); font-style:italic; font-weight:400; }   /* 미입력 = 예시(연도 2026·이름 nomute) 옅은 회색 */
  .cph-yr { font-variant-numeric:tabular-nums; min-width:1.6em; }   /* 연도 = 자유 수정(정수/-) */
  .cph-plat { cursor:pointer; color:var(--accent); font-weight:600; padding:1px 4px; border-bottom:1px dashed rgba(var(--accent-rgb),.45); -webkit-tap-highlight-color:transparent; -webkit-user-select:none; user-select:none; transition:color .15s, border-color .15s; }
  .cph-plat:hover { border-bottom-color:var(--accent); }
  /* 플랫폼 픽토그램 팝업 — 작은 글래스 메뉴(.seg button 글래스 톤 계승) */
  .platpop { position:absolute; top:100%; left:0; margin-top:6px; z-index:9; display:flex; gap:6px; padding:7px;
    background:linear-gradient(150deg, rgba(38,64,46,.7), rgba(11,21,15,.82)); backdrop-filter:blur(16px) saturate(1.2); -webkit-backdrop-filter:blur(16px) saturate(1.2);
    border:1px solid rgba(255,255,255,.12); border-radius:12px; box-shadow:0 12px 30px rgba(0,0,0,.4); }
  .platpop.none { display:none; }
  /* 촤르륵 = 팝업 펼쳐짐 + 픽토그램 좌→우 스태거 등장(display none→flex 전환마다 재생) */
  .platpop:not(.none) { transform-origin:top left; animation:platpop-in .2s cubic-bezier(.2,.7,.3,1); }
  @keyframes platpop-in { from { opacity:0; transform:translateY(-5px) scale(.9); } to { opacity:1; transform:none; } }
  .platpop:not(.none) .ppbtn { animation:ppbtn-in .26s both cubic-bezier(.2,.8,.3,1); }
  .platpop:not(.none) .ppbtn:nth-child(1) { animation-delay:.02s; }
  .platpop:not(.none) .ppbtn:nth-child(2) { animation-delay:.05s; }
  .platpop:not(.none) .ppbtn:nth-child(3) { animation-delay:.08s; }
  .platpop:not(.none) .ppbtn:nth-child(4) { animation-delay:.11s; }
  .platpop:not(.none) .ppbtn:nth-child(5) { animation-delay:.14s; }
  .platpop:not(.none) .ppbtn:nth-child(6) { animation-delay:.17s; }
  @keyframes ppbtn-in { from { opacity:0; transform:translateX(-9px) scale(.78); } to { opacity:1; transform:none; } }
  @media (prefers-reduced-motion:reduce) { .platpop:not(.none), .platpop:not(.none) .ppbtn { animation:none; } }
  .ppbtn { min-width:38px; height:34px; display:grid; place-items:center; padding:0 8px; background:linear-gradient(165deg, rgba(34,56,41,.42), rgba(14,26,18,.52)); border:1px solid rgba(255,255,255,.09); border-radius:var(--r-s); color:var(--mut); cursor:pointer; font:inherit; font-weight:600; font-size:11px; transition:border-color .15s, background .15s, color .15s; }
  .ppbtn:hover { color:var(--fg); border-color:rgba(255,255,255,.2); }
  .ppbtn.on { border-color:rgba(var(--accent-rgb),.5); color:var(--accent); background:linear-gradient(165deg, rgba(var(--accent-rgb),.16), rgba(var(--accent-rgb),.05)); }
  .ppbtn:active { transform:scale(var(--press-m,.9)); }
  .ppbtn svg { width:15px; height:15px; display:block; }
  .gpbtn { min-width:auto; height:32px; padding:0 13px; font-size:12px; }   /* 안내문 팝업 = 텍스트 버튼(경고/AI/자유문구) · 픽토그램(.ppbtn) 글래스 톤 계승 */
  /* 교정 칩 = 버튼 아래·바뀐 단어만·탭으로 점등 토글(노랑=적용 / 회색=그대로) */
  .spellchips { display:flex; flex-wrap:wrap; gap:7px; margin-top:11px; }
  .spellchips[hidden] { display:none; }
  .spchip { font:inherit; font-size:12px; padding:6px 11px; border-radius:var(--r-s); cursor:pointer; user-select:none;
    border:1px solid var(--line); background:rgba(255,255,255,.04); color:var(--mut); transition:.15s; display:inline-flex; align-items:center; gap:6px; }
  .spchip::before { content:''; width:7px; height:7px; border-radius:50%; background:var(--mut); transition:.15s; flex:none; }
  .spchip.on { border-color:rgba(var(--warn-rgb),.55); background:rgba(var(--warn-rgb),.12); color:var(--warn); font-weight:700; }
  .spchip.on::before { background:var(--warn); box-shadow:0 0 7px rgba(var(--warn-rgb),.8); }
  .chk { display:flex; align-items:center; gap:9px; margin-top:14px; font-size:14px; color:var(--fg); cursor:pointer; }   /* 체크박스 = k.html .chk 계승 */
  /* 축약 체크 = 수집함 확인 토글(.sc-tg.ack) 체크표시 그대로 계승 — 안 누름 −(회색) → 누름 ✓(초록·한 획 드로우-인) + 글래스 박스 초록 틴트 + 눌림 scale(운영자 260622) */
  .chk input { position:absolute; left:0; width:18px; height:18px; margin:0; opacity:0; cursor:pointer; }
  .chk .cbox { flex:none; width:24px; height:24px; display:grid; place-items:center; border-radius:var(--r-s);
    border:1px solid rgba(255,255,255,.14); background:rgba(8,15,11,.34); color:rgba(255,255,255,.5);
    backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); transition:background .14s, transform .1s, color .14s, border-color .14s; }
  .chk .cbox .ackm { width:15px; height:15px; display:block; }
  .chk .cbox .ackm path { transition:opacity .16s ease, stroke-dashoffset .42s .08s cubic-bezier(.6,0,.2,1); }
  .chk .cbox .sc-dash { stroke:var(--mut); opacity:1; }
  .chk .cbox .sc-chk { stroke:var(--accent); opacity:0; stroke-dasharray:24; stroke-dashoffset:24; }
  .chk input:checked + .cbox { border-color:rgba(var(--accent-rgb),.5); background:rgba(var(--accent-rgb),.14); color:var(--accent); }
  .chk input:checked + .cbox .sc-dash { opacity:0; }
  .chk input:checked + .cbox .sc-chk { opacity:1; stroke-dashoffset:0; }
  .chk:active .cbox { transform:scale(var(--press-m,.9)); }
  .chk input:focus-visible + .cbox { box-shadow:0 0 0 2px rgba(var(--accent-rgb),.45); }
  @media (prefers-reduced-motion:reduce) { .chk .cbox .ackm path { transition:none; } }
  .chk .abbrhint { color:var(--mut); font-weight:400; font-size:11px; }
  /* 복사칩 = 뉴스 요약 키워드칩(.cref-kw) 표기방식·복사 액티브 그대로 계승(검정 글래스 칩 + 탭 복사 + 초록 눌림 플래시 · 운영자 260622) */
  .kwline { margin-top:7px; }
  .kwchip { display:inline-block; max-width:100%; font-size:11px; font-weight:600; color:var(--accent); line-height:1.5; white-space:normal; word-break:break-word;
    padding:3px 11px; border-radius:8px; background:rgba(0,0,0,.42); border:1px solid rgba(255,255,255,.08); box-shadow:0 1px 4px rgba(0,0,0,.35);
    backdrop-filter:blur(6px); -webkit-backdrop-filter:blur(6px); cursor:pointer; -webkit-tap-highlight-color:transparent; transition:background .15s, color .15s, border-color .15s; }
  .kwchip:active { transform:scale(var(--press-l,.98)); }
  @keyframes kwcopy {
    0%   { transform:scale(1);   background:rgba(0,0,0,.42); border-color:rgba(255,255,255,.08); }
    32%  { transform:scale(.93); background:rgba(var(--accent-rgb),.18); border-color:rgba(var(--accent-rgb),.55); }
    100% { transform:scale(1);   background:rgba(0,0,0,.42); border-color:rgba(255,255,255,.08); } }
  .kwchip.copied { animation:kwcopy .42s ease; }
  @media (prefers-reduced-motion:reduce) { .kwchip.copied { animation:none; } }
  .out { margin-top:18px; }
  .status { font-size:13px; color:var(--mut); white-space:pre-wrap; }
  .status.err { color:#ff8a8a; }
  .status.ok { color:var(--accent); }   /* 맞춤법 자동교정 알림(비-에러·잠깐) */
  /* 대기열/로그 — 제작 건별 행(동시 처리) */
  .jobs { display:flex; flex-direction:column; gap:6px; margin:10px 0 0; }
  .job { display:flex; flex-wrap:wrap; align-items:center; gap:8px; font-size:12px; padding:8px 11px; border-radius:var(--r-s); background:rgba(8,15,11,.34); border:1px solid var(--line); }   /* flex-wrap = 다중 변형(.jvars)이 아래 줄 전체폭으로 떨어짐 */
  .job .jlab { font-weight:800; color:var(--accent); }
  .job .jvar { color:#fff; font-weight:400; }   /* OPA·변형 라벨 = 흰색·일반체(초록 제목과 구분 · 운영자 260619) */
  .job .jvars { flex-basis:100%; display:flex; flex-direction:column; align-items:flex-start; gap:3px; margin-top:2px; padding-left:0; margin-bottom:3px; }   /* 다중 변형([1]·[2]…) = 줄바꿈·헤더와 동일 좌측선(들여쓰기 0) · margin-top 65%(헤더~[1] 좁힘) · margin-bottom = 박스 상하 시각 여백 대칭(헤더줄 「전체」버튼 오프셋 보정 · 운영자 260620) */
  /* 변형 줄 = 클릭(해당 변형으로 캐러셀 점프) + 개별 다운로드 — 이미지 나온 변형만 활성(운영자 260620 아이디어 1·2) */
  .job .jvars .jvar { display:inline-flex; align-items:center; gap:9px; }
  .job .jvars .jvar.on .jvar-tx { cursor:pointer; border-bottom:1px dashed rgba(255,255,255,.26); transition:color .15s, border-color .15s; }
  .job .jvars .jvar.on .jvar-tx:hover { color:var(--accent); border-color:var(--accent); }
  .job .jvar-dl { display:inline-flex; align-items:center; justify-content:center; width:26px; height:26px; color:rgba(255,255,255,.72); background:rgba(255,255,255,.06); border:1px solid var(--line); border-radius:8px; text-decoration:none; transition:transform .12s, background .15s, color .15s; }   /* 26px = 모바일 터치 오발 여지 축소(폰 주력 · 검증5 반영) */
  .job .jvar-dl:hover { background:rgba(255,255,255,.15); color:#fff; }
  .job .jvar-dl:active svg { transform:scale(var(--press-xs,.82)); }   /* 픽토온리(.dlbtn이 plate 제거=transparent) → SVG만 축소(배경 안 따라움직임·분신술10·운영자 260628) */
  .job .jvar-dl svg { display:block; width:12px; height:12px; transition:transform .12s ease; }
  .job .jst { margin-left:auto; color:var(--mut); white-space:nowrap; display:inline-flex; align-items:center; gap:5px; }   /* 상태 아이콘(SVG)+글자 수직중앙(운영자 260622) */
  .job .jst svg { display:block; width:14px; height:14px; flex:none; }
  .job .jst .jspin { animation:thspin .9s linear infinite; }
  @keyframes thspin { to { transform:rotate(360deg); } }
  .thfocus { animation:thfocus 2.2s ease both; border-radius:10px; }   /* 알림 #done=<id> 착지 항목 강조 = '해당 작업' 식별(잡 행/이력 항목 공용) */
  @keyframes thfocus { 0%,100%{ box-shadow:0 0 0 0 rgba(var(--accent-rgb),0); } 18%,46%{ box-shadow:0 0 0 3px rgba(var(--accent-rgb),.55); } }
  @media (prefers-reduced-motion:reduce){ .thfocus { animation:none; } }
  .job.done .jst { color:var(--accent); }
  .job.err { border-color:rgba(255,90,90,.4); } .job.err .jst { color:#ff9b9b; }
  /* 실패 잡 재시도 = 같은 설정으로 재발사(운영자 260620 아이디어 3) */
  .job .jretry { flex:none; display:inline-flex; align-items:center; gap:5px; font-weight:800; font-size:10.5px; line-height:1; color:#ffb4b4; cursor:pointer; white-space:nowrap; background:rgba(40,12,12,.5); border:1px solid rgba(255,120,120,.36); border-radius:999px; padding:6px 11px; backdrop-filter:blur(10px); -webkit-backdrop-filter:blur(10px); transition:transform .12s, background .15s, color .15s, border-color .15s; }
  .job .jretry:hover { background:rgba(255,90,90,.2); color:#fff; border-color:rgba(255,120,120,.6); }
  .job .jretry:active { transform:scale(var(--press-l,.95)); }
  .job .jretry svg { display:block; width:12px; height:12px; }
  .job .jretry[disabled] { opacity:.5; pointer-events:none; }
  /* 실패 잡 삭제(휴지통) = 우측·세로중앙 글래스 아이콘(운영자 260622) */
  .job .jdel { flex:none; display:inline-flex; align-items:center; justify-content:center; width:28px; height:28px; color:rgba(255,255,255,.6); cursor:pointer; background:rgba(255,255,255,.05); border:1px solid var(--line); border-radius:8px; transition:transform .12s, background .15s, color .15s, border-color .15s; }
  .job .jdel:hover { background:rgba(255,90,90,.18); color:#ff9b9b; border-color:rgba(255,120,120,.5); }
  .job .jdel:active { transform:scale(var(--press-s,.85)); }
  .job .jdel svg { display:block; width:14px; height:14px; }
  /* 완성 이미지 캐러셀 — 뷰어 카드 피드(.feedtrack) 계승: 스크롤 스냅 + 글래스 화살표 */
  .carwrap { margin-top:14px; }
  .cartrackwrap { position:relative; }
  .cartrack { display:flex; overflow-x:auto; scroll-snap-type:x mandatory; scroll-behavior:smooth; -webkit-overflow-scrolling:touch; scrollbar-width:none; border-radius:10px; }
  .cartrack::-webkit-scrollbar { display:none; }
  @media (hover:hover) and (pointer:fine) { .cartrack { cursor:grab; } .cartrack.dragging { cursor:grabbing; scroll-behavior:auto; scroll-snap-type:none; } }   /* PC 잡아끌기 — 뉴스 카드피드(.feedtrack) 계승 */
  .carslide { flex:0 0 100%; scroll-snap-align:center; scroll-snap-stop:always; position:relative; }
  .carslide img { width:100%; border:1px solid var(--line); border-radius:10px; display:block; }
  .carslide .cap { position:absolute; left:8px; top:8px; background:rgba(0,0,0,.5); color:#fff; font-size:10.5px; font-weight:700; padding:2px 9px; border-radius:999px; backdrop-filter:blur(4px); -webkit-backdrop-filter:blur(4px); }
  .carslide .cap-var { font-weight:400; }   /* 캡션 변형(OPA) = 일반체(흰색은 .cap 상속 · 운영자 260619) */
  .carnav { position:absolute; top:50%; transform:translateY(-50%); width:38px; height:38px; display:grid; place-items:center; border-radius:50%; cursor:pointer;
    background:rgba(12,16,14,.5); color:#fff; border:1px solid rgba(255,255,255,.18); font-size:22px; line-height:1; padding-bottom:3px;
    backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px); opacity:.85; transition:opacity .15s, transform .1s; }
  .carnav:hover { opacity:1; } .carnav:active { transform:translateY(-50%) scale(var(--press-m,.9)); }
  .carnav.prev { left:8px; } .carnav.next { right:8px; }
  .carnav:disabled { opacity:0; pointer-events:none; }
  .carbar { display:flex; align-items:center; gap:10px; margin-top:8px; }
  .carcount { font-size:11.5px; color:var(--mut); }
  .carsave { display:none; }   /* (구) 캐러셀 아래 배치 폐지 — 전체 다운로드은 캐러셀 우상단 오버레이로 이동(아래 .saveall) */
  /* 전체(전체 다운로드) = 잡(결과) 행 우측 인라인 버튼(운영자 260619 — 캐러셀 오버레이서 이동, index.html .fi-saveall 패턴 일치). 글래스 톤(§📋). */
  .job .jsave { flex:none; display:inline-flex; align-items:center; gap:5px; font-weight:800; font-size:10.5px; line-height:1; color:#fff; cursor:pointer; white-space:nowrap;
    background:rgba(8,15,11,.46); border:1px solid rgba(255,255,255,.18); border-radius:999px; padding:6px 11px;
    backdrop-filter:blur(10px); -webkit-backdrop-filter:blur(10px); box-shadow:0 2px 8px rgba(0,0,0,.28); }
  .job .jsave:active { transform:scale(var(--press-l,.95)); } .job .jsave svg { display:block; width:12px; height:12px; }
  .job .jsave-row { flex-basis:100%; display:flex; justify-content:flex-end; margin-top:4px; }   /* 전체 = 완료 시각줄 아래·우측정렬(운영자 260622) · 변형 없을 때만 단독 행 */
  .job .jgrid { flex-basis:100%; display:flex; align-items:flex-start; gap:8px; margin-top:2px; }   /* 변형목록(좌) + 전체(우) 한 띠 = 전체 줄 좌측 공백 활용 · 1개/n개 동일(운영자 260626) */
  .job .jgrid .jvars { flex:1 1 auto; margin-top:0; }     /* 좌측 = 변형 [1]…[n] 채움 */
  .job .jgrid .jsave-row { flex:0 0 auto; margin-top:1px; }   /* 우측 = 전체(변형 [1]과 상단 정렬·광학 1px) */
  .result img { width:100%; border:1px solid var(--line); border-radius:10px; }
  .slot { margin-bottom:14px; }
  .slot-lab { font-size:12.5px; color:var(--mut); margin-bottom:5px; font-weight:600; }
  .slot-img { min-height:40px; position:relative; }
  .slot-img img { width:100%; border:1px solid var(--line); border-radius:10px; display:block; }
  /* 결과 이미지 다운로드 (우상단) = 뉴스 피드 캐러셀 .sbtn 글래스 그대로 계승(§📋 · 34px·bg .3·border .14·hover·active .85) */
  .imgdl { position:absolute; top:10px; right:10px; width:34px; height:34px; display:grid; place-items:center; border:0; border-radius:10px; text-decoration:none; z-index:2; transition:transform .12s, background .15s, color .15s; }   /* 다운로드 = .dlbtn 표준(강조색 10%·그림자·✓팝링)에서 색/효과 상속 · 여긴 위치/크기만(운영자 260622) */
  .imgdl:active { transform:scale(var(--press-xs,.82)); }   /* 눌림(색 채움·✓팝링은 .dlbtn 표준) */
  /* 수정(편집) = 다운로드 옆 — 이전 제작의 입력 조건을 작성기로 복원(운영자 260624). 색=accent 토큰(.dlbtn과 동일 계열·연필 아이콘으로 구분)·✓팝링 없음(다운로드 아님) */
  .imgedit { position:absolute; top:10px; width:34px; height:34px; display:grid; place-items:center; border:0; border-radius:10px; z-index:2; cursor:pointer; color:var(--accent); background:rgba(0,0,0,.20); transition:transform .12s, background .15s; }
  .imgedit:hover { background:rgba(0,0,0,.24); }
  .imgedit:active { transform:scale(var(--press-xs,.82)); }
  .imgedit svg { width:14px; height:14px; }
  .imgdl svg { display:block; width:14px; height:14px; }
  /* ▼ 다운로드 버튼 표준(전 앱 공통 · 강조색 + 10% 반투명 + 클릭 ✓팝+링 · 정본=여기 · 운영자 260622) — 새 다운로드 버튼은 .dlbtn 한 클래스만 추가, 색·효과 재설계 금지 */
  .dlbtn { color:var(--accent) !important; background:rgba(var(--accent-rgb),.10) !important; border-color:rgba(var(--accent-rgb),.22) !important; filter:drop-shadow(0 1px 2px rgba(0,0,0,.45)); }
  .dlbtn:hover { background:rgba(var(--accent-rgb),.16) !important; }
  /* 이미지 위 오버레이 버튼(이력·캐러셀 다운로드) 플레이트 = 중립 검정 20%(펜 .imgedit·휴지통과 통일·녹색 아님 · 운영자 260624). 행 버튼(.jsave·.jvar-dl)·전역 .dlbtn 표준은 그린 유지. */
  .imgdl.dlbtn { background:rgba(0,0,0,.20) !important; border-color:transparent !important; }
  .imgdl.dlbtn:hover { background:rgba(0,0,0,.24) !important; }
  /* 개별 변형 다운로드(.jvar-dl) = 도형(글래스 박스) 제거·픽토그램만 · 색=변형 라벨 흰글씨(.jvar #fff)와 동일 · 26px 탭영역은 투명 유지(터치 보존) · 아이콘 14px = 12px 라벨과 광학 높이 정합 (운영자 260626) */
  .job .jvar-dl.dlbtn { background:transparent !important; border-color:transparent !important; color:#fff !important; filter:none; }
  .job .jvar-dl.dlbtn:hover { background:transparent !important; color:var(--accent) !important; }
  .job .jvar-dl.dlbtn svg { width:14px; height:14px; }
  .dlbtn .dl-ack { position:absolute; inset:0; border-radius:inherit; overflow:hidden; display:grid; place-items:center; pointer-events:none; z-index:6; color:var(--accent); }   /* overflow:hidden = ✓팝·링 리플을 버튼 안에 가둠(이미지 위 오버레이서 밖으로 새 '위에 중첩' 차단 · 운영자 260628) */
  /* 픽토그램-온리 다운로드(투명 ↓ ·이미지 위 ↓) = ✓팝 오버레이가 ↓아이콘/기존이미지와 중첩 → ✓ 제거하고 :active scale 액티브만(전체저장 .jsave 선례 동일 · 같은 ↓ 이모지 전체 적용 · 운영자 260628) */
  .jvar-dl.dlbtn .dl-ack, .imgdl.dlbtn .dl-ack { display:none !important; }
  .dlbtn .dl-ack > svg { width:18px; height:18px; filter:drop-shadow(0 1px 2px rgba(0,0,0,.5)); animation:dlAckPop .7s cubic-bezier(.18,1.5,.4,1) forwards; }   /* 팝 = 컨테이너 아닌 ✓ 글리프에만(컨테이너는 버튼 크기 고정 = 정확 클립) */
  .dlbtn .dl-ack .dl-ring { position:absolute; inset:0; border-radius:inherit; border:1.5px solid rgba(var(--accent-rgb),.7); animation:dlRing .55s ease-out forwards; }
  @keyframes dlAckPop { 0%{opacity:0;transform:scale(0)} 30%{opacity:1;transform:scale(1.15)} 55%{transform:scale(1)} 80%{opacity:1} 100%{opacity:0;transform:scale(1)} }
  @keyframes dlRing { from{transform:scale(.35);opacity:.9} to{transform:scale(1);opacity:0} }   /* 안→가장자리로 차오르는 리플(밖으로 안 넘침). 옛 1→1.5 확장은 버튼 밖 침범 = 중첩 원인(폐기) */
  @media (prefers-reduced-motion:reduce){ .dlbtn .dl-ack > svg, .dlbtn .dl-ack .dl-ring { animation:none; } .dlbtn .dl-ack { opacity:0; } }
  /* ▼ 전체저장(.jsave) = 미니멀 텍스트(시안 9번·index .cref-dlall과 통일·운영자 260623): 글래스/테두리/채움 없이 아이콘+라벨만, 완료 시 ✓ 팝(채움 없음·글자 강조색 유지). 정본 = 구성도 §9. */
  .jsave.dlbtn { position:relative; overflow:hidden; background:transparent !important; border-color:transparent !important; backdrop-filter:none !important; -webkit-backdrop-filter:none !important; box-shadow:none !important; padding:6px 6px; }
  .jsave.dlbtn:hover { background:rgba(255,255,255,.06) !important; }
  .jsave.dlbtn .dl-ack { display:none !important; }
  .jsave > svg, .jsave .dlseq-ic, .jsave .jslbl { position:relative; z-index:1; }
  .jsave .jslbl { transition:color .18s; }
  .jsave .dlseq-ic { width:12px; height:12px; display:inline-grid; }
  .jsave .dlseq-ic svg { grid-area:1/1; width:12px; height:12px; }
  .jsave .dlseq-ic .chk { opacity:0; }
  .jsave.dlbtn::before { display:none; }   /* 미니멀 = 좌→우 채움 없음 */
  .jsave.dlbtn.dlseq-busy, .jsave.dlbtn.dlseq-done { color:var(--accent) !important; }   /* 채움 없으니 글자 강조색 유지 */
  .jsave.dlbtn.dlseq-done .dlseq-ic .dn { opacity:0; }
  .jsave.dlbtn.dlseq-done .dlseq-ic .chk { opacity:1; animation:dlChkPop .42s cubic-bezier(.22,.61,.36,1); }
  @keyframes dlChkPop { 0%{transform:scale(.3)} 58%{transform:scale(1.3)} 100%{transform:scale(1)} }
  @media (prefers-reduced-motion:reduce){ .jsave.dlbtn.dlseq-done .dlseq-ic .chk { animation:none; } }
  /* 이전 제작(12h) 접힘 섹션 */
  .hist { margin-top:20px; padding-top:6px; }   /* 구분선(border-top) 제거 — 헤더+간격으로 충분(운영자 260626) */
  .hist-h { width:100%; display:flex; align-items:center; gap:8px; background:none; border:none; color:var(--fg); cursor:pointer; padding:10px 2px; font:inherit; font-size:13px; font-weight:700; }
  .hist-ttl { display:inline-flex; align-items:center; gap:6px; transition:color .3s ease, text-shadow .3s ease; }
  .hist.open .hist-ttl { color:var(--accent); text-shadow:0 0 10px rgba(var(--accent-rgb),.45); }   /* 펼침 = '이전 제작' 네온그린 점등(운영자 260626) */
  .hist { scroll-margin-top:14px; }   /* 자동 스크롤 시 상단 약간의 여백 */
  .hist-cnt { color:var(--mut); font-weight:600; font-size:12px; }
  .hist-ar { margin-left:auto; color:var(--hist-accent); transition:transform .2s, color .3s ease; }   /* 접이 affordance = 보라(중요 버튼 마커·운영자 260626) */
  .hist.open .hist-ar { transform:rotate(180deg); }
  /* 이전 제작 리모트 접기 — 펼쳐지고 헤더가 위로 지나가면 하단 중앙에 등장(스크롤 업 없이 접기 · 보라=접기 마커 톤 · 운영자 260626) */
  #histRemote { position:fixed; left:50%; bottom:22px; transform:translateX(-50%) translateY(10px); z-index:71;
    display:inline-flex; align-items:center; gap:5px; padding:9px 15px; border-radius:999px; cursor:pointer; font:inherit; font-size:12.5px; font-weight:700; white-space:nowrap;
    color:var(--hist-accent); background:rgba(18,14,26,.7); backdrop-filter:blur(14px) saturate(1.2); -webkit-backdrop-filter:blur(14px) saturate(1.2);
    border:1px solid rgba(var(--hist-rgb),.4); box-shadow:0 10px 26px rgba(0,0,0,.55), 0 0 14px rgba(var(--hist-rgb),.18);
    opacity:0; pointer-events:none; transition:opacity .25s ease, transform .25s cubic-bezier(.22,.61,.36,1); }
  #histRemote svg { stroke:currentColor; }
  #histRemote.show { opacity:1; transform:translateX(-50%) translateY(0); pointer-events:auto; }
  #histRemote:active { transform:translateX(-50%) translateY(0) scale(.93); }
  @media (prefers-reduced-motion:reduce){ #histRemote { transition:opacity .2s; } }
  .hist-body { margin-top:6px; }
  .hist-tools { display:flex; align-items:center; justify-content:flex-end; gap:8px; margin-bottom:10px; }
  .hist-note { color:var(--mut); font-size:11px; font-weight:500; margin-left:9px; }   /* 헤더 옆 설명(최근 12시간 내 제작 건) */
  .hist-bul { color:var(--hist-accent); font-size:var(--fs-label); font-weight:var(--fw-b); transition:color .3s ease; }   /* 보라 = 특수 블릿(이전제작 = 따로 구분이 맞음·운영자 260629) · 펼치면 그린 점등 · 굵기 = 소머리 블릿 표준(--fw-b 700 · 형광 .csec::before와 동일·색만 보라) */
  .hist.open .hist-bul { color:var(--accent); }
  .hist-clr { background:rgba(255,255,255,.05); border:1px solid var(--line); color:var(--mut); font:inherit; font-size:11px; padding:4px 10px; border-radius:8px; cursor:pointer; transition:color .15s, background .15s, border-color .15s; }
  .hist-clr:hover { color:var(--fg); border-color:rgba(255,255,255,.2); }
  /* 기록 지우기 = 인라인 재확인→확인 게이지(네이티브 팝업 폐지·전송 상태머신 .go.firing 계승 · 운영자 260622) */
  .hist-clr.arm { color:var(--amber); border-color:var(--amber); background:rgba(var(--amber-rgb),.15); }
  .hist-clr.firing { color:var(--on-accent); border-color:var(--accent); pointer-events:none;
    background:linear-gradient(var(--accent),var(--accent)) left/0% 100% no-repeat, rgba(255,255,255,.05); animation:goFill .46s linear forwards; }
  @media (prefers-reduced-motion:reduce) { .hist-clr.firing { animation-duration:.15s; } }
  .hist-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:18px 10px; }   /* 행간 여백 확보 — 각 카드 위 시각 라벨 숨쉬게(운영자 260621) */
  /* 이전 제작 펼침 = 촤르륵 스태거(요약 cardIn 결 계승 · #histBody 숨김→표시 시 재생 · 운영자 260626) */
  .hist-grid > .hist-it { animation:histIn .32s cubic-bezier(.22,.61,.36,1) both; }
  .hist-grid > .hist-it:nth-child(2){ animation-delay:.04s } .hist-grid > .hist-it:nth-child(3){ animation-delay:.08s }
  .hist-grid > .hist-it:nth-child(4){ animation-delay:.12s } .hist-grid > .hist-it:nth-child(5){ animation-delay:.16s }
  .hist-grid > .hist-it:nth-child(n+6){ animation-delay:.2s }
  @keyframes histIn { from { opacity:0; transform:translateY(10px) scale(.985); } to { opacity:1; transform:none; } }
  @media (prefers-reduced-motion:reduce) { .hist-grid > .hist-it { animation:none; } }
  .hist-it { display:flex; flex-direction:column; }
  .hist-hd { color:var(--fg); font-size:11.5px; font-weight:600; margin:0 0 6px 7px; }   /* 제작 시각 = 오전/오후 H:MM · 흰색 · 좌측 들여쓰기(운영자 260621) */
  .hist-thumb { position:relative; }
  .hist-thumb img { width:100%; aspect-ratio:4/5; object-fit:cover; border:1px solid var(--line); border-radius:var(--r-s); display:block; background:var(--pan); }
  .hist-thumb .imgdl { top:6px; right:6px; width:28px; height:28px; }
  .hist-thumb .imgdl svg { width:12px; height:12px; }
  .hist-thumb .imgedit { top:6px; right:40px; width:28px; height:28px; }   /* 다운로드(우상단) 바로 왼쪽 = '옆에' */
  .hist-thumb .imgedit svg { width:12px; height:12px; }
  .hist-cap { position:absolute; left:6px; top:6px; max-width:calc(100% - 42px); background:rgba(0,0,0,.6); color:var(--fg); font-size:9.5px; font-weight:700; padding:2px 7px; border-radius:999px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .hist-cap-v { font-weight:400; }
  @media (max-width:480px){ .hist-grid { grid-template-columns:repeat(2,1fr); } }
  /* 텍스트칸 붙여넣기↔복사 (우상단 · 뷰어 .copy 계승) */
  .iobtn { position:absolute; top:8px; right:8px; width:30px; height:30px; display:grid; place-items:center; padding:0; color:var(--mut); background:rgba(255,255,255,.06); border:1px solid var(--line); border-radius:var(--r-s); cursor:pointer; z-index:2; transition:transform .12s, background .15s, color .15s, border-color .15s; backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); -webkit-tap-highlight-color:transparent; }
  .iobtn:hover { background:rgba(255,255,255,.12); color:var(--fg); }
  .iobtn:active { transform:scale(var(--press-s,.85)); }
  .iobtn.ok { background:var(--accent); color:var(--on-accent); border-color:var(--accent); }
  .iobtn svg { display:block; }
  /* 클립 버튼(입력칸용) = 입력칸 위 우측 테두리에 중앙정렬로 걸친 동그라미 (시안 2A·운영자 260624)
     평소=중립 회색 / 누름(:active)=형광 플래시 / 성공(.ok)=도형 채움 없이 ✓ 체크만 형광(링 중립 유지) */
  .iobtn-edge { top:0; right:14px; transform:translateY(-50%); width:26px; height:26px; border-radius:50%; opacity:.6;   /* 입력칸 복사/붙여넣기·지우개 = opacity 60%(은은하게 · 운영자 260625) */
    background:rgba(26,28,26,.3); border-color:rgba(255,255,255,.17); color:var(--mut); box-shadow:inset 0 1px 0 rgba(255,255,255,.2); -webkit-backdrop-filter:blur(13px) saturate(1.3); backdrop-filter:blur(13px) saturate(1.3); }   /* G1 글래스모피즘(상단 inset 광택·blur13·saturate · 운영자 260625) */
  .iobtn-edge:hover { color:var(--fg); border-color:rgba(255,255,255,.27); }
  .iobtn-edge:active { transform:translateY(-50%) scale(var(--press-s,.85)); color:var(--accent); border-color:rgba(var(--accent-rgb),.6); }   /* 누름 = 형광 플래시 */
  .iobtn-edge.ok { background:rgba(26,28,26,.3); color:var(--accent); border-color:rgba(255,255,255,.17); }   /* 성공 = 링 중립 유지·체크(✓)만 형광(2A) */
  .iobtn-edge svg { width:13px; height:13px; }
  /* 붙여넣기 우측에 지우개 동반(부제·제목·자막) = 동일 크기 2버튼: [붙여넣기/복사 | 지우개] (운영자 260625) */
  .iobtn-pp { right:46px; }                          /* 붙여넣기 = 항상 노출(복사 추가돼도 유지) · 지우개 좌측 */
  .iobtn-erase { right:14px; }                       /* 지우개 = 최우측(붙여넣기 우측) · 누르면 입력 비움 */
  .iobtn-off { opacity:.3; pointer-events:none; }    /* 빈칸 = 지울 것 없음 → 흐리게·비활성 */
  .iobtn-undo { color:var(--fg); border-color:rgba(255,255,255,.34); }   /* 지움 직후 ~10초 = 되돌리기(흰 픽토그램·평소보다 또렷한 링 · 운영자 260626) */
  /* 복사(추가) = 내용 있을 때만 붙여넣기 *좌측*에 별도 노출(붙여넣기 버튼은 복사로 안 바뀌고 유지 · 운영자 260627). 빈칸=숨김, 간격 32px 등간 */
  .iobtn-copy { right:46px; }                        /* 지우개 없는 입력 = [복사 46 | 붙여넣기 14] */
  .iobtn-copy-e { right:78px; }                      /* 지우개 동반 = [복사 78 | 붙여넣기 46 | 지우개 14] */
  .iobtn-hide { display:none; }                      /* 내용 비면 복사 숨김(붙여넣기·지우개는 유지) */
  #cardBox { margin-top:9px; }                 /* 카드 텍스트 = '텍스트' 라벨 제거·간격 축소(헤더/오버레이와 동일 9px · 운영자 260624) */
  #cardBox .edwrap { position:relative; }       /* 칩 에디터 클립버튼(2A) 기준 — 재렌더(#edChips innerHTML 교체)에도 버튼 보존 위해 바깥 래퍼 */
  #cardBox .iobtn-edge { right:44px; }           /* 카드만 클립을 좌측으로 — 칩 줄 우측 +(단어추가, 박스우측 9~25px 점유) 버튼과 19px 간격 확실 분리(운영자 260624). 지우개(최우측)=이 위치(44). */
  #cardBox .iobtn-pp { right:76px; }             /* 카드 붙여넣기 = 지우개(44) 좌측 32px (지우개 동반 3버튼 · 운영자 260628) */
  #cardBox .iobtn-copy { right:108px; }          /* 카드 복사 = 붙여넣기(76) 좌측 32px = [복사 108 | 붙여넣기 76 | 지우개 44] (운영자 260628 3버튼) */
  .slot-wait { font-size:13px; color:var(--mut); }
  .none { display:none; }

  /* ── 카드 텍스트 칩 에디터 (인라인 — /5 카드뉴스) ── */
  .ed-chips { display:flex; flex-direction:column; align-items:stretch; gap:5px; min-height:34px; padding:6px; background:rgba(5,12,8,.4); border:1px dashed var(--line2); border-radius:var(--r-m); }
  .ed-line { display:flex; flex-wrap:nowrap; align-items:center; gap:calc(6px * var(--eds,1)); min-height:calc(30px * var(--eds,1)); position:relative; padding-right:22px; }
  .ed-chip { flex:none; font-size:calc(16px * var(--eds,1)); line-height:1.4; padding:calc(2px * var(--eds,1)) calc(3px * var(--eds,1)); border-radius:7px; background:rgba(255,255,255,.05); border:1px solid var(--line2); color:var(--fg); cursor:pointer; user-select:none; white-space:nowrap; transition:background .12s, color .12s, border-color .12s; }
  .ed-chips.ed-building .ed-chip { transition:none; }   /* 재빌드 프레임 = 갓 생성 칩 전환 억제(툭 튐 0) · 다음 프레임 복원(분신술 A5·운영자 260628) */
  .ed-chip:hover { border-color:rgba(var(--accent-rgb),.4); }
  .ed-add { position:absolute; right:2px; top:50%; transform:translateY(-50%); flex:none; width:16px; height:calc(30px * var(--eds,1)); padding:0; border-radius:5px; display:inline-flex; align-items:center; justify-content:center; font:800 16px/1 inherit; color:var(--accent); background:rgba(var(--accent-rgb),.1); border:1px solid rgba(var(--accent-rgb),.42); cursor:pointer; }
  .ed-add:active { transform:translateY(-50%) scale(var(--press-m,.9)); }
  .ed-add.cap { color:transparent; cursor:not-allowed; opacity:.55; border-color:rgba(255,77,77,.5); filter:brightness(.6); background:repeating-linear-gradient(45deg, rgba(255,77,77,.5) 0 3px, transparent 3px 6px), rgba(10,14,12,.6); }
  .ed-empty { min-width:calc(46px * var(--eds,1)); min-height:calc(22px * var(--eds,1)); cursor:text; white-space:normal; }
  .ed-empty:empty::before { content:'입력…'; color:var(--mut); opacity:.5; }
  .ed-chip:empty { min-width:calc(15px * var(--eds,1)); }
  .ed-addw { flex:none; display:inline-flex; align-items:center; justify-content:center; width:calc(22px * var(--eds,1)); height:calc(22px * var(--eds,1)); border-radius:50%; color:var(--accent); font:800 calc(15px * var(--eds,1))/1 inherit; cursor:pointer; user-select:none; align-self:center; background:rgba(var(--accent-rgb),.1); border:1px solid rgba(var(--accent-rgb),.4); }
  .ovc { color:#ff5d5d; font-weight:800; }
  .emon { color:var(--accent); font-weight:800; }
  .ed-chip.on { background:var(--accent-dim); border-color:var(--accent); color:var(--accent); font-weight:800; box-shadow:0 0 8px rgba(var(--accent-rgb),.3); }
  .ed-chip.warn { border-color:rgba(255,176,32,.55); }
  .ed-chip.warn.on { border-color:var(--accent); }
  .ed-chip.over { border-color:#ff5d5d; background:rgba(255,77,77,.14); }
  .ed-chip.editing { outline:2px solid var(--accent); outline-offset:1px; background:rgba(var(--accent-rgb),.08); color:var(--fg); cursor:text; white-space:normal; word-break:break-word; max-width:100%; }
  .ed-chip.editing.over { outline-color:#ff5d5d; color:#ff7a7a; background:rgba(255,77,77,.12); }
  .ed-chip.reject { border-color:#ff5d5d !important; color:#ff7a7a; background:rgba(255,77,77,.12); animation:edshake .42s; }
  @keyframes edshake { 0%,100%{transform:translateX(0)} 18%{transform:translateX(-4px)} 38%{transform:translateX(4px)} 58%{transform:translateX(-3px)} 78%{transform:translateX(2px)} }
  /* 확인 모달 — 네이티브 confirm 대체(뉴스 요약기 글래스 모달 느낌 계승: 반투명 글래스 blur30 + 뒤 dimmed·블러7 backdrop + 팝인) */
  .cfm { border:none; border-radius:22px; padding:0; width:88vw; max-width:420px; color:var(--fg);
    position:fixed; inset:0; margin:auto; height:max-content;
    background:linear-gradient(165deg, rgba(27,44,32,.62), rgba(11,19,14,.74)); backdrop-filter:blur(30px) saturate(1.6); -webkit-backdrop-filter:blur(30px) saturate(1.6);
    border:1px solid rgba(255,255,255,.13); box-shadow:0 30px 80px rgba(0,0,0,.5), inset 0 1px 0 rgba(255,255,255,.14);
    animation:cfmIn .2s cubic-bezier(.22,.61,.36,1) both; }
  .cfm::backdrop { background:rgba(4,8,5,.46); backdrop-filter:blur(7px); -webkit-backdrop-filter:blur(7px); animation:cfmBd .2s ease both; }   /* 뒤 화면 가려지고(블러) 새 창 뜨는 느낌 = 뉴스 모달과 동일(.46) */
  @keyframes cfmIn { from { opacity:0; transform:scale(.93) translateY(10px); } to { opacity:1; transform:none; } }
  @keyframes cfmBd { from { opacity:0; } to { opacity:1; } }
  @media (prefers-reduced-motion:reduce) { .cfm, .cfm::backdrop { animation:none; } }
  .cfm-in { padding:20px 20px 16px; }
  .cfm-msg { font-size:15px; font-weight:600; line-height:1.55; color:var(--fg); }
  .cfm-bot { display:flex; gap:10px; margin-top:18px; justify-content:flex-end; }
  .cfm-btn { padding:9px 18px; border-radius:999px; font:inherit; font-size:13.5px; font-weight:700; cursor:pointer;
    border:1px solid var(--line); background:rgba(255,255,255,.05); color:var(--fg); }
  .cfm-btn:active { transform:scale(var(--press-l,.97)); }
  .cfm-btn.go2 { border:none; background:linear-gradient(135deg,#d8ff3d,var(--accent)); color:var(--on-accent); box-shadow:0 6px 16px rgba(var(--accent-rgb),.3); }
  html.inmodal, html.inmodal body { background:transparent; }   /* 모달(iframe)에선 투명 → #tooldlg 글래스로 뒤 피드 자연스럽게 비침(타 메뉴와 통일)·운영자 260626 */
  html.inmodal body::before { display:none; }   /* 모달 안에선 자체 실크(feed_bg) 배경 끔 = 글래스 뒤로 실제 뷰어 피드가 보이게(자체 배경이 덮던 것 해소)·운영자 260626 */
  /* 축약어 등록 다이얼로그 (cfm 글래스 계승) */
  .abdlg { border:none; border-radius:20px; padding:0; width:92vw; max-width:460px; color:var(--fg);
    position:fixed; inset:0; margin:auto; height:max-content; max-height:84vh; overflow:auto;
    background:linear-gradient(165deg, rgba(27,44,32,.62), rgba(11,19,14,.74)); backdrop-filter:blur(30px) saturate(1.6); -webkit-backdrop-filter:blur(30px) saturate(1.6);
    border:1px solid rgba(255,255,255,.13); box-shadow:0 30px 80px rgba(0,0,0,.5), inset 0 1px 0 rgba(255,255,255,.14);
    animation:cfmIn .2s cubic-bezier(.22,.61,.36,1) both; }
  .abdlg::backdrop { background:rgba(4,8,5,.46); backdrop-filter:blur(7px); -webkit-backdrop-filter:blur(7px); animation:cfmBd .2s ease both; }
  .abdlg-in { padding:18px 18px 16px; position:relative; }
  /* 닫기 X = 정본 .tool-x 글래스 사각(30px·우상단) — 옛 무스타일 bare 버튼 교정(분신술 1·2 P0) */
  .abdlg .dlg-x { position:absolute; top:14px; right:14px; width:30px; height:30px; flex:none; display:grid; place-items:center; padding:0; z-index:2;
    background:rgba(255,255,255,.06); border:1px solid var(--line); border-radius:var(--r-s); color:var(--fg); cursor:pointer; transition:color .15s, border-color .15s, transform .12s; }
  .abdlg .dlg-x:hover { color:var(--accent); border-color:rgba(var(--accent-rgb),.4); }
  .abdlg .dlg-x:active { transform:scale(var(--press-s,.85)); }
  .abdlg .dlg-x svg { width:15px; height:15px; }
  .abdlg-h { font-size:15px; font-weight:700; color:var(--accent); margin:0 0 8px; padding-right:34px; }   /* X 자리 확보 */
  .abdlg-note { font-size:11.5px; color:var(--mut); line-height:1.55; margin:0 0 14px; }
  .abdlg-note code { color:var(--fg); background:rgba(255,255,255,.07); border-radius:5px; padding:1px 5px; font-size:11px; }
  .abdlg-tbl { display:flex; flex-direction:column; gap:7px; }
  .abrow { display:grid; grid-template-columns:28px 1fr 1fr 34px; gap:8px; align-items:center; }
  .abrow.abhd { font-size:11.5px; color:var(--mut); font-weight:600; padding:0 2px; }
  .abrow .abno { text-align:center; color:var(--mut); font-size:12px; font-variant-numeric:tabular-nums; }
  .abrow input { padding:9px 10px; border-radius:8px; font-size:14px; }   /* bg·border·focus = 전역 input[type=text] 상속(중복 raw 제거) */
  .abdel { width:30px; height:30px; display:grid; place-items:center; border-radius:8px; cursor:pointer; font-size:17px; line-height:1; padding:0;
    background:rgba(255,90,98,.10); border:1px solid rgba(255,90,98,.28); color:#ff9aa0; }
  .abdel:active { transform:scale(var(--press-m,.9)); }
  .abdelh { text-align:center; }
  .abrow.abfix input { opacity:.5; color:var(--mut); cursor:default; }   /* 기본 4종 = 잠금(읽기전용) */
  .abfixtag { font-size:9.5px; color:var(--mut); text-align:center; align-self:center; letter-spacing:-.3px; }
  .abadd { margin-top:12px; width:100%; padding:11px; border-radius:10px; font:inherit; font-size:13.5px; font-weight:700; cursor:pointer;
    color:var(--accent); background:rgba(var(--accent-rgb),.10); border:1px dashed rgba(var(--accent-rgb),.45); }
  .abadd:active { transform:scale(.99); }
</style>
<script>if(window.self!==window.top)document.documentElement.classList.add('inmodal');</script>
</head>
<body>
<div class="wrap">

  <div class="tabs" id="tabs">
    <div class="tab" data-app="2"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="9" r="1.6"/><path d="M21 16l-5-5L5 21"/></svg>썸네일</div>
    <div class="tab" data-app="3"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M14.8 9.3a3.5 3.5 0 1 0 0 5.4"/></svg>저작권</div>
    <div class="tab" data-app="5"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M7 9.5h6M7 13h10"/></svg>카드뉴스</div>
  </div>

  <div class="panel">
    <!-- /5 카드뉴스 배경 이미지 = 제작 버튼과 한 행으로 이동(ly .filerow 통일·260628) -->

    <!-- OPA (1 — 오버레이 투명도: 58 기본 / 30 / 직접입력) -->
    <div id="opaBox" class="none">
      <label class="fl">투명도 (OPA)</label>
      <div class="seg" id="opaSeg">
        <button data-opa="58" class="on">58</button>
        <button data-opa="30">30</button>
        <button data-opa="custom" id="opaCustom"><span class="lab">직접입력</span><input type="text" id="opaNum" class="opa-in" inputmode="numeric" pattern="[0-9]*" maxlength="2" placeholder="OPA" autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false"></button>
      </div>
    </div>

    <!-- lines (1 포스트) — 텍스트(2/3) + 배경 이미지 슬롯(1/3·옵션) -->
    <div id="linesBox" class="none">
      <label class="fl">텍스트</label>
      <div class="covrow">
        <textarea id="lines" class="covta" placeholder=""></textarea>
        <div class="covimg" id="pImgSlot" role="button" tabindex="0" aria-label="배경 이미지 첨부"></div>
        <input type="file" accept="image/*" id="pFile" hidden>
      </div>
      <div class="gospec" id="postSpec"><span class="gs-bul">•</span> <span class="gs-lbl">축약</span>: <span class="gs-v on gs-tog" id="psAbbr" role="button" tabindex="0" title="탭=ON/OFF">ON</span> <span id="linesTrk" class="trk"></span></div>
    </div>

    <!-- /2 릴스 — 단일 폼(헤더 + 오버레이 + 옵션). 채운 섹션만 발사(B·운영자 260624): 헤더(부제+제목)→흰칸 / 자막→오버레이(OPA60[+30]) / 둘 다→동시. 포맷 분기(기본·헤더·오버레이) 폐지 — 백엔드(흰칸/오버레이 모드) 불변. -->
    <div id="reelsBox" class="none">
      <div id="rCombo">
        <input type="checkbox" id="cBg" hidden>      <!-- 배경(nobg 헤더) = 옵션줄 '배경' 토글 / hidden=발사 상태 유지 -->
        <div class="csec">헤더</div>
        <input type="text" id="cSub" class="cf cf-sub" placeholder="부제" autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false">
        <input type="text" id="cTitle" class="cf cf-title" placeholder="제목" autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false">
        <span id="cHdrTrk" class="trk cmtrk"></span>   <!-- 부제/제목 자간 초과 안내(헤더 탭과 동일) -->
        <div class="csec">오버레이 <span class="ovsep">|</span> <span id="ovFmtTog" class="ovfmt post" role="button" tabindex="0" title="탭=포스트(4:5)↔릴스(9:16) · 자간 한도 다름(−45/−30) · 헤더 입력 중엔 릴스 고정">포스트</span></div>   <!-- 포맷=텍스트 시작 전 선택(자간 한도 분기) · OPA 등은 옵션줄 -->
        <div class="covrow">
          <textarea id="cLines" class="covta" placeholder="강조는 별표로, 최대 3줄 가능"></textarea>
          <div class="covimg" id="cImgSlot" role="button" tabindex="0" aria-label="자막 이미지 첨부"></div>
          <input type="file" accept="image/*" id="cFile" hidden>
        </div>
        <span id="cLinesTrk" class="trk cmtrk"></span>   <!-- 자막 자간 초과 안내 -->
      </div>
    </div>

    <!-- /3 저작권 — · 포맷 + · 저작권(ON/OFF·자연 문구 탭수정) + · 안내문(팝업 선택) · 제작버튼 공유 (운영자 260624) -->
    <div id="copyBox" class="none">
      <!-- · 포맷 = 단일 토글(한 번에 하나만 · 탭=포스트↔릴스 · 썸네일 #ovFmtTog 패턴) · 기본 릴스 · 저작권·안내문 공유 -->
      <div class="csec">포맷 <span id="cpFmtTog" class="ovfmt reels" role="button" tabindex="0" aria-label="포맷 — 탭=포스트↔릴스" title="탭=포스트(4:5)↔릴스(9:16)">릴스</span></div>

      <!-- · 저작권 [ON] · 기본 ON · 탭=켜기/끄기 -->
      <div class="csec">저작권 <span class="onoff on" id="copyTog" role="button" tabindex="0" aria-pressed="true" title="탭=저작권 켜기/끄기">ON</span></div>
      <!-- ⓒ 2026. nomute(instagram). all rights reserved. — 자연 문구, 부분 탭=수정 · 'all rights…'는 편집화면만 줄바꿈(출력은 이어짐) -->
      <div class="cphline" id="cphLine">
        <span class="cph-st">ⓒ&nbsp;</span><span class="cph-ed cph-yr" id="cphYear" contenteditable="true" inputmode="numeric" enterkeyhint="done" spellcheck="false" role="textbox" aria-label="연도" data-ph="2026" title="탭=연도 수정">2026</span><span class="cph-st">.&nbsp;</span><span class="cph-ed cph-nm" id="cphName" contenteditable="true" enterkeyhint="done" spellcheck="false" role="textbox" aria-label="계정명" data-ph="nomute" title="탭=이름 수정"></span><span class="cph-st">(</span><span id="cphPlat" class="cph-plat" data-plat="instagram" role="button" tabindex="0" title="탭=플랫폼 선택">instagram</span><span class="cph-st">).</span><span class="cph-br"></span><span class="cph-st">all rights reserved.</span>
        <!-- 플랫폼 픽토그램 팝업 — 탭하면 촤르륵 펼쳐짐 -->
        <div class="platpop none" id="platPop" role="menu" aria-label="플랫폼 선택">
          <button type="button" class="ppbtn" data-plat="youtube" title="유튜브" role="menuitem">YT</button>
          <button type="button" class="ppbtn" data-plat="instagram" title="인스타그램" role="menuitem">IG</button>
          <button type="button" class="ppbtn" data-plat="threads" title="스레드" role="menuitem">Th</button>
          <button type="button" class="ppbtn" data-plat="X" title="X" role="menuitem">X</button>
          <button type="button" class="ppbtn" data-plat="facebook" title="페이스북" role="menuitem">Fb</button>
          <button type="button" class="ppbtn ppbtn-custom" data-plat="custom" title="직접입력" role="menuitem"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg></button>
        </div>
      </div>
      <input type="text" id="cplat" class="none" placeholder="플랫폼 직접입력 (예: tiktok)" style="margin-top:8px" autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false">

      <!-- · 안내문 [OFF] · 기본 OFF · 탭=팝업(경고/AI/자유문구) → 고르면 ON·출력 -->
      <div class="csec gsec" id="guideSec">안내문 <span class="onoff" id="guideTog" role="button" tabindex="0" aria-haspopup="true" aria-pressed="false" title="탭=경고/AI/자유문구 고르기">OFF</span>
        <div class="platpop gpop none" id="guidePop" role="menu" aria-label="안내문 종류">
          <button type="button" class="ppbtn gpbtn" data-gm="caution" role="menuitem">경고</button>
          <button type="button" class="ppbtn gpbtn" data-gm="ai" role="menuitem">AI</button>
          <button type="button" class="ppbtn gpbtn" data-gm="free" role="menuitem">자유문구</button>
        </div>
      </div>
      <textarea id="warnLines" class="none" placeholder="안내문 텍스트"></textarea>
    </div>

    <!-- /5 카드뉴스 — 칩 에디터 인라인(텍스트 입력 전면 교체·처음부터) -->
    <div id="cardBox" class="none">
      <div class="csec">텍스트 및 이미지</div>   <!-- 섹션 소머리(•) = ly '• 파일'·헤더 .csec 기틀 계승(텍스트 칩+배경 이미지 입력 구간 · 운영자 260629) -->
      <div class="edwrap"><div class="ed-chips" id="edChips" aria-label="단어 — 탭하면 강조"></div></div>
    </div>

    <div class="csec none" id="rOptHead">옵션</div>
    <div class="gospec none" id="goSpec"><span class="gs-lbl">배경</span>: <span class="gs-v gs-tog" id="gsBg" role="button" tabindex="0" title="탭=배경(흰칸 없는 버전) 추가">OFF</span> &nbsp;&nbsp; <span class="gs-lbl">OPA</span> <span class="gs-v on gs-tog" id="gsOpa1" role="button" tabindex="0" title="탭=ON/OFF (60)">60</span> <span class="gs-v gs-tog gsop-step" id="gsOpa2Dn" role="button" tabindex="0" title="-5" hidden>−</span><span class="gs-v gs-tog" id="gsOpa2" role="button" tabindex="0" title="탭=추가/끄기 · 켜면 −/+ 또는 스크롤·드래그로 값 조절">+30</span><span class="gs-v gs-tog gsop-step" id="gsOpa2Up" role="button" tabindex="0" title="+5" hidden>+</span> <span style="color:var(--mut)"> | </span><span class="gs-v" id="gsImg" title="이미지 첨부 시 자막 합성본(JPG)">합성본</span> &nbsp;&nbsp; <span class="gs-lbl">축약</span>: <span class="gs-v on gs-tog" id="gsAbbr" role="button" tabindex="0" title="탭=ON/OFF">ON</span></div>
    <div class="makerow" id="makeRow">
      <!-- 카드뉴스 배경 이미지(/5만 표시) — 제작 버튼과 한 행(ly 통일·260628) -->
      <div id="imgBox" class="none">
        <label class="file" id="fileLab" aria-label="이미지 선택" title="탭해서 이미지 선택"><span class="filepic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="9.5" r="1.5"/><path d="M21 16l-5-5L5 20"/></svg></span>
          <input type="file" accept="image/*" id="file" style="display:none">
        </label>
      </div>
      <div class="gowrap">
        <button class="go" id="go">이미지 제작</button>
        <label class="chk go-abbr" id="abbrBox" title="이 → 李 · 윤 → 尹 · ... → ⋯"><input type="checkbox" id="abbr" checked><span class="cbox" aria-hidden="true"><svg class="ackm" viewBox="0 0 24 24" fill="none" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path class="sc-dash" d="M6 12h12"/><path class="sc-chk" d="M5 13l4 4L19 7"/></svg></span> 축약</label>
      </div>
    </div>
    <div class="spellchips" id="spellChips" hidden></div>
  </div>

  <div class="out">
    <div class="status" id="status"></div>
    <!-- N/N장 카운터 = 대기열 위(요약 · 운영자) -->
    <div class="carbar" id="carbar" hidden><span class="carcount" id="carcount"></span></div>
    <!-- 대기열/로그 — 제작 버튼 누른 게 다 여기 쌓이고 각자 상태 표시(동시 가능) -->
    <div class="jobs" id="jobs"></div>
    <!-- 완성 이미지 = 캐러셀(나온 순서대로 한 장씩 추가) · 전체 다운로드은 결과물 아래(해당 부분) -->
    <div class="carwrap" id="carwrap" hidden>
      <div class="cartrackwrap">
        <div class="cartrack" id="cartrack"></div>
        <button class="carnav prev" id="carPrev" type="button" aria-label="이전">‹</button>
        <button class="carnav next" id="carNext" type="button" aria-label="다음">›</button>
        <a class="imgdl dlbtn" id="carDl" href="#" aria-label="다운로드" hidden></a>
      </div>
    </div>
    <!-- 이전 제작(12시간) — 창 닫아도 localStorage 보관·맨아래 접힘 토글(운영자 260621) -->
    <div class="hist" id="hist" hidden>
      <button class="hist-h" id="histH" type="button" aria-expanded="false">
        <span class="hist-ttl"><span class="hist-bul" aria-hidden="true">•</span>이전 제작 <span class="hist-cnt" id="histCnt"></span></span>
        <span class="hist-note">최근 12시간 내 제작 건</span>
        <svg class="hist-ar" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="hist-body" id="histBody" hidden>
        <div class="hist-tools"><button class="hist-clr" id="histClr" type="button">기록 지우기</button></div>
        <div class="hist-grid" id="histGrid"></div>
      </div>
    </div>
  </div>
</div>

<!-- 확인 모달 — 네이티브 confirm 대체(앱 UI 계승) -->
<dialog id="cfmdlg" class="cfm">
  <div class="cfm-in">
    <div class="cfm-msg" id="cfmMsg"></div>
    <div class="cfm-bot">
      <button class="cfm-btn" id="cfmNo" type="button">취소</button>
      <button class="cfm-btn go2" id="cfmYes" type="button">진행</button>
    </div>
  </div>
</dialog>

<!-- 축약어 등록 = '축약' 토글 롱프레스 → 사용자 커스텀 치환쌍(축약 전→후) 추가/삭제. 기본 4종은 불변(항상 적용). -->
<dialog id="abbrDlg" class="abdlg">
  <div class="abdlg-in">
    <button class="dlg-x" id="abbrX" type="button" aria-label="닫기"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6 18 18M18 6 6 18"/></svg></button>
    <div class="abdlg-h">축약어 등록</div>
    <div class="abdlg-note"><b>기본</b> 표시 4종은 항상 적용(수정·삭제 불가). 그 아래 <b>+ 추가</b>로 직접 등록 — <b>축약 전</b>에 <u>앞뒤 글자까지</u> 넣어 범위를 정함(예: <code>군 </code>→<code>軍 </code>, 또는 <code>군,</code>→<code>軍,</code>).</div>
    <div class="abdlg-tbl" id="abbrTbl">
      <div class="abrow abhd"><span class="abno">no</span><span>축약 전</span><span>축약 후</span><span class="abdelh">삭제</span></div>
    </div>
    <button class="abadd" id="abbrAdd" type="button">+ 추가</button>
  </div>
</dialog>

<!-- OPA 조절 = 섹션 헤더 '• 오버레이 (OPA 60)'의 60에 인라인 휠/드래그(별도 팝업 없음) -->

<script src="nm-svg.js"></script><!-- 공유 아이콘 SSOT(§🎨 CII P1·운영자 260628) — 인라인 복제 폐지·단일정본 -->
<script>
const $ = s => document.querySelector(s);
// 네이티브 confirm 대체 — 앱 글래스 모달(뉴스 요약기 UI 계승). 진행=true / 취소·바깥·ESC=false.
function askConfirm(msg) {
  return new Promise(resolve => {
    const dlg = $('#cfmdlg'); $('#cfmMsg').textContent = msg;
    const done = v => { dlg.close(); cleanup(); resolve(v); };
    const onYes = () => done(true), onNo = () => done(false);
    const onBackdrop = e => { if (e.target === dlg) done(false); };   // 바깥 클릭 = 취소
    const onCancel = e => { e.preventDefault(); done(false); };       // ESC(native)
    // ⚠️ iframe(도구 모달) 안에서 뜰 때: 캡처단계로 ESC 자체처리 + stopPropagation → 부모 #tooldlg가 먼저 닫혀 프로미스 고아되는 레이스 차단
    const onKey = e => { if (e.key === 'Escape') { e.preventDefault(); e.stopPropagation(); done(false); } };
    function cleanup() {
      $('#cfmYes').removeEventListener('click', onYes); $('#cfmNo').removeEventListener('click', onNo);
      dlg.removeEventListener('click', onBackdrop); dlg.removeEventListener('cancel', onCancel);
      document.removeEventListener('keydown', onKey, true);
    }
    $('#cfmYes').addEventListener('click', onYes); $('#cfmNo').addEventListener('click', onNo);
    dlg.addEventListener('click', onBackdrop); dlg.addEventListener('cancel', onCancel);
    document.addEventListener('keydown', onKey, true);
    dlg.showModal();
  });
}
let APP = '1', FMT = 'post';
let cOpa1on = true, cOpa2on = false, cOpa2val = 30;   // 자막 OPA: 60(고정값·토글) + 보조(기본30·스크롤 조절·토글) · 최소 1개 (운영자 260624)
let ovFmt = 'post';   // 썸네일 통합: 오버레이 포맷 'post'(4:5·기본·시안) | 'reels'(9:16·레몬). 헤더 입력 중엔 'reels' 강제(effOvFmt). 자간 한도 분기(−45/−30) · 운영자 260624
let _spellReview = null, _spellApplied = false, _applyingSpell = false;   // 맞춤법 교정 리뷰 상태(칩 개별선택)
const IMG = { b64: '', name: '' };    // /1·/5 배경
const CIMG = { b64: '', name: '' };   // /2 릴스 자막 배경(옵션)
const PIMG = { b64: '', name: '' };   // /1 포스트 배경(옵션·슬롯) — 카드뉴스 IMG와 분리(위젯 desync 방지·260624)

// ---- 탭 ----
function selApp(a) {
  APP = a;
  document.querySelectorAll('.tab').forEach(t => t.classList.toggle('on', t.dataset.app === a));
  // 표시 토글
  $('#imgBox').classList.toggle('none', a !== '5');   // 배경 = /5 카드뉴스만(포스트는 텍스트 covrow 슬롯·260624)
  $('#linesBox').classList.toggle('none', a !== '1');   // 텍스트 = /1 포스트만 (/5는 칩 에디터)
  $('#cardBox').classList.toggle('none', a !== '5');                    // 카드뉴스 = /5 인라인 칩 에디터
  $('#reelsBox').classList.toggle('none', a !== '2');
  $('#copyBox').classList.toggle('none', a !== '3');   // 저작권+안내문 통합 = /3
  $('#abbrBox').classList.add('none');   // 축약 = 전 탭 goSpec 명세 ON 토글로 이동(버튼 안 체크박스 폐지)
  $('#opaBox').classList.toggle('none', a !== '1');   // OPA = /1 포스트만
  // (linesMax 폐지 — 포스트 설명줄을 postSpec 축약 명세로 대체)
  if (a === '5') { if (!edLines.length) edLines = [[]]; renderEditChips(); }   // 인라인 칩 에디터 init/refresh
  if (a === '1') updateTrkHint('lines', 'linesTrk', 'post');                   // 실시간 자간
  if (a === '2') updateComboTrk();                                             // 릴스 단일 폼 자간 안내(부제/제목·자막)
  if (a === '3') { syncCpFmt(); syncCopyTog(); syncGuide(); }                  // 포맷 세그·저작권 ON/OFF·안내문 토글 UI 갱신
  clearSpellReview();                                                          // 앱 바뀌면 진행 중이던 교정 리뷰 폐기
  const gb = $('#go');                                                         // 버튼 문구 = '이미지 제작'(맞춤법 교정은 기능 유지·문구만 간소화·운영자 260629)
  if (gb) { const lbl = '이미지 제작'; gb.dataset.label = lbl;
    if (!gb.classList.contains('firing') && !gb.classList.contains('okdone') && !gb.classList.contains('spell-arm')) gb.textContent = lbl; }
  updateGoSpec();
}
document.querySelectorAll('.tab').forEach(t => t.onclick = () => { selApp(t.dataset.app); window.scrollTo({ top: 0, behavior: 'smooth' }); });   // 탭 전환 = 맨 위로(새 탭 처음부터 · 운영자 260626)

// ---- 줄 수 하드캡 (포스트3·카드뉴스4·릴스자막3·경고문2 — 넘는 줄 못 쓰게) ----
function maxLinesFor(ta) {
  if (ta.id === 'lines') return APP === '1' ? 3 : APP === '5' ? 4 : 0;
  if (ta.id === 'cLines') return 3;
  if (ta.id === 'warnLines') return 2;
  return 0;
}
['lines', 'cLines', 'warnLines'].forEach(id => {
  const ta = document.getElementById(id);
  ta.addEventListener('keydown', e => {
    if (e.key === 'Enter') { const m = maxLinesFor(ta); if (m && ta.value.split('\n').length >= m) e.preventDefault(); }
  });
  ta.addEventListener('input', () => {
    const m = maxLinesFor(ta); if (!m) return;
    const ls = ta.value.split('\n'); if (ls.length > m) ta.value = ls.slice(0, m).join('\n');   // 붙여넣기 등 초과분 잘라냄
  });
});

// ---- /3 저작권+안내문 (260624) — · 포맷(릴스 기본)·저작권 ON/OFF·자연문구 탭수정·안내문 팝업 ----
let cpFmt = 'reels';     // 저작권/안내문 공유 포맷 (post|reels) · 기본 릴스(운영자 260624)
let copyOn = true;       // 저작권 ON/OFF (기본 ON · 누르면 OFF=제작서 빠짐)
let guideMode = '';      // 안내문 모드 ('' | caution | ai | free) · 기본 OFF
const GLAB = { caution: '경고', ai: 'AI', free: '자유문구' };
const WARN_PRESETS = {   // (Opus 5인 만장일치 검토 — AI=AI기본법 §31② 표시의무, caution=자율 안내)
  ai: '본 이미지는 생성형 AI로 제작·합성되었습니다.',
  caution: '공익적 목적의 사회 시사 콘텐츠입니다.\n민감한 내용이 포함될 수 있으니 유의 바랍니다.',   // 기본 2줄(운영자 260628 — '공익적 목적의'·2줄 '시청에' 제거)
};
// 연도 = 자유 수정(정수/-/. 허용 — 키보드 구조상 . 입력됨). getYear()=빈값이면 2026. 이름 = 탭=수정.
function getYear() { return ($('#cphYear').textContent || '').replace(/[^0-9.\-]/g, '') || '2026'; }
function setYear(v) { const s = String(v == null ? '' : v).replace(/[^0-9.\-]/g, ''); $('#cphYear').textContent = s || '2026'; }
function getName() { return ($('#cphName').textContent || '').replace(/\s+/g, ' ').trim(); }
function setName(v) { $('#cphName').textContent = v || ''; }
// 플랫폼 = 픽토그램 span(#cphPlat)의 data-plat. custom이면 직접입력칸(#cplat) 값.
function getPlatform() {
  return $('#cphPlat').dataset.plat === 'custom' ? $('#cplat').value.trim() : $('#cphPlat').dataset.plat;
}
// 포맷 단일 토글 UI — 한 번에 하나만 표시(썸네일 #ovFmtTog 패턴) · 포스트=시안/릴스=레몬
function syncCpFmt() {
  const t = $('#cpFmtTog'); if (!t) return;
  t.textContent = cpFmt === 'post' ? '포스트' : '릴스';
  t.classList.toggle('post', cpFmt === 'post'); t.classList.toggle('reels', cpFmt === 'reels');
  t.setAttribute('aria-label', '포맷 ' + t.textContent + ' (탭=전환)');   // SR이 현재값 읽게(도형 없어 경계 약해진 보완 · 분신술8)
}
// 저작권 ON/OFF UI — 토글 라벨·점등 + 문구 dim(OFF=제작서 빠짐 신호)
function syncCopyTog() {
  const t = $('#copyTog'); if (t) { t.textContent = copyOn ? 'ON' : 'OFF'; t.classList.toggle('on', copyOn); t.setAttribute('aria-pressed', copyOn ? 'true' : 'false'); }
  $('#cphLine') && $('#cphLine').classList.toggle('off', !copyOn);
}
// 안내문 UI — OFF(미선택)/종류명(경고·AI·자유문구) · 점등 + textarea(켜졌을 때만) + 붙여넣기(자유문구일 때만)
function syncGuide() {
  const t = $('#guideTog'); if (t) { t.textContent = guideMode ? GLAB[guideMode] : 'OFF'; t.classList.toggle('on', !!guideMode); t.setAttribute('aria-pressed', guideMode ? 'true' : 'false'); }
  const wl = $('#warnLines'); if (!wl) return;
  const wrap = wl.parentNode, btn = wrap && wrap.querySelector('.iobtn');   // attachCopyPaste가 감싼 wrap+버튼
  if (btn) {   // wrap 통째 토글 = OFF일 때 붙여넣기 버튼 플로팅/오버랩 제거
    wl.classList.remove('none'); wrap.classList.toggle('none', !guideMode);
    // 안내문 ON(caution·AI·free)이면 3종 버튼 모두 노출 — 생성된 경고문에도 붙여넣기·복사·지우개(운영자 260628). 개별 가시성(복사·지우개=내용 유무)은 attachCopyPaste refresh가 관리.
  } else { wl.classList.toggle('none', !guideMode); }     // 폴백(attach 전)
}
// 포맷 단일 토글 클릭 = 포스트↔릴스 전환(썸네일 #ovFmtTog와 동일 로직)
(function () {
  const t = $('#cpFmtTog'); if (!t) return;
  const tog = () => { cpFmt = (cpFmt === 'post') ? 'reels' : 'post'; syncCpFmt(); };
  t.addEventListener('click', tog);
  t.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); tog(); } });
})();
// 저작권 ON/OFF 클릭
(function () {
  const t = $('#copyTog'); if (!t) return;
  const tog = () => { copyOn = !copyOn; syncCopyTog(); };
  t.addEventListener('click', tog);
  t.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); tog(); } });
})();
// 문구 속 탭=수정 — 커서 끝 헬퍼 + 연도(숫자/- 만) + 이름(줄바꿈 제거) + Enter=편집 종료
function ceCaretEnd(el) { const r = document.createRange(); r.selectNodeContents(el); r.collapse(false); const s = getSelection(); s.removeAllRanges(); s.addRange(r); }
function ceBlur(el) { const fn = el && el.blur; if (fn) fn.call(el); }   // 편집 종료(모바일 키보드 내림) · 변수 경유 = check_refs의 CSS raw-blur 카운트 오탐 회피(DOM 이벤트)
(function () {
  const yr = $('#cphYear');
  if (yr) yr.addEventListener('input', () => { const clean = yr.textContent.replace(/[^0-9.\-]/g, ''); if (clean !== yr.textContent) { yr.textContent = clean; if (clean) ceCaretEnd(yr); } });
  const nm = $('#cphName');
  if (nm) nm.addEventListener('input', () => { if (/[\n\r]/.test(nm.textContent)) { nm.textContent = nm.textContent.replace(/[\n\r]+/g, ' '); ceCaretEnd(nm); } });
  [yr, nm].forEach(e => { if (e) e.addEventListener('keydown', ev => { if (ev.key === 'Enter') { ev.preventDefault(); ceBlur(e); } }); });
})();
// 안내문 = 라디오(같은 거 재선택=OFF) · caution/ai=프리셋 채움, free=비움 · 팝업서 고름
function setGuide(gm) {
  guideMode = (guideMode === gm) ? '' : gm;   // 재선택 = OFF
  if (guideMode === 'caution') { $('#warnLines').value = WARN_PRESETS.caution; $('#warnLines').dispatchEvent(new Event('input', { bubbles: true })); }
  else if (guideMode === 'ai') { $('#warnLines').value = WARN_PRESETS.ai; $('#warnLines').dispatchEvent(new Event('input', { bubbles: true })); }
  else if (guideMode === 'free') { $('#warnLines').value = ''; $('#warnLines').dispatchEvent(new Event('input', { bubbles: true })); }
  syncGuide();
  selApp('3');   // 버튼 라벨('및 맞춤법 교정') 갱신 — guideMode 의존
  if (guideMode) $('#warnLines').focus();   // 자유문구(free)는 빈 칸 커서 활성화
}
// 안내문 팝업 — #guideTog 탭하면 #guidePop 촤르륵(플랫폼 팝업과 동일), 고르면 setGuide(ON 전환·출력)
(function () {
  const trig = $('#guideTog'), pop = $('#guidePop'); if (!trig || !pop) return;
  const open = () => { pop.querySelectorAll('.gpbtn').forEach(b => b.classList.toggle('on', b.dataset.gm === guideMode)); pop.classList.remove('none'); };
  const close = () => pop.classList.add('none');
  const toggle = () => pop.classList.contains('none') ? open() : close();
  trig.addEventListener('click', e => { e.stopPropagation(); toggle(); });
  trig.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); } });
  pop.querySelectorAll('.gpbtn').forEach(b => b.onclick = () => { setGuide(b.dataset.gm); close(); });
  document.addEventListener('click', e => { if (!pop.contains(e.target) && e.target !== trig) close(); });   // 바깥 탭 = 닫기
})();
// 플랫폼 픽토그램 팝업 — #cphPlat 탭하면 #platPop 열고, 옵션 고르면 data-plat·텍스트 갱신
(function () {
  const trig = $('#cphPlat'), pop = $('#platPop'); if (!trig || !pop) return;
  const open = () => { pop.querySelectorAll('.ppbtn').forEach(b => b.classList.toggle('on', b.dataset.plat === trig.dataset.plat)); pop.classList.remove('none'); };
  const close = () => pop.classList.add('none');
  trig.addEventListener('click', e => { e.stopPropagation(); pop.classList.contains('none') ? open() : close(); });
  trig.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); pop.classList.contains('none') ? open() : close(); } });
  pop.querySelectorAll('.ppbtn').forEach(b => b.onclick = () => {
    const plat = b.dataset.plat, custom = plat === 'custom';
    trig.dataset.plat = plat;
    trig.textContent = custom ? '직접' : plat;   // custom = 라벨 '직접'(실제 값은 #cplat)
    $('#cplat').classList.toggle('none', !custom);
    close();
    if (custom) $('#cplat').focus();
  });
  document.addEventListener('click', e => { if (!pop.contains(e.target) && e.target !== trig) close(); });   // 바깥 탭 = 닫기
})();

// ---- OPA 세그 (58 기본 / 30 / 직접입력 = 버튼 안 입력창 · 2자리 자동 이탈) ----
const opaNum = $('#opaNum');
// OPA = 다중선택 토글(기본 58만 ON → 1장 · 30은 탭하면 추가 = 둘 다 생성). 선택된 것들이 곧 생성 장수.
// 최소 1개 유지 = 마지막 1개는 못 끔(0개 미선택 불가). custom = 추가 opa 토글.
document.querySelectorAll('#opaSeg button').forEach(b => b.onclick = () => {
  if (b.dataset.opa === 'custom') { b.classList.add('on'); opaNum.focus(); opaNum.select(); return; }   // 직접입력 = 값 기반: 펼쳐서 포커스만(끄지 않음)·끄기는 값 비우고 벗어남(/2와 통일)
  const onCnt = document.querySelectorAll('#opaSeg button.on').length;
  if (b.classList.contains('on') && onCnt <= 1) return;   // 마지막 1개 해제 금지(0개 불가)
  b.classList.toggle('on');
});
opaNum.addEventListener('input', () => {   // 숫자만·1~99(0 불가·2자리 상한), 2자리 차면 자동 blur
  let v = opaNum.value.replace(/[^0-9]/g, '').slice(0, 2);   // 2자리 상한 — 3자리 키보드 퀴크 제거(최대 99)
  if (v !== '') v = String(Math.min(99, parseInt(v, 10)));
  if (v === '0') v = '';   // opa 값 0 차단
  opaNum.value = v;
  if (v.length >= 2) opaNum.blur();
});
opaNum.addEventListener('blur', () => {   // 값 없이 벗어나면 직접입력 끔(라벨 복귀) = '끄려면 값 비우기'
  if (!opaNum.value) $('#opaCustom').classList.remove('on');
});
function getOpas() {   // 선택된(.on) opa 전부 = 생성할 장수. custom은 값(1~99) 있을 때만 추가. 빈배열 폴백 [58].
  const out = [];
  document.querySelectorAll('#opaSeg button.on').forEach(b => {
    if (b.dataset.opa === 'custom') { const n = parseInt(opaNum.value, 10); if (Number.isFinite(n) && n >= 1) out.push(Math.min(99, n)); }
    else { const n = parseInt(b.dataset.opa, 10); if (Number.isFinite(n)) out.push(n); }
  });
  return out.length ? out : [58];
}

// ---- 릴스 = 단일 폼(포맷 분기 폐지 · 260624). selRmode/RMODE 제거 — selApp(2)이 폼 표시·자간 init 담당. ----
// 제작 직전 결과물 명세(릴스 옵션줄) — 배경/OPA30/이미지/축약 상태 실시간 반영(활성=accent). show=APP 2만.
function syncOnOff(id, on) { const e = $(id); if (e) { e.textContent = on ? 'ON' : 'OFF'; e.classList.toggle('on', !!on); } }   // OFF/ON 토글 표시(축약·배경 공용·260624)
function syncAbbrSpec(id) { syncOnOff(id, $('#abbr').checked); }
function updateGoSpec() {
  // 릴스 단일 폼 옵션줄 (배경 / OPA 60[+30] / 합성본 / 축약)
  const spec = $('#goSpec'), head = $('#rOptHead');
  const show2 = (APP === '2');
  if (head) head.classList.toggle('none', !show2);
  if (spec) {
    spec.classList.toggle('none', !show2);
    if (show2) {
      syncOnOff('#gsBg', $('#cBg').checked);            // 배경(nobg 헤더) OFF/ON — 흰칸 고정, 배경 추가 여부
      const o1 = $('#gsOpa1'); if (o1) o1.classList.toggle('on', cOpa1on);                    // 60 토글
      const o2 = $('#gsOpa2'); if (o2) { o2.classList.toggle('on', cOpa2on); o2.textContent = cOpa2on ? String(cOpa2val) : '+30'; }   // 보조(30·조절) 토글
      const od = $('#gsOpa2Dn'), ou = $('#gsOpa2Up'); if (od) od.hidden = !cOpa2on; if (ou) ou.hidden = !cOpa2on;   // −/+ 스테퍼 = 보조 ON일 때만
      $('#gsImg').classList.toggle('on', !!CIMG.b64);   // 이미지 첨부 → 합성본 자동
      syncAbbrSpec('#gsAbbr');
    }
  }
  // 포스트(/1) 명세 — 축약만(OPA 세그·이미지·텍스트는 유지). postSpec은 linesBox 안이라 show는 linesBox 종속.
  if (APP === '1') syncAbbrSpec('#psAbbr');
}
$('#abbr').addEventListener('change', updateGoSpec);
// ── 릴스 옵션줄 컨트롤 — 배경·OPA30·축약 클릭 토글(hidden 체크박스 연동 → 발사 로직 그대로). ──
(function () {
  const tog = cb => { if (cb) { cb.checked = !cb.checked; updateGoSpec(); } };
  const bind = (id, cb) => { const t = $(id); if (!t) return; t.addEventListener('click', () => tog(cb)); t.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); tog(cb); } }); };
  // 축약 토글 = 짧게=ON/OFF · 길게(550ms)=축약어 등록 다이얼로그(운영자 260624)
  const bindAbbr = id => {
    const t = $(id); if (!t) return;
    let lpT = null, longed = false;
    const clr = () => { clearTimeout(lpT); lpT = null; };
    t.addEventListener('pointerdown', () => { longed = false; clr(); lpT = setTimeout(() => { longed = true; openAbbrDlg(); }, 550); });
    t.addEventListener('pointerup', clr); t.addEventListener('pointercancel', clr); t.addEventListener('pointerleave', clr);
    t.addEventListener('click', e => { if (longed) { e.preventDefault(); e.stopPropagation(); longed = false; return; } tog($('#abbr')); });
    t.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); tog($('#abbr')); } });
    t.addEventListener('contextmenu', e => { e.preventDefault(); openAbbrDlg(); });   // PC 우클릭 = 등록 리스트(모바일=롱프레스)
    t.title = '탭=ON/OFF · 길게/우클릭=축약어 등록';
  };
  bind('#gsBg', $('#cBg')); bindAbbr('#gsAbbr');   // 릴스 옵션줄(배경 / 축약=짧게토글·길게등록)
  bindAbbr('#psAbbr');   // 포스트 축약(짧게토글·길게등록)
})();

// ── 축약어 등록 다이얼로그 — 사용자 커스텀 치환쌍(축약 전→후) CRUD. 기본 4종은 불변(항상 적용). ──
function abbrRenumber() { document.querySelectorAll('#abbrTbl .abrow:not(.abhd)').forEach((r, i) => { const n = r.querySelector('.abno'); if (n) n.textContent = i + 1; }); }
function abbrSaveRows() {
  const pairs = [];
  document.querySelectorAll('#abbrTbl .abrow:not(.abhd):not(.abfix)').forEach(r => { const f = r.querySelector('.abfrom').value, to = r.querySelector('.abto').value; if (f) pairs.push({ from: f, to: to }); });   // 잠금(기본4종) 제외 · from 있어야 저장(to 빈값=삭제치환 허용)
  try { localStorage.setItem(ABBR_KEY, JSON.stringify(pairs)); } catch {}
}
function abbrAddRow(from, to, fixed) {   // fixed=true → 기본 4종(읽기전용·삭제불가·저장제외) / false → 사용자 커스텀
  const tbl = $('#abbrTbl'); if (!tbl) return null;
  const row = document.createElement('div'); row.className = 'abrow' + (fixed ? ' abfix' : '');
  if (fixed) {
    row.innerHTML = '<span class="abno"></span><input class="abfrom" type="text" readonly tabindex="-1"><input class="abto" type="text" readonly tabindex="-1"><span class="abfixtag">기본</span>';
    row.querySelector('.abfrom').value = from; row.querySelector('.abto').value = to;
  } else {
    row.innerHTML = '<span class="abno"></span><input class="abfrom" type="text" placeholder="군 " autocapitalize="off" autocomplete="off" autocorrect="off" spellcheck="false"><input class="abto" type="text" placeholder="軍 " autocapitalize="off" autocomplete="off" autocorrect="off" spellcheck="false"><button class="abdel" type="button" aria-label="삭제">×</button>';
    row.querySelector('.abfrom').value = from || ''; row.querySelector('.abto').value = to || '';
    row.querySelector('.abfrom').addEventListener('input', abbrSaveRows);
    row.querySelector('.abto').addEventListener('input', abbrSaveRows);
    row.querySelector('.abdel').addEventListener('click', () => { row.remove(); abbrRenumber(); abbrSaveRows(); });
  }
  tbl.appendChild(row); abbrRenumber(); return row;
}
function abbrRenderRows() {
  const tbl = $('#abbrTbl'); if (!tbl) return;
  tbl.querySelectorAll('.abrow:not(.abhd)').forEach(r => r.remove());
  ABBR_BUILTIN.forEach(([f, t]) => abbrAddRow(f, t, true));   // 기본 4종 = 잠금 행(리스트에 보이되 수정/삭제 불가·항상 적용)
  const cur = abbrCustom();
  if (cur.length) cur.forEach(p => abbrAddRow(p.from, p.to)); else abbrAddRow('', '');   // 사용자 커스텀(없으면 빈 1행)
}
let _abbrPushed = false;
function closeAbbrDlg(viaBack) {
  abbrSaveRows();
  const dlg = $('#abbrDlg'); if (dlg && dlg.open) dlg.close();
  if (_abbrPushed && !viaBack) { _abbrPushed = false; try { history.back(); } catch {} } else _abbrPushed = false;
}
function openAbbrDlg() {
  const dlg = $('#abbrDlg'); if (!dlg) return;
  abbrRenderRows();
  try { history.pushState({ abbrDlg: 1 }, ''); _abbrPushed = true; } catch { _abbrPushed = false; }
  dlg.showModal();
}
(function () {
  const dlg = $('#abbrDlg'); if (!dlg) return;
  const x = $('#abbrX'); if (x) x.addEventListener('click', () => closeAbbrDlg(false));
  const add = $('#abbrAdd'); if (add) add.addEventListener('click', () => { const r = abbrAddRow('', ''); const inp = r && r.querySelector('.abfrom'); if (inp) inp.focus(); });
  dlg.addEventListener('cancel', e => { e.preventDefault(); closeAbbrDlg(false); });   // ESC
  dlg.addEventListener('click', e => { if (e.target === dlg) closeAbbrDlg(false); });   // 백드롭
  window.addEventListener('popstate', () => { if (dlg.open) closeAbbrDlg(true); });     // 폰 뒤로가기
})();
$('#cBg').addEventListener('change', updateGoSpec);     // 배경 → 헤더 nobg 추가(흰칸 + nobg = 2장)

// ── 릴스 자막 OPA = 60 토글 + 보조(기본30·스크롤 조절) 토글 · 최소 1개 (운영자 260624) ──
// 60 = 고정값 on/off · 보조 = 클릭으로 추가/끄기, 켜면 값을 휠/드래그로 위아래 조절. 보조 ON이면 60 OFF 가능(둘 다 끄기만 차단).
function _opaToggle(which) {
  if (which === 1) { if (cOpa1on && !cOpa2on) return; cOpa1on = !cOpa1on; }   // 마지막 1개 못 끔(0개 방지)
  else { if (cOpa2on && !cOpa1on) return; cOpa2on = !cOpa2on; }
  updateGoSpec();
}
(function () {
  const o1 = $('#gsOpa1'), o2 = $('#gsOpa2');
  if (o1) { o1.addEventListener('click', () => _opaToggle(1)); o1.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); _opaToggle(1); } }); }
  if (o2) {
    let _adjT = null, py = null, acc = 0, moved = false;
    const setVal = v => { cOpa2val = Math.max(1, Math.min(100, v | 0)); if (cOpa2on) { o2.textContent = String(cOpa2val); o2.classList.add('opa-adjusting'); clearTimeout(_adjT); _adjT = setTimeout(() => o2.classList.remove('opa-adjusting'), 420); } };   // 조절 중 mut → 멈추면 강조색
    o2.addEventListener('click', () => { if (moved) { moved = false; return; } _opaToggle(2); });   // 드래그로 움직였으면 토글 억제
    o2.addEventListener('wheel', e => { if (!cOpa2on) return; e.preventDefault(); setVal(cOpa2val + (e.deltaY < 0 ? 1 : -1)); }, { passive: false });
    o2.addEventListener('pointerdown', e => { if (!cOpa2on) return; py = e.clientY; acc = 0; moved = false; try { o2.setPointerCapture(e.pointerId); } catch (_) {} });
    o2.addEventListener('pointermove', e => { if (py === null) return; acc += (py - e.clientY); py = e.clientY; while (acc >= 12) { setVal(cOpa2val + 1); acc -= 12; moved = true; } while (acc <= -12) { setVal(cOpa2val - 1); acc += 12; moved = true; } });   // 위로 끌면 값 증가
    const end = () => { py = null; }; o2.addEventListener('pointerup', end); o2.addEventListener('pointercancel', end);
    o2.addEventListener('keydown', e => { if (!cOpa2on) { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); _opaToggle(2); } return; } if (e.key === 'ArrowUp') { e.preventDefault(); setVal(cOpa2val + 1); } else if (e.key === 'ArrowDown') { e.preventDefault(); setVal(cOpa2val - 1); } else if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); _opaToggle(2); } });
    // −/+ 탭 스테퍼(모바일 드래그 보완) = ±5. ON일 때만 의미(updateGoSpec가 노출 토글).
    const od = $('#gsOpa2Dn'), ou = $('#gsOpa2Up');
    const step = d => () => { if (cOpa2on) setVal(cOpa2val + d); };
    if (od) { od.addEventListener('click', step(-5)); od.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); step(-5)(); } }); }
    if (ou) { ou.addEventListener('click', step(5)); ou.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); step(5)(); } }); }
  }
})();

// ---- 릴스 자막 OPA → 켜진 슬롯값(60 고정 / 보조=조절) 배열, 최소 [60] ----
function getComboOpas() { const out = []; if (cOpa1on) out.push(60); if (cOpa2on) out.push(cOpa2val); const u = [...new Set(out)]; return u.length ? u : [60]; }

// ---- 파일 (재사용 바인더 — #file=/1·/5 배경) ----
function bindFile(inp, lab, store) {
  // 빈 상태 = 플레이트 없는 픽토그램만(ly .file 통일) · 누름 피드백은 CSS .file:active svg 축소뿐.
  // 옛 .picking 강조(누름→업로드창 열림 동안 배경/테두리)는 PC에서 파일 대화상자가 별창이라 페이지 뒤로 노출 → 폐지(ly엔 없음·자막생성기와 동일 동작·운영자 260628).
  const inpId = inp.id;   // ⚠️ innerHTML 교체 시 새 input에 원래 id 복원 — 안 하면 #file id 소실 → FAB(rfab3) imgInput()=getElementById('file')가 null → 이미지 선택 '선택적으로만 작동' 버그(운영자 260628)
  const rebindInput = () => { const ni = lab.querySelector('input'); if (ni) { ni.onchange = handler; if (inpId) ni.id = inpId; } };
  const reset = () => {   // 휴지통 → 업로드 취소: store 비우고 라벨 초기 상태로 + input 재바인드(운영자 260622)
    store.b64 = ''; store.name = '';
    lab.classList.remove('has');
    lab.innerHTML = '<span class="filepic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="9.5" r="1.5"/><path d="M21 16l-5-5L5 20"/></svg></span><input type="file" accept="image/*" style="display:none">';
    rebindInput();
  };
  const applyImg = (b64, name) => {   // b64+이름 → 미리보기 렌더(파일선택·수정복원 공용)
    store.b64 = b64; store.name = name || '';
    lab.innerHTML = '<div class="fileprev"><img src="' + b64 + '"><button type="button" class="filerm" aria-label="이미지 삭제" title="이미지 삭제">' + TRASH_SVG + '</button><span class="fn">' + (name || '') + '</span></div>' +
      '<input type="file" accept="image/*" style="display:none">';
    lab.classList.add('has');
    rebindInput();   // innerHTML 교체로 사라진 input 재바인드 + id 복원(FAB getElementById('file') 유지)
    const rm = lab.querySelector('.filerm');   // 휴지통 = 라벨 클릭(파일창 열림) 안 타게 차단 후 삭제
    if (rm) rm.onclick = ev => { ev.preventDefault(); ev.stopPropagation(); reset(); };
  };
  const handler = e => {
    const f = e.target.files[0]; if (!f) return;
    const r = new FileReader();
    r.onload = () => applyImg(r.result, f.name);
    r.readAsDataURL(f);
  };
  const applyRef = (url) => {   // 합성본 빗금 참고본(원본 없음·타 기기) — store 비움(재렌더 시 재선택 필요)
    store.b64 = ''; store.name = '';
    lab.innerHTML = '<div class="fileprev refonly"><img src="' + esc(url) + '"><span class="refhatch" aria-hidden="true"></span><span class="refbadge">참고</span><button type="button" class="filerm" aria-label="이미지 삭제" title="이미지 삭제">' + TRASH_SVG + '</button></div>' +
      '<input type="file" accept="image/*" style="display:none">';
    lab.classList.add('has');
    rebindInput();
    const rm = lab.querySelector('.filerm');
    if (rm) rm.onclick = ev => { ev.preventDefault(); ev.stopPropagation(); reset(); };
  };
  inp.onchange = handler;
  lab._reset = reset;   // 수정 복원 시 이미지 위젯 비우기(외부 호출용)
  lab._set = applyImg;   // 수정 복원 시 원본 이미지 주입(외부 호출용)
  lab._setRef = applyRef;   // 수정 복원 시 합성본 빗금 참고본(원본 없음·타 기기)
}
bindFile($('#file'), $('#fileLab'), IMG);
// 이미지 슬롯(텍스트 2/3 우측 1/3) — 기본(자막)·오버레이 공용 바인더. 미선택=사진 픽토그램 / 선택=썸네일+X. input은 슬롯 밖(innerHTML 교체에 안전)·rfab b3도 직접 click.
function bindSlotImg(slotSel, inputSel, store) {
  const slot = $(slotSel), inp = $(inputSel); if (!slot || !inp) return;
  const PHOTO = '<span class="covimg-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"></rect><circle cx="8.5" cy="9.5" r="1.5"></circle><path d="M21 16l-5-5L5 20"></path></svg></span><span class="covimg-t">이미지</span>';
  const XS = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 6 18 18M18 6 6 18"/></svg>';
  const empty = () => { slot.classList.remove('has', 'refonly'); slot.innerHTML = PHOTO; updateGoSpec(); };
  const filled = (url, kb) => { slot.classList.remove('refonly'); slot.classList.add('has'); slot.innerHTML = '<img src="' + url + '" alt=""><button type="button" class="covimg-x" aria-label="이미지 삭제">' + XS + '</button>' + (kb ? '<span class="covimg-kb">' + kb + 'KB</span>' : ''); updateGoSpec(); };
  slot.addEventListener('click', e => {
    if (e.target.closest('.covimg-x')) { e.preventDefault(); e.stopPropagation(); store.b64 = ''; store.name = ''; inp.value = ''; empty(); return; }   // X = 삭제 → 빈 슬롯
    if (!slot.classList.contains('has')) inp.click();   // 빈 슬롯 = 파일 선택(채운 상태는 X로만 비우고 재선택)
  });
  slot.addEventListener('keydown', e => { if ((e.key === 'Enter' || e.key === ' ') && !slot.classList.contains('has')) { e.preventDefault(); inp.click(); } });
  inp.onchange = e => {
    const f = e.target.files[0]; if (!f) return;
    const r = new FileReader();
    r.onload = () => { store.b64 = r.result; store.name = f.name; filled(r.result, Math.round(f.size / 1024)); };
    r.readAsDataURL(f);
  };
  slot._reset = () => { store.b64 = ''; store.name = ''; inp.value = ''; empty(); };   // 수정 복원 시 슬롯 비우기(외부 호출용)
  slot._set = (b64, name) => { store.b64 = b64; store.name = name || ''; filled(b64); };   // 수정 복원 시 원본 이미지 주입(외부 호출용)
  slot._setRef = (url) => {   // 합성본 빗금 참고본(원본 없음·타 기기) — store 비움(재렌더 시 재선택 필요). X=비우기·재선택.
    store.b64 = ''; store.name = ''; inp.value = '';
    slot.classList.add('has', 'refonly');
    slot.innerHTML = '<img src="' + esc(url) + '" alt=""><span class="refhatch" aria-hidden="true"></span><span class="refbadge">참고</span><button type="button" class="covimg-x" aria-label="이미지 삭제">' + XS + '</button>';
    updateGoSpec();
  };
  empty();
}
bindSlotImg('#cImgSlot', '#cFile', CIMG);   // 릴스 자막 슬롯
bindSlotImg('#pImgSlot', '#pFile', PIMG);   // 포스트 배경 슬롯(전 full-width #fileLab → 슬롯·260624)

// ==== 붙여넣기↔복사 + 다운로드 (뷰어 버튼 UIUX 계승) ====
// 잡 상태 픽토그램(이모지 ✅⚠⏳ 폐지 → SVG 통일·글자와 수직중앙 · 운영자 260622)
const SPIN_SVG = '<svg class="jspin" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M21 12a9 9 0 1 1-6.2-8.6"/></svg>';
const EDIT_SVG = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>';   // 연필 = 수정(이전 제작 → 작성기 복원)
// 전체저장(.jsave) 다운로드 시퀀스 버튼 = 다운↔체크 스왑 한 벌 (완료 시 ✓ 팝 · 정본 패턴 구성도 §9)
const DLSEQ_IC = '<span class="dlseq-ic">' + DOWNLOAD_SVG.replace('<svg ', '<svg class="dn" ') + CHECK_SVG.replace('<svg ', '<svg class="chk" ') + '</span>';
// 전체저장 시퀀스 — 순차 저장(진행 i/N·좌→우 채움) → ✓ 팝 → 우측 드레인 풀림(index dlAllSeq와 동일 연출·운영자 260622)
// job 기반 — renderJob이 다운 도중 잡 행을 재렌더해 .jsave를 새로 그려도(innerHTML 교체) job._dlSt로 상태를 복원,
// 매 스텝 live() 로 *현재* 버튼에 적용 → ✓가 확실히 뜸(운영자 260623 버그픽스). 완료 hold 1.5s로 또렷.
async function jSaveSeq(job) {
  if (!job || job._dlbusy) return;
  const saves = (job.saves || []).filter(s => s && s.url);
  if (!saves.length) return;
  job._dlbusy = 1;
  const live = () => document.querySelector('#job-' + job.n + ' .jsave');
  const apply = st => { const b = live(); if (!b) return; b.classList.remove('dlseq-busy', 'dlseq-done', 'dlseq-snap'); if (st && st.cls) b.classList.add(st.cls); b.style.setProperty('--p', st ? st.p : '0'); const l = b.querySelector('.jslbl'); if (l) l.textContent = st ? st.txt : '전체'; b.style.pointerEvents = (st && st.cls === 'dlseq-busy') ? 'none' : ''; };
  for (let i = 0; i < saves.length; i++) {
    dlBlob(saves[i].url, saves[i].dlname);
    job._dlSt = { cls: 'dlseq-busy', p: String((i + 1) / saves.length), txt: `저장 중… ${i + 1}/${saves.length}` };
    apply(job._dlSt);
    await new Promise(r => setTimeout(r, 300));
  }
  job._dlSt = { cls: 'dlseq-done', p: '1', txt: '완료' };
  apply(job._dlSt);   // 꽉 채움 + ✓ 팝
  setTimeout(() => {   // ✓ 1.5s 보여준 뒤 즉시 복귀(드레인 없음)
    job._dlSt = null;
    const b = live();
    if (b) { b.classList.add('dlseq-snap'); b.classList.remove('dlseq-done', 'dlseq-busy'); b.style.setProperty('--p', '0'); const l = b.querySelector('.jslbl'); if (l) l.textContent = '전체'; requestAnimationFrame(() => { const bb = live(); if (bb) bb.classList.remove('dlseq-snap'); }); b.style.pointerEvents = ''; }
    job._dlbusy = 0;
  }, 1500);
}
const RETRY_SVG = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v6h6"/><path d="M3.51 14a9 9 0 1 0 .49-5"/></svg>';
const TRASH_SVG = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/></svg>';
const ERASE_UNDO_MS = 10000;   // 지움 후 되돌리기 노출 시간(~10초) → 지나면 원래 지우개로
async function clipCopy(text, btn, after) {   // 복사 → ✓ 피드백
  try { await navigator.clipboard.writeText(text || ''); } catch {}
  btn.innerHTML = CHECK_SVG; btn._icon = 'check'; btn.classList.add('ok');   // _icon 갱신 = 'ok' 해제 후 refresh가 원아이콘 복원(번쩍 가드와 짝)
  setTimeout(() => { btn.classList.remove('ok'); after(); }, 1200);
}
// ⚠️⚠️ 통일 기틀(운영자 260628): 칩/입력칸 붙여넣기 = readText 우선 / 막힌 환경(모바일 iframe·칩은 네이티브 길게눌러 붙여넣기 불가)엔 '길게 눌러 붙여넣기' 폴백.
//   thumb.html(카드뉴스 제작 칩·입력칸) ↔ index.html(카드 변경 칩·입력칸) **양쪽 동일 유지** — 한쪽 바뀌면 반드시 양쪽 통일. 정본 동기화 의무(§📐 드리프트 차단).
async function clipPasteText() {   // 클립보드 텍스트 읽기(폴백 포함) — 칩·textarea 공용
  try { if (navigator.clipboard && navigator.clipboard.readText) { const t = await navigator.clipboard.readText(); if (t) return t; } } catch {}
  return await clipPasteFallback();   // readText 거부/빈값 → 사용자 네이티브 붙여넣기 받는 입력
}
function clipPasteFallback() {
  return new Promise(resolve => {
    const ov = document.createElement('dialog'); ov.className = 'pastefb';   // dialog = top-layer(열린 모달 위에도 보장)
    ov.innerHTML = '<div class="pastefb-box"><div class="pastefb-msg">아래 칸을 <b>길게 눌러 “붙여넣기”</b> 하면 자동 반영돼</div>'
      + '<textarea class="pastefb-ta" placeholder="여기에 붙여넣기" autocapitalize="off" autocomplete="off" spellcheck="false"></textarea>'
      + '<div class="pastefb-row"><button type="button" class="pastefb-btn pastefb-cancel">취소</button><button type="button" class="pastefb-btn pastefb-ok">적용</button></div></div>';
    document.body.appendChild(ov);
    const ta = ov.querySelector('.pastefb-ta'); let done = false;
    const finish = v => { if (done) return; done = true; try { ov.close(); } catch {} ov.remove(); resolve(v || null); };
    ta.addEventListener('paste', () => setTimeout(() => { if (ta.value) finish(ta.value); }, 30));   // 붙여넣기 즉시 자동 반영
    ov.querySelector('.pastefb-ok').onclick = () => finish(ta.value);
    ov.querySelector('.pastefb-cancel').onclick = () => finish(null);
    ov.addEventListener('cancel', e => { e.preventDefault(); finish(null); });   // ESC
    ov.addEventListener('click', e => { if (e.target === ov) finish(null); });   // 백드롭 탭
    try { ov.showModal(); } catch { ov.setAttribute('open', ''); }
    setTimeout(() => { try { ta.focus(); } catch {} }, 60);
  });
}
function attachCopyPaste(el, withErase) {   // 빈칸=붙여넣기 / 내용 있으면 [복사][붙여넣기](+지우개) — 붙여넣기는 복사로 안 바뀌고 항상 유지, 복사는 좌측에 별도 추가(운영자 260627·기존 단일 토글에서 분리). withErase=붙여넣기 우측 지우개(입력 비움)
  const wrap = document.createElement('div'); wrap.style.position = 'relative'; wrap.classList.add('iowrap');   // iowrap = 머리↔첫칸 간격 단일소스(#rCombo > .iowrap margin-top) 타겟 + 입력칸 밀착(클립 라인정렬)
  if (el.classList.contains('covta')) { wrap.classList.add('covta'); el.classList.remove('covta'); }   // covrow flex(2/3)를 wrap이 승계 = 클립 부착해도 슬롯 안 찌부(운영자 260624)
  el.parentNode.insertBefore(wrap, el); wrap.appendChild(el);
  const split = true;   // 전 입력칸 통일 = 붙여넣기 항상 유지 + 복사 별도(좌측) · warnLines(안내문/경고문)도 3종(운영자 260628)
  const nBtn = (split ? 2 : 1) + (withErase ? 1 : 0);   // 복사+붙여넣기(+지우개)
  el.style.paddingRight = (el.tagName !== 'TEXTAREA') ? (14 + nBtn * 32) + 'px' : '42px';   // 입력칸(단일행)=버튼 수만큼 우측 폭 확보(글자 세로중앙=버튼과 겹침 방지) · 텍스트칸=버튼이 1행 위 테두리로 떠 안 겹침 → 42 유지(폭 보존 = 좁은 폰 줄바꿈 방지·운영자 260625)
  const btn = document.createElement('button'); btn.type = 'button'; btn.className = 'iobtn iobtn-edge' + (withErase ? ' iobtn-pp' : ''); wrap.appendChild(btn);   // 붙여넣기(분리 시 항상) / 토글(warnLines) = 테두리 걸친 동그라미(시안 2A·260624) · 지우개 동반 시 좌측(iobtn-pp)
  let copyB = null;
  if (split) {   // 복사 = 내용 있을 때만 노출·붙여넣기 좌측·동일 크기 (붙여넣기 유지 위해 별도 버튼 · 운영자 260627)
    copyB = document.createElement('button'); copyB.type = 'button'; copyB.className = 'iobtn iobtn-edge iobtn-copy' + (withErase ? ' iobtn-copy-e' : '') + ' iobtn-hide';
    copyB.innerHTML = COPY_SVG; copyB.setAttribute('aria-label', '복사'); copyB.title = '복사';
    copyB.onclick = ev => { ev.preventDefault(); clipCopy(el.value, copyB, refresh); };   // 복사 전용(붙여넣기 안 건드림)
    wrap.appendChild(copyB);
  }
  let eraser = null, undoTimer = null, undoVal = '', prog = false;   // prog = 프로그램적 변경(지움/복원) 표시 → 그때의 input은 되돌리기창 종료 트리거 아님
  const setIcon = (b, svg, key) => { if (b._icon !== key) { b.innerHTML = svg; b._icon = key; } };   // 아이콘 동일하면 innerHTML 재대입 안 함 = 타이핑마다 SVG 파괴·재생성(번쩍거림) 차단(운영자 260628)
  const refresh = () => {
    const filled = (el.value || '').trim().length > 0;
    if (split) {
      if (!btn.classList.contains('ok')) { setIcon(btn, PASTE_SVG, 'paste'); btn.dataset.mode = 'paste'; btn.setAttribute('aria-label', '붙여넣기'); btn.title = '붙여넣기'; }   // 붙여넣기는 항상 붙여넣기(복사로 안 바뀜)
      if (copyB && !copyB.classList.contains('ok')) { setIcon(copyB, COPY_SVG, 'copy'); copyB.classList.toggle('iobtn-hide', !filled); }   // 복사 = 내용 있을 때만 좌측 노출
    } else if (!btn.classList.contains('ok')) {   // warnLines = 기존 단일 토글(빈칸 붙여넣기 ↔ 차면 복사)
      setIcon(btn, filled ? COPY_SVG : PASTE_SVG, filled ? 'copy' : 'paste'); btn.dataset.mode = filled ? 'copy' : 'paste'; btn.setAttribute('aria-label', filled ? '복사' : '붙여넣기');
    }
