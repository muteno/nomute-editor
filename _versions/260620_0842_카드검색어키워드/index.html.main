%FONTFACE%
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  html, body { background:#0b0d0c; }
  ::selection { background:rgba(30,215,96,.28); }
  body { color:#e9e9e9; font-family:'Pretendard Variable',Pretendard,-apple-system,BlinkMacSystemFont,'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic','Segoe UI',Roboto,sans-serif; -webkit-font-smoothing:antialiased; font-size:15px; line-height:1.72; }   /* 임베드 woff2=흔한 한글 서브셋 / 한자·희귀한글·必·ⓒ는 OS 한국어 폰트(Apple SD/Noto/Malgun)로 per-glyph 폴백 */
  .nm-root { position:relative; min-height:100vh; padding:30px 16px 56px; overflow:hidden; }
  .nm-bg { position:absolute; inset:0; z-index:0; pointer-events:none; overflow:hidden; }
  .nm-wrap { position:relative; z-index:1; max-width:720px; margin:0 auto; }
  .nm-head { display:flex; align-items:flex-start; gap:14px; margin:0 2px 26px; }
  .nm-head-l { flex:1; min-width:0; }
  .nm-logo { display:block; width:78px; height:78px; object-fit:contain; margin:-8px 0 10px -8px; }
  .nm-meta { display:flex; flex-wrap:wrap; align-items:center; gap:9px 16px; margin:0 0 14px; font-size:12.5px; }
  .nm-badge { display:inline-flex; align-items:center; height:25px; padding:0 12px; border-radius:999px; background:rgba(30,215,96,.16); border:1px solid rgba(30,215,96,.42); color:#1ED760; font-weight:800; font-size:11.5px; letter-spacing:.02em; flex:none; white-space:nowrap; }
  .nm-mline { display:inline-flex; align-items:center; gap:11px; flex-wrap:wrap; }
  .nm-media { color:#fff; font-weight:800; white-space:nowrap; }
  .nm-dotsep { width:3px; height:3px; border-radius:50%; background:#565656; flex:none; }
  .nm-date { color:#9a9a9a; font-weight:500; white-space:nowrap; }
  .nm-reporter { color:#c4c4c4; font-weight:600; white-space:nowrap; }
  .nm-title { font-size:23px; font-weight:900; line-height:1.34; margin:0; letter-spacing:-.6px; color:#fff; }
  .nm-allbtn { flex:none; align-self:flex-start; margin-top:9px; display:inline-flex; align-items:center; gap:4px; height:26px; padding:0 11px; border:none; border-radius:999px; background:#1ED760; color:#000; font-family:inherit; font-size:11px; font-weight:600; cursor:pointer; transition:transform .12s, background .15s; }
  .nm-allbtn:hover { background:#1FE065; transform:scale(1.03); }
  .nm-allbtn:active { transform:scale(.95); }
  .nm-allbtn.ok { background:#1ED760; }
  .nm-grp { margin:20px 4px 8px; font-size:11px; font-weight:800; letter-spacing:.12em; text-transform:uppercase; color:#7d7d7d; }
  .nm-sec { position:relative; background:rgba(28,30,29,.64); -webkit-backdrop-filter:blur(18px) saturate(120%); backdrop-filter:blur(18px) saturate(120%); border:1px solid rgba(255,255,255,.12); border-radius:14px; padding:18px 20px; margin:0 0 14px; box-shadow:0 8px 30px rgba(0,0,0,.4), inset 0 1px 0 rgba(255,255,255,.08); transition:background .15s; }
  .nm-sec:hover { background:rgba(42,44,43,.72); }
  .nm-tip { background:linear-gradient(180deg,rgba(30,215,96,.17),rgba(20,140,80,.06)); border:1px solid rgba(30,215,96,.34); box-shadow:0 8px 30px rgba(0,0,0,.35), inset 0 1px 0 rgba(255,255,255,.1); }
  .nm-tip:hover { background:linear-gradient(180deg,rgba(30,215,96,.22),rgba(20,140,80,.1)); }
  .nm-h { display:flex; align-items:center; gap:9px; font-size:13px; font-weight:700; letter-spacing:.04em; color:#fff; margin:0 0 10px; text-transform:uppercase; }
  .nm-tip .nm-h { color:#1ED760; }
  .nm-dot { width:7px; height:7px; border-radius:50%; background:#1ED760; display:inline-block; flex:none; }
  .nm-tip .nm-dot { box-shadow:0 0 8px rgba(30,215,96,.7); }
  .nm-body { background:rgba(0,0,0,.3); -webkit-backdrop-filter:blur(8px); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,.1); border-radius:9px; padding:13px 15px; word-break:break-word; overflow-wrap:anywhere; }   /* 내부 스크롤 제거 = 펼침(화면 스크롤 우선) + 긴 URL·연속문자 박스 안에서 줄바꿈(복사 칸 벗어남 방지 · 운영자 260620) */
  .nm-tip .nm-body { background:rgba(0,0,0,.28); border:1px solid rgba(30,215,96,.22); }
  .nm-body > :first-child { margin-top:0; }
  .nm-body > :last-child { margin-bottom:0; }
  .nm-body p { margin:7px 0; color:#e6e6e6; }
