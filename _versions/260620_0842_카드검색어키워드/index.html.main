const CROSS_POW = 1.6;   // cross^POW. 조정 가능(↑일수록 다매체 더 지배).
const crossConvex = c => Math.pow(c.cross || 0, CROSS_POW);
// 2) 시간 가속 감점(Hill): 발생(발행 pubAge=scTs, 화면 'N시간 전') 기준. 최신엔 거의 1, ~12h 넘으면 *가속* 침몰
//    (8→10h보다 10→12h가 더 깎임 — 운영자 "12h 후 가속"). 활동시각(last_report)은 활성 사이클서 0~2h 균일이라
//    시간축이 죽어 폐기 → 발행 기준 복원(계속보도 가치는 scFollow가 따로 가점 — 역할 분리).
//    timeW=1/(1+(age/HALF)^POW): 6h=.91·12h=.56·18h=.27·24h=.14·36h=.045·48h=.02 (13·3.0 — 12h 반값·이후 가속).
const ACC_T_HALF = 13, ACC_T_POW = 3.0;   // 반값 나이(h)·가속지수 — 12h 후 가속 침몰(운영자 260618: 18·2.5는 12h=.73로 완만 → cross^1.6 볼록에 눌려 철지난 다수매체가 상위 점유 '묵은 피드'였음. 13·3.0=12h 반값·이후 급강). 조정 가능.
const timeAcc = c => 1 / (1 + Math.pow(Math.max(0, (Date.now() - scTs(c)) / 3600000) / ACC_T_HALF, ACC_T_POW));
// 누적(좌) 정렬 = cross 볼록가점 × 시간 가속감점(발행) × 연속보도(scFollow) × AI 경중(gradeW). 다수동시+최신+계속+양질=상단.
const scScore = c => crossConvex(c) * timeAcc(c) * scFollow(c) * gradeW(c);
let scRT = {};   // 정렬 중 픽 상태 참조용(renderScrap이 채움)
// pinB = 확정 breaking & 아직 안 픽이면 1(픽하면 0). 누적칼럼 강제핀은 260617 제거 — 이 값은 pinFresh(신규칼럼 최신속보 핀)에서만 씀.
const pinB = c => { const r = scRT[candId(c)] || {}; return (isBreaking(c) && !r.picked && !r.acked) ? 1 : 0; };   // 확인(✓)·픽 = 핀 해제(상단 고정 안 함 — 확인=처리됨, 운영자 260619)
// 최신 핀 = 확정 속보 AND 발생 4h 내(최신)만 상단 고정. 오래된 속보는 핀 안 함 → fastScore decay로 하강(findable but 톱 아님 — 16h 속보가 최신 톱 차지하던 문제 해결).
const pinFresh = c => (pinB(c) && (Date.now() - scTs(c)) < FAST_MAX_H * 3600000) ? 1 : 0;
// 수집함 배지(사건 속성) = 🚨긴급(breaking 신규<4h·미확인) / ⚡이슈(4h~24h AND [cross≥8 또는 aged breaking]) / 없음. 신규(<4h)엔 이슈 안 뜸(이슈=넓게 쌓인 누적 속성)·1일↑ 없음(운영자 260618). 나이기준=scTs(발행·칼럼 경계와 동일)·brkIssueKind(피드)와 동일 규칙. ⚠️ ✓확인(acked)해도 🚨 유지 = 긴급은 사건속성·계속 표시(운영자 260620 · 4h 지나면 자연히 ⚡이슈).
const scBadge = c => { const ageH = (Date.now() - scTs(c)) / 3600000;
  if (isBreaking(c) && ageH < FAST_MAX_H) return '<span class="sc-brk brk-hot">🚨 긴급</span>';   // ✓확인해도 유지(운영자 260620: 긴급=사건속성) · 4h후 ⚡이슈
  if (ageH >= FAST_MAX_H && ageH < 24 && ((c.cross || 0) >= 8 || isBreaking(c))) return '<span class="sc-brk">⚡ 이슈</span>';
  return ''; };
// 카드 테두리 점등(앰버 '이슈') = <12h AND cross≥16(=이슈배지 8×2). 긴급(빨강) 테두리 없음 — breaking=긴급이라 무조건 켜져 의미 없음(🚨배지+빨강 프로필링+토스트 3중으로 충분)·aged-breaking 노이즈 제거. 운영자 260619. (배지 scBadge는 그대로: ⚡이슈=cross≥8.)
const scLit = c => ((Date.now() - scTs(c)) / 3600000) < 12 && (c.cross || 0) >= 16;
const SC_COLS_HTML =
  '<div class="scrap-col green"><div class="scrap-coltitle ct-cross">누적</div><div class="scrap-list" data-col="cross"></div></div>' +
  '<div class="scrap-col black"><div class="scrap-coltitle ct-new">신규</div><div class="scrap-list" data-col="new"></div></div>';
function makeScItem(c, st, col) {       // 카드 1장 생성(반환). col='cross'(누적/주요도)면 👎 없음 — 다매체 누적=검증된 메이저.
  const el = document.createElement('div');
  el.className = 'sc-item' + (scLit(c) ? ' breaking' : '') + (st.score ? ' rated' : '') + (st.picked ? ' picked' : '') + (st.picked && pickFailedShow(c) ? ' pickfail' : '') + (st.acked ? ' acked' : '');
  el.dataset.cid = candId(c);   // Picking…→PICKED 제자리 갱신 매칭용
  const lo = (c.cross || 0) < 2 ? ' lo' : '';
  const tm = scRelTime(c.published) || c.time || '';
  const catB = articleCat({ category: c.cat, title: c.title });
  const triage = true;   // 누적·최신 둘 다 트리아지([👎][PASS][PICK]+사유)로 통일(사용자 요청 — 판단 기준 일원화)
  const showMemo = !triage && (st.score === 1 || st.score === 5);   // 극단 평점(1·5) = 이유 입력칸(누적만)
  const moreN = (st.picked && st.pickCross != null) ? Math.max(0, (c.cross || 0) - st.pickCross) : 0;   // 픽 후 추가 보도 매체 수
  el.innerHTML =
    `<div class="sc-top">${scBadge(c)}${catB ? catChip(catB) : ''}<span class="sc-cross${lo}">⛓ ${c.cross || 0}</span>${moreN ? `<span class="sc-more" title="픽 후 추가 보도 매체">＋${moreN} 더</span>` : ''}<span class="sc-media">${esc(c.media || '')}${tm ? ' · ' + esc(tm) : ''}</span></div>
     <div class="sc-title"><a href="${esc(c.url || '#')}" target="_blank" rel="noopener"></a></div>
     <div class="sc-bot${triage ? ' triage' : ''}">${triage
       ? (st.picked
           ? (pickFailedShow(c)
               ? failChipHtml(c)
               : ((pickSettled(c) || !DATA_LOADED)
                   ? `<div class="sc-got" aria-label="픽 완료" title="탭하면 피드에서 이 기사 열기">PICKED</div>`
                   : `<div class="sc-got picking" aria-label="분석 중"><span>Picking…</span></div>`))
           : `<button class="sc-tg down" type="button" aria-label="관심 없음">${THUMBDOWN_SVG}</button><button class="sc-tg pass" type="button">PASS</button><button class="sc-tg pick" type="button">PICK</button><button class="sc-tg ack${st.acked ? ' on' : ''}" type="button" aria-label="확인 — 봤음 표시" title="확인 — 봤다고 표시(신규와 구분·흐려짐)">${CHECK_SVG}</button>`)
       : `<div class="sc-stars">${[1, 2, 3, 4, 5].map(n => `<button class="sc-star${st.score >= n ? ' on' : ''}" type="button" data-n="${n}" aria-label="관심도 ${n}점">★</button>`).join('')}</div><button class="sc-pick${st.picked ? ' done' : ''}" type="button" title="${st.picked ? '큐레이션 보냄 — 몇 분 뒤 피드에 떠' : '분석·카드 자동 생성(피드로) — 한 번 더 눌러 확정'}"><span>${st.picked ? '큐레이션 ✓' : 'PICK'}</span></button>`}</div>
     ${showMemo ? `<div class="sc-memo"><input class="sc-memo-in" data-id="${esc(candId(c))}" type="text" maxlength="200" placeholder="왜 ${st.score}점? 한 줄 (안 쓰면 주요도서 숨김·엔터 저장)"></div>` : ''}`;
  el.querySelector('.sc-title a').textContent = c.title || '(제목 없음)';
  if (triage) {   // 최신 = [👎][PASS][PICK] → 각각 사유(객관식) 받고 처리. PICK은 잔류(PICKED 비활성), down/pass는 접힘.
    if (!st.picked) {
      el.querySelector('.sc-tg.down').onclick = () => askReason('down', c, el);
      el.querySelector('.sc-tg.pass').onclick = () => askReason('pass', c, el);
      el.querySelector('.sc-tg.pick').onclick = () => askReason('pick', c, el);
      el.querySelector('.sc-tg.ack').onclick = () => toggleAck(c, el);
    } else if (pickFailedShow(c)) {   // 픽했는데 분석 실패/무응답 = Failed 칩(탭→원문 / 길게·우클릭→메뉴) 배선
      wireFailChip(el.querySelector('.sc-fail'), c);
    } else {   // PICKED(완료) = 탭하면 피드(메뉴3)로 이동 + 해당 기사 팝업
      const g = el.querySelector('.sc-got:not(.picking)'); if (g) g.onclick = () => pickedOpen(c);
    }
  } else {   // 누적 = ★평점 + PICK 2단 확인게이지(기존)
    el.querySelectorAll('.sc-star').forEach(s => s.onclick = () => rateCard(c, +s.dataset.n));
    const _pk = el.querySelector('.sc-pick');
    if (!st.picked) {
      const _lbl = _pk.querySelector('span'); let _armed = false, _armT;
      _pk.onclick = () => {
        if (_pk.classList.contains('firing')) return;
        if (!_armed) { _armed = true; _pk.classList.add('arm'); _lbl.textContent = '재확인';
          clearTimeout(_armT); _armT = setTimeout(() => { _armed = false; _pk.classList.remove('arm'); _lbl.textContent = 'PICK'; }, 3500); return; }
        clearTimeout(_armT); _pk.classList.remove('arm'); _pk.classList.add('firing'); _lbl.textContent = '전송';
        setTimeout(() => pickCard(c), 720);
      };
    }
  }
  const mi = el.querySelector('.sc-memo-in');
  if (mi) {
    mi.value = st.memo || '';
    const saveMemo = () => {
      const v = mi.value.trim().slice(0, 200);
      const cur = ratingsAll()[candId(c)] || {};
      if (v === (cur.memo || '')) return;
      saveRating(candId(c), { memo: v });
      postRate({ id: candId(c), url: c.url || '', title: c.title || '', score: cur.score || 0, picked: !!cur.picked, memo: v });
    };
    mi.onblur = saveMemo;
    mi.onkeydown = e => { if (e.key === 'Enter') { e.preventDefault(); mi.blur(); } };
  }
  return el;
}
const _rateTimers = {};
function rateCard(c, n) {
  const id = candId(c); ratedKeep.add(id);
  // 진행 중 메모 입력 보존 — 별점 변경 재렌더로 텍스트·포커스·커서 유실 방지
  const af = document.activeElement, editing = (af && af.classList && af.classList.contains('sc-memo-in')) ? af : null;
  const mid = editing ? editing.dataset.id : null, mpos = editing ? (editing.selectionStart != null ? editing.selectionStart : (editing.value || '').length) : 0;
  if (editing) saveRating(mid, { memo: (editing.value || '').trim().slice(0, 200) });
  saveRating(id, { score: n }); renderScrap();   // ratedKeep = 이번 세션 유지(다음 갱신 때 제외)
  if (mid) { const mi2 = [...document.querySelectorAll('.sc-memo-in')].find(x => x.dataset.id === mid); if (mi2) { mi2.focus({ preventScroll: true }); try { mi2.setSelectionRange(mpos, mpos); } catch {} } }
  clearTimeout(_rateTimers[id]);   // 빠른 재평가(3→4→5)는 묶어 1회만 발사(커밋 스팸 방지)
  _rateTimers[id] = setTimeout(() => { const s = ratingsAll()[id] || {}; postRate({ id, url: c.url || '', title: c.title || '', score: s.score || n, picked: !!s.picked, memo: s.memo || '' }); }, 1000);
}
async function pickCard(c) {
  const id = candId(c); const cur = ratingsAll()[id] || {};
  if (cur.picked) return;                                  // 한 번만(중복 발사 방지)
  if (!c.url) { alert('원문 url이 없어 큐레이션 불가'); return; }
  saveRating(id, { picked: true, pickCross: c.cross || 0 }); renderScrap();   // 낙관적 표시 + 픽 시점 cross 스냅(증분 표시용)
  clearTimeout(_rateTimers[id]);
  postRate({ id, url: c.url, title: c.title || '', score: cur.score || 0, picked: true });   // 관심도 원장(데이터)
  try {   // 큐레이션 발동 = pending 적재 → 분석 → 카드(피드에 등장). 실패 시 되돌려 재시도 가능.
    // alt = 같은 사건 타매체(cluster_members) — 분석기 대체fetch + 썸네일 검색이미지 '유사' 보강 소스(applyTriage와 동일·주 픽 경로 누락 복구)
    const alt = [...new Set((c.cluster_members || []).map(_normU))].filter(u => u && u !== _normU(c.url)).slice(0, 8);
    const r = await fetch('api/pick', { method: 'POST', headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ url: c.url, title: c.title || '', alt }) });
    const j = await r.json().catch(() => ({}));
    if (!r.ok) throw new Error(j.error || ('HTTP ' + r.status));
  } catch (e) {
    saveRating(id, { picked: false }); renderScrap();
    postRate({ id, url: c.url, title: c.title || '', score: cur.score || 0, picked: false });   // 서버 원장도 롤백(로컬만 되돌리면 영구 불일치)
    alert('큐레이션 발동 실패 — 다시 시도해줘\n' + (e.message || e));
  }
}
// 👎 관심없음 = 별점 1점 미만(취향 부정신호) → dismissed 기록(이유=메모) → 풀에서 제외. DB(ratings.jsonl)에 누적.
// 카드 자연스럽게 접혀 사라짐(인박스 클리어 공용 — 👎·pass·pick 후).
function collapseCard(el) {
  if (!el) { renderScrap(); return; }
  el.style.height = el.offsetHeight + 'px'; el.style.overflow = 'hidden';
  el.getBoundingClientRect();
  el.classList.add('removing');
  el.style.height = '0'; el.style.marginTop = '0'; el.style.marginBottom = '0';
  el.style.paddingTop = '0'; el.style.paddingBottom = '0';
  let done = false; const fin = () => { if (done) return; done = true; el.remove(); };
  el.addEventListener('transitionend', fin, { once: true }); setTimeout(fin, 440);
}
// ── 트리아지(신규·누적) = [👎][PASS][PICK] + 무조건 사유(객관식) 선택 ──
// 사유 = 나중 알고리즘이 '왜 제꼈나'를 정량화할 지표. 의미 기준 정본 = docs/curation-rubric.md.
const TRIAGE = {
  down: { q: '관심 없음 — 왜?', reasons: [
    { k: '국지적', d: '국지적·개별·특정 회사 사안 = 범국민적 공감 어려움' },
    { k: '기업·정책', d: '기업·문화계 영리목적·정부 정책 보도자료 / 특정 주식 보도 = 콘텐츠 부적합(전국민 관심↓)' },
    { k: '가치없음', d: '콘텐츠화 할 가치가 없는 기사' },
    { k: '직접입력', input: true } ] },
  pass: { q: '패스 — 왜?', reasons: [
    { k: '애매함', d: '조금 이목은 끌 수 있어도 콘텐츠로 다룰 가치는 그닥·애매(옛 별로 통합)' },
    { k: '늦은 보도', d: '이미 시간 지나 뒤늦게 올라온 보도 — 시의성·속보성 없어 콘텐츠 부적합' },
    { k: '기타', input: true } ] },
  pick: { q: 'PICK — 왜?', reasons: [
    { k: '속보/사건', d: '빠르게 전달하면 모두가 감정적 격동을 느낄 것이라 판단' },
    { k: '토픽/논란', d: '범국민적 토픽·주제라고 판단' },
    { k: '대세픽', d: '국민적 인기 — 지금 다수가 주목하는 대세 흐름(트렌드·화제성)' },
    { k: '지식', d: '효과적 콘텐츠면 팔로워가 유용하다고 느낄 것이라 판단' },
    { k: '직접입력', input: true } ] },
};
function askReason(act, c, el) {
  if (!el) return;
  const ex = el.querySelector('.sc-rsn');   // 이미 열린 사유 패널: 같은 액션=토글 닫기 / 다른 액션=갈아끼움(전환 버그 수정)
  if (ex) { const same = ex.dataset.act === act; ex.remove(); if (same) return; }
  const A = TRIAGE[act];
  const p = document.createElement('div'); p.className = 'sc-rsn rsn-' + act; p.dataset.act = act;
  p.innerHTML = `<div class="sc-rsn-q">${A.q}</div>
    <div class="sc-rsn-chips">${A.reasons.map(r => `<button type="button" class="sc-rsn-c${r.input ? ' inp' : ''}" data-k="${esc(r.k)}"${r.d ? ` title="${esc(r.d)}"` : ''}>${esc(r.k)}</button>`).join('')}</div>
    <div class="sc-rsn-iw" hidden><input class="sc-rsn-in" type="text" maxlength="200" placeholder="이유 한 줄"></div>
    <button type="button" class="sc-rsn-x" aria-label="취소">✕</button>`;
  el.appendChild(p);
  const iw = p.querySelector('.sc-rsn-iw'), input = p.querySelector('.sc-rsn-in');
  p.querySelector('.sc-rsn-x').onclick = () => p.remove();
  p.querySelectorAll('.sc-rsn-c').forEach(b => b.onclick = () => {
    const k = b.dataset.k;
    if (b.classList.contains('inp')) {
      iw.hidden = false; setTimeout(() => input.focus({ preventScroll: true }), 30);
      input.onkeydown = e => { if (e.key === 'Enter') { e.preventDefault(); applyTriage(act, c, el, k, input.value); } else if (e.key === 'Escape') { e.preventDefault(); p.remove(); } };
      return;
    }
    applyTriage(act, c, el, k, '');
  });
}
// 트리아지 확정 — action(down/pass/pick)+reason 기록(DB 누적·정량화) → 인박스서 접힘. pick은 큐레이션 디스패치.
function applyTriage(act, c, el, reason, text) {
  if (el) { if (el.dataset.fired) return; el.dataset.fired = '1'; }   // 사유칩 연타 = 중복 발사(api/pick 2건·중복 적재) 차단
  const id = candId(c); const memo = (text || '').trim();
  const patch = { action: act, reason }; if (memo) patch.memo = memo;
  if (act === 'down') patch.dismissed = true;
  if (act === 'pick') { patch.picked = true; patch.pickedAt = Date.now(); }
  saveRating(id, patch);
  const cur = ratingsAll()[id] || {};
  postRate({ id, url: c.url || '', title: c.title || '', score: cur.score || 0, picked: !!cur.picked, memo: cur.memo || memo, dismissed: !!cur.dismissed, action: act, reason });
  if (act === 'pick' && c.url) {   // PICK = 큐레이션 발동(pending→분석→카드)
    // alt = 같은 사건 다른 매체 url(cluster_members) — 원매체가 막힌 매체(403)면 분석기가 접근 가능한
    // 대체매체로 본문 확보(item3). 원 url 제외·정규화 중복제거·최대 8개(dispatch 페이로드 절제).
    const alt = [...new Set((c.cluster_members || []).map(_normU))].filter(u => u && u !== _normU(c.url)).slice(0, 8);
    fetch('api/pick', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ url: c.url, title: c.title || '', alt }) }).catch(() => {});
  }
  if (act === 'pick') {   // 픽 = 사라지지 말고 제자리서 'Picking…'(분석 중) → 피드 진입 시 PICKED
    if (el) { el.classList.add('picked'); const rsn = el.querySelector('.sc-rsn'); if (rsn) rsn.remove(); const bot = el.querySelector('.sc-bot'); if (bot) bot.innerHTML = '<div class="sc-got picking" aria-label="분석 중"><span>Picking…</span></div>'; }
    pollPicking();   // 분석 완료(피드 등장)까지 폴 → 떴으면 PICKED, 실패면 분석 실패
  } else {
    collapseCard(el);   // down/pass = 접혀 사라짐
  }
  detectBreaking();   // 리액션(픽/패스/관심없음) = 긴급이면 프로필 점등 재평가(처리분은 breakingNow서 빠짐)
}
function postRate(p) { fetch('api/rate', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(p) }).catch(() => {}); }
// 확인(ack) 토글 — '이 기사 봤음'을 수동 표시(신규와 구분·흐려짐 · 로컬 localStorage). 결정(PICK)은 아님. ⚠️ 긴급 배지는 안 끔(유지·운영자 260620) · 핀 해제는 유지.
function toggleAck(c, el) {
  const id = candId(c); const acked = !((ratingsAll()[id] || {}).acked);
  saveRating(id, { acked });
  if (el) { el.classList.toggle('acked', acked); const b = el.querySelector('.sc-tg.ack'); if (b) b.classList.toggle('on', acked);
    if (acked && scRT[id]) scRT[id].acked = true;   // 정렬 스냅샷도 갱신(다음 핀 재평가서 즉시 반영 · 핀 해제는 유지)
  }
  detectBreaking();   // 확인✓ = 토스트 재평가(breakingNow서 acked 제외 → 재알림 차단). 긴급 배지·프로필은 안 건드림(점등 폐지·배지 유지).
}
// ── 탭 전환 (피드 · 스크랩 · SNS) ── 기본=피드. FAB(제작도구)·X는 외부/팝업이라 여기서 안 다룸.
// 탭별 공유 헤더바(주제+짧은 설명) — 펫이 그 위로 걷는 상단바. 설명은 임시(짧게 · 나중 수정).
const VIEWHEAD = {
  feed:  ['뉴스 요약', '들어온 기사를 요약·시사점으로 한눈에.'],
  scrap: ['스크랩 큐레이션 - 레거시', 'RSS로 모은 후보 — 관심도 ★로 큐레이션.'],
  sns:   ['스크랩 큐레이션 - SNS', '소셜 공유용으로 큐레이션한 짧은 카드.'],
};
function setViewhead(tab) {
  const [t, s] = VIEWHEAD[tab] || VIEWHEAD.feed;
  const vt = $('#vhTitle'), vs = $('#vhSub');
  if (vt) vt.textContent = t;
  if (vs) vs.textContent = s;
}
function showTab(tab) {
  CURTAB = tab;
  closeFailMenu();   // 탭 전환 시 Failed 칩 컨텍스트 메뉴도 닫음(토스트→showTab 직행 경로는 closeOverlays 안 거침)
  const fb = $('.filterbar'), wp = $('.wrap'), sv = $('#scrapview'), snv = $('#snsview');
  if (fb) fb.hidden = (tab !== 'feed');
  if (wp) wp.hidden = (tab !== 'feed');
  if (sv) sv.hidden = (tab !== 'scrap');
  if (snv) snv.hidden = (tab !== 'sns');
  // 배너(2겹)·프로필 컬러 = body.tab-scrap가 CSS로 구동(스크랩=앰버 디졸브 / 그 외=초록). SNS 전용 배너는 추후.
  document.body.classList.toggle('tab-scrap', tab === 'scrap');
  document.body.dataset.tab = tab;   // 카드만 토글 = 피드 탭에서만 표시(CSS body[data-tab=feed])
  try { localStorage.setItem('nomute_tab', tab); } catch {}   // 새로고침 복원용

  setViewhead(tab);
  $('#bnav').querySelectorAll('.bnav-i[data-tab]').forEach(b => b.classList.toggle('active', b.dataset.tab === tab));
  if (tab === 'scrap') { loadCandidates(); loadPickFails(); markPickFailSeen(); markBreakingSeen(); }   // 탭 진입 = 매번 강제 재요청(최신). 수집함 열면 현재 긴급 = 본 것 처리 → 토스트 재알림 차단(프로필 확인 루틴 폐지 후 de-dup은 여기 · 운영자 260620).
  else if (tab === 'sns') loadSocial();
  else load();   // 피드 = 기사 재요청(load 내부서 render)
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// 소스(커뮤니티) 정치 성향 색 틴트 — 통념·근사(운영자 요청 '조금'). 진보=파랑·보수=빨강·중도/취미/미분류=중립(시안).
// ⚠️ 성향은 논쟁적·근사치 → 조정 가능. 미등록 소스는 중립 유지.
const SOC_LEAN_MAP = { '클리앙': 'l', '보배드림': 'l', '오유': 'l', '82쿡': 'l', '더쿠': 'l', '인스티즈': 'l', '네이트판': 'l', '루리웹': 'l', '에펨코리아': 'r', '디시': 'r', '일베': 'r' };
const socLean = s => { const v = SOC_LEAN_MAP[s]; return v === 'l' ? 'lean-l' : v === 'r' ? 'lean-r' : ''; };
// SNS 뷰 — 소셜 버스트(커뮤니티 비정치 공론화 이슈) 레인. social_burst.py → social_candidates.json 렌더.
// 행 = {title,url,sources[],source_count,posts,age_h,burst}. 시안 테마. 정본 설계 = docs/social-burst.md §35.3.
function renderSns() {
  const list = $('#snsList'); if (!list) return;
  if (!SOCIAL_LOADED) { list.innerHTML = `<div class="empty">불러오는 중…</div>`; return; }
  const q = ($('#q') ? $('#q').value : '').trim().toLowerCase();
  const rows = q ? SOCIAL.filter(r => ((r.title || '') + ' ' + (r.sources || []).join(' ')).toLowerCase().includes(q)) : SOCIAL;
  if (!rows.length) { list.innerHTML = `<div class="empty">${q ? '검색 결과 없음' : '소셜 스캔 대기 — 커뮤니티 공론화 이슈(갑질·학폭·이웃분쟁·황당사건 등 비정치)가 교차소스로 잡히면 여기 떠.'}</div>`; return; }
  list.innerHTML = '';
  rows.forEach((r, i) => {
    const el = document.createElement('a');
    el.className = 'soc-item';
    el.href = r.url || '#'; el.target = '_blank'; el.rel = 'noopener';
    el.style.animationDelay = Math.min(i, 14) * 32 + 'ms';
    const ago = relAge(r.age_h);
    el.innerHTML = `<div class="soc-top"><span class="soc-burst">🔥 ${(+r.burst || 0).toFixed(1)}</span><span class="soc-src">⛓ ${r.source_count || 0}소스</span>${(r.posts > r.source_count) ? `<span class="soc-posts">글 ${r.posts}</span>` : ''}${ago ? `<span class="soc-age">${esc(ago)}</span>` : ''}</div>
      <div class="soc-title"></div>
      <div class="soc-srcs">${(r.sources || []).map(s => '<span class="soc-chip ' + socLean(s) + '"></span>').join('')}</div>`;
    el.querySelector('.soc-title').textContent = r.title || '';
    const chips = el.querySelectorAll('.soc-chip'); (r.sources || []).forEach((s, k) => { if (chips[k]) chips[k].textContent = s; });
    list.appendChild(el);
  });
}

// ── ✨ 요약 요청(멀티모달 입력) — 자연어+캡처 → 큐레이션 요청 ──
const askdlg = $('#askdlg');
let askImages = [];   // 압축 이미지 {dataUrl, kb}
const ASK_MAX = 8;
let _askResolveId = null;   // 실패 픽 복구로 열렸으면 그 candId — 전송 성공 시 복구표시
function openAsk(opts) {
  opts = opts || {};
  bpop.hidden = true; linkpop.hidden = true; $('#askStatus').textContent = '';
  _askResolveId = opts.resolveId || null;
  if (opts.prefill != null) $('#askText').value = opts.prefill;   // 실패 복구 = 제목·URL 프리필(전문은 사용자가 붙임)
  updateAskClip(); askdlg.showModal();
  setTimeout(() => { const ta = $('#askText'); ta.focus(); if (opts.prefill != null) { const i = ta.value.length; try { ta.setSelectionRange(i, i); } catch {} } }, 60);
}
$('#askmenu').addEventListener('click', e => { e.preventDefault(); openAsk(); });
// 제작 도구(썸네일·릴스·영상) = + 메뉴 항목 클릭 → 새 페이지 대신 뷰어 위 모달(iframe)로 등장. href는 폴백.
const tooldlg = $('#tooldlg');
// 폰/브라우저 뒤로가기 = 도구 닫고 메인으로(앱 이탈 차단). 열 때 히스토리 1칸 푸시 → 백버튼이 그 칸을 pop.
let toolPopHandled = false;   // popstate(백버튼)로 닫혔는지 — close 핸들러의 히스토리 정리 분기
window.addEventListener('popstate', () => { if (tooldlg.open) { toolPopHandled = true; tooldlg.close(); } });
// 도구 모달: showModal()을 src보다 먼저(iframe가 표시된 상태서 로드 → 애니 정상·빈화면 차단) · 배경 스크롤 락 · 열 때 #toolX 포커스
function openTool(src, title) {
  const wasOpen = tooldlg.open;
  $('#toolTitle').textContent = title || '제작 도구';
  $('#toolframe').src = src;   // showModal 전에 로드 시작 → 모달 뜰 때 콘텐츠 준비(프레임 따로·콘텐츠 따로 2단 깜빡임 완화)
  closeOverlays(); document.documentElement.style.overflow = 'hidden';
  tooldlg.showModal(); setTimeout(() => $('#toolX').focus(), 0);
  if (!wasOpen) history.pushState({ tool: true }, '');   // 백버튼 = 메인 복귀(앱 밖으로 안 나감)
}
$('#bpop').addEventListener('click', e => { const a = e.target.closest('a[data-tool]'); if (a) { e.preventDefault(); openTool(a.getAttribute('href'), a.textContent.trim()); } });
$('#toolX').addEventListener('click', () => tooldlg.close());
tooldlg.addEventListener('close', () => { $('#toolframe').src = 'about:blank'; if (!document.querySelector('dialog[open]')) document.documentElement.style.overflow = ''; const f = $('#toolfab'); if (f) f.focus();
  if (toolPopHandled) toolPopHandled = false;                                   // 백버튼으로 닫힘 = 히스토리 이미 pop됨
  else if (history.state && history.state.tool) history.back(); });             // X·백드롭·ESC로 닫힘 = 푸시한 칸 정리   // iframe 정지 + 스크롤락 해제(중첩 가드) + 트리거 포커스 복귀
tooldlg.addEventListener('click', e => { if (e.target === tooldlg) tooldlg.close(); });   // 백드롭 클릭 닫기
$('#toolframe').addEventListener('load', () => { try { const d = $('#toolframe').contentDocument; if (d) d.addEventListener('keydown', e => { if (e.key === 'Escape') { e.preventDefault(); tooldlg.close(); } }); } catch (_) {} });   // iframe 포커스 시 ESC 안 먹는 문제 → 같은 출처 contentDocument에 ESC 브릿지
$('#askX').addEventListener('click', () => askdlg.close());
askdlg.addEventListener('click', e => { if (e.target === askdlg) askdlg.close(); });   // 바깥(백드롭) 클릭 닫기
// 복사·붙여넣기 = 캐러셀 .sbtn 계승 컨텍스트 1버튼: 비었으면 붙여넣기 / 문자열 있으면 복사. (CLAUDE.md 플랫폼 공통)
function updateAskClip() { const b = $('#askClip'); if (!b) return; const has = $('#askText').value.trim().length > 0; b.innerHTML = has ? COPY_SVG : PASTE_SVG; const lbl = has ? '복사' : '붙여넣기'; b.setAttribute('aria-label', lbl); b.title = lbl; }
$('#askText').addEventListener('input', updateAskClip);
$('#askClip').addEventListener('click', async () => {
  const ta = $('#askText'), b = $('#askClip');
  if (ta.value.trim()) {                                  // 문자열 있음 = 복사(체크 플래시)
    try { await navigator.clipboard.writeText(ta.value); b.innerHTML = CHECK_SVG; b.classList.add('ok'); $('#askStatus').textContent = '복사됨'; setTimeout(() => { b.classList.remove('ok'); updateAskClip(); }, 1200); } catch { $('#askStatus').textContent = '복사 실패'; }
  } else {                                                 // 비었음 = 붙여넣기
    try { const t = await navigator.clipboard.readText(); ta.value = t; ta.focus(); updateAskClip(); } catch { $('#askStatus').textContent = '클립보드 권한 막힘 — 직접 붙여넣어'; }
  }
});
$('#askFile').addEventListener('change', e => { addAskImages(e.target.files); e.target.value = ''; });
$('#askText').addEventListener('paste', e => { const imgs = [...(e.clipboardData?.items || [])].filter(i => i.type.startsWith('image/')).map(i => i.getAsFile()).filter(Boolean); if (imgs.length) { e.preventDefault(); addAskImages(imgs); } });
async function addAskImages(files) {
  for (const f of [...files]) {
    if (!f.type || !f.type.startsWith('image/')) continue;
    if (askImages.length >= ASK_MAX) { $('#askStatus').textContent = `이미지는 최대 ${ASK_MAX}장`; break; }
    try { askImages.push(await compressImg(f)); } catch {}
  }
  renderAskImgs();
}
async function compressImg(file, max = 1280, q = 0.6) {   // 토큰 절약: 긴 변 1280px·JPEG로 압축(고품질 해석 불필요)
  const url = URL.createObjectURL(file);
  const img = await new Promise((res, rej) => { const i = new Image(); i.onload = () => res(i); i.onerror = rej; i.src = url; });
  let w = img.width, h = img.height; const s = Math.max(w, h);
  if (s > max) { w = Math.round(w * max / s); h = Math.round(h * max / s); }
  const cv = document.createElement('canvas'); cv.width = w; cv.height = h; cv.getContext('2d').drawImage(img, 0, 0, w, h);
  URL.revokeObjectURL(url);
  const blob = await new Promise(r => cv.toBlob(r, 'image/jpeg', q));
  const dataUrl = await new Promise(r => { const fr = new FileReader(); fr.onload = () => r(fr.result); fr.readAsDataURL(blob); });
  return { dataUrl, kb: Math.round(blob.size / 1024) };
}
function renderAskImgs() {
  const host = $('#askImgs');
  host.innerHTML = askImages.map((im, i) => `<div class="askimg"><img src="${im.dataUrl}" alt=""><button class="askimg-x" type="button" data-i="${i}" aria-label="제거">✕</button><span class="askimg-kb">${im.kb}KB</span></div>`).join('');
  host.querySelectorAll('.askimg-x').forEach(b => b.onclick = () => { askImages.splice(+b.dataset.i, 1); renderAskImgs(); });
}
$('#askSend').addEventListener('click', async () => {
  const text = $('#askText').value.trim();
