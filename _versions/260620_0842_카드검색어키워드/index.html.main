  const btn = $('#askSend'); btn.disabled = true; $('#askStatus').textContent = '보내는 중…';
  try {
    const r = await fetch('api/submit', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ text, images: askImages.map(im => im.dataUrl) }) });
    const d = await r.json().catch(() => ({}));
    if (r.ok && d.ok) { $('#askStatus').textContent = '✅ 요청됨 — 큐레이션해서 뉴스요약에 올라와'; $('#askText').value = ''; updateAskClip(); askImages = []; renderAskImgs();
      if (_askResolveId) { pfAddResolved(_askResolveId); _askResolveId = null; markPickFailSeen(); if (CURTAB === 'scrap') renderScrap(); }   // 실패 픽 복구 전송 완료 → '분석 실패' 표시·링 소거
      setTimeout(() => { askdlg.close(); btn.disabled = false; }, 1600); return; }   // 성공 = 닫힐 때까지 disabled 유지(1.6s 내 중복전송 차단)
    else { $('#askStatus').textContent = '❌ ' + (d.error || `서버 ${r.status}`); }
  } catch { $('#askStatus').textContent = '❌ 전송 실패 (백엔드 배선 전이면 예상된 동작)'; }
  btn.disabled = false;
});
// ── Failed 칩 컨텍스트 메뉴(실패 사유·내용 입력) + 전문 직접 입력 모달 ──
$('#failmenu').addEventListener('click', e => {
  const it = e.target.closest('.failmenu-it'); if (!it) return;
  e.stopPropagation();
  const c = _failMenuC; closeFailMenu();
  if (!c) return;
  if (it.dataset.act === 'diag') failDownload(c);
  else if (it.dataset.act === 'paste') openPaste(c);
});
document.addEventListener('click', e => { const m = $('#failmenu'); if (m && !m.hidden && !m.contains(e.target)) closeFailMenu(); });
window.addEventListener('scroll', closeFailMenu, { capture: true, passive: true });   // 스크롤=위치 stale → 닫기(캡처=스크롤 컨테이너 포함·passive=메인 스크롤 성능 유지)
window.addEventListener('resize', closeFailMenu);
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeFailMenu(); });
// 전문 직접 입력 모달 — askdlg UIUX 계승(.sbtn 클립 컨텍스트 1버튼·X·전송). 전송=api/pick body 경로(재분석) → Failed→Picking.
$('#pasteX').addEventListener('click', () => pastedlg.close());
pastedlg.addEventListener('click', e => { if (e.target === pastedlg) pastedlg.close(); });   // 백드롭 닫기
function updatePasteClip() { const b = $('#pasteClip'); if (!b) return; const has = $('#pasteText').value.trim().length > 0; b.innerHTML = has ? COPY_SVG : PASTE_SVG; const lbl = has ? '복사' : '붙여넣기'; b.setAttribute('aria-label', lbl); b.title = lbl; }
$('#pasteText').addEventListener('input', updatePasteClip);
$('#pasteClip').addEventListener('click', async () => {
  const ta = $('#pasteText'), b = $('#pasteClip');
  if (ta.value.trim()) {
    try { await navigator.clipboard.writeText(ta.value); b.innerHTML = CHECK_SVG; b.classList.add('ok'); $('#pasteStatus').textContent = '복사됨'; setTimeout(() => { b.classList.remove('ok'); updatePasteClip(); }, 1200); } catch { $('#pasteStatus').textContent = '복사 실패'; }
  } else {
    try { const t = await navigator.clipboard.readText(); ta.value = t; ta.focus(); updatePasteClip(); } catch { $('#pasteStatus').textContent = '클립보드 권한 막힘 — 입력칸 길게눌러 붙여넣기'; }
  }
});
$('#pasteSend').addEventListener('click', async () => {
  const c = _pasteC; if (!c || !c.url) { $('#pasteStatus').textContent = '대상 정보 없음 — 메뉴를 다시 열어줘'; return; }
  const text = $('#pasteText').value.trim();
  if (text.length < 30) { $('#pasteStatus').textContent = '기사 전문을 붙여넣어줘 (너무 짧음)'; return; }
  const btn = $('#pasteSend'); btn.disabled = true; $('#pasteStatus').textContent = '보내는 중…';
  const alt = [...new Set((c.cluster_members || []).map(_normU))].filter(u => u && u !== _normU(c.url)).slice(0, 8);   // 대체 fetch 후보(원매체 403 우회 보조)
  try {
    const r = await fetch('api/pick', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ url: c.url, title: c.title || '', alt, body: text }) });
    const d = await r.json().catch(() => ({}));
    if (r.ok && d.ok) {
      $('#pasteStatus').textContent = '✅ 재분석 시작 — 곧 Picking…으로, 완료되면 PICKED';
      const id = candId(c);
      saveRating(id, { picked: true, pickedAt: Date.now() });   // pickedAt 리셋 → pickTimedOut 해제(새 분석창)
      pfAddResub(id);                                            // pfailHas 억제 → Failed→Picking(임시창)
      markPickFailSeen();                                        // 실패 알림 링/토스트 소거
      setTimeout(() => { pastedlg.close(); btn.disabled = false; if (CURTAB === 'scrap') renderScrap(); pollPicking(); }, 1300);
      return;
    }
    $('#pasteStatus').textContent = '❌ ' + (d.error || `서버 ${r.status}`);
  } catch { $('#pasteStatus').textContent = '❌ 전송 실패'; }
  btn.disabled = false;
});
// ── 요약 수정 배선 — FAB(콘텐츠 초안~시사점 구간 점등)→팝업(좌측 펼침·즉시 포커스) · 클립(.sbtn 캐러셀) · 전송(1차 재확인→2차 PICK 게이지 발사) ──
let revConfirmT = null;
function resetRevSend() {   // 발사 버튼 원복(재확인 해제)
  clearTimeout(revConfirmT);
  const btn = $('#revSend'); if (!btn) return;
  btn.classList.remove('confirm');
  const lbl = btn.querySelector('span'); if (lbl) lbl.textContent = '수정 →';
}
let _revHintT;
function showReviseHint() {   // 잠금 FAB 클릭 시 은은한 '수정 중' 표식(1.3s 페이드 — 침묵 대신 피드백)
  const fab = $('#revFab'); if (!fab) return;
  fab.classList.add('hint');
  clearTimeout(_revHintT); _revHintT = setTimeout(() => fab.classList.remove('hint'), 1300);
}
function openRev() {
  if (!CUR) { return; }
  if (isRevising(CUR)) { showReviseHint(); return; }   // 진행 중(물결) 재수정 차단 — 경로 1: 연필 FAB 클릭 + 은은한 '수정 중' 힌트
  resetRevSend();
  $('#revStatus').textContent = ''; $('#revSend').classList.remove('firing'); $('#revSend').disabled = false;
  updateRevClip(); revdlg.showModal();
  $('#revFab').classList.remove('show');         // 팝업 열림 → FAB 숨김(닫히면 updateRevFab가 복원)
  setTimeout(() => $('#revText').focus(), 60);   // 열리자마자 커서 활성(askdlg 패턴)
}
function updateRevClip() {   // .sbtn 컨텍스트 1버튼: 비었으면 붙여넣기 / 문자열 있으면 복사(CLAUDE.md 플랫폼 공통)
  const b = $('#revClip'); if (!b) return;
  const has = $('#revText').value.trim().length > 0;
  b.innerHTML = has ? COPY_SVG : PASTE_SVG;
  const lbl = has ? '복사' : '붙여넣기'; b.setAttribute('aria-label', lbl); b.title = lbl;
}
// ── 요약 ⬇ HTML 다운로드 — 본문(#mdbody)을 '노뮤트 다크' 서식(글래스 카드)으로 항목별 복사 박스 단독 HTML 저장(공유용). 로고 임베드 · Pretendard는 CDN(폴백=시스템). ──
const NM_LOGO = 'data:image/png;base64,';
// 단독 HTML 안에서 돌 복사·맨위로 스크립트 — toString()으로 생성 파일에 그대로 박는다(이스케이프 회피). self-contained.
function _expCopy() {
  var CHECK = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width:15px;height:15px;display:block"><path d="M5 13l4 4L19 7"></path></svg>';
  function secText(box) {
    var out = [], h = box.querySelector('h2');
    if (h) out.push(h.textContent.trim());
    var body = box.querySelector('[data-body]') || box;
    if (body.tagName === 'PRE') { out.push(body.textContent.replace(/\s+$/, '')); return out.join('\n'); }
    Array.prototype.forEach.call(body.children, function (el) {
      var tag = el.tagName;
      if (tag === 'BUTTON') return;
      if (tag === 'UL' || tag === 'OL') {
        Array.prototype.forEach.call(el.querySelectorAll('li'), function (li) { out.push('• ' + li.textContent.trim().replace(/\s+/g, ' ')); });
      } else if (tag === 'PRE') { out.push(el.textContent.replace(/\s+$/, '')); }
      else { var t = el.textContent.trim().replace(/\s+/g, ' '); if (t) out.push(t); }
    });
    return out.join('\n');
  }
  function fullText() {
    var h1 = document.querySelector('h1'), parts = [h1 ? h1.textContent.trim() : '', ''];
    Array.prototype.forEach.call(document.querySelectorAll('[data-sec]'), function (b) { parts.push(secText(b), ''); });
    var s = document.querySelector('.src'), c = document.querySelector('.cr');
    if (s) parts.push(s.textContent.trim());
    if (c) parts.push(c.textContent.trim());
    return parts.join('\n');
  }
  function legacy(t) { var ta = document.createElement('textarea'); ta.value = t; document.body.appendChild(ta); ta.select(); var ok = false; try { ok = document.execCommand('copy'); } catch (e) {} ta.remove(); return ok; }
  function copyText(t) { if (navigator.clipboard && navigator.clipboard.writeText) return navigator.clipboard.writeText(t).then(function () { return true; }, function () { return legacy(t); }); return Promise.resolve(legacy(t)); }
  function flash(btn, label) { var orig = btn.innerHTML; btn.classList.add('ok'); btn.innerHTML = CHECK + (label ? '<span>완료</span>' : ''); setTimeout(function () { btn.classList.remove('ok'); btn.innerHTML = orig; }, 1300); }
  Array.prototype.forEach.call(document.querySelectorAll('[data-sec]'), function (box) {
    var btn = box.querySelector('.nm-secbtn'); if (!btn) return;
    btn.addEventListener('click', function () { copyText(secText(box)).then(function (ok) { if (ok) flash(btn, false); }); });
  });
  var all = document.querySelector('.nm-allbtn');
  if (all) all.addEventListener('click', function () { copyText(fullText()).then(function (ok) { if (ok) flash(all, true); }); });
  var top = document.querySelector('.nm-top');
  if (top) {
    var onScroll = function () { top.style.display = (window.scrollY || document.documentElement.scrollTop || 0) > 320 ? 'inline-flex' : 'none'; };
    window.addEventListener('scroll', onScroll, { passive: true }); onScroll();
    top.addEventListener('click', function () { window.scrollTo({ top: 0, behavior: 'smooth' }); });
  }
}
const SUMMARY_TPL = `<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8">
