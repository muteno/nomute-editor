const fastScore = c => ((c.burst || 0) + (c.breaking ? 5 : 0)) * Math.pow(0.5, Math.max(0, (Date.now() - scTs(c)) / 3600000) / FAST_HALF_H) * scFollow(c) * gradeW(c);
const JUNK_HEAD = /^\s*[\[\(](알림|공고|부고|부음|동정|인사|사진|포토|표|그래픽|운세|날씨|증시)[\]\)]/;   // 머리표 junk(뉴스 아님) — 양 컬럼서 제외. 조정 가능.
