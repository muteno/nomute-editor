  <a href="https://www.instagram.com/" target="_blank" rel="noopener">인스타그램 ↗</a>
</div>
<!-- 대기열 — 뉴스요약 버튼 길게 누르면. 분석 대기/중(pending/) 기사: 들어온시각 · 주요내용 · 전달방식 -->
<div class="bpop qpop" id="qpop" hidden>
  <div class="qh"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7.5V12l3 1.8"/></svg><b>대기열</b><button class="qh-rf" id="qpopRf" type="button" aria-label="새로고침" title="새로고침">↻</button><button class="qh-tr" id="qpopTrash" type="button" aria-label="내역 지우기" title="내역 지우기"><svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M8 6V4h8v2M6 6l1 14h10l1-14M10 10v7M14 10v7"/></svg></button><button class="qh-x" id="qpopX" type="button" aria-label="닫기" title="닫기">✕</button></div>
  <div class="qconfirm" id="qpopConfirm" hidden><span>내역을 정말 지우시겠습니까?</span><span class="qcf-btns"><button id="qcfYes" type="button">지우기</button><button id="qcfNo" type="button">취소</button></span></div>
  <div class="qlist" id="qpopList"></div>
  <div class="qpage" id="qpopPage"></div>
</div>
<!-- Failed 칩 컨텍스트 메뉴 — 길게 누르거나(480ms) 우클릭. 실패 사유(진단 MD 다운로드) · 내용 입력(전문 붙여넣기 재분석). .bpop 글래스 계승. -->
<div class="failmenu" id="failmenu" hidden role="menu" aria-label="실패 처리">
  <button class="failmenu-it" data-act="diag" type="button" role="menuitem"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M9 13h6M9 17h6"/></svg>실패 사유</button>
  <button class="failmenu-it" data-act="paste" type="button" role="menuitem"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>내용 입력</button>
</div>

<script>
const $ = s => document.querySelector(s);
let DATA = [], DATA_LOADED = false;   // DATA_LOADED = 피드 1회 로드 완료 — 새로고침 시 DATA 전 picked가 Picking…으로 깜빡 방지
let CUR = '';
let CUR_A = null;     // 현재 모달에 연 기사 객체(요약 PDF 다운로드에서 제목·출처 참조)
let CUR_STATE = '';   // 모달에 마지막 렌더한 카드 state — 안 바뀌면 재렌더 생략(펼친 프롬프트 보존)
marked.setOptions({ breaks:true });

// 민감 태그 — 에디터 본체(01 [민감 이슈 분기]) 통제어휘 5개. 전부 보호성 → 앰버 경고 틴트(.warn).
// (대분류·정치민감 태그는 본체에 없어 정합 위해 폐기 — 옛 큐 잔여 태그는 sensChips가 muted로 흘림.)
const SENS_PROTECT = ['#성범죄','#자살자해','#아동피해','#재난참사','#추모'];
// '카드만' 토글 = 이미지까지 실제 렌더된 기사만(text_done=프롬프트만은 제외 — 자동 생성이라 거의 전건이 포함돼버림)
const hasCardImage = a => a.cards && a.cards.state === 'done';
// R 필터 칩 상태 — 카테고리(OR)
const FILTERS = { cats: new Set(), breaking: false, issue: false };
const CHIP_CATS = ['사회','경제','문화','국제','테크'];
function renderChips() {
  const c = $('#chips'); if (!c) return;
  const none = !FILTERS.cats.size;
  let h = `<button class="chip${none ? ' on' : ''}" data-f="all">전체</button>`;
  h += `<button class="chip chip-brk${FILTERS.breaking ? ' on' : ''}" data-f="breaking">긴급</button>`;   // 긴급(breaking) 토글
  h += `<button class="chip chip-iss${FILTERS.issue ? ' on' : ''}" data-f="issue">이슈</button>`;   // 이슈(cross≥8) 토글
  h += CHIP_CATS.map(cat => `<button class="chip${FILTERS.cats.has(cat) ? ' on' : ''}" data-cat="${cat}">${cat}</button>`).join('');
  c.innerHTML = h;
}

async function load() {
  try {
    const r = await fetch('articles.json?_=' + Date.now());
    const j = await r.json();
    DATA = j.articles || [];
    dateHead(j.count || DATA.length);
  } catch(e) { DATA = []; const d = $('#dhCnt'); if (d) d.textContent = 'articles.json 없음'; }
  const _firstLoad = !DATA_LOADED; DATA_LOADED = true;   // 첫 로드 완료 표시
  render();
  if (_firstLoad && CURTAB === 'scrap' && SCRAP_LOADED) renderScrap();   // 첫 DATA 도착 = 수집함 1회 재렌더(pickInFeed 정확·Picking 깜빡 보정)
  if ($('#dlg').open && CUR) {
    const a = DATA.find(x => x.file === CUR);
    // 상태 안 바뀌면 재렌더 생략 — 60초 폴링이 펼쳐둔 프롬프트를 도로 접는 것 방지
    if (a && ((a.cards && a.cards.state) || '') !== CUR_STATE) { cardSec(a); feedSec(a); }
  }
  // 변경 발사 후 자동 제자리 교체 — Map에서 새 이미지(?v 갱신) 온 카드만 빼고 1회 재구성(스크롤 보존).
  if (REPENDING.size && $('#dlg').open && CUR) {
    const a = DATA.find(x => x.file === CUR), c = a && a.cards;
    if (c && c.images && c.images.length) {
      const model = buildFeedModel(a); let swapped = false;
      for (const [k, v] of [...REPENDING]) {
        if (v.file !== CUR) continue;
        const slot = model.findIndex(m => m.n === v.card);
        const newImg = slot >= 0 ? (c.images[slot] || null) : null;
        if (newImg && newImg !== v.oldImg) { REPENDING.delete(k); swapped = true; }
      }
      if (swapped) {   // 새 이미지(+버전) 반영 — 캐러셀 위치 보존하며 피드 재구성(고정 UI가 현재 사진에 재바인딩)
        const tr = $('#feedsec .feedtrack');
        const keepIdx = tr ? Math.round(tr.scrollLeft / (tr.clientWidth || 1)) : 0;
        feedSec(a, keepIdx);
      }
    }
  }
  // 썸네일 '다시 만들기' 완료 감지 — gen 이미지 시그니처(?v=) 바뀌면 썸네일섹션 교체(버튼도 idle 복귀)·6분 타임아웃
  if (THUMB_REDO.size && $('#dlg').open && CUR && THUMB_REDO.has(CUR)) {
    const a = DATA.find(x => x.file === CUR);
    if (a) {
      const rec = THUMB_REDO.get(CUR), sig = thumbGenSig(a);
      if ((sig && sig !== rec.oldSig) || Date.now() - rec.t0 > 360000) {
        THUMB_REDO.delete(CUR);
        const old = $('#mdbody .thumbsec'), fresh = thumbSec(a);
        if (old && fresh) old.replaceWith(fresh); else if (old) old.remove();
      }
    }
  }
  reapplyReshooting();   // 재렌더(상태변화·교체)로 사라진 대기 카드 잠금 배지 재적용
}

function render() {
  const q = $('#q').value.trim().toLowerCase();
  const cardonly = $('#cardonly').checked;
  const rows = DATA.filter(a =>
    (!cardonly || hasCardImage(a)) &&
    (!q || (a.title+a.media).toLowerCase().includes(q)) &&
    (!FILTERS.cats.size || FILTERS.cats.has(articleCat(a))) &&
    (!FILTERS.breaking || a.breaking || /속보/.test(a.title || '')) &&
    (!FILTERS.issue || a.issue));
  const list = $('#list');
  if (!rows.length) { list.innerHTML = '<div class="empty">결과 없음</div>'; return; }
  list.innerHTML = '';
  rows.forEach((a, i) => {
    const c = document.createElement('div'); c.className='card';
    const kind = brkIssueKind(a); if (kind) c.classList.add(kind);   // 긴급/이슈 → 카드 테두리 점등(.card.brk/.iss) + 우상단 배지
    const g = Number(a.rev) || 0;                    // 서버 회차(완료색·정본) — 1=노랑·2=파랑·0=초록기본
    if (g % 3) c.dataset.gen = (((g % 3) + 3) % 3);
    if (isRevising(a.file)) {                         // 진행 중(클라 임시) = 진행바 물결(현재→다음 색)
      c.classList.add('revving');
      c.style.setProperty('--rv-from', 'rgb(' + revColor(g) + ')');
      c.style.setProperty('--rv-to', 'rgb(' + revColor(g + 1) + ')');
    }
    c.style.animationDelay = Math.min(i, 14) * 32 + 'ms';   // 촤르륵 스태거
    c.innerHTML = `
      <div class="cardmain">
        <div class="cardtop"><span class="catslot"><b style="color:${CAT_COLOR[articleCat(a)] || 'var(--fg)'}">${esc(articleCat(a))}</b></span>${dateLine(a)}${kind ? `<span class="urg ${kind}">${kind === 'brk' ? '긴급' : '이슈'}</span>` : ''}</div>
        <div class="row1"><span class="t"></span></div>
        <div class="s"></div>
        <div class="kv">
          <div><span>매체</span>${a.media ? `<b>${esc(a.media)}</b>` : '<b class="senshyphen">—</b>'}</div>
          <div><span>편향</span>${a.bias ? biasText(a.bias) : '<b class="senshyphen">—</b>'}</div>
          <div class="typecol"><span>민감</span><div class="typewrap">${sensChips(a.tags)}</div></div>
        </div>
        <div class="botrow">
          ${progGauge(a)}
        </div>
      </div>`;
    c.querySelector('.t').textContent = a.title;
    c.querySelector('.s').textContent = a.summary || '';
    c.onclick = () => open(a);
    // 진행바 세그먼트 = N/M/T 모달 점프(nav 통합·A5). 본문 클릭(open)과 충돌 방지 stopPropagation.
    c.querySelectorAll('.prog .seg[data-j]').forEach(seg => {
      const go = e => { e.stopPropagation(); open(a); requestAnimationFrame(() => jumpTo(seg.dataset.j)); };
      seg.onclick = go;
      seg.onkeydown = e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); go(e); } };
    });
    list.appendChild(c);
  });
}

// 편향 게이지 바 — N/10 → 옐로→그린 채움, 좌우 무관(N/A) → 빗금
function gauge(b) {
  const m = /(\d+)\s*\/\s*10/.exec(b || '');
  if (m) return `<div class="gauge"><i style="width:${Math.min(100, +m[1]*10)}%"></i></div>`;
  return `<div class="gauge na"></div>`;
}

// ── 카드 셀 하단 헬퍼들(#4~#7) ──
// (NMT 레일 제거 — 진행바 세그먼트가 N/M/T 점프 겸함. A5)
// 민감 태그 → 개별 칩. "#성범죄 #자살자해" 공백 split. "해당 없음"/빈값이면 muted '—'.
// 본체 5개(SENS_PROTECT)=앰버 경고 틴트(.warn). 목록 외(옛 큐 잔여 태그)=기본 muted.
function sensChips(tags) {
  if (!tags || tags === '해당 없음') return '<b class="senshyphen">—</b>';
  const arr = tags.split(/\s+/).filter(Boolean);
  if (!arr.length) return '<b class="senshyphen">—</b>';
  return arr.map(t => {
    const warn = SENS_PROTECT.includes(t) ? ' warn' : '';
    return `<span class="tagchip${warn}">${esc(t)}</span>`;
  }).join('');
}
// 진행 스텝퍼 B안 — 요약·프롬프트·카드 3세그먼트. 클릭 = N/M/T 모달 점프(nav 통합·A5). 기존 cards.state만.
function progGauge(a) {
  const st = (a.cards && a.cards.state) || '';
  const segs = [['요약','n'], ['프롬프트','m'], ['카드','t']];
  // 18분 초과 미완 = 멈춤 → 펄스 정지(무한 회전 방지·시간 기반 실패 로직).
  const up = a.cards && a.cards.updated;
  const stuck = up && (Date.now() - Date.parse(up)) / 60000 > 18;
  const hasMd = !!(a.cards && a.cards.md);   // 프롬프트(텍스트)까지 갔는지 → 실패 표식 위치 판정
  let done = 1, busy = false, fail = false;   // done=완료 세그먼트 수(요약은 큐 전건 완료)
  if (st === 'done') done = 3;
  // 멈춤(stuck)이면 '진행되다 깨짐' → 펄스 대신 그 세그먼트에 실패 표식(노랑 빗금·빨강 라벨), 재시도는 cardSec 버튼.
  else if (st === 'fired_partial') { done = 2; if (stuck) fail = true; else busy = true; }   // 카드 발사·이미지 대기
  else if (st === 'text_done') done = 2;                        // 프롬프트까지·카드 대기
  else if (st === 'generating') { if (stuck) fail = true; else busy = true; }   // 카드 프롬프팅 중
  else if (st === 'failed') { fail = true; if (hasMd) done = 2; }   // 텍스트 있으면 카드 단계 실패(seg 카드)
  // 실패 이력(error.log 잔존) = 한 번이라도 깨진 흔적 → 해당 단계에 영속 흉터(scar). 재시도·성공해도 유지.
  const scarSeg = (a.cards && a.cards.failedOnce) ? (hasMd ? 2 : 1) : -1;
  const aria = { n:'인스타 요약으로 이동', m:'카드 프롬프트로 이동', t:'카드 이미지로 이동' };
  const html = segs.map(([lb, j], i) => {
    let cls = '';
    if (i < done) cls = ' done';
    else if (i === done && busy) cls = ' cur';
    else if (i === done && fail) cls = ' fail';
    if (i === scarSeg) cls += ' scar';
    return `<div class="seg${cls}" data-j="${j}" role="button" tabindex="0" aria-label="${aria[j]}"><span class="sl">${lb}</span><span class="bar"></span></div>`;
  }).join('');
  return `<div class="prog">${html}</div>`;
}
// #1 보도일 — "M/D (요일)" + 시각(time:HH:MM이면 뒤에 붙임). 박스 없이 텍스트, 카드 맨 위.
function repDate(date) {
  const m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(date || '');
  if (!m) return esc(date || '');
  const W = ['일','월','화','수','목','금','토'];
  const d = new Date(+m[1], +m[2] - 1, +m[3]);
  return `${+m[2]}/${+m[3]} (${W[d.getDay()]})`;
}
// #1 보도일 + 시각 — a.time이 HH:MM 형식일 때만 ' HH:MM' 붙임(아니면 날짜만). 6/14 (일) 11:00 꼴.
function repDateTime(a) {
  const base = repDate(a.date);
  const t = (a.time || '').trim();
  return /^\d{1,2}:\d{2}$/.test(t) ? `${base} ${esc(t)}` : base;
}
// IN(적재) 날짜 — 파일명 YYMMDD-HHMM 파싱. WRITE는 repDateTime(a). (B)
function inDateTime(a) {
  const m = /^(\d{2})(\d{2})(\d{2})-(\d{2})(\d{2})/.exec(a.file || '');
  if (!m) return { txt: '', today: false };
  const W = ['일','월','화','수','목','금','토'];
  const d = new Date(2000 + +m[1], +m[2] - 1, +m[3]);
  return { txt: `${+m[2]}/${+m[3]} (${W[d.getDay()]}) ${m[4]}:${m[5]}`, today: `${m[1]}${m[2]}${m[3]}` === todayYMD6() };
}
// 상대시간: <1h 방금 / <24h N시간 전 / ≥24h N일 N시간 전. 무효(파싱실패 999 등)는 ''.
function relAge(h) {
  if (!isFinite(h) || h < 0 || h >= 900) return '';
  if (h < 1) return '방금';
  if (h < 24) return Math.floor(h) + '시간 전';
  return Math.floor(h / 24) + '일 ' + Math.floor(h % 24) + '시간 전';
}
// 첫줄 = IN(적재·파일명 KST) + 보도(발행). 둘 다 'N시간 전' 상대표기(시간값=강조색). 보도 상대 무효면 날짜 폴백.
function dateLine(a) {
  const inR = relAge(feedAgeH(a));
  const inHtml = inR ? `<span class="d-in"><i class="dl">스크랩</i><b class="ago">${inR}</b></span>` : '';
  const wrR = relAge(articleAgeH(a)) || repDate(a.date);
  const wrHtml = `<span class="d-wr"><i class="dl">보도</i><b class="ago">${wrR}</b></span>`;
  return inHtml + wrHtml;
}
// 편향 색(D) — 약우=연파랑·우=파랑·약좌=연빨강·좌=빨강·중립=연강조. 좌우무관 → "무관".
const BIAS_COLOR = { '약우':'#8fb4ff', '우':'#5b8fff', '약좌':'#ff9d9d', '좌':'#ff6b6b', '중립':'#74e89a' };
function biasText(bias) {
  const s = (bias || '').replace(BIAS_RE, '').trim();
  if (!s) return '';
  if (/무관|N\s*\/?\s*A/i.test(s)) return `<b class="bias" style="color:var(--mut)">무관</b>`;
  let col = 'var(--fg)';
  for (const k of ['약우','약좌','중립','우','좌']) if (s.includes(k)) { col = BIAS_COLOR[k]; break; }
  return `<b class="bias" style="color:${col}">${esc(s)}</b>`;
}
// 대분류(C) — 옛 큐 category 값 → 5버킷 UI 매핑(지침엔 없음·표면화만). 박스 없는 색글자.
const CAT_MAP = { '사회':'사회','정치':'사회','시사':'사회','경제':'경제','문화':'문화','국제':'국제','외교':'국제','테크':'테크','과학':'테크','IT':'테크','AI':'테크' };
const CAT_COLOR = { '사회':'#7fd0a0','경제':'#e7c977','국제':'#b79be8','문화':'#e89bc4','테크':'#7fc8d8' };
function catBucket(cat) { const c = (cat || '').trim(); return CAT_MAP[c] || (['사회','경제','문화','국제','테크'].includes(c) ? c : ''); }
function catChip(cat) {
  const b = catBucket(cat); if (!b) return '';
  return `<span class="cat" style="color:${CAT_COLOR[b]}">${esc(b)}</span>`;
}
// category 프론트매터가 없는 새 기사 → 제목+요약 키워드로 대분류 추정(배지 복원). 큐에 값 있으면 그게 정본.
const CAT_KW = {
  국제: ['트럼프','바이든','미국','중국','일본','러시아','우크라','이란','이스라엘','가자','전쟁','외교','정상','종전','협상','백악관','관세','푸틴','시진핑','나토','중동','북한','김정은','파병','수교'],
  경제: ['경제','금융','증시','주가','코스피','코스닥','환율','부동산','집값','금리','채무','부도','파산','매출','영업','실적','투자','수출','무역','물가','부채','임금','실업','고용','세금','연봉','상장','회장','은행','경영','독점','인수','합병'],
  사회: ['사건','사고','경찰','검찰','법원','재판','판결','구속','파업','교육','학교','복지','의료','병원','범죄','화재','시위','노조','국회','대통령','여당','야당','선거','의원','장관','수사','고소','논란','갑질','마약'],
  문화: ['영화','드라마','음악','가수','배우','공연','전시','예술','연예','아이돌','스포츠','축구','야구','올림픽','월드컵','중계','게임','웹툰','콘서트','앨범','예능','감독'],
  테크: ['AI','인공지능','반도체','스타트업','플랫폼','과학','우주','로봇','데이터','클라우드','전기차','배터리','네이버','카카오','구글','애플','갤럭시','아이폰'],
};
function articleCat(a) {
  const b = catBucket(a.category); if (b) return b;   // 큐 category 있으면 정본
  const t = `${a.title || ''} ${a.summary || ''}`;
  let best = '', bn = 0;
  for (const k in CAT_KW) { let n = 0; for (const w of CAT_KW[k]) if (t.includes(w)) n++; if (n > bn) { bn = n; best = k; } }
  return bn ? best : '사회';   // 운영자 260617: 미분류 0 — frontmatter category 없고 키워드도 0이면 사회(catch-all)로 강제 분류.
}
// (참고) 피드 배지 정본 = 아래 brkIssueKind. 최신 판정 기준 = feedAgeH(스크랩/IN 시각).
function articleAgeH(a) {   // 보도(발행) 나이 — a.date(+a.time)=KST → Date.UTC(−9h)로 절대시각 고정(브라우저 TZ 무관·feedAgeH와 동일 기준). 무효=999.
  a = a || {};   // null 방어
  const dm = /^(\d{4})[.\-](\d{1,2})[.\-](\d{1,2})/.exec(String(a.date || ''));
  if (!dm) return 999;
  const tm = /^(\d{1,2}):(\d{2})/.exec(String(a.time || '').trim());
  const t = Date.UTC(+dm[1], +dm[2] - 1, +dm[3], (tm ? +tm[1] : 0) - 9, tm ? +tm[2] : 0);
  return isNaN(t) ? 999 : Math.max(0, (Date.now() - t) / 3600000);
}
// 피드 최신 판정(긴급↔이슈 전이용) = 스크랩(IN) 시각(파일명 YYMMDD-HHMM) 기준 — 항상 정확(보도시각 time은 빈 경우 多 → 폴백만).
function feedAgeH(a) {
  const m = /^(\d{2})(\d{2})(\d{2})-(\d{2})(\d{2})/.exec(a.file || '');
  if (m) return Math.max(0, (Date.now() - Date.UTC(2000 + +m[1], +m[2] - 1, +m[3], +m[4] - 9, +m[5])) / 3600000);   // 파일명=KST wall-clock → UTC instant(−9h) = 브라우저 TZ 무관·KST 고정(수집함 scTs와 동일 절대시각 기준)
  return articleAgeH(a);
}
// 배지 = 상호배타·나이 전이(문서 §라벨 최종확정·수집함 scBadge와 동일): 긴급(breaking 신규<4h) → 이슈(4h~24h AND [cross≥8 또는 aged breaking]) → 1일↑·신규(<4h)·비이슈는 없음. 둘 다 만족이면 긴급 우선.
// 긴급/이슈 분류(상호배타·긴급우선) → 카드 테두리 점등 클래스. 'brk'(IN<4h breaking)·'iss'(4h~24h AND [cross≥8 또는 aged breaking])·''(1일↑·신규<4h·비이슈).
function brkIssueKind(a) {
  const brk = a.breaking || /속보/.test(a.title || ''), ageH = feedAgeH(a);
  if (brk && ageH < FAST_MAX_H) return 'brk';            // breaking 신규(<4h) → 긴급(이슈도 만족이면 긴급 우선)
  if (ageH >= FAST_MAX_H && ageH < 24 && (a.issue || brk)) return 'iss';   // 4h~24h AND (cross≥8 OR aged breaking) → 이슈 · 신규(<4h)엔 안 뜸·1일↑ 없음(260618)
  return '';
}

function open(a) {
  CUR = a.file; CUR_A = a;
  const md = $('#mdbody');
  md.innerHTML = DOMPurify.sanitize(marked.parse(a.body || ''));
  decorate(md);
  addCopyButtons(md);
  md.insertAdjacentHTML('afterbegin', overviewMeta(a));   // Z: 요약 헤더 아래 기본 개요(지침칩 대체)
  const tsec = thumbSec(a);   // 썸네일 후보(검색 3 + AI생성 3) — 기사 제목 바로 아래
  if (tsec) { const h1 = md.querySelector('h1'); (h1 ? h1.insertAdjacentElement('afterend', tsec) : md.insertAdjacentElement('afterbegin', tsec)); }
  cardSec(a);
  feedSec(a);     // 섹션 3: 카드 피드(이미지 있을 때만 표시)
  $('#revStatus').textContent = '';   // 수정 요청 상태 리셋(이전 카드 잔상 제거)
  applyReviseMarks();   // 이 기사가 변경 중이면 IG/Thread 소주제 '(변경 중)' + 연필 FAB 물결
  setupScrub();   // 모달 헤더 = 스크롤 위치 스크러버(게이지 + 요약·프롬프트·카드 틱 + 클릭 점프)
  const src = $('#src'); if (a.url){ src.href=a.url; src.style.display=''; } else src.style.display='none';
  const dlg = $('#dlg'); dlg.showModal(); dlg.scrollTop = 0;  // 재진입 시 이전 스크롤 위치 유지 버그 → 맨 위 리셋
  const dt = $('#dlgtop'); if (dt) dt.classList.remove('show');   // 모달 탑 버튼(제거됨) 초기 숨김 — null 가드(없으면 throw로 아래 스크롤락·포커스가 안 돌던 잠복버그 차단)
  updateRevFab();   // 열릴 때 FAB 초기 상태(맨 위라 보통 숨김)
  document.documentElement.style.overflow = 'hidden';   // PC: 모달 밖(백드롭) 스크롤 시 배경 페이지 스크롤 차단(#5)
  // 첫 focusable 버튼(요약/원문)이 showModal에 auto-focus되면 포커스 링(테두리)·상태바 URL 노출 →
  // 닫기(X) 버튼으로 포커스를 옮겨 차단. (.dlg-x 명시 — 첫 버튼=요약 ⬇에 링 안 생기게.)
  const cb = $('#dlg').querySelector('.dlg-x'); if (cb) cb.focus();
}

function addCopyButtons(root) {
  root.querySelectorAll('pre').forEach(pre => {
    const code = pre.querySelector('code');
    // 강조 마커 *문구*/**문구** → 문구만 강조색 <i>(별표 미표시). 복사는 codeCopyText가 data-mk로 *…* 복원.
    if (code && !code.dataset.hl) {
      code.dataset.hl = '1';
      code.innerHTML = code.innerHTML.replace(/(\*{1,2})([^*\n<>]+?)\*{1,2}/g,
        (m, mk, t) => `<i class="cem" data-mk="${mk}">${t}</i>`);
    }
    pre.appendChild(copyBtn(() => code ? codeCopyText(code) : pre.innerText, '복사'));
  });
}
// 강조 <i class="cem" data-mk="*|**"> → *문구*/**문구** 복원(나머지 텍스트 그대로) — 복사 시 합성기 포맷 보존.
function codeCopyText(code) {
  let out = '';
  code.childNodes.forEach(n => {
    if (n.nodeType === 1 && n.classList && n.classList.contains('cem')) {
      const mk = n.getAttribute('data-mk') || '*'; out += mk + n.textContent + mk;
    } else { out += n.textContent; }
  });
  return out;
}

// 오늘(브라우저 로컬=KST) YYMMDD — 기사 파일명 앞 6자와 비교(자정 기준 New/Today)
function todayYMD6() {
  const n = new Date(), p = x => String(x).padStart(2,'0');
  return `${String(n.getFullYear()).slice(2)}${p(n.getMonth()+1)}${p(n.getDate())}`;
}
// 다운로드 파일명 시각 프리픽스 = 기사 IN 시각(파일명 YYMMDD-HHMM) → yymmdd_hhmm. 시스템 파일규칙과 일치(모든 다운로드 일관). 없으면 다운로드 시각.
function dlStamp(a) {
  const m = a && /^(\d{6})-(\d{4})/.exec(a.file || '');
  if (m) return `${m[1]}_${m[2]}`;
  const n = new Date(), p = x => String(x).padStart(2, '0');
  return `${String(n.getFullYear()).slice(2)}${p(n.getMonth() + 1)}${p(n.getDate())}_${p(n.getHours())}${p(n.getMinutes())}`;
}
// 날짜 헤더: yyyy-mm-dd 요일 │ Today {오늘} / {총합}
function dateHead(total) {
  const W = ['일','월','화','수','목','금','토'];
  const n = new Date();
  const dd = $('#dhDate'); if (dd) dd.textContent = `${n.getMonth()+1}월 ${n.getDate()}일 ${W[n.getDay()]}`;
  const t6 = todayYMD6();
  const todayN = DATA.filter(a => (a.file||'').slice(0,6) === t6).length;
  const dc = $('#dhCnt'); if (dc) dc.innerHTML = `오늘 <b${todayN ? '' : ' class="z"'}>${todayN}</b> / ${total}`;
}

// 긴 박스(카드 프롬프트·요약 드래프트) 3줄 클립 + 더보기/접기
function addClip(pre) {
  pre.classList.add('clip');
  const mb = document.createElement('button');
  mb.className = 'morebtn'; mb.textContent = '더 보기 ▾';
  mb.onclick = ev => { ev.stopPropagation();
    const clipped = pre.classList.toggle('clip');
    mb.textContent = clipped ? '더 보기 ▾' : '접기 ▴'; };
  pre.after(mb);
}

// 다이제스트 후처리: [썸네일] 섹션 제거 · 헤더 이모지 strip(💡 시사점 유지) · 편향 색도형 strip · 키워드 강조 · 드래프트 더보기
const BIAS_RE = /[🟥🟦🟩🟨🟧🟪🟫🔴🟠🟡🟢🔵🟣⬛⬜📊✅]/gu;
const KW_RE = /(앵글 후보\s*[①-⑳0-9]*|약보수 보정|[가-힣A-Za-z0-9]{1,8} ?관점)/g;
function decorate(root) {
  // 1) [썸네일 타이틀] 섹션 제거(h3 + 다음 heading 전까지) — 맨 위 기사 제목이 곧 썸네일
  root.querySelectorAll('h3').forEach(h => {
    if (!/썸네일/.test(h.textContent)) return;
    let n = h.nextElementSibling;
    while (n && !/^H[1-3]$/.test(n.tagName)) { const k = n; n = n.nextElementSibling; k.remove(); }
    h.remove();
  });
  // 2) 섹션 헤더 이모지 strip(시사점 💡만 유지) + 드래프트 글자수 메타(— 약 N자) 미강조
  root.querySelectorAll('h2, h3').forEach(h => {
    if (/시사점/.test(h.textContent)) return;
    if (h.firstChild && h.firstChild.nodeType === 3)
      h.firstChild.data = h.firstChild.data.replace(/^\s*\p{Extended_Pictographic}️?\s*/u, '');
    // h3 드래프트 [라벨 — 약 N/M자]: 라벨·실제 카운트(N)만 강조, 나머지([·—·약·/M·자])는 미강조
    const dm = h.textContent.match(/^(\[)(.+?)(\s*[—\-]\s*약\s*)(\d+)(.*)$/);
    if (dm) { h.innerHTML = `<span class="cnt">${esc(dm[1])}</span>${esc(dm[2])}<span class="cnt">${esc(dm[3])}</span>${esc(dm[4])}<span class="cnt">${esc(dm[5])}</span>`; return; }
    // h2 섹션: 📍 말머리 + 괄호 부연(…)은 흰색(강조 해제)
    if (h.tagName === 'H2') {
      const pm = h.textContent.match(/^(.+?)\s*\(([^)]+)\)\s*$/);   // AO: 부제 괄호 부연 제거(해시태그도 X)
      if (pm) h.innerHTML = '📍 ' + esc(pm[1].trim());
      else if (h.firstChild && h.firstChild.nodeType === 3 && !/^📍/.test(h.firstChild.data)) h.firstChild.data = '📍 ' + h.firstChild.data;
    }
  });
  // 2c) 섹션 헤더(h2) 바로 밑 서브헤더(h3) = 사이 구분선·빈 줄 제거(콘텐츠 초안→자유요약 등)
  root.querySelectorAll('h3').forEach(h => {
    const pv = h.previousElementSibling;
    if (pv && pv.tagName === 'H2') h.classList.add('subtop');
  });
  // 2b) 기사 제목(h1) 맨 앞 이모지 제거(요청 — 제목엔 이모지 X)
  root.querySelectorAll('h1').forEach(h => {
    if (h.firstChild && h.firstChild.nodeType === 3)
      h.firstChild.data = h.firstChild.data.replace(/^\s*\p{Extended_Pictographic}️?\s*/u, '');
  });
  // 3) 본문 텍스트노드: 편향 색도형 strip + 키워드 강조 (pre/code/헤더 제외 — 복사 draft 보존)
  const nodes = [], tw = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
  for (let n; (n = tw.nextNode());) {
    if (!n.parentElement || n.parentElement.closest('pre, code, h1, h2, h3')) continue;
    nodes.push(n);
  }
  nodes.forEach(n => {
    const s = n.data.replace(BIAS_RE, '');
    const parts = s.split(KW_RE);
    if (parts.length < 2) { if (s !== n.data) n.data = s; return; }
    const frag = document.createDocumentFragment();
    parts.forEach((p, i) => { if (!p) return;
      if (i % 2) {
        if (/^앵글 후보/.test(p)) {                                                  // 앵글 후보 ①② = 배지 도형(번호 포함)
          const sp = document.createElement('span'); sp.className = 'angle'; sp.textContent = p.trim(); frag.append(sp);
        } else {
          const sp = document.createElement('span'); sp.className = 'kw'; sp.textContent = p; frag.append(sp);   // J: 약보수 보정 줄바꿈 제거(편향과 같은 줄)
        }
      } else frag.append(document.createTextNode(p)); });
    n.replaceWith(frag);
  });
  // G: 앵글 후보 배지 뒤 ' : ' 콜론 제거
  root.querySelectorAll('.angle').forEach(ag => {
    const nx = ag.nextSibling;
    if (nx && nx.nodeType === 3) nx.data = nx.data.replace(/^\s*:\s*/, ' ');
  });
  // M: 편향 줄(단독 p) — 좌우무관/N/A면 '편향: 무관'으로 축약(보정 면제 문구 제거, 메인과 동일), 그 외엔 • 말머리만
  root.querySelectorAll('p').forEach(p => {
    if (!/^\s*편향\s*[:：]/.test(p.textContent)) return;
    if (/무관|N\s*\/?\s*A/i.test(p.textContent)) p.innerHTML = '편향: <b class="bias" style="color:var(--mut)">무관</b>';
    p.classList.add('bullet');
  });
  // 4) 요약 드래프트 더보기/접기 — '자유요약'만 클립(IG·Thread는 전체 표시)
  root.querySelectorAll('pre').forEach(pre => {
    let h = pre.previousElementSibling;
    while (h && !/^H[1-3]$/.test(h.tagName)) h = h.previousElementSibling;
    if (h && /자유요약/.test(h.textContent)) addClip(pre);
  });
  // 5) 상단 기사 제목 = 복사 버튼 없음(#3) — 카드뉴스 제목만 복사 영역으로(cardSec)
}

// ── 썸네일 후보 섹션 — 기사 제목 바로 아래(픽한 기사). 검색 이미지 3 + AI 생성 3(각 4:5 캐러셀). ──
// 데이터: a.cards.thumb_search[]={img,link,label} (기사 og:image+유사 · label=''(대표)/'유사') · a.cards.thumb_gen[]={img,label} (Gemini 3화풍).
// 백엔드 채워지기 전(P1): 검색=라이브 폴백(Wikimedia 이미지 + 구글 검색 링크) / 생성=대기 플레이스홀더.
function thumbSec(a) {
  const c = a.cards || {};
  if (!a.body && !c.state) return null;   // 픽(분석)된 기사에만
  // 실제 이미지(검색 og:image / AI 생성)가 하나라도 있을 때만 표시 — 빈 안내·레거시 폴백(구글검색 링크·위키미디어·'곧 반영' placeholder)은 띄우지 않음(요약 위 잡음 제거 · 운영자 260620)
  const search = Array.isArray(c.thumb_search) ? c.thumb_search : [];
  const gen = Array.isArray(c.thumb_gen) ? c.thumb_gen : [];
  if (!search.length && !gen.length) return null;
  const wrap = document.createElement('div'); wrap.className = 'thumbsec';
  wrap.innerHTML = '<div class="thumbsec-h">🖼 썸네일 후보 — 검색 · AI 생성</div>';
  // 1) 검색 이미지(4:5 × 3) — 실제 추출분이 있을 때만. 라벨 옆 토큰=검색·비전 비용(현재 0)
  if (search.length) {
    wrap.appendChild(thumbStatic('🔎 검색 이미지', search, 'search',
      'https://www.google.com/search?tbm=isch&q=' + encodeURIComponent((a.title || '뉴스').slice(0, 100)), c.thumb_usage));
  }
  // 2) AI 생성(4:5 × 3) — 생성분이 있을 때만. 라벨 옆 토큰=생성 비용(4화풍+재생성 누적)
  if (gen.length) wrap.appendChild(thumbStatic('🍌 AI 생성', gen, 'gen', null, c.thumb_usage));
  return wrap;
}
// 제미나이 토큰/추정$ 표기(plain 텍스트 · 버튼 아님) — 라벨(🍌 AI 생성·🔎 검색) 우측. 형식 "$ 0.0, T 0".
// bucket={calls,total,cumulative}. 토큰=정확(API) · $=추정(이미지 토큰 단가). 운영자 260620: 돈아이콘·볼드·pill 제거.
const GEM_RATE = 0.00003;   // 이미지 토큰 추정단가(≈$30/1M·$0.039/장 기준). $=추정·T=정확. ⚠️ 실측 usage.json 들어오면 1콜 totalTokenCount로 재캘리브레이션(이미지 과금은 장당 고정이라 토큰선형은 근사)
function usageText(bucket, kind) {
  if (!bucket) return '';
  const tok = bucket.cumulative || 0;
  const usd = (tok * GEM_RATE).toFixed(1);
  const title = kind === 'search'
    ? (tok ? '검색·비전 제미나이 누적 ' + tok.toLocaleString() + '토큰 · 추정 $' + usd
           : '검색 = og:image 스크래핑(AI 비전 미사용) · 제미나이 0')
    : '제미나이 — 4화풍+재생성 누적 ' + tok.toLocaleString() + '토큰 · 추정 $' + usd
      + (bucket.calls ? ' (최근 ' + bucket.calls + '콜)' : '');
  return '<span class="cref-usage" title="' + esc(title) + '">$ ' + usd + ', T ' + tok.toLocaleString() + '</span>';
}
const REFRESH_SVG = '<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-2.64-6.36"/><path d="M21 4v5h-5"/></svg>';
const SEARCH_SVG = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>';
// 정적 캐러셀(thumb_search/thumb_gen) — items=[{img,label?,sid?}]. 탭=확대 · 우상단 액션행 .sbtn(저장 · 생성슬롯=재생성+저장 · §🎨 .slide-acts 계승). usage={gen,search}.
function thumbStatic(label, items, kind, href, usage) {
  const list = items.slice(0, 4);
  const wrap = document.createElement('div'); wrap.className = 'cref';
  // 검색 헤더 우측 = 글래스 .sbtn 아이콘(구글 이미지 검색) — 기존 초록 알약 텍스트 폐기(투박·운영자 260620)
  const hbtn = href ? '<a class="sbtn cref-srch" href="' + escUrl(href) + '" target="_blank" rel="noopener" title="구글 이미지 검색" aria-label="구글 이미지 검색">' + SEARCH_SVG + '</a>' : '';
  const bucket = usage ? (kind === 'gen' ? usage.gen : kind === 'search' ? usage.search : null) : null;
  wrap.innerHTML = '<div class="cref-h"><span class="cref-lblrow"><span class="cref-lbl">' + esc(label) + '</span>' + usageText(bucket, kind) + '</span>' + hbtn + '</div>'
    + '<div class="cref-track">' + (list.map((it, i) => {
        const cap = it.label ? '<span class="tgen-cap">' + esc(it.label) + '</span>' : '';
        return '<div class="cref-slot ' + kind + '" data-i="' + i + '" role="button" tabindex="0" aria-label="확대">'
          + '<img loading="lazy" referrerpolicy="no-referrer" src="' + escUrl(it.img) + '" alt=""'
          + ' onerror="this.closest(\'.cref-slot\').style.display=\'none\'">' + cap
          + '<div class="timg-acts">'
          +   '<button type="button" class="sbtn timg-dl" aria-label="이미지 저장">' + DOWNLOAD_SVG + '</button>'
          + '</div></div>';
      }).join('') || '<div class="cref-empty">이미지 없음</div>') + '</div>';
  wrap.querySelectorAll('.cref-slot').forEach(slot => {
    const i = +slot.dataset.i, it = list[i]; if (!it) return;
    const acts = slot.querySelector('.timg-acts');
    if (kind === 'gen' && it.sid) acts.insertBefore(thumbRedoSbtn(it.sid), acts.firstChild);   // 생성 슬롯마다 재생성 .sbtn(저장 앞)
    slot.querySelector('.timg-dl').addEventListener('click', e => { e.stopPropagation(); downloadImg(it.img, thumbDlName(label, it, i), e.currentTarget); });
    slot.addEventListener('click', e => { if (!e.target.closest('.timg-acts')) openLightbox(list, i, label); });   // 탭=확대(복사는 확대뷰에서)
    slot.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openLightbox(list, i, label); } });
  });
  return wrap;
}
// 슬롯별 '다시 만들기'(.sbtn 한 벌 계승 — 카드 캐러셀과 동일 컴포넌트) — 1차 탭=재확인(.confirm 앰버) · 2차 탭=전송(.busy '재생성 중').
// /api/thumbredo {article,sid} → 그 화풍 1개만 재생성(검색·타화풍 보존). 라이브 폴(load)이 새 이미지(?v=) 오면 섹션 통째 교체. 유료(Gemini 1장)·게이트 없음.
function thumbRedoSbtn(sid) {
  const b = document.createElement('button');
  b.type = 'button'; b.className = 'sbtn'; b.title = '이 화풍 다시 만들기'; b.setAttribute('aria-label', '이 화풍 다시 만들기');
  b.innerHTML = REFRESH_SVG;
  let stage = 0, t;
  const reset = () => { stage = 0; clearTimeout(t); b.classList.remove('confirm', 'busy'); b.innerHTML = REFRESH_SVG; b.title = '이 화풍 다시 만들기'; };
  b.addEventListener('click', async e => {
    e.stopPropagation();
    // 1차 = 재확인: 앰버 + 아이콘 ✓로 교체(폰은 hover title 안 떠서 색만으론 부족 → 아이콘 변화로 "한 번 더=실행" 가시화 · 오탭 과금 방지)
    if (stage === 0) { stage = 1; b.classList.add('confirm'); b.innerHTML = CHECK_SVG; b.title = '한 번 더 누르면 재생성'; clearTimeout(t); t = setTimeout(reset, 3000); return; }
    if (stage !== 1) return;
    clearTimeout(t); stage = 2; b.classList.remove('confirm'); b.classList.add('busy'); b.innerHTML = REFRESH_SVG;   // 전송 = busy(재생성 중 · 카드 reshooting dim 계승)
    try {
      const r = await fetch('/api/thumbredo', { method: 'POST', headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ article: CUR, sid }) });
      const j = await r.json().catch(() => ({}));
      if (!r.ok || j.error) throw new Error(j.error || ('HTTP ' + r.status));
      THUMB_REDO.set(CUR, { oldSig: thumbGenSig(CUR_A), t0: Date.now() });   // load 폴이 새 이미지(?v=) 오면 썸네일 섹션 교체(busy 유지=재생성 중)
    } catch (err) {
      b.classList.remove('busy'); b.classList.add('errflash'); b.title = String(err.message || err);
      setTimeout(reset, 2600);
    }
  });
  return b;
}

// ── 썸네일 이미지: 복사·저장·확대(라이트박스) — §🎨 .sbtn/.tool-x/<dialog>+popstate 계승 ──
function _flashBtn(btn, mode) {   // mode: true|'ok'=초록체크 · 'warn'=부분(앰버·URL만/새탭) · 'err'=실패(빨강)
  if (!btn) return;
  if (!btn.dataset.icon) btn.dataset.icon = btn.innerHTML;
  const m = mode === true ? 'ok' : mode;
  if (m === 'ok') { btn.innerHTML = CHECK_SVG; btn.classList.add('ok'); }
  else if (m === 'warn') { btn.innerHTML = CHECK_SVG; btn.classList.add('warnflash'); }
  else { btn.classList.add('errflash'); }
  setTimeout(() => { btn.innerHTML = btn.dataset.icon; btn.classList.remove('ok', 'warnflash', 'errflash'); }, 1500);
}
async function _blobToPng(blob) {   // 클립보드는 png가 가장 호환 — fetch blob(미오염)을 캔버스로 png 변환
  const bmp = await createImageBitmap(blob);
  const cv = document.createElement('canvas'); cv.width = bmp.width; cv.height = bmp.height;
  cv.getContext('2d').drawImage(bmp, 0, 0);
  return await new Promise(res => cv.toBlob(res, 'image/png'));
}
async function copyImg(url, btn) {
  if (!url) return;
  try {
    const blob = await (await fetch(url)).blob();
    const png = blob.type === 'image/png' ? blob : await _blobToPng(blob);
    await navigator.clipboard.write([new ClipboardItem({ 'image/png': png })]);
    _flashBtn(btn, 'ok');
  } catch (e) {                                            // 이미지 복사 불가(CORS·권한) → URL 텍스트라도(정직: warn 표시)
    try { await navigator.clipboard.writeText(url); if (btn) btn.title = '이미지 복사 불가(외부) — URL을 복사함'; _flashBtn(btn, 'warn'); }
    catch { _flashBtn(btn, 'err'); }
  }
}
async function downloadImg(url, name, btn) {
  if (!url) return;
  try {
    const blob = await (await fetch(url)).blob();
    const u = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = u; a.download = name; document.body.appendChild(a); a.click(); a.remove();
    setTimeout(() => URL.revokeObjectURL(u), 4000); _flashBtn(btn, 'ok');
  } catch (e) {                                            // 직접 저장 불가(CORS) → 새 탭(정직: warn 표시·폰 길게눌러 저장)
    window.open(url, '_blank', 'noopener'); if (btn) btn.title = '직접 저장 불가(외부) — 새 탭에서 길게눌러 저장'; _flashBtn(btn, 'warn');
  }
}
function thumbDlName(label, it, i) {
  const stamp = (typeof CUR_A !== 'undefined' && CUR_A) ? dlStamp(CUR_A) : '';
  const ext = ((/\.(png|jpe?g|webp)(?:\?|$)/i.exec(it.img || '') || [, 'png'])[1] || 'png').toLowerCase().replace('jpeg', 'jpg');
  const slug = dlSlug(it.label || label || 'thumb');
  return (stamp ? stamp + '_' : '') + slug + '_' + (i + 1) + '.' + ext;
}
let LBOX = null, LBOX_ITEMS = [], LBOX_LABEL = '', _lboxPop = false;
function thumbGenSig(a) { return ((a && a.cards && a.cards.thumb_gen) || []).map(g => g && g.img).join('|'); }
const THUMB_REDO = new Map();   // file → {oldSig,t0} : '다시 만들기' 후 새 gen 이미지 도착 감지(load 폴이 썸네일섹션 교체·타임아웃 6분)
function _ensureLbox() {
  if (LBOX) return LBOX;
  const d = document.createElement('dialog'); d.className = 'lbox'; d.id = 'lbox';
  d.innerHTML =
    '<div class="lbox-bar">'
    + '<button type="button" class="sbtn lbox-copy" aria-label="이미지 복사">' + COPY_SVG + '</button>'
    + '<button type="button" class="sbtn lbox-dl" aria-label="이미지 저장">' + DOWNLOAD_SVG + '</button>'
    + '<span class="lbox-no"></span>'
    + '<a class="lbox-src" target="_blank" rel="noopener" hidden>출처 ↗</a>'
    + '<button type="button" class="tool-x lbox-x" aria-label="닫기"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6 18 18M18 6 6 18"/></svg></button>'
    + '</div><div class="lbox-track"></div>';
  document.body.appendChild(d);
  const track = d.querySelector('.lbox-track');
  const idx = () => Math.round(track.scrollLeft / (track.clientWidth || 1));
  const cur = () => LBOX_ITEMS[idx()] || LBOX_ITEMS[0] || {};
  const sync = () => {
    d.querySelector('.lbox-no').textContent = LBOX_ITEMS.length ? (idx() + 1) + ' / ' + LBOX_ITEMS.length : '';
    const it = cur(), src = d.querySelector('.lbox-src');
    if (it.link) { src.href = it.link; src.hidden = false; } else src.hidden = true;
  };
  track.addEventListener('scroll', () => { clearTimeout(track._t); track._t = setTimeout(sync, 90); });
  d.querySelector('.lbox-copy').addEventListener('click', e => copyImg(cur().img, e.currentTarget));
  d.querySelector('.lbox-dl').addEventListener('click', e => downloadImg(cur().img, thumbDlName(LBOX_LABEL, cur(), idx()), e.currentTarget));
  d.querySelector('.lbox-x').addEventListener('click', () => d.close());
  d.addEventListener('click', e => { if (e.target === d) d.close(); });   // 백드롭 탭=닫기
  d.addEventListener('cancel', e => { e.preventDefault(); d.close(); });   // ESC=닫기
  d.addEventListener('close', () => { if (_lboxPop) { _lboxPop = false; } else if (history.state && history.state.lbox) history.back(); });
  d._track = track; d._sync = sync; LBOX = d; return d;
}
function openLightbox(items, i, label) {
  LBOX_ITEMS = items; LBOX_LABEL = label;
  const d = _ensureLbox(), track = d._track;
  track.innerHTML = items.map(it => '<div class="lbox-slide"><img referrerpolicy="no-referrer" src="' + escUrl(it.img) + '" alt=""></div>').join('');
  if (!d.open) { d.showModal(); history.pushState({ lbox: true }, ''); }   // 폰 뒤로가기=닫고 직전 화면 복귀
  requestAnimationFrame(() => { track.scrollLeft = i * track.clientWidth; d._sync(); });
}
window.addEventListener('popstate', () => { if (LBOX && LBOX.open) { _lboxPop = true; LBOX.close(); } });

// ── 카드뉴스 섹션 ──
function cardSec(a) {
  const sec = $('#cardsec'); sec.innerHTML = '';
  const c = a.cards || {}, st = c.state || '';
  CUR_STATE = st;
  // stale = 카드 제작 후 요약을 또 revise함(a.rev > 카드가 만들어진 회차 c.rev). 이미지 있는 카드(done/fired_partial)만 —
  // 이미지는 보존하고 '다시 제작'(앰버 버튼) 권유로 운영자가 새 요약 반영(text_done은 card_refresh가 자동 갱신하므로 제외).
  const stale = (st === 'done' || st === 'fired_partial') && (Number(a.rev || 0) > Number(c.rev || 0));
  // 18분 초과 미완 = 멈춤(시간 기반 실패 감지) — 경고·재시도 버튼 노출용(progGauge와 동일 기준).
  const stuckMin = c.updated ? Math.floor((Date.now() - Date.parse(c.updated)) / 60000) : 999;   // updated 없으면 비정상(스탬프 안 됨) = stuck 취급
  const stuck = stuckMin > 18;        // fired_partial = 이미지 렌더라 오래 걸림 → 18분 유지
  const genStuck = stuckMin > 15;     // generating = 프롬프팅(단발 콜)이라 빨라야 정상 → 15분 넘으면 실패 표시(운영자 260618)
  // 카드 phase 헤더에 상태 반영(접어도 보이게)
  const sumlabel = { '':'2. 카드뉴스', generating:'2. 카드뉴스 — 프롬프팅 중…', text_done:'2. 카드뉴스 — 텍스트·프롬프트',
    done:'2. 카드뉴스', fired_partial:'2. 카드뉴스 — 생성됨', failed:'2. 카드뉴스 — 실패' };
  const cs = $('#cardsum'); if (cs) cs.textContent = (st === 'generating' && genStuck) ? '2. 카드뉴스 — 실패(시간초과)' : (sumlabel[st] || '카드뉴스');   // 프롬프팅 15분 초과 = 접힌 헤더도 '실패'로(운영자: 영원히 진행중 차단)

  if (!st || st === 'failed') {
    if (st === 'failed') sec.insertAdjacentHTML('beforeend',
      `<div class="genstat">⚠️ 직전 카드 제작 실패 — 레포 cards/ 의 error.log 참조</div>`);
    const b = document.createElement('button');
    b.className = 'mkbtn';
    b.textContent = st === 'failed' ? '카드뉴스 다시 생성' : '카드뉴스 생성';
    b.onclick = () => makeCards(a.file, b);
    sec.appendChild(b);
    return;
  }
  if (st === 'generating') {
    if (genStuck) {   // 15분째 프롬프팅 멈춤 = 워크플로 중단/타임아웃 추정 → 실패로 표시·재시도
      sec.insertAdjacentHTML('beforeend',
        `<div class="genstat">⚠️ 카드 프롬프팅 실패 — ${stuckMin === 999 ? '' : stuckMin + '분째 '}멈춰 있어(워크플로 중단/타임아웃 추정). 아래로 다시 시도해줘.</div>`);
      const b = document.createElement('button');
      b.className = 'mkbtn';
      b.textContent = '🔄 카드 다시 만들기';
      b.onclick = () => makeCards(a.file, b);
      sec.appendChild(b);
    } else {
      sec.innerHTML = `<div class="genstat live">🍌 카드뉴스 프롬프팅 중입니다… 완료되면 여기에 자동으로 떠(1~2분 단위 갱신)</div>`;
    }
    return;
  }
  let note = {
    fired_partial: '🚀 일부만 생성됨 — 아래 재생성 버튼으로 나머지 채우기',
  }[st];
  if (st === 'fired_partial' && stuck)   // 발사 후 18분째 이미지 미완 = 인증 만료/렌더 실패 가능 → 재시도 유도
    note = `⚠️ 생성됐지만 ${stuckMin}분째 이미지 미완 — 인증 만료·렌더 실패일 수 있어. 아래로 다시 시도해줘.`;
  if (note) sec.insertAdjacentHTML('beforeend', `<div class="cardnote">${note}</div>`);
  // 카드 이미지는 섹션 3 '카드 피드'(feedSec)에서 렌더. #cardsec은 텍스트·프롬프트·복사·슛 정본 유지.
  if (c.md) {
    const div = document.createElement('div');
    div.innerHTML = DOMPurify.sanitize(marked.parse(c.md));
    div.querySelectorAll('h3').forEach(h => { h.textContent = '📍 ' + h.textContent; });   // [카드 N] = 말머리
    div.querySelectorAll('p > strong').forEach(s => {                                        // 텍스트·이미지프롬프트 = 소머리(•)
      if (/^(텍스트|이미지\s*프롬프트)$/.test((s.textContent || '').trim())) s.parentElement.classList.add('lbl');
    });
    // 이미지 프롬프트 박스 = 기본 3줄 클립 + 더보기/접기(내부 스크롤 X). 직전 라벨에 '이미지 프롬프트' 있는 pre.
    div.querySelectorAll('pre').forEach(pre => {
      const prev = pre.previousElementSibling;
      if (prev && /이미지\s*프롬프트/.test(prev.textContent || '')) addClip(pre);
    });
    addCopyButtons(div);   // 텍스트·프롬프트 각 블록 개별 복사
    // 카드별 검색어 줄 — 이미지 프롬프트 박스 아래 [현재 검색어(좌·1줄)] + [G+돋보기 구글 이미지 검색 버튼](운영자 260620).
    const G_SVG = '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 10.96v2.32h3.84c-.16 1-1.15 2.9-3.84 2.9-2.31 0-4.2-1.91-4.2-4.27s1.89-4.27 4.2-4.27c1.32 0 2.2.56 2.7 1.05l1.84-1.77c-1.18-1.1-2.68-1.77-4.54-1.77-3.74 0-6.74 3-6.74 6.76s3 6.76 6.74 6.76c3.89 0 6.47-2.74 6.47-6.59 0-.44-.05-.78-.11-1.12l-6.36.04z"/></svg>';
    const _refCards = parseCards(c.md), _refTtl = a.title || feedTitle(c.md) || '';
    [...div.querySelectorAll('pre')].filter(p => { const pv = p.previousElementSibling; return pv && /이미지\s*프롬프트/.test(pv.textContent || ''); })
      .forEach((pre, i) => {
        const q = (_refCards[i] && _refCards[i].caption) || _refTtl;   // 검색 쿼리 = 카드 캡션(없으면 제목)
        if (!q) return;
        const row = document.createElement('div'); row.className = 'srchrow';
        const note = document.createElement('span'); note.className = 'qnote';
        note.innerHTML = '현재 검색어 = <b>' + esc('"' + q + '"') + '</b>';
        const s = document.createElement('a'); s.className = 'gsrch';
        s.href = 'https://www.google.com/search?tbm=isch&q=' + encodeURIComponent(String(q).slice(0, 80));
        s.target = '_blank'; s.rel = 'noopener'; s.title = '구글 이미지 검색'; s.setAttribute('aria-label', '구글 이미지 검색');
        s.innerHTML = G_SVG + SEARCH_SVG;
        row.append(note, s);
        pre.insertAdjacentElement('afterend', row);   // 프롬프트 박스 바로 아래
      });
    const ch1 = div.querySelector('h1');   // 카드뉴스 제목(=썸네일)도 복사 가능 영역으로
    if (ch1) { const t = ch1.textContent; ch1.appendChild(copyBtn(() => t, '제목 복사')); }
    sec.appendChild(div);
  }
  // stale = 요약이 카드 제작 후 또 수정됨 → 이미지는 보존하고 '다시 제작'(앰버) 권유. 기본 슛/재발사 버튼 대체.
  if (stale) {
    sec.insertAdjacentHTML('beforeend',
      `<div class="cardnote stale">📝 카드 제작 뒤 요약이 수정됐어 — 이 카드는 옛 요약 기준이야. 이미지는 그대로 두고, 새 요약으로 <b>다시 제작</b>하려면 아래를 눌러(프롬프트·이미지 새로 생성).</div>`);
    const b = document.createElement('button');
    b.className = 'mkbtn stale';
    b.textContent = '🔄 다시 제작 (요약 수정 반영)';
    b.onclick = () => makeCards(a.file, b);   // full 모드 = 새 요약으로 프롬프트+이미지 재생성
    sec.appendChild(b);
    return;
  }
  // text_done = '슛'(이미지 발사) 버튼 — 이미지 나오면(done) 사라짐
  if (st === 'text_done') {
    const b = document.createElement('button');
    b.className = 'mkbtn';
    b.textContent = '🚀 이미지 생성 & 카드 합성';
    b.onclick = () => makeCards(a.file, b, 'shoot');
    sec.appendChild(b);
  }
  // fired_partial = 발사됐으나 미완 → 재발사(텍스트 재사용·렌더만). 멈춤이면 '다시 시도'로 강조.
  if (st === 'fired_partial') {
    const b = document.createElement('button');
    b.className = 'mkbtn';
    b.textContent = stuck ? '🔄 다시 시도(이미지 재생성)' : '🔄 재생성(이미지 다시)';
    b.onclick = () => makeCards(a.file, b, 'shoot');
    sec.appendChild(b);
  }
}

// ── 카드별 관련 이미지(샘플) — Wikimedia Commons(무키·CORS) + 구글 이미지 검색. 외국(국제) 기사면 영문 키워드로 검색(외국 소스 풍부 · 운영자 260619). ──
// 외국 엔티티 한→영(이미지 검색 앵커). CAT_KW.국제 기반 + 국가·인물·사건명사. 즉시·정확(번역 API보다 우선).
const FOREIGN_EN = {
  '트럼프':'Trump','바이든':'Biden','푸틴':'Putin','시진핑':'Xi Jinping','젤렌스키':'Zelensky','네타냐후':'Netanyahu',
  '김정은':'Kim Jong Un','마크롱':'Macron','숄츠':'Scholz','기시다':'Kishida','이시바':'Ishiba','모디':'Modi','에르도안':'Erdogan',
  '미국':'United States','중국':'China','일본':'Japan','러시아':'Russia','우크라이나':'Ukraine','우크라':'Ukraine',
  '이란':'Iran','이스라엘':'Israel','가자지구':'Gaza','팔레스타인':'Palestine','하마스':'Hamas','헤즈볼라':'Hezbollah','후티':'Houthi',
  '북한':'North Korea','대만':'Taiwan','홍콩':'Hong Kong','영국':'United Kingdom','프랑스':'France','독일':'Germany',
  '파키스탄':'Pakistan','베트남':'Vietnam','태국':'Thailand','필리핀':'Philippines','사우디':'Saudi Arabia','튀르키예':'Turkey','터키':'Turkey',
  '유럽':'Europe','나토':'NATO','유엔':'United Nations',
  '백악관':'White House','펜타곤':'Pentagon','크렘린':'Kremlin','중동':'Middle East','지중해':'Mediterranean',
  '전쟁':'war','종전':'ceasefire','휴전':'ceasefire','정상회담':'summit','회담':'talks','관세':'tariff','제재':'sanctions',
  '미사일':'missile','공습':'airstrike','드론':'drone','지진':'earthquake','홍수':'flood','산불':'wildfire','허리케인':'hurricane','난민':'refugee',
};
function foreignEnglish(title, caption) {
  const t = (title || '') + ' ' + (caption || ''), hits = [];
  for (const k in FOREIGN_EN) { const en = FOREIGN_EN[k]; if (t.includes(k) && !hits.includes(en)) hits.push(en); }
  return hits.slice(0, 5).join(' ');   // 엔티티·사건 영문(상위 5) — 이미지 검색 앵커
}
async function translateKoEn(text) {   // 무키·CORS 폴백(엔티티맵 0일 때만) — MyMemory ko→en
  if (!text) return '';
  try {
    const r = await fetch('https://api.mymemory.translated.net/get?q=' + encodeURIComponent(String(text).slice(0, 120)) + '&langpair=ko|en');
    const j = await r.json(); const t = (j && j.responseData && j.responseData.translatedText) || '';
    return /MYMEMORY WARNING|QUERY LENGTH|INVALID/i.test(t) ? '' : t.trim();
  } catch { return ''; }
}
function cardRefCarousel(caption, title, foreign) {
  const wrap = document.createElement('div'); wrap.className = 'cref';
  wrap.innerHTML = '<div class="cref-h"><span class="cref-lbl">🔎 관련 이미지' + (foreign ? ' · 외국(영문 검색)' : ' (샘플)') + '</span>'
    + '<a class="sbtn cref-srch" target="_blank" rel="noopener" title="구글 이미지 검색" aria-label="구글 이미지 검색">' + SEARCH_SVG + '</a></div>'   // §🎨 .sbtn 아이콘 통일(초록 알약 폐기)
    + '<div class="cref-track"><div class="cref-slot ld">불러오는 중…</div><div class="cref-slot ld"></div><div class="cref-slot ld"></div></div>';
  refResolveAndLoad(wrap, caption, title, foreign);
  return wrap;
}
// 쿼리 결정: 외국=영문(엔티티맵→번역 폴백)+구글 미국지역·영어 / 국내=국문. 그 뒤 구글버튼 href·Wikimedia 채움.
async function refResolveAndLoad(wrap, caption, title, foreign) {
  const btn = wrap.querySelector('.cref-srch'), track = wrap.querySelector('.cref-track');
  const ko = ((title || '') + ' ' + (caption || '')).replace(/\s+/g, ' ').trim();
  const setBtn = (q, ex) => { if (btn) btn.href = 'https://www.google.com/search?tbm=isch&q=' + encodeURIComponent((String(q).slice(0, 100) || '뉴스')) + (ex || ''); };
  if (!foreign) { setBtn(ko); loadRefImages((title || caption || ko).slice(0, 60), track); return; }   // 국내 = 국문
  let eq = foreignEnglish(title, caption);                   // 외국 1) 엔티티맵(즉시·정확)
  setBtn(eq || ko, '&gl=us&hl=en');                          // 버튼 먼저 세팅(클릭 데드윈도 차단) · 미국 지역·영어
  if (!eq) { eq = await translateKoEn(title || caption); if (eq) setBtn(eq, '&gl=us&hl=en'); }   // 2) 번역 폴백 → 갱신
  loadRefImages((eq || ko).slice(0, 60), track);
}
async function loadRefImages(query, track) {
  if (!track) return;
  try {
    const u = 'https://commons.wikimedia.org/w/api.php?action=query&generator=search&gsrsearch='
      + encodeURIComponent(query) + '&gsrnamespace=6&gsrlimit=8&prop=imageinfo&iiprop=url&iiurlwidth=640&format=json&origin=*';
    const r = await fetch(u); const j = await r.json();
    const pages = j && j.query && j.query.pages ? Object.values(j.query.pages) : [];
    const imgs = pages.map(p => p.imageinfo && p.imageinfo[0]).filter(ii => ii && ii.thumburl && /\.(jpe?g|png|webp)$/i.test(ii.url || '')).slice(0, 3);
    if (!imgs.length) { track.innerHTML = '<div class="cref-empty">관련 이미지 없음 — 위 ‘구글 이미지 검색’으로 찾아봐<br>(샘플 소스=위키미디어 · 추후 교체 가능)</div>'; return; }
    track.innerHTML = imgs.map(ii => '<a class="cref-slot" href="' + esc(ii.descriptionurl || ii.url) + '" target="_blank" rel="noopener"><img loading="lazy" src="' + esc(ii.thumburl) + '" alt=""></a>').join('');
  } catch { track.innerHTML = '<div class="cref-empty">이미지 조회 실패 — ‘구글 이미지 검색’ 이용</div>'; }
}

// ── 섹션 3: 카드 피드(인스타형 가로 스냅) — 이미지+캡션 1:1 · 개별/전체 다운로드 · 1b(수정·버전) 훅 ──
// cards.md = '### [카드 N]' 단위 → **텍스트**(캡션)·**이미지 프롬프트** 코드블록. images[i]와 1:1.
function parseCards(md = '') {
  const out = [];
  const re = /###\s*\[카드\s*(\d+)\][\s\S]*?\*\*텍스트\*\*\s*```(?:text)?\s*([\s\S]*?)```(?:[\s\S]*?\*\*이미지\s*프롬프트\*\*\s*```(?:text)?\s*([\s\S]*?)```)?/g;
  let m; while ((m = re.exec(md))) out.push({ n: +m[1], caption: (m[2] || '').trim(), prompt: (m[3] || '').trim() });
  return out;
}
function feedTitle(md = '') { const m = md.match(/^#\s+(.+)$/m); return m ? m[1].trim() : ''; }
// 화풍 한글 라벨 — 프롬프트 Style 줄 키워드 사전 매칭(매칭 0이면 칩 숨김 = 깨진 라벨 방지). 정본 1곳.
const STYLE_MAP = [
  [/serious drama|drama illustration|graphic novel|극화/, '극화'],   // 뉴스 기본 = 극화(만화풍 시리어스 드라마)
  [/korean manhwa|\bmanhwa\b/, '만화풍'], [/film-?noir|\bnoir\b/, '느와르'],
  [/chiaroscuro|low-key/, '명암 대비'], [/water\s?color/, '수채'], [/3d render|octane|pixar|unreal/, '3D 렌더'],
  [/photoreal|photo-?realistic|photograph/, '실사'], [/oil paint/, '유화'], [/flat\s?design|\bvector\b/, '플랫 벡터'],
  [/desaturated|muted palette/, '저채도'], [/single color accent|neon green|#0?ffd0?02/, '네온 포인트'],
];
// 화풍 = 첫 카드 이미지 프롬프트 산문(없으면 Style: 줄, 그도 없으면 전체) 키워드 매칭.
function styleSource(md = '') {
  const pm = md.match(/\*\*이미지\s*프롬프트\*\*\s*```(?:text)?\s*([\s\S]*?)```/);
  const sm = md.match(/^\s*Style:\s*(.+)$/mi);
  return (pm ? pm[1] : sm ? sm[1] : md).toLowerCase();
}
function styleLabels(md = '') {
  const s = styleSource(md), hits = [];
  for (const [re, ko] of STYLE_MAP) if (re.test(s) && !hits.includes(ko)) hits.push(ko);
  return hits.slice(0, 3);
}
// 개요 = 기사 요약(a.body)의 '한줄 요약' 머리 다음 문단(말머리·라벨 제외).
function oneLineSummary(body = '') {
  const m = body.match(/한\s*줄\s*요약[^\n]*\n+([\s\S]*?)(?=\n\s*\n|\n#|$)/);
  return m ? m[1].replace(/\s+/g, ' ').trim() : '';
}
// 분위기 — 프롬프트 Style 줄 키워드(정형). 표현기법의 값.
const MOOD_MAP = [
  [/film-?noir|\bnoir\b/, '느와르'], [/tense|suspense|thriller/, '긴장'],
  [/somber|melanchol|grief|tragic|mourn/, '비장'], [/serious|heavy|grave|drama/, '진중'],
  [/hope|warm|uplift|bright/, '희망적'], [/calm|quiet|still|serene/, '담담'],
];
function moodLabel(md = '') {
  const s = styleSource(md);
  for (const [re, ko] of MOOD_MAP) if (re.test(s)) return ko;
  return '진중';
}
// 민감 키워드 — 제목+요약 스캔(카드뉴스 민감 토픽 태그). 없으면 빈값.
const SENSITIVE_MAP = [
  [/성범죄|성착취|불법촬영|디지털\s?성|n번방/, '디지털성범죄'], [/전쟁|공습|미사일|교전|종전|개전|폭격/, '전쟁'],
  [/자살|부고|사망|숨졌|목숨|투신/, '인명피해'], [/마약|펜타닐|필로폰/, '마약'], [/아동|미성년|소아/, '아동'],
  [/참사|재난|붕괴|화재|침몰/, '참사'], [/학대|폭행|폭력|구타/, '폭력'], [/혐오|차별|증오/, '혐오'], [/테러/, '테러'],
];
// 주의(민감) 태그 — 제목+요약 스캔, 유관도(매칭 횟수)순 최대 2개.
function sensitiveTags(text = '') {
  const hits = [];
  for (const [re, ko] of SENSITIVE_MAP) {
    const m = text.match(new RegExp(re.source, 'gi'));
    if (m) hits.push({ ko, n: m.length });
  }
  hits.sort((a, b) => b.n - a.n);   // 많이 언급 = 더 유관
  return hits.slice(0, 2).map(h => h.ko);
}
function buildFeedModel(a) {
  const c = a.cards || {}, imgs = c.images || [], vmap = c.versions || {};
  const cards = parseCards(c.md);
  const base = cards.length ? cards : imgs.map((_, i) => ({ n: i + 1, caption: '', prompt: '' }));   // 파싱 실패 폴백
  return base.map((cd, i) => {
    const vh = vmap[String(cd.n)];   // 버전 히스토리(앞뒤) — [{img,text}…] v0..vK(마지막=현재)
    if (vh && vh.length > 1) {
      return {
        n: cd.n, ratio: '4/5',
        versions: vh.map((v, k) => ({ image: v.img, prompt: cd.prompt,
          caption: k === vh.length - 1 ? cd.caption : (v.text || cd.caption) })),
        cur: vh.length - 1,   // 현재 = 마지막 판
      };
    }
    return { n: cd.n, ratio: '4/5', versions: [{ caption: cd.caption, prompt: cd.prompt, image: imgs[i] || null }], cur: 0 };
  });
}

function feedSec(a, keepIdx = 0) {
  const ph = $('#ph-feed'), host = $('#feedsec'); if (!ph || !host) return;
  host.innerHTML = '';
  const c = a.cards || {}, imgs = c.images || [];
  if (!imgs.length) { ph.hidden = true; return; }     // 이미지 없으면 섹션 3 숨김(섹션 2가 텍스트·슛 담당)
  ph.hidden = false;

  const model = buildFeedModel(a);
  const title = feedTitle(c.md) || a.title || '카드 뉴스';
  const slug = title.replace(/[\\/:*?"<>|]+/g, '').replace(/\s+/g, '_').slice(0, 40) || 'nomute';
  const styles = styleLabels(c.md);
  const doneN = imgs.length, totalN = model.length, partial = c.state === 'fired_partial' || doneN < totalN;

  // 섹션 헤더 = '3. 카드 뉴스'만(총 N장은 표현기법 줄 좌측으로 이동).
  const sm = ph.querySelector('summary');
  if (sm) sm.textContent = '3. 카드 뉴스';

  // 개요 = 제목(부제·박스 밖) + 한줄요약 + 표현기법 1줄(총 N장 | 화풍 | 분위기 | 민감 키워드). 전부 기존 데이터 유도.
  const summary = oneLineSummary(a.body);
  const stags = sensitiveTags(`${title} ${summary}`);   // 최대 2개·유관도순
  const tech = `총 <b>${totalN}</b>장${partial ? ` (${totalN - doneN} 대기)` : ''}<span class="fi-sep">|</span>`
    + `화풍 : <b>${esc(styles[0] || '—')}</b><span class="fi-sep">|</span>분위기 : <b>${esc(moodLabel(c.md))}</b>`
    + (stags.length ? `<span class="fi-sep">|</span>주의 : ${stags.map(s => `<b class="acc">#${esc(s)}</b>`).join(' ')}` : '');

  const intro = document.createElement('div'); intro.className = 'feedhead';
  intro.innerHTML =
    `<div class="fi-top"><h3 class="fi-title">${esc(title)}</h3>
       <button class="fi-saveall" type="button" title="전체 다운로드">${DOWNLOAD_SVG}<span class="lbl">전체</span></button></div>
     <div class="fi-card">
       ${summary ? `<div class="fi-summary">${esc(summary)}</div>` : ''}
       <div class="fi-tech">${tech}</div>
     </div>`;
  host.appendChild(intro);
  intro.querySelector('.fi-saveall').onclick = e => saveAll(model, slug, e.currentTarget);   // 전체 다운로드(우측 정렬)

  const track = document.createElement('div'); track.className = 'feedtrack'; track.tabIndex = 0;
  track.setAttribute('aria-label', '카드 뉴스 피드 — 좌우로 한 장씩 넘겨보기');
  model.forEach((card, i) => track.appendChild(renderSlide(card, i, { slug, total: totalN, file: a.file })));
  const wrap = document.createElement('div'); wrap.className = 'feedwrap'; wrap.appendChild(track);
  if (totalN > 1) {   // 좌우 글래스 화살표(PC 넘김 — 모바일은 스와이프 병행)
    const step = dir => track.scrollBy({ left: dir * (track.clientWidth || 1), behavior: 'smooth' });
    const navP = document.createElement('button'), navN = document.createElement('button');
    navP.type = navN.type = 'button'; navP.className = 'feednav prev'; navN.className = 'feednav next';
    navP.setAttribute('aria-label', '이전'); navN.setAttribute('aria-label', '다음');
    navP.innerHTML = '‹'; navN.innerHTML = '›';
    navP.onclick = () => step(-1); navN.onclick = () => step(1);
    const updateNav = () => { const max = track.scrollWidth - track.clientWidth - 2; navP.disabled = track.scrollLeft <= 2; navN.disabled = track.scrollLeft >= max; };
    track.addEventListener('scroll', updateNav, { passive: true });
    wrap.append(navP, navN); requestAnimationFrame(updateNav);
  }
  host.appendChild(wrap);

  // 키보드 ←/→ = 한 장씩(스냅). 위치 카운트는 각 슬라이드 좌상단 오버레이.
  track.addEventListener('keydown', e => {
    const w = track.clientWidth || 1, idx = Math.round(track.scrollLeft / w);
    if (e.key === 'ArrowRight') { e.preventDefault(); track.scrollTo({ left: (idx + 1) * w, behavior: 'smooth' }); }
    if (e.key === 'ArrowLeft') { e.preventDefault(); track.scrollTo({ left: (idx - 1) * w, behavior: 'smooth' }); }
  });
  // PC: 마우스로 잡아끌어 좌우 넘김(터치는 네이티브 스와이프). 드래그 후 클릭(라이트박스)은 억제.
  track.addEventListener('mousedown', e => {
    if (e.button !== 0 || e.target.closest('.sbtn,.vbtn,.slide-fb,.feednav')) return;   // 버튼/패널 위에선 드래그 안 함
    const sl = track.scrollLeft, x0 = e.clientX; let moved = false;
    track.classList.add('dragging');
    const mv = ev => { track.scrollLeft = sl - (ev.clientX - x0); if (Math.abs(ev.clientX - x0) > 4) moved = true; };
    const up = () => {
      window.removeEventListener('mousemove', mv); window.removeEventListener('mouseup', up);
      track.classList.remove('dragging'); track._dragged = moved;
      const w = track.clientWidth || 1; track.scrollTo({ left: Math.round(track.scrollLeft / w) * w, behavior: 'smooth' });
    };
    window.addEventListener('mousemove', mv); window.addEventListener('mouseup', up); e.preventDefault();
  });
  track.addEventListener('click', e => { if (track._dragged) { e.stopPropagation(); e.preventDefault(); track._dragged = false; } }, true);   // 드래그 직후 클릭 억제

  // ── 고정 UI 오버레이 — 사진만 넘어가고 카운트·버튼·버전네비는 제자리. 스크롤 정착 시 현재 사진에 바인딩 ──
  const ui = document.createElement('div'); ui.className = 'feed-ui';
  ui.innerHTML =
    `<span class="slide-no"></span>
     <div class="slide-acts">
       <button class="sbtn fbup" type="button" aria-label="좋았던 카드">${THUMBUP_SVG}</button>
       <button class="sbtn fbdown" type="button" aria-label="아쉬운 카드">${THUMBDOWN_SVG}</button>
       <button class="sbtn edit" type="button" aria-label="이 카드 수정" title="이 카드 수정">${EDIT_SVG}</button>
       <button class="sbtn ovl" type="button" aria-label="오버레이만 투명 PNG" title="오버레이만 투명 PNG(글자+그라데이션)">${LAYERS_SVG}</button>
       <a class="sbtn save" aria-label="이 사진 저장">${DOWNLOAD_SVG}</a>
     </div>
     <div class="slide-ver">
       <button class="vbtn vprev" type="button" aria-label="이전 판">전</button>
       <button class="vbtn vnext" type="button" aria-label="다음 판">후</button>
     </div>`;
  wrap.appendChild(ui);
  const uiNo = ui.querySelector('.slide-no'), uiEdit = ui.querySelector('.edit'), uiSave = ui.querySelector('.save'),
    uiVer = ui.querySelector('.slide-ver'), uiVlbl = ui.querySelector('.vlbl'),
    uiVprev = ui.querySelector('.vprev'), uiVnext = ui.querySelector('.vnext');
  let curIdx = -1;
  const setSlideImage = (slideEl, image) => {   // 같은 자리 사진만 교체(버전 넘김)
    const im = slideEl && slideEl.querySelector('img'); if (!im) return;
    im.classList.remove('in'); im.onload = () => im.classList.add('in'); im.src = image;   // 라이트박스 끔(탭 확대 없음)
  };
  const syncFeed = idx => {   // 현재 사진(idx)에 오버레이 바인딩 — '넘어간 후 그 사진에 버튼 적용'
    const card = model[idx]; if (!card) return;
    curIdx = idx;
    const v = card.versions[card.cur] || {};
    uiNo.innerHTML = `<b>${card.n}</b>/${totalN}`;
    uiEdit.onclick = () => openEdit({ card, idx, file: a.file });
    if (v.image) { uiSave.style.display = ''; uiSave.href = v.image; uiSave.setAttribute('download', `${dlStamp(CUR_A)}_${slug}_${String(idx + 1).padStart(2, '0')}.jpg`); }
    else uiSave.style.display = 'none';
    ui.querySelector('.ovl').onclick = () => exportOverlay(card, idx, slug);   // 오버레이만 투명 PNG
    ui.querySelector('.fbup').onclick = () => onThumb(card, 'up', ui, a.file);
    ui.querySelector('.fbdown').onclick = () => onThumb(card, 'down', ui, a.file);
    applyVoteState(ui, a.file, card.n);   // 기존 투표(localStorage) 반영
    // 버전 네비 = 전/후. 여러 판일 때만 노출, 그 방향 판이 있으면 흰색+그림자(:not(:disabled)) 없으면 25% 비활성.
    const showVer = card.versions.length > 1;
    uiVer.classList.toggle('show', showVer);   // [hidden]은 .slide-ver{display}에 눌려서 안 먹음 → 클래스로 제어
    if (showVer) { uiVprev.disabled = card.cur <= 0; uiVnext.disabled = card.cur >= card.versions.length - 1; }
    const fb = ui.querySelector('.slide-fb'); if (fb) fb.remove();   // 카드 전환 = 열린 피드백 패널 닫기
    ui.classList.toggle('reshooting', !!(track.children[idx] && track.children[idx].classList.contains('reshooting')));   // 재생성 중 카드면 오버레이 조작 잠금
  };
  const changeVer = d => {
    const card = model[curIdx]; if (!card) return;
    const nc = card.cur + d; if (nc < 0 || nc >= card.versions.length) return;
    card.cur = nc; setSlideImage(track.children[curIdx], card.versions[nc].image); syncFeed(curIdx);
  };
  uiVprev.onclick = () => changeVer(-1); uiVnext.onclick = () => changeVer(1);
  track._sync = syncFeed;   // REPENDING 자동교체 후 재바인딩용
  // 스크롤로 다른 사진이 가운데 오면(인덱스 변화) 그 사진에 버튼 재바인딩
  track.addEventListener('scroll', () => {
    const idx = Math.round(track.scrollLeft / (track.clientWidth || 1));
    if (idx !== curIdx) syncFeed(idx);
  }, { passive: true });
  const startIdx = Math.min(Math.max(0, keepIdx), totalN - 1);
  if (startIdx > 0) requestAnimationFrame(() => { track.scrollLeft = startIdx * (track.clientWidth || 1); });   // REPENDING 후 위치 복원
  syncFeed(startIdx);
}

function renderSlide(card, i, ctx) {
  const v = card.versions[card.cur];
  const fig = document.createElement('div'); fig.className = 'slide'; fig.dataset.card = card.n;   // 자동 제자리 교체용
  // 슬라이드 = 사진만(버튼·카운트·버전네비는 고정 오버레이 .feed-ui로 이관 — 넘길 때 UI 그대로, 사진만 넘어감).
  if (v.image) {
    fig.innerHTML = `<div class="slide-img"><img class="slide-photo" loading="lazy" alt="카드 ${card.n}"></div>`;
    const im = fig.querySelector('img');
    im.onload = () => im.classList.add('in'); im.onerror = () => im.classList.add('in'); im.src = v.image;
    // 탭 확대(라이트박스) 끔 — 요청. (스와이프·드래그만)
  } else {
    fig.innerHTML = `<div class="slide-img"><div class="slide-wait">🍌 이미지 생성 대기…<br>다음 갱신 때 채워져</div></div>`;
  }
  return fig;   // 캡션은 이미지에 박혀 있어 미표시 — 텍스트는 수정 팝업(1b)에서 편집.
}

// 전체 다운로드 — zip 없이 순차 다운로드(250ms 간격 = 브라우저 다중 다운로드 차단 회피). iOS는 개별 ⬇ 폴백.
async function saveAll(model, slug, btn) {
  const imgs = model.map(m => m.versions[m.cur].image).filter(Boolean);
  if (!imgs.length) return;
  const lbl = (btn && btn.querySelector('.lbl')) || btn, orig = lbl ? lbl.textContent : '';
  for (let i = 0; i < imgs.length; i++) {
    const a = document.createElement('a');
    a.href = imgs[i]; a.download = `${dlStamp(CUR_A)}_${slug}_${String(i + 1).padStart(2, '0')}.jpg`;
    document.body.appendChild(a); a.click(); a.remove();
    if (lbl) lbl.textContent = `저장 중… ${i + 1}/${imgs.length}`;
    await new Promise(r => setTimeout(r, 250));
  }
  if (lbl) { lbl.textContent = '✓'; setTimeout(() => { lbl.textContent = orig || 'ALL'; }, 1800); }
}

// ── 카드 개별 변경(2차 팝업) — 텍스트(음절칩 강조)·이미지 희망 → 변경(1b) ──
let EDIT_CTX = null, edLines = [], PENDING_FOCUS = null, PENDING_EDIT = null, _edRendering = false;   // PENDING_FOCUS=빈줄 포커스 / PENDING_EDIT={li,wi}=어절칩 편집 진입 / _edRendering=재렌더 중 blur 차단
const MAX_LINES = 4;
function openEdit(o) {
  EDIT_CTX = o;
  const v = o.card.versions[o.card.cur], dlg = $('#editdlg');
  dlg.querySelector('.ed-title').textContent = `카드 ${o.card.n} 변경`;
  const img = dlg.querySelector('.ed-img'); img.src = v.image || ''; img.alt = `카드 ${o.card.n}`;
  edLines = parseEmphLines(v.caption || '');   // *마커 → 줄별 어절 배열(줄바꿈 보존·강조 어절)
  PENDING_FOCUS = null;
  $('#edWish').value = '';
  renderEditChips();
  dlg.querySelector('.ed-foot').classList.remove('confirm');   // 확인 게이트 초기화
  dlg.querySelector('.ed-body').scrollTop = 0; $('#edtop').classList.remove('show');   // 맨 위
  dlg.showModal();
  fitEditLines($('#edChips'));   // 모달 표시 직후(레이아웃 확정) 행 폭 즉시 맞춤(첫 열림 보장)
}
// "*전쟁 종전*을\n끝" → [[{text:'전쟁',on:true},…],[…]]. *마커=강조, \n=줄, 공백=어절 구분.
// 어절 중간서 강조가 끊기면(예: 종전을 = 종전 강조·을 비강조) on 통째 대신 글자맵 em[]로 보존(왕복 일치).
function parseEmphLines(s) {
  const arr = [...s]; const plain = []; const ce = []; let on = false;
  for (let p = 0; p < arr.length; p++) {
    if (arr[p] === '*') { on = !on; continue; }
    plain.push(arr[p]); ce.push(on);   // ce[i] = plain[i]가 강조 안인지
  }
  const lines = [[]]; let cur = lines[0]; let i = 0;
  while (i < plain.length) {
    const ch = plain[i];
    if (ch === '\n') { cur = []; lines.push(cur); i++; continue; }
    if (ch === ' ' || ch === '\t') { i++; continue; }   // 공백 = 어절 구분(토큰 안 만듦)
    let j = i, text = ''; const em = []; let allOn = true, allOff = true;
    while (j < plain.length && plain[j] !== ' ' && plain[j] !== '\t' && plain[j] !== '\n') {
      em.push(ce[j]); if (ce[j]) allOff = false; else allOn = false; text += plain[j]; j++;
    }
    if (allOn) cur.push({ text, on: true });
    else if (allOff) cur.push({ text, on: false });
    else cur.push({ text, on: false, em });   // 어절 중간 경계 → 글자맵 보존
    i = j;
  }
  return lines.slice(0, MAX_LINES);   // 로드 시 4줄 하드캡(방어)
}
// 카드 텍스트 제약(card-make 지침 §출력형식): 줄 ≤4 · 한글 ≤18/줄 · 가중폭 ≤19.5/줄. SOFT=14(실측 99% 보존·권장 줄넘김).
const EDLINE_HANGUL = 18, EDLINE_WIDTH = 19.5, EDLINE_SOFT = 14;
function edHangul(s) { return (s.match(/[가-힣]/g) || []).length; }
// 가중폭 = 한글/자모/전각/곡선따옴표·전각부호=1.0, 그외(영문·숫자·반각·공백)=0.5 (wcswidth/2 동치).
function edWidth(s) { let w = 0; for (const ch of s) w += /[가-힣ㄱ-ㅎㅏ-ㅣ‘-‟…　-〿＀-￯]/.test(ch) ? 1 : 0.5; return w; }
function edMarkWarn() {   // 줄별 '글자단위': 누적이 한도(가중폭19.5·한글18) 넘는 글자부터 빨강(_overFrom). 줄 길면 호박(_warn).
  for (const line of edLines) {
    let w = 0, hg = 0, over = false;
    line.forEach((wd, k) => {
      if (k) w += 0.5;   // 어절 사이 공백
      const wasOver = over; let from = -1;
      const chars = [...wd.text];
      for (let ci = 0; ci < chars.length; ci++) {
        w += edWidth(chars[ci]); hg += edHangul(chars[ci]);
        if (!over && (w > EDLINE_WIDTH || hg > EDLINE_HANGUL)) { over = true; from = ci; }   // 이 글자에서 처음 넘침
      }
      if (wasOver) { wd._over = true; wd._overFrom = 0; }          // 앞 어절서 이미 초과 → 통째 빨강
      else if (over) { wd._over = true; wd._overFrom = from >= 0 ? from : 0; }   // 이 어절의 from글자부터 빨강
      else { wd._over = false; wd._overFrom = -1; }
    });
    let tw = 0; line.forEach((wd, k) => { if (k) tw += 0.5; tw += edWidth(wd.text); });
