  .nm-body h3, .nm-body h4 { font-size:13.5px; font-weight:800; color:#fff; margin:11px 0 5px; }
  .nm-pre { white-space:pre-wrap; word-break:break-word; overflow-wrap:anywhere; background:rgba(0,0,0,.32); -webkit-backdrop-filter:blur(8px); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,.1); border-radius:9px; padding:13px 15px; margin:0; font-family:ui-monospace,SFMono-Regular,Menlo,'Apple SD Gothic Neo','Noto Sans KR',monospace; font-size:13px; line-height:1.65; color:#c8c8c8; }   /* 내부 스크롤 제거 = 펼침 → 화면 스크롤 우선 + 긴 문자열 박스 안 줄바꿈(복사 칸 벗어남 방지 · 운영자 260620) */
  .nm-secbtn { position:absolute; top:-13px; right:14px; width:34px; height:34px; display:inline-flex; align-items:center; justify-content:center; border-radius:50%; background:rgba(20,22,21,.55); -webkit-backdrop-filter:blur(12px); backdrop-filter:blur(12px); color:#fff; border:1px solid rgba(255,255,255,.18); cursor:pointer; box-shadow:0 4px 14px rgba(0,0,0,.45); transition:transform .1s, background .15s, color .15s; }
  .nm-tip .nm-secbtn { border-color:rgba(30,215,96,.5); }
  .nm-secbtn:hover { background:#1ED760; color:#000; border-color:#1ED760; }
  .nm-secbtn:active { transform:scale(.88); }
  .nm-secbtn.ok { background:#1ED760; color:#000; border-color:#1ED760; }
  .draft-scroll { scrollbar-width:thin; scrollbar-color:rgba(30,215,96,.5) rgba(255,255,255,.05); }
  .draft-scroll::-webkit-scrollbar { width:9px; }
  .draft-scroll::-webkit-scrollbar-track { background:rgba(255,255,255,.04); border-radius:9px; margin:4px 0; }
  .draft-scroll::-webkit-scrollbar-thumb { background:rgba(30,215,96,.42); border-radius:9px; border:2px solid transparent; background-clip:padding-box; }
  .draft-scroll::-webkit-scrollbar-thumb:hover { background:rgba(30,215,96,.72); background-clip:padding-box; }
  .nm-foot { margin:24px 2px 0; padding-top:16px; border-top:1px solid rgba(255,255,255,.12); }
  .nm-foot-h { font-size:11px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:#7d7d7d; margin:0 0 10px; }
  .src { list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:9px; font-size:13px; }
  .src li { display:flex; align-items:baseline; gap:8px; }
  .src .ic { flex:none; font-size:13px; line-height:1; position:relative; top:1px; }
  .src .meta { color:#9a9a9a; font-weight:500; }
  .nm-srclink { color:#fff; font-weight:800; text-decoration:none; border-bottom:1px solid rgba(30,215,96,.5); }
  .nm-srclink:hover { color:#1ED760; border-color:#1ED760; }
  .cr { text-align:center; color:#7d7d7d; font-size:12px; margin-top:18px; }
  .nm-top { position:fixed; right:18px; bottom:20px; z-index:30; width:44px; height:44px; display:none; align-items:center; justify-content:center; border-radius:50%; background:rgba(20,22,21,.62); -webkit-backdrop-filter:blur(14px) saturate(120%); backdrop-filter:blur(14px) saturate(120%); color:#1ED760; border:1px solid rgba(30,215,96,.4); cursor:pointer; box-shadow:0 8px 24px rgba(0,0,0,.5); transition:transform .14s, background .15s, color .15s; }
  .nm-top:hover { background:#1ED760; color:#000; border-color:#1ED760; transform:translateY(-2px); }
  .nm-top:active { transform:scale(.92); }
</style>
</head>
<body>
<div class="nm-root">
  <div class="nm-bg" aria-hidden="true">
    <div style="position:absolute;top:-180px;left:-150px;width:460px;height:460px;border-radius:50%;background:radial-gradient(circle at center,rgba(30,215,96,.17),rgba(30,215,96,0) 70%);filter:blur(50px);"></div>
    <div style="position:absolute;top:32%;right:-180px;width:560px;height:560px;border-radius:50%;background:radial-gradient(circle at center,rgba(20,120,70,.26),rgba(20,120,70,0) 70%);filter:blur(50px);"></div>
    <div style="position:absolute;bottom:-220px;left:18%;width:620px;height:620px;border-radius:50%;background:radial-gradient(circle at center,rgba(30,180,90,.18),rgba(10,40,28,0) 72%);filter:blur(60px);"></div>
    <div style="position:absolute;inset:0;background:radial-gradient(120% 90% at 50% 0%,rgba(255,255,255,.04),rgba(0,0,0,0) 55%);"></div>
    <div style="position:absolute;top:14%;left:62%;width:5px;height:5px;border-radius:50%;background:rgba(30,215,96,.6);box-shadow:0 0 10px 2px rgba(30,215,96,.45);"></div>
    <div style="position:absolute;top:46%;left:12%;width:4px;height:4px;border-radius:50%;background:rgba(30,215,96,.5);box-shadow:0 0 8px 2px rgba(30,215,96,.35);"></div>
    <div style="position:absolute;top:72%;left:78%;width:4px;height:4px;border-radius:50%;background:rgba(120,230,170,.45);box-shadow:0 0 9px 2px rgba(30,215,96,.3);"></div>
    <div style="position:absolute;top:30%;left:88%;width:3px;height:3px;border-radius:50%;background:rgba(180,255,210,.4);box-shadow:0 0 6px 1px rgba(30,215,96,.25);"></div>
  </div>
  <div class="nm-wrap">
    <div class="nm-head">
      <div class="nm-head-l">
        <img class="nm-logo" src="%LOGO%" alt="NO mute">
        %META%
        <h1 class="nm-title">%TITLE%</h1>
      </div>
      <button type="button" class="nm-allbtn" title="전체 복사"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;display:block"><rect x="9" y="9" width="11" height="11" rx="2"></rect><path d="M5 15V5a2 2 0 0 1 2-2h10"></path></svg><span>전체 복사</span></button>
    </div>
    %BOXES%
    <div class="nm-foot">
      <div class="nm-foot-h">출처</div>
      <ul class="src">%SRC%</ul>
      <div class="cr">%CR%</div>
    </div>
  </div>
  <button type="button" class="nm-top" title="맨 위로"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px;display:block"><path d="M12 19V6"></path><path d="M5 12l7-7 7 7"></path></svg></button>
</div>
<script>%SCRIPT%<\/script>
</body>
</html>`;
let _nmFontCss = null;   // Pretendard base64 캐시(세션 1회 fetch·재사용)
async function nmFontFace() {   // woff2 → @font-face(base64) 임베드용 CSS. 실패 시 '' → CDN 폴백.
  if (_nmFontCss !== null) return _nmFontCss;
  try {
    const r = await fetch('assets/fonts/pretendard.woff2', { cache: 'force-cache' });
    if (!r.ok) throw 0;
    const bytes = new Uint8Array(await r.arrayBuffer());
    let bin = ''; const CH = 0x8000;
    for (let i = 0; i < bytes.length; i += CH) bin += String.fromCharCode.apply(null, bytes.subarray(i, i + CH));
    _nmFontCss = "@font-face{font-family:'Pretendard Variable';font-weight:45 920;font-style:normal;font-display:swap;src:url(data:font/woff2;base64," + btoa(bin) + ") format('woff2-variations')}";
  } catch (e) { _nmFontCss = ''; }
  return _nmFontCss;
}
async function buildSummaryHtml() {
  const src = document.createElement('div');
  src.innerHTML = (($('#mdbody') || {}).innerHTML) || '';
  src.querySelectorAll('button, .copy, .ovmeta').forEach(el => el.remove());   // 뷰어 복사·더보기 + 개요칩(.ovmeta=매체·기자·IN 적재시각 등 내부 운영메타) 제거 — 공유 요약엔 불필요·출처줄과 중복·IN 유출 방지
  src.querySelectorAll('pre.clip').forEach(p => p.classList.remove('clip'));   // 클립 해제(전문 표시)
  src.querySelectorAll('img').forEach(el => el.remove());                      // 본문 이미지 제거(텍스트 요약)
  src.querySelectorAll('h1').forEach(el => el.remove());                       // 제목 h1은 헤더로 따로
  src.querySelectorAll('[style]').forEach(el => el.removeAttribute('style'));  // 뷰어 인라인 스타일 제거(서식 CSS만 적용)
  const SECBTN = '<button type="button" class="nm-secbtn" title="이 항목 복사"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width:15px;height:15px;display:block"><rect x="9" y="9" width="11" height="11" rx="2"></rect><path d="M5 15V5a2 2 0 0 1 2-2h10"></path></svg></button>';
  const tipRe = /시사점|💡/;
  const snsRe = /^\s*\[?\s*(IG|Thread|인스타|스레드|쓰레드)/i;   // 인스타·스레드(SNS) 소주제 = 다운로드 HTML서 배제 — [자유요약]은 유지(운영자 260620)
  const card = (name, inner, tip) => '<div class="nm-sec' + (tip ? ' nm-tip' : '') + '" data-sec>'
    + (name ? '<h2 class="nm-h"><span class="nm-dot"></span>' + esc(name) + '</h2>' : '')
    + inner + SECBTN + '</div>\n';
  const kids = [...src.children], isH = el => /^H[2-6]$/.test(el.tagName);
  let boxes = '', i = 0;
  while (i < kids.length) {                                                    // 헤딩 경계로 항목 분할
    if (isH(kids[i])) {
      const name = kids[i].textContent.trim();
      const parts = []; let j = i + 1;
      while (j < kids.length && !isH(kids[j])) { parts.push(kids[j]); j += 1; }
      if (snsRe.test(name)) { i = j; continue; }   // 인스타·스레드 섹션(헤딩+본문) 통째 제외 — 다운로드 HTML 불필요(운영자 260620)
      if (!parts.length) boxes += '<div class="nm-grp">' + esc(name) + '</div>\n';   // 본문 없는 그룹 헤더(예: 콘텐츠 초안)
      else if (parts.length === 1 && parts[0].tagName === 'PRE')
        boxes += card(name, '<pre class="nm-pre draft-scroll" data-body>' + parts[0].innerHTML + '</pre>', tipRe.test(name));
      else
        boxes += card(name, '<div class="nm-body draft-scroll" data-body>' + parts.map(p => p.outerHTML).join('') + '</div>', tipRe.test(name));
      i = j;
    } else {
      const parts = []; let j = i;
      while (j < kids.length && !isH(kids[j])) { parts.push(kids[j]); j += 1; }
      const body = parts.map(p => p.outerHTML).join('');
      if (body.trim()) boxes += card('', '<div class="nm-body draft-scroll" data-body>' + body + '</div>', false);
      i = j;
    }
  }
  const now = new Date(), pz = n => String(n).padStart(2, '0');
  const ymd = now.getFullYear() + '-' + pz(now.getMonth() + 1) + '-' + pz(now.getDate());
  const mdh1 = ($('#mdbody') ? $('#mdbody').querySelector('h1') : null);
  const title = (CUR_A && CUR_A.title) || (mdh1 ? mdh1.textContent.trim() : '') || '뉴스 요약';
  const cat = catBucket(CUR_A && CUR_A.category);
  const dt = CUR_A ? repDateTime(CUR_A) : '';
  const reporter = CUR_A && (CUR_A.reporter || CUR_A.byline);   // 파이프라인엔 기자 필드 없음 → 보통 미상
  const repMeta = '<span class="nm-reporter">' + (reporter ? esc(reporter) : '확인 必') + '</span>';   // 미상이면 '확인 必'(일반 글자 — 강조 없음)
  const repPar = reporter ? esc(reporter) : '확인 必';
  const mbits = [];
  if (CUR_A && CUR_A.media) mbits.push('<span class="nm-media">' + esc(CUR_A.media) + '</span>');
  mbits.push(repMeta);   // 기자(미상=확인 必) — 항상 표기
  if (dt) mbits.push('<span class="nm-date">' + dt + '</span>');
  const mline = mbits.length ? '<span class="nm-mline">' + mbits.join('<span class="nm-dotsep"></span>') + '</span>' : '';
  const badge = cat ? '<span class="nm-badge">' + esc(cat) + '</span>' : '';
  const meta = (badge || mline) ? ('<div class="nm-meta">' + badge + mline + '</div>') : '';
  let srcLi;
  if (CUR_A && (CUR_A.media || CUR_A.url)) {
    const mn = esc(CUR_A.media || '원문');
    const par = ' <span class="meta">(' + repPar + (dt ? ' · ' + dt : '') + ')</span>';   // (기자 · 보도일)
    const safeUrl = /^https?:\/\//i.test(CUR_A.url || '') ? esc(CUR_A.url) : '#';   // 스킴 화이트리스트 — javascript:/data: 등 차단
    const link = CUR_A.url ? '<a class="nm-srclink" href="' + safeUrl + '" target="_blank" rel="noopener">' + mn + '</a>' : '<span class="nm-srclink">' + mn + '</span>';
    srcLi = '<li><span class="ic">🔗</span><span>' + link + par + '</span></li>';
  } else { srcLi = '<li><span class="meta">출처 정보 없음</span></li>'; }
  const crLine = 'ⓒ ' + now.getFullYear() + '. 에디터 노뮤트(@no_mute, 인스타그램). all rights reserved. (' + ymd + ')';
  const fontCss = await nmFontFace();
  const fontHead = fontCss ? ('<style>' + fontCss + '</style>')
    : '<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin><link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@1.3.9/dist/web/variable/pretendardvariable.min.css">';
  return SUMMARY_TPL
    .replace('%FONTFACE%', () => fontHead)
    .replace(/%TITLE%/g, () => esc(title))
    .replace('%LOGO%', () => NM_LOGO)
    .replace('%META%', () => meta)
    .replace('%BOXES%', () => boxes)
    .replace('%SRC%', () => srcLi)
    .replace('%CR%', () => esc(crLine))
    .replace('%SCRIPT%', () => '(' + _expCopy.toString() + ')();');
}
let _pdfBusy = false;
async function downloadSummaryHtml() {
  if (_pdfBusy || !CUR_A) return; _pdfBusy = true;
  const btn = $('#pdfBtn'), old = btn ? btn.textContent : '';
  if (btn) { btn.textContent = '만드는 중…'; btn.disabled = true; }
  try {
    const html = await buildSummaryHtml();
    const blob = new Blob([html], { type: 'text/html;charset=utf-8' });
    const url = URL.createObjectURL(blob), a = document.createElement('a');
    a.href = url;
    a.download = dlStamp(CUR_A) + '_' + (((CUR_A && CUR_A.title) || '뉴스요약').replace(/[\\/:*?"<>|]+/g, ' ').slice(0, 60).trim() || '뉴스요약') + ' — 노뮤트.html';
    document.body.appendChild(a); a.click(); a.remove();
    setTimeout(() => URL.revokeObjectURL(url), 4000);
  } catch (e) {
    alert('요약 HTML 생성 실패: ' + ((e && e.message) || e));
  } finally {
    if (btn) { btn.textContent = old; btn.disabled = false; } _pdfBusy = false;
  }
}
$('#pdfBtn').addEventListener('click', downloadSummaryHtml);
$('#revFab').addEventListener('click', openRev);
$('#revX').addEventListener('click', () => revdlg.close());
revdlg.addEventListener('click', e => { if (e.target === revdlg) revdlg.close(); });   // 바깥(백드롭) 클릭 닫기
revdlg.addEventListener('close', () => { resetRevSend(); updateRevFab(); });            // 닫히면 재확인 해제 + FAB 구간 재평가(복원)
$('#revText').addEventListener('input', () => { updateRevClip(); resetRevSend(); });    // 텍스트 바꾸면 재확인 취소(오발사 방지)
$('#revClip').addEventListener('click', async () => {
  const ta = $('#revText'), b = $('#revClip');
  if (ta.value.trim()) {
    try { await navigator.clipboard.writeText(ta.value); b.innerHTML = CHECK_SVG; b.classList.add('ok'); $('#revStatus').textContent = '복사됨'; setTimeout(() => { b.classList.remove('ok'); updateRevClip(); }, 1200); } catch { $('#revStatus').textContent = '복사 실패'; }
  } else {
    try { const t = await navigator.clipboard.readText(); ta.value = t; ta.focus(); updateRevClip(); } catch { $('#revStatus').textContent = '클립보드 권한 막힘 — 직접 붙여넣어'; }
  }
});
$('#revSend').addEventListener('click', async () => {
  if (CUR && isRevising(CUR)) { $('#revStatus').textContent = '수정 반영 중 — 끝나면 다시'; return; }   // 진행 중 재전송 차단 — 경로 2: 전송 버튼
  const instruction = $('#revText').value.trim();
  if (!instruction) { $('#revStatus').textContent = '수정 지시를 한 줄 적어줘'; return; }
  if (!CUR) { $('#revStatus').textContent = '대상 카드를 못 찾음'; return; }
  const btn = $('#revSend'), lbl = btn.querySelector('span');
  if (!btn.classList.contains('confirm')) {   // 1차 클릭 = 재확인(아직 전송 안 함)
    btn.classList.add('confirm'); if (lbl) lbl.textContent = '재확인 →';
    $('#revStatus').textContent = '확인 — 다시 누르면 수정 요청을 보냄';
    clearTimeout(revConfirmT); revConfirmT = setTimeout(resetRevSend, 4000);   // 4초 내 재확인 없으면 원복
    return;
  }
  clearTimeout(revConfirmT);                   // 2차 클릭 = 실제 전송
  btn.classList.remove('confirm'); if (lbl) lbl.textContent = '수정 →';
  btn.disabled = true; $('#revStatus').textContent = '보내는 중…';
  try {
    const r = await fetch('api/revise', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ file: CUR, instruction }) });
    const d = await r.json().catch(() => ({}));
    if (r.ok && d.ok) {
      btn.classList.add('firing');   // PICK과 동일한 초록 게이지 모션(.firing → pickGauge)
      $('#revStatus').textContent = '✅ 수정 요청됨 — 잠시 후 반영돼';
      $('#revText').value = ''; updateRevClip();
      startRevising(CUR);   // '변경 중' 표시 시작 — 버튼 물결·피드바 펄스·IG/Thread 소주제 + 완료 폴링
      setTimeout(() => { revdlg.close(); btn.classList.remove('firing'); btn.disabled = false; }, 1600);   // 닫힐 때까지 disabled(중복전송 차단)
      return;
    }
    $('#revStatus').textContent = '❌ ' + (d.error || `서버 ${r.status}`);
  } catch { $('#revStatus').textContent = '❌ 전송 실패 (백엔드 배선 전이면 예상된 동작)'; }
  btn.disabled = false;
});
// ── PC(마우스) 전용: 팝업 모달 헤더 잡고 드래그 이동(메뉴 아님 · 운영자 260619) ──
function makeDraggable(dlg, handleSel) {
  if (!dlg || !window.matchMedia('(pointer:fine)').matches) return;   // 정밀 포인터(마우스)만 — 터치 제외
  const h = dlg.querySelector(handleSel); if (!h) return;
  h.classList.add('drag-handle');
  let dx = 0, dy = 0, sx = 0, sy = 0, bx = 0, by = 0, bL = 0, bT = 0, W = 0, on = false;   // dx/dy=현재 오프셋 · bx/by=드래그 시작 오프셋(고정)
  const move = e => {
    if (!on) return;
    let nx = bx + (e.clientX - sx), ny = by + (e.clientY - sy);   // 시작오프셋 + 시작마우스 기준 이동량 = 선형 1:1(누적 폭주 차단)
    nx = Math.max((80 - W) - bL, Math.min((window.innerWidth - 80) - bL, nx));   // 좌우 최소 80px 노출
    ny = Math.max(-bT, Math.min((window.innerHeight - 46) - bT, ny));            // 헤더 항상 보이게
    dlg.style.setProperty('transform', 'translate(' + nx + 'px,' + ny + 'px)', 'important');   // 진입애니/CSS 어떤 transform보다 우선
    dx = nx; dy = ny;   // 현재 오프셋 갱신(클램프 base·다음 드래그용 — move 계산엔 안 씀)
  };
  const end = () => { on = false; window.removeEventListener('pointermove', move); window.removeEventListener('pointerup', end); };
  h.addEventListener('pointerdown', e => {
    if (e.button !== 0 || e.target.closest('button, a, input, textarea, select, label, .dlg-prog')) return;   // 헤더 내 컨트롤 클릭은 드래그 아님
    on = true; sx = e.clientX; sy = e.clientY; bx = dx; by = dy;   // 시작마우스 + 시작오프셋 스냅샷(드래그 동안 고정)
    dlg.style.animation = 'none';   // 진입 애니가 transform 고정하는 것 확실 차단(fill-mode 무관)
    const r = dlg.getBoundingClientRect();
    bL = r.left - dx; bT = r.top - dy; W = r.width;   // 자연(translate 전) 위치 역산
    window.addEventListener('pointermove', move);     // document 레벨 = 포인터가 헤더 밖으로 나가도 끊김 없이 추적(setPointerCapture 실패 무관)
    window.addEventListener('pointerup', end);
    e.preventDefault();
  });
  dlg.addEventListener('close', () => { dx = dy = 0; dlg.style.transform = ''; dlg.style.animation = ''; on = false; });   // 닫으면 중앙 복귀 + 애니 복원(다음 열기 재생)
}
[['#dlg', '.dlg-h'], ['#editdlg', '.ed-h'], ['#askdlg', '.askhead'], ['#revdlg', '.askhead'], ['#pastedlg', '.askhead'], ['#tooldlg', '.tool-h']]
  .forEach(([d, sel]) => makeDraggable($(d), sel));

load();
loadRevising();   // 새로고침 전 진행 중이던 수정 복원(잠금·완료감지·라이브 전환 유지)
loadMessages();
loadCandidates();   // eager — 속보(breaking) 감지로 링/토스트(수집함 미진입이어도 알림)
loadPickFails();    // eager — 픽 분석 실패(전문 필요) 감지로 앰버 링/토스트(수집함 밖에서도 알림)
// 속보 라이브 감지 — 앱이 보일 때만 주기적으로 후보 재확인(데이터 ~15분 주기라 120s면 충분). quiet=목록 안 흔듦.
setInterval(() => { if (document.visibilityState === 'visible') { loadCandidates(true); loadPickFails(); loadMessages(); } }, 120000);
document.addEventListener('visibilitychange', () => { if (document.visibilityState === 'visible') { loadCandidates(true); loadPickFails(); loadMessages(); } });
setViewhead('feed');   // 기본 탭=뉴스요약 헤더 초기화
try { const _lt = localStorage.getItem('nomute_tab'); if (_lt && _lt !== 'feed' && ['scrap', 'sns'].includes(_lt)) showTab(_lt); } catch {}   // 새로고침 시 마지막 탭 복원
</script>
</body>
</html>
