        seq.push({ c: ' ', e: charEm(prev, pc.length - 1) && charEm(wd, 0) });
      }
      chars.forEach((c, ci) => seq.push({ c, e: charEm(wd, ci) }));
    });
    let out = '', on = false;
    seq.forEach(s => { if (s.e && !on) { out += '*'; on = true; } else if (!s.e && on) { out += '*'; on = false; } out += s.c; });
    if (on) out += '*';   // 줄끝 강조 닫기(합성기 '줄넘김 강조 금지')
    return out;
  }).filter(s => s !== '').join('\n');   // 빈 줄(앞·중간·끝) 제거 → 카드에 빈 줄 안 들어감
}
// 변경 흐름 — '변경'=확인 게이트 노출, '확인'=단일 카드 재발사(유료 Gemini, mode=edit) → 캐러셀 복귀·자동 제자리 교체.
const REPENDING = new Map();   // key `${file}#${card}` → {file, card, oldImg, textOnly, tries} — 카드별 동시 재생성 추적(단일슬롯 덮어쓰기 버그 수정)
let _polling = false;
const rpKey = (file, card) => file + '#' + card;

// ── 요약 수정(revise) 진행 표시 — 회차(rev)는 서버 정본(queue 프론트매터 → articles.json a.rev) ──
// 수정요청 전송 → 그 기사 '진행 중'(클라 임시: 연필 물결+잠금·피드바 펄스·소주제 펄스·(변경 중)).
// articles.json 폴링으로 a.rev가 올라가면 완료 → 임시상태 해제. 색(노랑 등)은 a.rev로 결정 = 영구·전 기기 일관·물결 없음.
const REVISING = new Map();   // file → { reqRev(요청시 서버 회차), ts } — 진행 중(물결·잠금) 클라 임시상태
const REV_PEND_KEY = 'nomute_rev_pending';   // 진행 상태 영속 — 새로고침/앱종료에도 잠금·완료전환·reqRev 유지
const RV_COLORS = ['15,253,2', '255,210,74', '12,208,247'];   // 0 원본 초록 · 1 노랑(이슈색) · 2 파랑(SNS) · 순환
const revColor = g => RV_COLORS[(((g % 3) + 3) % 3)];
const artRev = file => { const a = DATA.find(x => x.file === file); return a ? (Number(a.rev) || 0) : 0; };   // 서버 회차
const isRevising = file => REVISING.has(file);
const saveRevising = () => { try { localStorage.setItem(REV_PEND_KEY, JSON.stringify([...REVISING])); } catch {} };
function loadRevising() {   // 부팅 복원 — 진행 중이던 수정(20분 내)만 되살려 폴 재개(reqRev 원값 보존 = 완료 오인 방지)
  try {
    const now = Date.now();
    for (const [file, v] of JSON.parse(localStorage.getItem(REV_PEND_KEY) || '[]'))
      if (v && typeof v.ts === 'number' && now - v.ts < 20 * 60000) REVISING.set(file, v);
  } catch {}
  if (REVISING.size) startRevisePoll();
}
function startRevising(file) {
  if (!file) return;
  REVISING.set(file, { reqRev: artRev(file), ts: Date.now() });   // 요청 시점 서버 회차 스냅(완료 = a.rev가 이보다 ↑)
  saveRevising();
  render();                                                  // 피드 카드 물결·잠금 반영
  if ($('#dlg').open && CUR === file) applyReviseMarks();
  startRevisePoll();
}
let _revPoll = null;
function startRevisePoll() {
  if (_revPoll) return;
  _revPoll = setInterval(async () => {
    await load();                                            // DATA 갱신(articles.json = a.rev 최신)
    let changed = false;
    for (const [file, v] of [...REVISING]) {
      if (artRev(file) > v.reqRev) {                         // 서버 회차 ↑ = 수정 반영 완료
        REVISING.delete(file); changed = true;
        if ($('#dlg').open && CUR === file) {                // 열린 본문 자동 갱신(스크롤 위치 보존)
          const a = DATA.find(x => x.file === file);
          if (a) { const dlg = $('#dlg'), st = dlg ? dlg.scrollTop : 0; open(a); if (dlg) dlg.scrollTop = st; }
        }
      } else if (Date.now() - v.ts > 20 * 60000) {           // 20분 폴백 — revise 최대 15분+빌드 여유(색은 a.rev로 추후 자동 반영)
        REVISING.delete(file); changed = true;
      }
    }
    if (changed) { saveRevising(); render(); if ($('#dlg').open && CUR) applyReviseMarks(); }
    if (!REVISING.size) { clearInterval(_revPoll); _revPoll = null; }
  }, 20000);
}
// 연필 FAB — 진행 중: 현재→다음 색 왕복 물결+잠금 / 완료(a.rev>0): 회차색 고정(물결 X) / 원본: 평소.
function applyReviseFab() {
  const fab = $('#revFab'); if (!fab) return;
  const pending = !!(CUR && isRevising(CUR));
  const g = CUR ? artRev(CUR) : 0;
  fab.classList.toggle('revving', pending);
  fab.classList.toggle('locked', pending);
  fab.classList.toggle('revdone', !pending && g > 0);
  if (pending) {
    fab.style.setProperty('--rv-from', 'rgb(' + revColor(g) + ')');
    fab.style.setProperty('--rv-to', 'rgb(' + revColor(g + 1) + ')');
    fab.style.setProperty('--rv-ring', 'rgba(' + revColor(g + 1) + ',.5)');
  } else if (g > 0) {
    fab.style.setProperty('--rv-solid', revColor(g));
  }
}
// 본문 IG·Thread 소주제 — 진행 중: 강조↔노랑 펄스 + (변경 중) 흰색 / 완료(a.rev>0): 노랑 고정.
function applyReviseMarks() {
  const root = $('#mdbody'); if (!root) { applyReviseFab(); return; }
  const pending = !!(CUR && isRevising(CUR));
  const g = CUR ? artRev(CUR) : 0;
  root.querySelectorAll('h3').forEach(h => {
    const old = h.querySelector('.revchg'); if (old) old.remove();
    h.classList.remove('revsec', 'revsec-done'); h.style.removeProperty('--rv-solid');
    if (!/\[\s*(IG|Thread|인스타|스레드|쓰레드)/i.test(h.textContent)) return;
    if (pending) {                                           // 진행 중 = 펄스 + (변경 중)
      h.classList.add('revsec');
      const s = document.createElement('i'); s.className = 'revchg'; s.textContent = ' (변경 중)';
      h.appendChild(s);
    } else if (g > 0) {                                      // 완료 = 노랑 고정(펄스 없음)
      h.classList.add('revsec-done');
      h.style.setProperty('--rv-solid', revColor(g));
    }
  });
  applyReviseFab();
}
function submitEdit() {
  if (!EDIT_CTX) return;
  if (!buildEmphText().trim()) { alert('텍스트가 비어 있어.'); return; }
  if (edAnyOver()) { alert('빨간 글자 = 카드 한 줄 한도(한글 18자) 초과야.\n그 어절을 줄이거나 지우고, 필요하면 + 로 새 줄을 만들어줘.'); return; }
  // 이미지 수정 희망이 비면 = 문구만 교체(기존 장면 그대로 로컬 합성·과금 0) → 확인 없이 바로 변경.
  // 채우면 = 이미지까지 재생성(유료) → 한 번만 확인.
  if (!$('#edWish').value.trim()) { fireEdit(); return; }
  $('#editdlg .ed-cmsg').textContent = '이미지까지 다시 생성할까요? (유료)';
  $('#editdlg .ed-foot').classList.add('confirm');
}
function fireEdit() {
  if (!EDIT_CTX) return;
  const ctx = EDIT_CTX, text = buildEmphText().trim(), wish = $('#edWish').value.trim();
  // 확인 게이트(유료 재생성)면 '확인' 버튼, 아니면(문구만) '변경' 버튼에 진행표시.
  const btn = $('#editdlg .ed-foot').classList.contains('confirm') ? $('#editdlg .ed-cyes') : $('#edGo');
  const label = btn.textContent; btn.disabled = true; btn.textContent = '변경 중…';
  const reset = () => { btn.disabled = false; btn.textContent = label; };
  fetch('api/make-cards', {
    method: 'POST', headers: { 'content-type': 'application/json' },
    body: JSON.stringify({ article: ctx.file, mode: 'edit', card: String(ctx.card.n), text, wish }),
  }).then(async r => ({ ok: r.ok, j: await r.json().catch(() => ({})) }))
    .then(({ ok, j }) => {
      reset();
      if (ok && j.ok) {
        REPENDING.set(rpKey(ctx.file, ctx.card.n), { file: ctx.file, card: ctx.card.n, oldImg: ctx.card.versions[ctx.card.cur].image, textOnly: !wish, tries: 0 });
        markReshooting(ctx.card.n, !wish);   // wish 비면 = 문구만(이미지 유지) → 배지 문구 구분
        $('#editdlg').close();          // 보던 캐러셀 그대로(스크롤 유지)
        pollWhilePending();
      } else { alert(j.error || `실패 (${ok ? 'ok' : 'err'})`); }
    }).catch(e => { reset(); alert('요청 실패: ' + e.message); });
}
function markReshooting(n, textOnly) {
  const s = $(`#feedsec .slide[data-card="${n}"]`); if (!s) return;
  s.classList.add('reshooting');
  const ui = $('#feedsec .feed-ui'); if (ui) ui.classList.add('reshooting');   // 편집은 현재 표시 카드 = 오버레이 즉시 잠금(중복 발사 방지)
  if (!s.querySelector('.reshoot-badge')) {
    const b = document.createElement('div'); b.className = 'reshoot-badge';
    b.textContent = textOnly ? '✍️ 문구 바꾸는 중…' : '🍌 다시 그리는 중…';
    (s.querySelector('.slide-img') || s).appendChild(b);
  }
}
// 18s 간격 단일 루프 — Map 전체를 훑어 새 이미지 오면 제자리 교체(load). 카드당 상한 ~6분(20회).
function reapplyReshooting() {   // 재렌더로 사라진 잠금 배지를 대기 중 카드에 재적용
  if (!REPENDING.size || !$('#dlg').open || !CUR) return;
  for (const v of REPENDING.values()) if (v.file === CUR) markReshooting(v.card, v.textOnly);
}
async function pollWhilePending() {
  if (_polling || !REPENDING.size) return;   // 단일 루프(중복 폴러 방지)
  _polling = true;
  while (REPENDING.size) {
    await new Promise(res => setTimeout(res, 18000));
    for (const [k, v] of [...REPENDING]) { v.tries++; if (v.tries > 20) REPENDING.delete(k); }   // 상한 초과 = 포기
    if (!REPENDING.size) break;
    await load();
  }
  _polling = false;
}


// ── 따봉/다운 피드백 누적 — 좋았던/아쉬운 카드의 (텍스트+프롬프트)를 측면(이미지/텍스트)·의견과 적재 → 품질개선 데이터 ──
function openFeedback(card, vote, slideEl, file) {
  const host = slideEl.querySelector('.slide-img') || slideEl; if (!host) return;   // 오버레이(.feed-ui)면 자신이 host
  const ex = host.querySelector('.slide-fb'); if (ex) { ex.remove(); }
  const up = vote === 'up';
  const fb = document.createElement('div'); fb.className = 'slide-fb';
  fb.innerHTML =
    `<button type="button" class="fb-x" aria-label="닫기">✕</button>
     <div class="fb-vote">${up ? '👍 좋았던 점' : '👎 아쉬운 점'} <span class="fb-sub">— 무엇에 대해?</span></div>
     <div class="fb-aspect"><button type="button" data-a="image" class="on">이미지</button><button type="button" data-a="text">텍스트</button></div>
     <input class="fb-comment" maxlength="300" placeholder="의견">
     <div class="fb-act"><button type="button" class="fb-save">기록</button></div>`;
  let aspect = 'image';
  fb.querySelectorAll('.fb-aspect button').forEach(b => b.onclick = () => {
    aspect = b.dataset.a; fb.querySelectorAll('.fb-aspect button').forEach(x => x.classList.toggle('on', x === b));
  });
  fb.querySelector('.fb-x').onclick = () => fb.remove();
  fb.querySelector('.fb-save').onclick = () => submitFeedback({ file, card: card.n, vote, aspect, comment: fb.querySelector('.fb-comment').value.trim() }, fb, slideEl);
  host.appendChild(fb);
  setTimeout(() => fb.querySelector('.fb-comment').focus({ preventScroll: true }), 50);
}
function submitFeedback(p, fb, slideEl) {
  const save = fb.querySelector('.fb-save'); save.disabled = true; save.textContent = '기록 중…';
  fetch('api/feedback', {
    method: 'POST', headers: { 'content-type': 'application/json' },
    body: JSON.stringify({ action: 'record', article: p.file, card: String(p.card), vote: p.vote, aspect: p.aspect, comment: p.comment }),
  }).then(async r => ({ ok: r.ok, j: await r.json().catch(() => ({})) }))
    .then(({ ok, j }) => {
      if (ok && j.ok) {
        setVote(p.file, p.card, p.vote);            // 1표 상태 저장 → 반대쪽 잠금
        applyVoteState(slideEl, p.file, p.card);
        fb.innerHTML = '<div class="fb-done">기록됐어 — 고마워! 🙌</div>';
        setTimeout(() => fb.remove(), 1100);
      } else { save.disabled = false; save.textContent = '기록'; alert(j.error || '실패'); }
    }).catch(e => { save.disabled = false; save.textContent = '기록'; alert('요청 실패: ' + e.message); });
}
// ── 투표 상태(1카드 1표·localStorage) — 기록하면 반대쪽 잠금, 같은 쪽 재탭=취소(DB 삭제) ──
function getVote(file, card) { try { return (JSON.parse(localStorage.getItem('nomute_fb') || '{}'))[`${file}#${card}`] || null; } catch { return null; } }
function setVote(file, card, v) {
  let m = {}; try { m = JSON.parse(localStorage.getItem('nomute_fb') || '{}'); } catch { /* noop */ }
  if (v) m[`${file}#${card}`] = v; else delete m[`${file}#${card}`];
  try { localStorage.setItem('nomute_fb', JSON.stringify(m)); } catch { /* noop */ }
}
function applyVoteState(fig, file, card) {
  const v = getVote(file, card), up = fig.querySelector('.fbup'), down = fig.querySelector('.fbdown');
  if (!up || !down) return;
  up.classList.toggle('voted', v === 'up'); down.classList.toggle('voted', v === 'down');
  up.disabled = v === 'down'; down.disabled = v === 'up';   // 하나 기록되면 다른 쪽 비활성
}
function onThumb(card, vote, fig, file) {
  const cur = getVote(file, card.n);
  if (cur === vote) { confirmCancelVote(card, vote, fig, file); return; }   // 같은 쪽 재탭 = 취소
  if (cur) return;                                                          // 다른 쪽 이미 투표 = 잠김(disabled)
  openFeedback(card, vote, fig, file);                                      // 미투표 = 패널(크로스전환은 패널서)
}
function confirmCancelVote(card, vote, fig, file) {
  const host = fig.querySelector('.slide-img') || fig; if (!host) return;   // 오버레이(.feed-ui)면 자신이 host
  const ex = host.querySelector('.slide-fb'); if (ex) ex.remove();
  const fb = document.createElement('div'); fb.className = 'slide-fb';
  fb.innerHTML = `<button type="button" class="fb-x" aria-label="닫기">✕</button>
     <div class="fb-vote">${vote === 'up' ? '👍 좋아요' : '👎 아쉬워요'} 취소할까요? <span class="fb-sub">— 기록도 삭제돼</span></div>
     <div class="fb-act"><button type="button" class="fb-save">취소(삭제)</button></div>`;
  fb.querySelector('.fb-x').onclick = () => fb.remove();
  fb.querySelector('.fb-save').onclick = () => {
    const save = fb.querySelector('.fb-save'); save.disabled = true; save.textContent = '삭제 중…';
    fetch('api/feedback', {
      method: 'POST', headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ action: 'delete', article: file, card: String(card.n), vote }),
    }).then(async r => ({ ok: r.ok, j: await r.json().catch(() => ({})) }))
      .then(({ ok, j }) => {
        if (ok && j.ok) { setVote(file, card.n, null); applyVoteState(fig, file, card.n); fb.innerHTML = '<div class="fb-done">취소됐어 ✓</div>'; setTimeout(() => fb.remove(), 900); }
        else { save.disabled = false; save.textContent = '취소(삭제)'; alert(j.error || '실패'); }
      }).catch(e => { save.disabled = false; save.textContent = '취소(삭제)'; alert('요청 실패: ' + e.message); });
  };
  host.appendChild(fb);
}
// ── 슛 PIN 입력 UI ──
// confirm/prompt 대체. #pindlg(4칸)로 4자리 PIN을 받아 Promise로 돌려준다.
// 한 자 입력→다음 칸 자동이동, 4번째 입력→엔터 없이 자동 resolve. 취소=null.
// 숫자만(비숫자 무시), 백스페이스로 이전 칸, 4자리 붙여넣기 분배. ⚠️ PIN은 세션/로컬에 저장 안 함(매번 입력).
let _pinWired = false, _pinResolve = null;
function _pinCells() { return [...$('#pindlg').querySelectorAll('.pin-cell')]; }
function _pinValue() { return _pinCells().map(c => c.value).join(''); }
function _pinReset() {                       // 칸 비우고 첫 칸 포커스
  const cells = _pinCells();
  cells.forEach(c => { c.value = ''; c.classList.remove('filled'); });
  const boxes = $('#pinboxes'); boxes.classList.remove('err', 'shake');
  cells[0].focus();
}
function _pinShake(msg) {                     // 오답: 흔들기 + 에러문구 + 초기화 재입력
  const boxes = $('#pinboxes'), err = $('#pinerr');
  if (err) err.textContent = msg || '암호가 틀렸어. 다시.';
  boxes.classList.add('err');
  boxes.classList.remove('shake'); void boxes.offsetWidth;   // 리플로우 → 애니 재시작
  boxes.classList.add('shake');
  const cells = _pinCells();
  cells.forEach(c => { c.value = ''; c.classList.remove('filled'); });
  cells[0].focus();
}
function _wirePin() {                         // 입력 배선(1회만)
  if (_pinWired) return; _pinWired = true;
  const dlg = $('#pindlg'), cells = _pinCells();
  cells.forEach((cell, i) => {
    cell.addEventListener('input', () => {
      cell.value = (cell.value.match(/\d/g) || []).join('').slice(-1);   // 숫자 1자만 유지
      cell.classList.toggle('filled', !!cell.value);
      $('#pinboxes').classList.remove('err');
      if (cell.value && i < cells.length - 1) cells[i + 1].focus();      // 다음 칸 자동 이동
      if (_pinValue().length === cells.length) {                          // 4자리 다 차면 자동 인증(엔터 X)
        const v = _pinValue();
        if (_pinResolve) { const r = _pinResolve; _pinResolve = null; r(v); }
      }
    });
    cell.addEventListener('keydown', e => {
      if (e.key === 'Backspace' && !cell.value && i > 0) { cells[i - 1].focus(); e.preventDefault(); }   // 빈 칸 백스페이스 → 이전 칸
      else if (e.key === 'ArrowLeft' && i > 0) { cells[i - 1].focus(); e.preventDefault(); }
      else if (e.key === 'ArrowRight' && i < cells.length - 1) { cells[i + 1].focus(); e.preventDefault(); }
    });
    cell.addEventListener('paste', e => {                                 // 4자리 붙여넣기 → 칸 분배
      const txt = (e.clipboardData || window.clipboardData).getData('text') || '';
      const digits = (txt.match(/\d/g) || []).slice(0, cells.length);
      if (!digits.length) return;
      e.preventDefault();
      cells.forEach((c, k) => { c.value = digits[k] || ''; c.classList.toggle('filled', !!c.value); });
      const last = Math.min(digits.length, cells.length) - 1;
      cells[Math.min(last + 1, cells.length - 1)].focus();
      if (_pinValue().length === cells.length && _pinResolve) {
        const r = _pinResolve; _pinResolve = null; r(_pinValue());
      }
    });
  });
  // dialog가 닫히면(취소·esc·백드롭) 대기 중 Promise를 null로 정리
  dlg.addEventListener('close', () => { if (_pinResolve) { const r = _pinResolve; _pinResolve = null; r(null); } });
}
// PIN 한 번 받기 — err 있으면 흔들기 표시 후 재입력. resolve = 4자리 문자열 또는 null(취소)
function askPin(err) {
  _wirePin();
  const dlg = $('#pindlg');
  if (!dlg.open) dlg.showModal();
  if (err) _pinShake(err); else { $('#pinerr').textContent = ''; _pinReset(); }
  // showModal 직후 자동 포커스 보장(브라우저 따라 빗나가는 케이스 대비)
  requestAnimationFrame(() => { const c = _pinCells()[0]; if (c && !_pinValue()) c.focus(); });
  return new Promise(res => { _pinResolve = res; });
}

async function makeCards(target, btn, mode) {
  const shoot = mode === 'shoot';
  // L: PIN 게이트 제거 — 바로 발사(사용자 요청 260614·지출 직접 모니터링·내일 재설정 예정).
  // (PIN UI/askPin/#pindlg는 dead로 남겨둠 — 재게이트 시 makeCards만 되돌리면 됨.)
  try {
    const r = await fetch('api/make-cards', {
      method: 'POST', headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ article: target, mode: shoot ? 'shoot' : 'full' }),
    });
    const j = await r.json().catch(() => ({}));
    if (r.ok && j.ok) {
      if (btn) btn.outerHTML = `<div class="genstat live">🚀 생성됨 — 워크플로 시작, 1~2분 내 ⏳로 바뀜</div>`;
      return;
    }
    alert(j.error || `실패 (${r.status})`);
  } catch (e) { alert('요청 실패: ' + e.message); }
}
const COPY_SVG = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>';
const PASTE_SVG = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/></svg>';
const DOWNLOAD_SVG = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="M7 11l5 5 5-5"/><path d="M5 21h14"/></svg>';
const LAYERS_SVG = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 2 7l10 5 10-5-10-5z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/></svg>';
// ── 오버레이만 투명 PNG (클라이언트 canvas — card_news.py 렌더 포팅: 하단 그라데이션 + 글자, 투명 배경) ──
const OVL = { W: 1080, H: 1350, FS: 54, LH: 88, SX: 87, SY: 888, HL: '#0FFD02', DEF: '#ffffff' };
const OVL_OPEN = '“‘「『«‹', OVL_CLOSE = '”’」』»›';
let _ovlFont = false;
async function ovlLoadFont() {   // 카드 폰트(NotoSansCJK Bold) 근사 = Noto Sans KR 700
  if (_ovlFont) return;
  if (!document.getElementById('ovl-font')) {
    const l = document.createElement('link'); l.id = 'ovl-font'; l.rel = 'stylesheet';
    l.href = 'https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@700&display=block';
    document.head.appendChild(l);
  }
  try { await document.fonts.load('700 54px "Noto Sans KR"'); await document.fonts.ready; } catch { /* 실패 시 시스템 한글 폴백 */ }
  _ovlFont = true;
}
function ovlGradient(ctx) {   // 상단 38.6% 투명 → 하단 alpha 236 (곡선 a=1.268 b=3.217)
  const start = Math.floor(OVL.H * 0.386), a = 1.268, b = 3.217;
  for (let row = start; row < OVL.H; row++) {
    const t = (row - start) / (OVL.H - start);
    let al = (Math.pow(t, a) / (Math.pow(t, a) + Math.pow(1 - t, b))) * 236;
    al = Math.max(0, Math.min(236, al));
    ctx.fillStyle = `rgba(0,0,0,${(al / 255).toFixed(4)})`;
    ctx.fillRect(0, row, OVL.W, 1);
  }
}
function ovlSegs(line) {   // *강조* → [{h:true|false, text}]
  const out = [];
  line.split(/(\*[^*]+\*)/).forEach(p => { if (!p) return; (p.startsWith('*') && p.endsWith('*')) ? out.push({ h: true, text: p.slice(1, -1) }) : out.push({ h: false, text: p }); });
  return out;
}
function ovlOffsets(ctx, lines) {   // 여는 따옴표가 줄 넘어 닫힐 때 그 사이 줄 들여쓰기(card_news compute_line_offsets)
  const offs = [], stack = [], ascii = { '"': false, "'": false }, mw = ch => ctx.measureText(ch).width;
  for (const line of lines) {
    let cur = stack.reduce((s, w) => s + w, 0);
    for (const ch in ascii) if (ascii[ch]) cur += mw(ch);
    offs.push(cur);
    for (const ch of line.replace(/\*([^*]+)\*/g, '$1')) {
      if (OVL_OPEN.includes(ch)) stack.push(mw(ch));
      else if (OVL_CLOSE.includes(ch)) { if (stack.length) stack.pop(); }
      else if (ch === '"' || ch === "'") ascii[ch] = !ascii[ch];
    }
  }
  return offs;
}
async function exportOverlay(card, idx, slug) {
  const cap = ((card.versions[card.cur] || {}).caption || '').trim();
  if (!cap) { alert('이 카드는 텍스트가 없어 — 오버레이 뽑을 게 없음.'); return; }
  const btn = $('#feedsec .feed-ui .sbtn.ovl'); if (btn) btn.classList.add('busy');
  try {
    await ovlLoadFont();
    const cv = document.createElement('canvas'); cv.width = OVL.W; cv.height = OVL.H;
    const ctx = cv.getContext('2d');
    ovlGradient(ctx);
    ctx.font = `700 ${OVL.FS}px "Noto Sans KR","Apple SD Gothic Neo","Malgun Gothic",sans-serif`;
    ctx.textBaseline = 'top'; ctx.textAlign = 'left';
    const lines = cap.split('\n'), offs = ovlOffsets(ctx, lines);
    lines.forEach((line, i) => {
      let x = OVL.SX + offs[i]; const y = OVL.SY + i * OVL.LH;
      ovlSegs(line).forEach(seg => { ctx.fillStyle = seg.h ? OVL.HL : OVL.DEF; ctx.fillText(seg.text, x, y); x += ctx.measureText(seg.text).width; });
    });
    cv.toBlob(blob => {
      if (!blob) { alert('PNG 생성 실패'); return; }
      const url = URL.createObjectURL(blob), a = document.createElement('a');
      a.href = url; a.download = `${dlStamp(CUR_A)}_${slug}_overlay_${String(idx + 1).padStart(2, '0')}.png`;
      document.body.appendChild(a); a.click(); a.remove(); setTimeout(() => URL.revokeObjectURL(url), 1500);
    }, 'image/png');
  } catch (e) { alert('오버레이 생성 실패: ' + e.message); }
  finally { if (btn) btn.classList.remove('busy'); }
}
const EDIT_SVG = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>';
const THUMBUP_SVG = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 10v11H4a1 1 0 0 1-1-1v-9a1 1 0 0 1 1-1h3z"/><path d="M7 10l4.5-7.5a2 2 0 0 1 2.5 2V8h5a2 2 0 0 1 2 2.3l-1.4 8A2 2 0 0 1 17.6 20H7"/></svg>';
const THUMBDOWN_SVG = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 14V3h3a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1h-3z"/><path d="M17 14l-4.5 7.5a2 2 0 0 1-2.5-2V16H5a2 2 0 0 1-2-2.3l1.4-8A2 2 0 0 1 6.4 4H17"/></svg>';
const CHECK_SVG = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>';
async function copyText(text, btn) {
  text = (text || '').replace(/\n+$/, '');
  let ok = false;
  try { await navigator.clipboard.writeText(text); ok = true; } catch {}
  if (!ok) {   // 폴백: 모달(showModal)은 dialog 밖이 inert → textarea를 #dlg 안에 두고 선택영역 명시
    const ta = document.createElement('textarea');
    ta.value = text; ta.setAttribute('readonly', '');
    ta.style.position = 'fixed'; ta.style.top = '0'; ta.style.opacity = '0';
    $('#dlg').appendChild(ta); ta.focus(); ta.select();
    try { ta.setSelectionRange(0, text.length); } catch {}
    try { ok = document.execCommand('copy'); } catch {}
    ta.remove();
  }
  if (btn) { btn.innerHTML = CHECK_SVG; btn.classList.add('ok');
    setTimeout(() => { btn.innerHTML = COPY_SVG; btn.classList.remove('ok'); }, 1500); }
}
function copyBtn(getText, label) {
  const b = document.createElement('button'); b.className = 'copy'; b.type = 'button';
  b.innerHTML = COPY_SVG; b.setAttribute('aria-label', label || '복사');
  b.onclick = ev => { ev.stopPropagation(); copyText(getText(), b); };
  return b;
}
// 모달 섹션 점프(N=요약·IG / M=카드 프롬프트 / T=카드 이미지). 각 섹션의 윗 구분선이
// 스티키 헤더 바로 아래 오도록 dialog를 정확히 스크롤(A6). 타깃 없으면 안전 return.
// SNS 요약 = 본문(#mdbody)의 IG(인스타) 초안 시작점. 없으면 '콘텐츠 초안' 헤더.
function igHead() {
  const md = $('#mdbody'); if (!md) return null;
  const hs = [...md.querySelectorAll('h1,h2,h3,h4')];
  return hs.find(h => /^\s*\[?\s*IG\b/i.test(h.textContent)) || hs.find(h => /콘텐츠\s*초안/.test(h.textContent)) || null;
}
// '이 기사의 시사점' 헤더 — 요약 영역의 끝 앵커(FAB 점멸 구간 종료점).
function sisaHead() {
  const md = $('#mdbody'); if (!md) return null;
  return [...md.querySelectorAll('h1,h2,h3,h4')].find(h => /시사점/.test(h.textContent)) || null;
}
// 요약 수정 FAB 가시 구간 — '콘텐츠 초안(IG 드래프트)'이 화면 중앙 위로 올라온 뒤부터,
// '이 기사의 시사점'이 화면 중앙 위로 넘어가기 전까지. (둘 다 화면 중앙 기준 = 사용자 정의)
function revFabVisible() {
  const dlg = $('#dlg'); if (!dlg || !dlg.open) return false;
  const sum = $('#ph-sum'); if (!sum) return false;
  const centerY = window.innerHeight / 2;
  const start = igHead() || sum;                            // 콘텐츠 초안 — 없으면 요약 섹션 시작
  if (start.getBoundingClientRect().top > centerY) return false;   // 아직 콘텐츠 초안 전(중앙 밑) → 숨김
  const endH = sisaHead();                                  // 이 기사의 시사점
  if (endH) return endH.getBoundingClientRect().top > centerY;     // 시사점이 중앙 위로 넘어가면 숨김
  return sum.getBoundingClientRect().bottom > centerY;      // 시사점 헤더 없는 옛 포맷 → 요약 섹션 끝 기준
}
function updateRevFab() {
  const fab = $('#revFab'); if (!fab) return;
  const dlg = $('#dlg');
  const show = !!(dlg && dlg.open && !revdlg.open && revFabVisible());   // 팝업 열려 있으면 FAB 숨김(겹침 방지)
  fab.classList.toggle('show', show);
  // #dlg가 backdrop-filter라 그 박스가 fixed/absolute 컨테이닝블록 → 내부 absolute는 콘텐츠와 함께 스크롤됨.
  // top을 scrollTop만큼 보정해 뷰포트 70%(중하단) 라인에 고정(스크롤해도 화면 같은 자리).
  if (show) fab.style.top = Math.round(dlg.scrollTop + dlg.clientHeight * 0.7 - 26) + 'px';
  applyReviseFab();   // FAB 재노출 시 '변경 중' 물결 유지
}
function jumpTo(which) {
  const sec = $('#cardsec');
  let el;
  if (which === 'n')      el = $('#ph-sum');                       // 1/4 요약(시작 = 위 구분선)
  else if (which === 's') el = igHead() || $('#ph-sum');           // 2/4 SNS 요약(인스타 초안 시작점)
  else if (which === 'm') el = $('#ph-card');                      // 3/4 프롬프트 — 카드뉴스 텍스트
  else if (which === 't') { const f = $('#ph-feed'); el = (f && !f.hidden) ? f : (sec.querySelector('.mkbtn') || $('#ph-card')); }  // 4/4 카드 피드
  if (!el) return;
  const d = el.closest('details'); if (d) d.setAttribute('open', '');   // 접혀 있으면 펼침
  const dlg = $('#dlg'), stickyH = ($('.dlg-h') ? $('.dlg-h').offsetHeight : 0);
  requestAnimationFrame(() => {
    const top = dlg.scrollTop + (el.getBoundingClientRect().top - dlg.getBoundingClientRect().top) - stickyH;
    dlg.scrollTo({ top: Math.max(0, top), behavior: matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth' });
  });
}
const esc = s => String(s ?? '').replace(/[&<>"]/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[m]));   // String() = 비문자열(숫자·객체) 입력도 안전(api/candidates 직독 등 빌드 우회 대비)
// URL 속성 전용 — 위험 스킴(javascript:·data:·vbscript:) 차단 후 esc. 외부 출처(CSE 검색 link/img) href·src 하드닝.
const escUrl = u => { const s = String(u ?? '').trim(); return /^(javascript|data|vbscript):/i.test(s) ? '#' : esc(s); };


// Z: 요약 헤더 아래 기본 개요 — 대분류·매체·기자명·WRITE·IN. 기존 데이터만(기자명=본문 Fact 출처 패턴).
function overviewMeta(a) {
  const cat = catBucket(a.category);
  const rp = ((a.body || '').match(/출처[:：]\s*[^()\n]*\(([^)]+)\)/) || [, ''])[1].trim();
  const inn = inDateTime(a);
  const p = [];
  if (cat) p.push(`<span class="ov-cat" style="color:${CAT_COLOR[cat]}">${esc(cat)}</span>`);
  if (a.media) p.push(`<span class="ov-media">${esc(a.media)}</span>`);
  p.push(esc(rp || '-'));   // 기자명 항상 표기, 없으면 '-'(사용자 결정)
  p.push(`<span class="ov-l">WRITE</span><span class="ov-d">${esc(repDateTime(a))}</span>`);
  if (inn.txt) p.push(`<span class="ov-l">IN</span><span class="ov-d">${esc(inn.txt)}</span>`);
  return `<div class="ovmeta">${p.join('<span class="ov-sep">·</span>')}</div>`;
}

// ── 알림·메시지 ──
let MSGS = [];
async function loadMessages() {
  try {
    const r = await fetch('messages.json?_=' + Date.now());
    MSGS = await r.json();
    if (!Array.isArray(MSGS)) MSGS = [];
  } catch { MSGS = []; }   // 없으면 조용히 빈 배열(배지·테두리 숨김)
  renderMsgBadge();
}
function renderMsgBadge() {
  const n = MSGS.length;
  const prof = $('#profile'), badge = $('#pbadge');
  if (prof) prof.classList.toggle('hasmsg', n > 0);
  if (badge) badge.textContent = n > 99 ? '99+' : String(n);
  const bc = $('#msgbtncnt'); if (bc) bc.textContent = n ? `(${n})` : '';
}
function renderMsgList() {
  const cnt = $('#msgpopcnt'); if (cnt) cnt.textContent = MSGS.length ? `${MSGS.length}건` : '';
  const list = $('#msglist'); if (!list) return;
  if (!MSGS.length) { list.innerHTML = '<div class="msgempty">새 메시지 없음</div>'; return; }
  list.innerHTML = '';
  MSGS.forEach(m => {
    const it = document.createElement('div'); it.className = 'msgitem';
    const t = document.createElement('div'); t.className = 'mt'; t.textContent = m.text || '';
    it.appendChild(t);
    if (m.ts) { const d = document.createElement('div'); d.className = 'md8'; d.textContent = m.ts; it.appendChild(d); }
    list.appendChild(it);
  });
}

// ── 긴급 속보 웹푸시(구독) — service worker(sw.js) + PushManager. 발송 = push_send.py. VAPID 공개키 박음(비밀 아님). 정본 = CLAUDE.md §🚨 ──
const VAPID_PUB = 'BORNTh3cNd05vsxi2fZ-BykxM0NwKGTvIETz81g757RVFL6cDu29aAv5I7uit0WbGOmiZ4hlyMOEvb8B2HptU-I';
const pushOK = () => 'serviceWorker' in navigator && 'PushManager' in window && 'Notification' in window;
const b64ToU8 = s => { const pad = '='.repeat((4 - s.length % 4) % 4); const b = atob((s + pad).replace(/-/g, '+').replace(/_/g, '/')); return Uint8Array.from([...b].map(c => c.charCodeAt(0))); };
async function pushState() {   // 'on'|'off'|'denied'|'unsupported'
  if (!pushOK()) return 'unsupported';
  if (Notification.permission === 'denied') return 'denied';
  try { const r = await navigator.serviceWorker.getRegistration(); const s = r && await r.pushManager.getSubscription(); return s ? 'on' : 'off'; } catch { return 'off'; }
}
async function pushRefresh() {
  const row = $('#pushrow'), btn = $('#pushbtn'); if (!row || !btn) return;
  const st = await pushState();
  if (st === 'unsupported') { row.hidden = true; return; }   // iOS 미설치 등 = 숨김
  row.hidden = false;
  if (st === 'denied') { btn.textContent = '차단됨'; btn.classList.remove('on'); btn.disabled = true; return; }
  btn.disabled = false; btn.textContent = st === 'on' ? '켜짐 ✓' : '켜기'; btn.classList.toggle('on', st === 'on');
}
async function pushToggle() {
  const btn = $('#pushbtn'); if (!btn || !pushOK()) return;
  btn.disabled = true; btn.textContent = '…';
  try {
    const reg = await navigator.serviceWorker.register('sw.js'); await navigator.serviceWorker.ready;
    const cur = await reg.pushManager.getSubscription();
    if (cur) {   // 끄기
      await fetch('api/push', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ action: 'unsubscribe', subscription: cur.toJSON() }) }).catch(() => {});
      await cur.unsubscribe();
    } else {     // 켜기 — 권한 요청 → 구독 → 서버 저장
      const perm = await Notification.requestPermission();
      if (perm !== 'granted') { await pushRefresh(); return; }
      const sub = await reg.pushManager.subscribe({ userVisibleOnly: true, applicationServerKey: b64ToU8(VAPID_PUB) });
      const r = await fetch('api/push', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ action: 'subscribe', subscription: sub.toJSON() }) });
      if (!r.ok) { await sub.unsubscribe().catch(() => {}); throw new Error('구독 저장 실패(' + r.status + ')'); }
    }
  } catch (e) { alert('알림 설정 실패: ' + (e.message || e)); }
  finally { await pushRefresh(); }
}
const _pushBtn = $('#pushbtn'); if (_pushBtn) _pushBtn.addEventListener('click', pushToggle);

// 프로필 메뉴
const pmenu = $('#pmenu');
const msgpop = $('#msgpop');
// 오버레이 상호배타 — 하나 열 때 나머지(프로필·메시지·제작도구·링크·검색) 닫기(겹침 방지)
function closeOverlays(keep) {
  if (keep !== 'pmenu') pmenu.hidden = true;
  if (keep !== 'msg') msgpop.hidden = true;
  if (keep !== 'bpop') bpop.hidden = true;
  if (keep !== 'linkpop') linkpop.hidden = true;
  if (keep !== 'qpop') qpop.hidden = true;
  if (keep !== 'search') closeSearch();
  closeFailMenu();   // Failed 칩 컨텍스트 메뉴도 같이 닫음(겹침 방지 — 자기 자신은 직후 다시 표시)
}
$('#profile').addEventListener('click', e => { e.stopPropagation(); const willOpen = pmenu.hidden; closeOverlays('pmenu'); pmenu.hidden = !willOpen; });
document.addEventListener('click', e => {
  if (!pmenu.hidden && !pmenu.contains(e.target) && !$('#profile').contains(e.target)) pmenu.hidden = true;
  if (!msgpop.hidden && !msgpop.contains(e.target) && !$('#profile').contains(e.target)) msgpop.hidden = true;
});
$('#refresh').addEventListener('click', () => { pmenu.hidden = true; load(); loadMessages(); loadCandidates(); loadPickFails(); });
$('#topRefresh').addEventListener('click', () => location.reload());   // 강제 하드 새로고침(코드+데이터 · 탭은 localStorage 복원). 운영자 260619.
// (🚨 긴급 확인 버튼 핸들러 폐지 — 운영자 260620: 프로필 긴급 점등·확인 루틴 제거. 토스트 재알림 de-dup은 수집함 진입(showTab scrap)으로 이전.)
// 메시지함 위치 = 프로필(아바타) 우측 라인·세로 중앙 기준 → 좌하단으로 펼침(고정좌표·뷰포트 기준)
function placeMsgpop() {
  const pr = $('#profile').getBoundingClientRect();
  const top = Math.round(pr.top + pr.height / 2);
  msgpop.style.top = top + 'px';                                       // 프로필 세로 중앙 → 아래로
  msgpop.style.right = Math.max(8, Math.round(window.innerWidth - pr.right)) + 'px';   // 프로필 우측 라인 → 좌측(좌측 넘침 방지)
  msgpop.style.left = 'auto'; msgpop.style.bottom = 'auto';
  msgpop.style.maxHeight = (window.innerHeight - top - 12) + 'px';     // 하단 넘침 방지(내부 스크롤)
}
['resize', 'orientationchange'].forEach(ev => window.addEventListener(ev, () => { if (!msgpop.hidden) placeMsgpop(); }, { passive: true }));
$('#msgbtn').addEventListener('click', e => { e.stopPropagation(); closeOverlays('msg'); renderMsgList(); pushRefresh(); placeMsgpop(); msgpop.hidden = false; });
$('#msgclose').addEventListener('click', e => { e.stopPropagation(); msgpop.hidden = true; });

// 모달 닫히면 배경 스크롤 복구(#5 — 닫기 버튼·Esc 모두 close 이벤트)
$('#dlg').addEventListener('close', () => { document.documentElement.style.overflow = ''; });
$('#dlg').addEventListener('scroll', updateScrub, { passive: true });

// 모달 헤더 스크러버 — 스크롤 위치 게이지 + 섹션(요약·프롬프트·카드) 틱 + 클릭 점프. 맨위=원문/X, 스크롤=스크러버.
function setupScrub() {
  const dp = $('#dlgprog'); if (!dp) return;
  const h = $('.dlg-h'); if (h) h.classList.remove('scrolled');   // 열릴 땐 맨 위(원문/X)
  dp.innerHTML = `<div class="scrub"><div class="scrub-bar" id="scrubBar"><div class="scrub-fill" id="scrubFill"></div><i class="scrub-tick" data-j="n"></i><i class="scrub-tick" data-j="s"></i><i class="scrub-tick" data-j="m"></i><i class="scrub-tick" data-j="t"></i><div class="scrub-dot" id="scrubDot"></div></div><div class="scrub-labels"><span class="scrub-lb" data-j="n">요약</span><span class="scrub-lb" data-j="s">SNS 요약</span><span class="scrub-lb" data-j="m">프롬프트</span><span class="scrub-lb" data-j="t">카드</span></div></div>`;
  const bar = $('#scrubBar');
  bar.onclick = e => {
    const dlg = $('#dlg'), r = bar.getBoundingClientRect(), range = dlg.scrollHeight - dlg.clientHeight;
    dlg.scrollTo({ top: Math.max(0, Math.min(1, (e.clientX - r.left) / r.width)) * range, behavior: 'smooth' });
  };
  dp.querySelectorAll('.scrub-lb').forEach(lb => { lb.onclick = () => jumpTo(lb.dataset.j); });
  requestAnimationFrame(updateScrub);
}
function scrubTargets() {
  const sec = $('#cardsec'), f = $('#ph-feed');
  return { n: $('#ph-sum'), s: igHead(), m: $('#ph-card'), t: (f && !f.hidden) ? f : (sec ? (sec.querySelector('.mkbtn') || null) : null) };
}
function updateScrub() {
  const dlg = $('#dlg'); if (!dlg || !dlg.open) return;
  const dp = $('#dlgprog'); if (!dp || !dp.firstElementChild) return;
  const range = dlg.scrollHeight - dlg.clientHeight, st = dlg.scrollTop;
  const pct = range > 0 ? Math.max(0, Math.min(100, st / range * 100)) : 0;
  const fill = $('#scrubFill'), dot = $('#scrubDot');
  if (fill) fill.style.width = pct + '%';
  if (dot) dot.style.left = pct + '%';
  const top = dlg.getBoundingClientRect().top, tg = scrubTargets();
  const hh = ($('.dlg-h') ? $('.dlg-h').offsetHeight : 0);
  let cur = 'n';
  ['n', 's', 'm', 't'].forEach(k => {
    const el = tg[k], tick = dp.querySelector(`.scrub-tick[data-j="${k}"]`), lb = dp.querySelector(`.scrub-lb[data-j="${k}"]`);
    if (!el) { if (tick) tick.style.display = 'none'; if (lb) lb.classList.add('off'); return; }
    if (lb) lb.classList.remove('off');
    const off = st + (el.getBoundingClientRect().top - top);
    const p = range > 0 ? Math.max(0, Math.min(100, off / range * 100)) : 0;
    if (tick) { tick.style.display = ''; tick.style.left = p + '%'; }
    if (st >= off - hh - 8) cur = k;
  });
  dp.querySelectorAll('.scrub-lb').forEach(lb => lb.classList.toggle('cur', lb.dataset.j === cur && !lb.classList.contains('off')));
  const hd = $('.dlg-h'); if (hd) hd.classList.toggle('scrolled', st > 60);
  updateRevFab();   // 요약 수정 FAB 점멸 구간 갱신(콘텐츠 초안~시사점)
}

// (모달 플로팅 N/M/T 네비는 카드 셀 .nmt 버튼으로 이관 — render()에서 배선)

// 맨 위로 — 첫 화면(스크롤 전)엔 숨김, 어느정도 내려가면 페이드인 노출(탑 버튼이 안 떠도 되게)
const totop = $('#totop');
totop.addEventListener('click', () => window.scrollTo({ top:0, behavior:'smooth' }));
const fadeTop = () => { const on = window.scrollY > 240; totop.style.opacity = on ? '1' : '0'; totop.style.pointerEvents = on ? 'auto' : 'none'; };
window.addEventListener('scroll', fadeTop, { passive:true }); fadeTop();
// (모달 내부 '맨 위로' 버튼 제거 — #dlg backdrop-filter가 position:fixed를 깨 '날아다님' + sticky 헤더로 대체 가능)
// 카드 변경 팝업 배선(1회) — 텍스트는 어절칩(입력창 없음). 맨위로 = ed-body 스크롤.
$('#edGo').onclick = submitEdit;
$('#editdlg .ed-cno').onclick = () => $('#editdlg .ed-foot').classList.remove('confirm');
$('#editdlg .ed-cyes').onclick = fireEdit;
const edBody = $('#editdlg .ed-body'), edTop = $('#edtop');
edTop.onclick = () => edBody.scrollTo({ top: 0, behavior: 'smooth' });
edBody.addEventListener('scroll', () => {
  const ae = document.activeElement;   // 입력 중(키보드 자동스크롤)엔 토글 안 함 — '번쩍' 방지(상태는 그대로 유지)
  if (ae && (ae.tagName === 'TEXTAREA' || ae.tagName === 'INPUT' || ae.isContentEditable)) return;
  edTop.classList.toggle('show', edBody.scrollTop > 56);   // 조금만 내려도 노출
}, { passive: true });
// 화면 회전·리사이즈 시 어절칩 행 폭 재계산(팝업 열려 있을 때만)
window.addEventListener('resize', () => { if ($('#editdlg').open) fitEditLines($('#edChips')); }, { passive: true });
// 메인 모달 #dlg·편집팝업 #editdlg 백드롭(바깥) 클릭 = 닫기
$('#dlg').addEventListener('click', e => { if (e.target.id === 'dlg') $('#dlg').close(); });
$('#editdlg').addEventListener('click', e => { if (e.target.id === 'editdlg') $('#editdlg').close(); });

let CURTAB = 'feed';   // 현재 탭(검색이 어느 콘텐츠에 걸릴지 결정)
function searchActive() { if (CURTAB === 'scrap') renderScrap(); else if (CURTAB === 'sns') renderSns(); else render(); }
$('#q').addEventListener('input', searchActive);   // 검색바=탭별: 레거시→후보 전반 / 뉴스요약→기사 / SNS→SNS
// 접이식 검색: 아이콘 클릭 → 좌측으로 펼침+커서 포커스 / 바깥 클릭 → 접힘
const topsearch = $('#topsearch'), searchToggle = $('#searchToggle');
function closeSearch() {   // 검색바 접으면 숨은 필터 잔존 방지 — 쿼리 비우고 활성 탭 재렌더
  if (!topsearch.classList.contains('open')) return;
  topsearch.classList.remove('open');
  const q = $('#q'); if (q && q.value) { q.value = ''; searchActive(); }
}
searchToggle.addEventListener('click', e => { e.stopPropagation(); if (topsearch.classList.contains('open')) closeSearch(); else { closeOverlays('search'); topsearch.classList.add('open'); $('#q').focus(); } });
document.addEventListener('click', e => { if (topsearch.classList.contains('open') && !topsearch.contains(e.target)) closeSearch(); });
$('#cardonly').addEventListener('change', render);
// R 필터 칩 토글
$('#chips').addEventListener('click', e => {
  const b = e.target.closest('button'); if (!b) return;
  if (b.dataset.f === 'all') { FILTERS.cats.clear(); }
  else if (b.dataset.f === 'breaking') { FILTERS.breaking = !FILTERS.breaking; }
  else if (b.dataset.f === 'issue') { FILTERS.issue = !FILTERS.issue; }
  else if (b.dataset.cat) { const k = b.dataset.cat; FILTERS.cats.has(k) ? FILTERS.cats.delete(k) : FILTERS.cats.add(k); }
  renderChips(); render();
});
renderChips();
// W 실시간 시계(초까지·KST)
function tickClock() {
  const el = $('#dhClock'); if (!el) return;
  const t = new Date().toLocaleTimeString('en-GB', { timeZone: 'Asia/Seoul', hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
  el.innerHTML = `<b class="ck-t">${t}</b> KST`;
}
setInterval(tickClock, 1000); tickClock();
// (주기 자동 새로고침 제거 — 사용자 요청 260614. 갱신 = 메뉴 새로고침 버튼.)

// S(개정) 하단 네비 — 스크랩/피드=인앱 탭 전환 / SNS=<a> 직접 이동 / FAB(+)=제작도구 팝업.
const bpop = $('#bpop'), linkpop = $('#linkpop'), qpop = $('#qpop');
function popAt(pop, btn) {        // 팝업을 버튼 위에 띄움(좌우 화면 밖 안 나가게 클램프)
  const r = btn.getBoundingClientRect();
  pop.style.left = Math.max(120, Math.min(r.left + r.width / 2, window.innerWidth - 120)) + 'px';
  pop.style.bottom = (window.innerHeight - r.top + 8) + 'px';
}
$('#bnav').addEventListener('click', e => {
  // 레거시/SNS/뉴스요약 = 탭 전환(showTab). ＋=제작도구 팝업 / 링크=피드 탐색 팝업(둘은 상호 배타).
  const b = e.target.closest('.bnav-i[data-tab]');
  if (b) { e.preventDefault(); if (lpFired) { lpFired = false; return; } closeOverlays(); showTab(b.dataset.tab); return; }   // 롱프레스(대기열) 후 click이면 탭전환 스킵 · 일반 탭전환 = 열린 팝업 자동 닫힘
  const f = e.target.closest('#toolfab');
  if (f) { e.preventDefault(); const wasOpen = !bpop.hidden; closeOverlays('bpop'); if (!wasOpen) { popAt(bpop, f); bpop.hidden = false; } else bpop.hidden = true; return; }
  const lk = e.target.closest('#linkfab');
  if (lk) { e.preventDefault(); const wasOpen = !linkpop.hidden; closeOverlays('linkpop'); if (!wasOpen) { popAt(linkpop, lk); linkpop.hidden = false; } else linkpop.hidden = true; return; }
});
document.addEventListener('click', e => {
  if (!bpop.hidden && !bpop.contains(e.target) && !$('#bnav').contains(e.target)) bpop.hidden = true;
  if (!linkpop.hidden && !linkpop.contains(e.target) && !$('#bnav').contains(e.target)) linkpop.hidden = true;
  if (!qpop.hidden && !qpop.contains(e.target) && !$('#bnav').contains(e.target)) qpop.hidden = true;
});

// ── 대기열(뉴스요약 롱프레스 480ms) — 분석 대기/중(pending/) 기사 개요. api/pending 라이브 조회(파이프라인 0 변경·읽기전용). ──
const qFeedBtn = $('#bnav .bnav-i[data-tab="feed"]');
let lpTimer = null, lpFired = false;
let QITEMS = [], QPAGE = 0; const QPER = 5;   // 대기열 = 페이지당 5개 페이지네이션
function lpStart(e) { if (e && e.button) return;   // 1차 버튼(좌클릭/터치)만 롱프레스 — 우클릭은 contextmenu가 처리(중복 방지)
  lpFired = false; clearTimeout(lpTimer); lpTimer = setTimeout(() => { lpFired = true; openQueue(); }, 480); }
function lpCancel() { clearTimeout(lpTimer); }
if (qFeedBtn) {
  qFeedBtn.addEventListener('pointerdown', lpStart);
  ['pointerup', 'pointercancel', 'pointerleave'].forEach(ev => qFeedBtn.addEventListener(ev, lpCancel));
  qFeedBtn.addEventListener('contextmenu', e => { e.preventDefault(); openQueue(); });   // PC 우클릭 = 대기열(네이티브 메뉴 막고 즉시 열기)
}
function openQueue() {
  closeOverlays('qpop');
  qClearConfirm(false);
  const r = qFeedBtn.getBoundingClientRect();
  qpop.style.left = '50%';
  qpop.style.bottom = (window.innerHeight - r.top + 12) + 'px';   // 네비 위로(크게·위로 띄움)
  qpop.style.maxHeight = (r.top - 16) + 'px';   // 네비 위 가용높이로만 캡(하한 없음 → 박스 top=4px 항상 ≥0, 짧은 뷰포트서도 헤더 안 잘림). 헤더·페이지=flex:none, 리스트만 압축.
  qpop.hidden = false;
  loadQueue();
}
const qEsc = s => String(s == null ? '' : s).replace(/[&<>"]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
function qAgo(t) {
  if (!t) return '?';
  const m = Math.max(0, Math.round((Date.now() - t) / 60000));
  if (m < 1) return '방금';
  if (m < 60) return m + '분 전';
  const h = Math.floor(m / 60), r = m % 60;
  return h + '시간' + (r ? ' ' + r + '분' : '') + ' 전';
}
const DL_SVG = '<svg viewBox="0 0 24 24" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12M7 11l5 5 5-5M5 21h14"/></svg>';
// SUCC 제목 = 피드(DATA)서 file 매칭 우선(없으면 API title). file은 .md 유무 양쪽 허용.
function qTitle(it) {
  if (it.status === 'succ') { const a = DATA.find(x => x && x.file && (x.file === it.id || String(x.file).replace(/\.md$/, '') === it.id)); if (a && a.title) return a.title; return it.title || '분석 완료'; }
  return it.title || '(내용 없음)';
}
function qRowHtml(it) {
  const cls = it.via === '전문' ? 'paste' : 'url';
  let right;
  if (it.status === 'succ') right = '<span class="qb qb-succ">SUCC</span><button class="qgo" type="button">바로가기</button>';
  else if (it.status === 'fail') right = '<span class="qb qb-fail">FAIL</span><button class="qdl" type="button" aria-label="진단 다운로드" title="실패 원인 진단 MD 다운로드">' + DL_SVG + '</button>';
  else right = '<span class="qb qb-proc">처리중</span><span class="qvia ' + cls + '">' + qEsc(it.via || '') + '</span>';
  return '<div class="qrow q-' + it.status + '"><span class="qt">' + qEsc(qAgo(it.t)) + '</span><span class="qmain">' + qEsc(qTitle(it)) + '</span>' + right + '</div>';
}
function pagerHtml(pages, cur) {   // 5개/페이지 · 페이지번호 슬라이딩 윈도우(최대 5개)
  if (pages <= 1) return '';
  let h = '<button class="qpg-nav" data-pg="' + Math.max(0, cur - 1) + '"' + (cur === 0 ? ' disabled' : '') + '>‹</button>';
  const W = 5, end = Math.min(pages, Math.max(0, cur - 2) + W), start = Math.max(0, end - W);
  for (let i = start; i < end; i++) h += '<button class="qpg' + (i === cur ? ' on' : '') + '" data-pg="' + i + '">' + (i + 1) + '</button>';
  h += '<button class="qpg-nav" data-pg="' + Math.min(pages - 1, cur + 1) + '"' + (cur === pages - 1 ? ' disabled' : '') + '>›</button>';
  return h;
}
function renderQueuePage() {
  const box = $('#qpopList'), pg = $('#qpopPage'); if (!box) return;
  if (!QITEMS.length) { box.innerHTML = '<div class="qempty">대기·최근 내역 없음 ✓<small>새 공유·픽 대기 중</small></div>'; if (pg) pg.innerHTML = ''; return; }
  const pages = Math.ceil(QITEMS.length / QPER);
  QPAGE = Math.min(Math.max(0, QPAGE), pages - 1);
  const slice = QITEMS.slice(QPAGE * QPER, QPAGE * QPER + QPER);
  box.innerHTML = slice.map(qRowHtml).join('');
  slice.forEach((it, i) => {
    const row = box.children[i]; if (!row) return;
    const go = row.querySelector('.qgo'); if (go) go.onclick = (e) => { e.stopPropagation(); qGo(it.id); };
    const dl = row.querySelector('.qdl'); if (dl) dl.onclick = (e) => { e.stopPropagation(); qDownload(it); };
  });
  if (pg) {
    pg.innerHTML = pagerHtml(pages, QPAGE);
    pg.querySelectorAll('[data-pg]').forEach(b => b.onclick = (e) => { e.stopPropagation(); QPAGE = +b.dataset.pg; renderQueuePage(); });
  }
}
let qGen = 0;
async function loadQueue() {
  const g = ++qGen;   // 세대 토큰 — ↻ 연타 시 늦게 온 stale 응답 폐기(페이지 튕김 방지)
  const box = $('#qpopList'); if (!box) return;
  box.innerHTML = '<div class="qempty">불러오는 중…</div>'; const pg = $('#qpopPage'); if (pg) pg.innerHTML = '';
  let items;
  try {
    const r = await fetch('api/pending?_=' + Date.now());
    if (g !== qGen) return;
    if (!r.ok) { box.innerHTML = '<div class="qempty">대기열 조회 실패 (' + r.status + ')</div>'; return; }
    const j = await r.json(); items = j.items || [];
  } catch { if (g === qGen) box.innerHTML = '<div class="qempty">네트워크 오류 — 다시 시도</div>'; return; }
  if (g !== qGen) return;
  let cut = 0; try { cut = +localStorage.getItem('nomute_q_cleared') || 0; } catch {}
  QITEMS = items.filter(it => !it.t || it.t > cut);   // '내역 지우기' 컷오프 이후만(API 최신순 유지)
  QPAGE = 0;
  renderQueuePage();
}
// 피드(메뉴3) 이동 + 해당 기사 모달. 즉시 매칭되면 바로, 없으면(빌드 랙) load() 후 재매칭.
async function feedOpenBy(match) {
  qpop.hidden = true;
  showTab('feed');
  let a = match();
  if (a) { open(a); return; }   // 즉시(이미 피드에 있음 = 흔한 경우)
  try { await load(); } catch {}   // 빌드 랙 — 기사 재요청 후 재매칭
  a = match();
  if (a) open(a); else qFlash('피드 반영 중 — 곧 표시돼');
}
function qGo(id) {   // SUCC 바로가기 — queue 파일명(id) ↔ DATA.file(.md 양쪽 허용) 매칭
  feedOpenBy(() => DATA.find(x => x && x.file && (x.file === id || String(x.file).replace(/\.md$/, '') === id)));
}
function qFlash(msg) {   // 짧은 토스트(바로가기 빌드 랙 안내)
  let t = document.getElementById('qFlash');
  if (!t) { t = document.createElement('div'); t.id = 'qFlash'; t.className = 'qflash'; document.body.appendChild(t); }
  t.textContent = msg; t.classList.add('show');
  clearTimeout(t._h); t._h = setTimeout(() => t.classList.remove('show'), 2600);
}
function qDownload(it) {   // FAIL 진단 MD(5W1H·입출력·원인·식별자 — 클로드 전달용) 생성·다운로드
  const enteredK = it.t ? new Date(it.t).toLocaleString('ko-KR', { timeZone: 'Asia/Seoul' }) : '?';
  const nowK = new Date().toLocaleString('ko-KR', { timeZone: 'Asia/Seoul' });
  const d = it.diag || {};
  const mins = d.mins != null ? d.mins : (it.t ? Math.round((Date.now() - it.t) / 60000) : '?');
  const failed = d.kind === 'failed';
  const L = [];
  L.push('# 대기열 처리 실패 진단 — ' + qTitle(it));
  L.push('', '> 자동 생성(뷰어 대기열). 이 파일을 클로드에게 전달하면 원인 분석·복구에 사용합니다.', '');
  L.push('## 요약 (5W1H)');
  L.push('- **언제(When)**: 제출 ' + enteredK + ' (KST) · 진단 ' + nowK + ' · 경과 약 ' + mins + '분');
  L.push('- **무엇(What)**: ' + qTitle(it) + (it.src ? ' · 출처 ' + it.src : ''));
  L.push('- **어떻게(How)**: 전달방식 ' + (it.via || '?') + (/-pick-/.test(it.id) ? ' · 수집함 PICK' : ' · 폰 공유') + ' · pending 파일 `' + it.id + '.txt`');
  L.push('- **어디서(Where)**: ' + (failed ? '`pending/failed/`(분석 실패 격리)' : '`pending/`(미처리 잔류)'));
  L.push('- **누가(Who)**: 운영자 제출');
  L.push('- **왜(Why·추정)**: ' + (failed ? '분석 단계 실패(아래 로그 참조)' : 'analyze 워크플로 미완/실패 또는 Commit 실패(20분+ 미처리). 단 직렬 배치면 분석이 아직 진행 중일 수도 있음 — Actions run 확인.'));
  L.push('', '## 입력 (Input)');
  L.push('- pending 파일: `' + it.id + '.txt`');
  L.push('- line1: `' + (d.line1 || (it.via === '전문' ? 'paste:…' : (it.src || '?'))) + '`');
  L.push('- 본문 동봉: ' + (d.hasBody ? '예' : '아니오'));
  if (d.bodyHead) L.push('', '본문 일부:', '', '````', d.bodyHead, '````');   // 4백틱 펜스 = 본문 내 ``` 충돌 방지
  L.push('', '## 출력/현황 (Output)');
  L.push('- 상태: ' + (failed ? 'FAIL — 분석 단계 실패' : 'FAIL — stuck(pending 잔류·미완)'));
  if (d.log) L.push('- 실패 로그:', '', '````', d.log, '````');
  else L.push('- queue 생성/피드 반영: 없음(미완)');
  L.push('', '## 진단 힌트 (클로드용)');
  L.push('- pending 잔류 = `news-analyze` 워크플로 미완 또는 `Commit results` 실패.');
  L.push('- 확인: GitHub Actions `news-analyze` 최근 run → `Analyze pending articles`/`Commit results` 스텝 로그.');
  L.push('- 복구: `news-analyze` workflow_dispatch 재실행.');
  L.push('- 입력 식별자(grep용): `' + it.id + '`');
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([L.join('\n')], { type: 'text/markdown;charset=utf-8' }));
  a.download = '대기열실패_' + it.id + '.md';
  document.body.appendChild(a); a.click(); a.remove();
  setTimeout(() => { try { URL.revokeObjectURL(a.href); } catch {} }, 1500);
}
function qClearConfirm(show) { const c = $('#qpopConfirm'); if (c) c.hidden = !show; }
$('#qpopRf').addEventListener('click', e => { e.stopPropagation(); loadQueue(); });
$('#qpopTrash').addEventListener('click', e => { e.stopPropagation(); const cf = $('#qpopConfirm'); qClearConfirm(cf ? cf.hidden : true); });   // 토글(null 가드)
$('#qcfNo').addEventListener('click', e => { e.stopPropagation(); qClearConfirm(false); });
$('#qcfYes').addEventListener('click', e => { e.stopPropagation(); try { localStorage.setItem('nomute_q_cleared', String(Date.now())); } catch {} qClearConfirm(false); loadQueue(); });   // 컷오프 = now → 현재 내역 숨김
$('#qpopX').addEventListener('click', e => { e.stopPropagation(); qpop.hidden = true; qClearConfirm(false); });   // 닫기(작은 ✕)


// ── 스크랩(수집·큐레이션) 뷰 ─────────────────────────────────────
// candidates.json = RSS 후보(제목·매체·시각·교차점수·카테고리·url). 관심도 ★ = localStorage(UI 상태) + api/rate(레포 누적=취향 데이터).
let CANDS = [], SCRAP_LOADED = false;
let SOCIAL = [], SOCIAL_LOADED = false, SOCIAL_LOADING = false;   // 소셜 버스트(커뮤니티 공론화) 레인 = SNS 탭(메뉴2). social_candidates.json(scraper/social_burst.py 출력 · 설계 docs/social-burst.md).
const RKEY = 'nm_ratings';
const ratingsAll = () => { try { return JSON.parse(localStorage.getItem(RKEY) || '{}'); } catch { return {}; } };
const saveRating = (id, patch) => { const r = ratingsAll(); r[id] = { ...(r[id] || {}), ...patch }; localStorage.setItem(RKEY, JSON.stringify(r)); };
const candId = c => c.id || c.url || c.title;
const scRelTime = iso => {   // published(ISO) → 상대시각(렌더 시점 계산 = 안 틀어짐)
  if (!iso) return '';
  const t = new Date(iso); if (isNaN(t)) return '';
  const s = Math.max(0, (Date.now() - t.getTime()) / 1000);
  if (s < 60) return '방금 전';
  if (s < 3600) return Math.floor(s / 60) + '분 전';
  if (s < 86400) return Math.floor(s / 3600) + '시간 전';
  const d = Math.floor(s / 86400);
  if (d === 1) return '1일 ' + Math.floor((s % 86400) / 3600) + '시간 전';   // 1일대(24~48h)는 시간까지 — '1일 전'끼리 구분(2일+는 그대로)
  return d + '일 전';
};
let SCRAP_LOADING = false;
async function loadCandidates(quiet) {   // quiet=라이브 폴링: CANDS·속보감지만 갱신, 목록 재렌더 안 함(재애니 깜빡임 방지)
  if (SCRAP_LOADING) return; SCRAP_LOADING = true;   // 동기 가드 — eager 부트 + 탭 진입 + 라이브폴 중복 fetch 방지
  if (!quiet) ratedKeep.clear();   // 갱신(새로고침/부트/탭 첫 진입) = 별점 매긴 카드 리스트서 비움(라이브폴은 유지)
  try {
    // api/candidates = 라이브 서빙(GitHub 직독, 빌드 우회) 우선 → 실패 시 정적 candidates.json 폴백.
    for (const u of ['api/candidates', 'candidates.json?_=' + Date.now()]) {
      try {
        const r = await fetch(u);
        if (r.ok) { const d = await r.json(); if (Array.isArray(d)) { CANDS = d; SCRAP_LOADED = true; detectBreaking(); detectPickFail(); if (!quiet && CURTAB === 'scrap') renderScrap(); return; } }
      } catch { /* 다음 소스 */ }
    }
    CANDS = []; SCRAP_LOADED = true; if (!quiet && CURTAB === 'scrap') renderScrap();
  } finally { SCRAP_LOADING = false; }
}
// SNS 레인 로드 — social_candidates.json(커뮤니티 공론화 후보). 없거나 비면 빈 레인(정상). 탭 진입 시 1회.
async function loadSocial() {
  if (SOCIAL_LOADING) return; SOCIAL_LOADING = true;
  try {
    const r = await fetch('social_candidates.json?_=' + Date.now());
    if (r.ok) { const d = await r.json(); if (Array.isArray(d)) SOCIAL = d; }
  } catch { /* 없으면 빈 레인 */ }
  finally { SOCIAL_LOADED = true; SOCIAL_LOADING = false; if (CURTAB === 'sns') renderSns(); }
}
// ── 🚨 속보 알림(포그라운드 · Phase 1) — backend가 breaking 확정한 사건을 토스트+프로필 링으로.
// 본 것(candId)은 BRK_SEEN에 누적 → 재알림 안 함. 수집함 열면 현재 속보 = 본 것 처리(링 끔).
const BKEY = 'nomute_brk_seen';
const brkSeen = () => { try { return new Set(JSON.parse(localStorage.getItem(BKEY) || '[]')); } catch { return new Set(); } };
// ⚡ 유효 breaking = backend 속보확정(breaking) AND 경중 게이트가 잡음/경미(grade 0·1)로 깐 게 아님(미채점 null=유보 통과). 배지·핀·최신·토스트 공용 단일규칙 — 'grade1 경미인데 ⚡이슈' 모순 차단(260617).
const isBreaking = c => !!c.breaking && (c.grade == null || c.grade >= 2);
const breakingNow = () => CANDS.filter(c => { const r = ratingsAll()[candId(c)] || {}; return isBreaking(c) && (Date.now() - scTs(c)) < FAST_MAX_H * 3600000 && !r.dismissed && !r.action && !r.score && !r.picked && !r.acked; });   // 토스트·점등=최신 속보만(<FAST_MAX_H=4h). 처리분(action/score/picked/dismissed)·확인(ack)·AI 경중<2 제외 → 확인✓ 누르면 점등 꺼짐.
function detectBreaking() {
  const seen = brkSeen();
  const fresh = breakingNow().filter(c => !seen.has(candId(c)));
  // 프로필 긴급 점등(has-breaking) 폐지 — 운영자 260620. 긴급 알림 = 토스트(아래) + 🚨배지로 충분.
  if (fresh.length && CURTAB !== 'scrap') showToast(fresh.length, fresh[0]);   // 토스트는 수집함 밖에서만
}
function markBreakingSeen() {
  const seen = brkSeen();
  breakingNow().forEach(c => seen.add(candId(c)));
  try { localStorage.setItem(BKEY, JSON.stringify([...seen])); } catch {}
  document.body.classList.remove('has-breaking');
}
let _toastT;
function showToast(n, sample) {
  let t = document.getElementById('nmToast');
  if (!t) {
    t = document.createElement('div'); t.id = 'nmToast'; t.className = 'nm-toast';
    t.onclick = () => { t.classList.remove('show'); showTab('scrap'); };   // 탭 → 수집함(거기서 markBreakingSeen)
    document.body.appendChild(t);
  }
  const title = sample ? esc((sample.title || '').slice(0, 38)) : '';
  t.innerHTML = `<span class="tg">🚨 긴급</span><span>${n}건${title ? ' · ' + title + '…' : ''} <b>탭해서 보기</b></span>`;
  requestAnimationFrame(() => t.classList.add('show'));
  clearTimeout(_toastT); _toastT = setTimeout(() => t.classList.remove('show'), 6500);
}
// ── ⚠ 픽 분석 실패 알림 — fetch 막는 매체(chosun 등)로 분석 실패해 'PICKED'로 남고 피드에 안 뜬
//    '내가 픽한' 기사. 속보와 동일 급(프로필 링·토스트)으로 알리고, 수집함서 '다시'(전문 붙여넣기)로 복구.
//    build-viewer 가 pending/failed/ → picks-failed.json 으로 떨궈줌(이미 queue에 든 복구분은 제외). ──
let PFAIL = new Map();   // 정규화url → {reason, ts}
const PF_SKEY = 'nomute_pickfail_seen', PF_RKEY = 'nomute_pickfail_resolved';
const _normU = u => String(u || '').trim().replace(/\/+$/, '');   // build-viewer normUrl 과 동일(끝슬래시만)
// 멤버기반 picked 승계 — rep url이 점프(클러스터 split)해 candId가 바뀌어도, cluster_members 중
// picked 찍힌 옛 url이 있으면 PICKED 유지(+pickCross 증분). 스크래퍼 별칭승계의 뷰어 짝.
function ratingFor(c) {
  const rt = ratingsAll(), own = rt[candId(c)] || {};
  if (own.picked) return own;
  for (const m of (c.cluster_members || [])) {
    const rm = rt[m] || rt[_normU(m)];
    if (rm && rm.picked) return { ...own, picked: true, pickCross: rm.pickCross };   // 멤버로 PICKED 승계
  }
  return own;
}
const pfSeen = () => { try { return new Set(JSON.parse(localStorage.getItem(PF_SKEY) || '[]')); } catch { return new Set(); } };
const pfResolved = () => { try { return new Set(JSON.parse(localStorage.getItem(PF_RKEY) || '[]')); } catch { return new Set(); } };
const pfAddResolved = id => { try { const s = pfResolved(); s.add(id); localStorage.setItem(PF_RKEY, JSON.stringify([...s])); } catch {} };
// 전문 직접 입력(재제출) 진행창 — Failed 칩 메뉴 '내용 입력'으로 전문을 보낸 직후 candId→타임스탬프 기록.
//   활성 동안(폴 상한과 동일) pfailHas 억제 → Failed가 Picking…으로 전환. 성공하면 pickInFeed로 PICKED(영구),
//   창 지나도 미성공이면 다시 Failed(재실패 인지·또 시도 가능). pfResolved(영구해소·api/submit 경로)와 달리 *임시*.
const PF_USKEY = 'nomute_pickfail_resub';
const pfResub = () => { try { return JSON.parse(localStorage.getItem(PF_USKEY) || '{}'); } catch { return {}; } };
const pfAddResub = id => { try { const m = pfResub(); m[id] = Date.now(); localStorage.setItem(PF_USKEY, JSON.stringify(m)); } catch {} };
const pfResubActive = id => { const t = pfResub()[id]; return !!t && (Date.now() - t < PICK_TIMEOUT_MS + 60000); };
// 실패 표시 대상 = picks-failed 에 있음 + 복구표시 안 함(api/submit) + 재제출창 아님(전문 직접입력 진행 중) + 피드 미등장(늦은 성공이면 PICKED 우선·stale 실패기록 무시).
const pfailHas = c => PFAIL.has(_normU(c.url)) && !pfResolved().has(candId(c)) && !pfResubActive(candId(c)) && !pickInFeed(c);
const pfReason = c => (PFAIL.get(_normU(c.url)) || {}).reason || '';
async function loadPickFails() {
  try {
    const r = await fetch('picks-failed.json?_=' + Date.now());
    if (r.ok) { const d = await r.json(); if (Array.isArray(d)) PFAIL = new Map(d.map(x => [_normU(x.url), { reason: x.reason || '', ts: x.ts || '' }])); }
  } catch { /* 없으면 무시 */ }
  detectPickFail();
}
// 알림 대상 = 내가 픽함(로컬 ratings) + 실패목록에 있음(같은 기기서 픽→실패 인지).
const pickFailNow = () => CANDS.filter(c => { const r = ratingsAll()[candId(c)] || {}; return r.picked && pickFailedShow(c); });   // 링/토스트 알림 대상 = 서버실패 OR 무응답 타임아웃
// ── 픽 후 'Picking…'(분석 중) → 뉴스요약(피드)에 떴으면 PICKED · 실패면 '분석 실패' ──
const pickInFeed = c => { const us = new Set([_normU(c.url), ...((c.cluster_members || []).map(_normU))].filter(Boolean)); return DATA.some(a => a && a.url && us.has(_normU(a.url))); };   // 픽 결과가 피드(3번 메뉴)에 등장했나 — 후보 url *또는 cluster_members*(같은 사건 타 매체) 매칭. 막힌 매체(403)는 분석기가 다른 클러스터 멤버 url로 분석해 정확 url 불일치 → 영구 Picking 갇히던 버그 차단(260619)
const pickSettled = c => pickInFeed(c) || pfResolved().has(candId(c));   // 픽 종결 = 피드 등장 OR 실패복구 해소 → 둘 다 'Picking' 탈출(해소된 픽이 영구 Picking에 갇히던 버그 차단·260618)
// 무응답 타임아웃 — 픽 후 PICK_TIMEOUT_MS 지나도 피드 미등장·서버 실패기록(picks-failed)도 없음 = '무응답 실패'로 표시(운영자: 길게 안 끌기).
// ⚠ 비파괴 = client 표시일 뿐(pending/failed 안 만듦) → 늦게 피드 뜨면 pickInFeed로 PICKED 자동복구. 백엔드 analyze는 최대 ~15분(900s 모델+빌드/배포)이라 10분은 '대부분 끝남' 지점(드물게 느린 건 자동복구).
const PICK_TIMEOUT_MS = 10 * 60000;
const pickTimedOut = c => { if (!DATA_LOADED) return false; const r = ratingsAll()[candId(c)] || {}; if (!r.picked || pickInFeed(c) || pfailHas(c) || pfResolved().has(candId(c)) || pfResubActive(candId(c))) return false; return !r.pickedAt || (Date.now() - r.pickedAt > PICK_TIMEOUT_MS); };   // pickedAt 없는 옛 픽 = 즉시 타임아웃 처리(무한 Picking 차단·260618)
const pickFailedShow = c => pfailHas(c) || pickTimedOut(c);   // 화면 '실패' 표시 = 서버 분석실패(picks-failed) OR 클라 무응답 타임아웃
const failChipHtml = c => `<button class="sc-fail" type="button" title="${esc('분석 실패 — 탭=원문 열기 · 길게/우클릭=메뉴(실패 사유·내용 입력): ' + (pfReason(c) || (pickTimedOut(c) ? '무응답(10분 초과)' : 'fetch 차단')))}">Failed</button>`;
const pickingNow = () => DATA_LOADED ? CANDS.filter(c => { const r = ratingsAll()[candId(c)] || {}; return r.picked && !pickSettled(c) && !pickFailedShow(c); }) : [];   // 픽했는데 아직 피드 미등장·미실패·미해소·미타임아웃 = 분석 중. DATA 로드 전엔 [](깜빡 방지)
let _pickPolling = false;
async function pollPicking() {   // 분석 완료까지 폴링 → Picking… 칩만 제자리 교체(전체 재렌더 X = 깜빡임 방지)
  if (_pickPolling || !pickingNow().length) return;
  _pickPolling = true;
  const t0 = Date.now();
  while (Date.now() - t0 < PICK_TIMEOUT_MS + 60000) {   // 상한 = 무응답 타임아웃(PICK_TIMEOUT_MS 10분)+1분 그레이스 = 픽 조건과 일치(15분 헛폴·무한 재시동 차단·260618)
    await new Promise(r => setTimeout(r, 25000));
    if (document.visibilityState !== 'visible') continue;   // 백그라운드면 쉼
    try { await load(); await loadPickFails(); } catch {}   // 피드(DATA)·실패목록 갱신
    let remaining = 0;
    document.querySelectorAll('.sc-item.picked').forEach(el => {
      if (el.querySelector('.sc-got:not(.picking)')) return;   // 이미 PICKED(완료)면 건너뜀(실패칩은 늦은 성공 자동복구 위해 재평가)
      const c = CANDS.find(x => candId(x) === el.dataset.cid), bot = el.querySelector('.sc-bot');
      if (!c || !bot) return;
      if (pickSettled(c)) { bot.innerHTML = '<div class="sc-got" aria-label="픽 완료" title="탭하면 피드에서 이 기사 열기">PICKED</div>'; el.classList.remove('pickfail'); const g = bot.querySelector('.sc-got'); if (g) g.onclick = () => pickedOpen(c); return; }   // 피드 등장 OR 해소 → PICKED(클릭=피드 이동+팝업)
      if (pickFailedShow(c)) { bot.innerHTML = failChipHtml(c); wireFailChip(bot.querySelector('.sc-fail'), c); el.classList.add('pickfail'); return; }   // Failed 표시(remaining 미가산 → 전건 PICKED/Failed면 즉시 break, 헛폴 차단). 늦은 성공은 pickInFeed·다음 render로 자동복구.
      remaining++;
    });
    if (!remaining) break;
  }
  _pickPolling = false;
}
function detectPickFail() {
  const seen = pfSeen();
  const fresh = pickFailNow().filter(c => !seen.has(candId(c)));
  document.body.classList.toggle('has-pickfail', fresh.length > 0);   // 점등 = 전 탭. 해제 = 수집함 진입(markPickFailSeen).
  if (fresh.length && CURTAB !== 'scrap') showFailToast(fresh.length, fresh[0]);
}
function markPickFailSeen() {
  const seen = pfSeen();
  pickFailNow().forEach(c => seen.add(candId(c)));
  try { localStorage.setItem(PF_SKEY, JSON.stringify([...seen])); } catch {}
  document.body.classList.remove('has-pickfail');
}
let _failToastT;
function showFailToast(n, sample) {
  let t = document.getElementById('nmFailToast');
  if (!t) {
    t = document.createElement('div'); t.id = 'nmFailToast'; t.className = 'nm-toast fail';
    t.onclick = () => { t.classList.remove('show'); showTab('scrap'); };   // 탭 → 수집함(거기서 '다시' 복구)
    document.body.appendChild(t);
  }
  const title = sample ? esc((sample.title || '').slice(0, 34)) : '';
  t.innerHTML = `<span class="tg">⚠ 분석 실패</span><span>${n}건${title ? ' · ' + title + '…' : ''} <b>전문 붙여넣어 복구</b></span>`;
  requestAnimationFrame(() => t.classList.add('show'));
  clearTimeout(_failToastT); _failToastT = setTimeout(() => t.classList.remove('show'), 7000);
}
// Failed 탭 = 묻지 말고 그냥 원문으로 이동(요약요청 모달 안 띄움 · 운영자 요청 260618). 제목 <a>와 동일 동작.
function failOpen(c) {   // ⚠️ window.open이 전역 open(피드 모달)에 가려져 빈 모달이 뜨던 버그 → 앵커 클릭으로 원문 새 탭
  if (!c || !c.url) return;
  const a = document.createElement('a'); a.href = c.url; a.target = '_blank'; a.rel = 'noopener noreferrer';
  document.body.appendChild(a); a.click(); a.remove();
}
// Failed 칩 배선 — 탭=원문 열기 / 길게(480ms)·우클릭=컨텍스트 메뉴(실패 사유·내용 입력). 대기열(qFeedBtn) 롱프레스 패턴 계승.
function wireFailChip(fb, c) {
  if (!fb) return;
  let t = null, lp = false;   // lp = 롱프레스 발화 — 직후 합성 click 억제(원문 안 열림)
  fb.onclick = e => { e.stopPropagation(); if (lp || Date.now() - _failMenuAt < 500) { lp = false; return; } failOpen(c); };   // lp=롱프레스 / 타임스탬프=메뉴 첫항목 focus→칩 blur→lp 리셋이 데스크톱 마우스 홀드의 trailing click 억제를 깨던 것 봉합(둘 중 하나면 원문 안 엶)
  fb.addEventListener('pointerdown', e => { if (e.button) return; lp = false; clearTimeout(t); t = setTimeout(() => { lp = true; openFailMenu(c, fb); }, 480); });
  ['pointerup', 'pointercancel', 'pointerleave'].forEach(ev => fb.addEventListener(ev, () => clearTimeout(t)));
  fb.addEventListener('contextmenu', e => { e.preventDefault(); e.stopPropagation(); clearTimeout(t); openFailMenu(c, fb); });   // 우클릭은 click 미발생 → lp 안 건드림
  fb.addEventListener('blur', () => { lp = false; });   // 메뉴를 ESC/외부클릭으로 닫아 lp 가 true로 남았을 때 다음 키보드 Enter 1회 삼킴 방지(pointerup 리셋은 합성 click 억제를 깨므로 금지)
  fb.addEventListener('pointermove', e => { if (Math.abs(e.movementX) + Math.abs(e.movementY) > 8) clearTimeout(t); });   // 칩이 스크롤 리스트(수집함) 안 — 드래그 스크롤로 손가락 이동하면 롱프레스 타이머 취소(스크롤 중 메뉴 오발 차단)
}
let _failMenuC = null, _failMenuAt = 0;   // _failMenuAt = 메뉴 오픈 시각 — 직후 합성 click 억제(아래 onclick)
function openFailMenu(c, anchor) {
  const m = $('#failmenu'); if (!m || !anchor) return;
  closeOverlays(); _failMenuC = c;
  m.hidden = false;   // 먼저 표시해야 offset 측정 가능
  const r = anchor.getBoundingClientRect(), mh = m.offsetHeight, mw = m.offsetWidth;
  let top = r.bottom + 6;
  if (top + mh > window.innerHeight - 8) top = r.top - mh - 6;   // 아래 공간 부족 → 칩 위로
  top = Math.max(8, top);
  let left = r.left + r.width / 2 - mw / 2;
  left = Math.max(8, Math.min(left, window.innerWidth - mw - 8));
  m.style.top = top + 'px'; m.style.left = left + 'px';
  _failMenuAt = Date.now();   // focus()가 칩 blur→lp 리셋을 유발해도 직후 click 은 위 onclick 의 타임스탬프 가드로 억제
  const f0 = m.querySelector('.failmenu-it'); if (f0) f0.focus();   // 키보드 접근성 — 첫 항목 포커스(Tab/Enter 도달)
}
function closeFailMenu() { const m = $('#failmenu'); if (m && !m.hidden) m.hidden = true; }
// 실패 사유 = 왜 실패했는지 다음에 조치할 수 있게 육하원칙으로 정리한 진단 MD(대기열 qDownload 와 동일 결) — 클릭 시 바로 다운로드(표시 X).
function failDownload(c) {
  if (!c) return;
  const nowK = new Date().toLocaleString('ko-KR', { timeZone: 'Asia/Seoul' });
  const rt = ratingsAll()[candId(c)] || {};
  const pickedK = rt.pickedAt ? new Date(rt.pickedAt).toLocaleString('ko-KR', { timeZone: 'Asia/Seoul' }) : '?';
  const reason = pfReason(c) || (pickTimedOut(c) ? '무응답(10분+ 미반영) — 서버 실패기록 없음(analyze 미완/지연 추정)' : 'fetch 차단(403 추정)');
  const onServer = PFAIL.has(_normU(c.url));   // 서버 실패목록(picks-failed) 등재 = 분석단계 실패 / 아니면 클라 타임아웃
  const mems = [...new Set((c.cluster_members || []).map(_normU))].filter(u => u && u !== _normU(c.url));
  const L = [];
  L.push('# 픽 분석 실패 진단 — ' + (c.title || '(제목 없음)'));
  L.push('', '> 자동 생성(수집함 Failed 칩). 이 파일을 클로드에게 전달하면 원인 분석·복구에 사용합니다. 또는 같은 메뉴의 「내용 입력」으로 기사 전문을 붙여넣어 재분석할 수 있습니다.', '');
  L.push('## 요약 (5W1H)');
  L.push('- **언제(When)**: 픽 ' + pickedK + ' (KST) · 진단 ' + nowK);
  L.push('- **무엇(What)**: ' + (c.title || '(제목 없음)') + (c.media ? ' · 매체 ' + c.media : ''));
  L.push('- **어디서(Where)**: ' + (onServer ? '`pending/failed/`(분석 단계 실패로 격리) + `picks-failed.json` 등재' : '서버 실패기록 없음 — 클라이언트 무응답 타임아웃(10분 초과)'));
  L.push('- **어떻게(How)**: 수집함 PICK → api/pick → pending → news-analyze. 원매체 fetch 가 데이터센터 IP 403 으로 막히면 본문 확보 실패.');
  L.push('- **누가(Who)**: 운영자 픽');
  L.push('- **왜(Why·추정)**: ' + reason);
  L.push('', '## 입력 (Input)');
  L.push('- 원문 URL: ' + (c.url || '(없음)'));
  L.push('- 식별자(candId): `' + candId(c) + '`');
  L.push('- 교차보도(cross): ' + (c.cross != null ? c.cross : '?') + ' 매체');
  if (mems.length) { L.push('- 같은 사건 다른 매체(cluster_members · 대체 fetch 후보):'); mems.slice(0, 12).forEach(u => L.push('  - ' + u)); }
  L.push('', '## 진단·복구 힌트 (클로드용)');
  L.push('- 데이터센터 IP 403 = 매체 WAF(조선·동아·연합·중앙 등)가 러너 IP 차단. 헤더로 못 뚫음 → **기사 전문 직접 입력**이 정공법.');
  L.push('- 복구 A(웹앱): 이 메뉴의 「내용 입력」 → 기사 본문 붙여넣기 → 전송. body 동봉 pending 으로 재분석(403 무관).');
  L.push('- 복구 B(폰): Termux 공유로 전문 전달(가정용 IP=200).');
  L.push('- 대체: 위 cluster_members 중 접근 가능한 매체를 alt 로 줘 본문 확보.');
  L.push('- 확인: GitHub Actions `news-analyze` 최근 run → `Analyze pending articles` 스텝 로그(`pending/failed/*.log`).');
  try {
    const a = document.createElement('a');
    a.href = URL.createObjectURL(new Blob([L.join('\n')], { type: 'text/markdown;charset=utf-8' }));
    a.download = '픽실패_' + candId(c).replace(/[^\w.-]+/g, '_').slice(0, 40) + '.md';
    document.body.appendChild(a); a.click(); a.remove();
    setTimeout(() => { try { URL.revokeObjectURL(a.href); } catch {} }, 1500);
  } catch (e) { console.warn('진단 MD 다운로드 실패', e); }   // Blob/ObjectURL 극한 실패(모바일 WebView 등) — 미처리 예외 차단(손상 없음·재시도 가능)
}
// 내용 입력 = 기사 전문을 직접 붙여넣어 재분석(막힌 매체 403 우회). askdlg UIUX 계승(.sbtn 클립·X·전송).
let _pasteC = null;
function openPaste(c) {
  if (!c) return;
  if (pastedlg.open) return;   // 전송 중(1.3s)·이미 열림 = 재진입 차단(_pasteC 덮어쓰기·중복 커밋 방지)
  _pasteC = c;
  $('#pasteStatus').textContent = ''; $('#pasteText').value = '';
  $('#pasteSub').textContent = (c.title || '').slice(0, 80) || (c.url || '');
  updatePasteClip();
  pastedlg.showModal();
  setTimeout(() => $('#pasteText').focus(), 60);
}
// PICKED 클릭 → 피드(메뉴3) 이동 + 해당 기사 팝업. 픽 결과가 피드에 떴으니(pickInFeed) url/클러스터로 매칭해 open(a).
function pickedOpen(c) {   // PICKED → 피드 이동+모달. url/cluster 매칭, 없으면 load() 후 재매칭(feedOpenBy 공용)
  const us = new Set([_normU(c.url), ...((c.cluster_members || []).map(_normU))].filter(Boolean));
  feedOpenBy(() => DATA.find(x => x && x.url && us.has(_normU(x.url))));
}
// 보관한도(데이터)는 크게(10일·수천 건) 두되, 화면은 컬럼당 SC_PAGE장만 그려 가볍게 유지.
// 전량 렌더 + 매 탭마다 재렌더는 수백 장 넘으면 모바일이 버벅임 → '더 보기'로 청크 추가.
const SC_PAGE = 150;
const scShown = { cross: SC_PAGE, new: SC_PAGE };   // 컬럼별 현재 렌더 장수(재렌더에도 유지)
let ratedKeep = new Set();   // 이번 세션에 별점 매긴 카드 = 다음 갱신(새로고침) 전까진 유지, 갱신 때 리스트서 제외
function renderScrap() {
  closeFailMenu();   // 전체 재렌더 = Failed 칩 노드 교체 → 열린 컨텍스트 메뉴 앵커가 stale → 닫음
  const host = $('#scrapList'); if (!host) return;
  const q = ($('#q') ? $('#q').value : '').trim().toLowerCase();
  const rt = ratingsAll(); scRT = rt;   // scRT = 정렬에서 픽 상태(누적 고정 제외) 참조
  const base = q ? CANDS.filter(c => ((c.title || '') + ' ' + (c.media || c.source || '')).toLowerCase().includes(q)) : CANDS;   // 수집된 후보 전반 대상
  const pool = base.filter(c => {
    const r = rt[candId(c)] || {};
    if (r.dismissed) return false;                                  // 👎 관심없음 = 영구 제외
    if (r.score >= 1 && !ratedKeep.has(candId(c))) return false;    // 별점 매긴 건 = 다음 갱신 때 제외(이번 세션은 유지·DB엔 남김)
    if (JUNK_HEAD.test(c.title || '')) return false;                // 머리표 junk([알림]·[사진]·[부고] 등 = 뉴스 아님) 양 컬럼서 제외
    return true;
  });
  if (!pool.length) { host.classList.remove('scrap-cols'); host.innerHTML = `<div class="scrap-empty">${q ? '검색 결과 없음' : '수집 대기 중 — 스크래퍼(RSS)가 돌면 여기 후보가 쌓여.'}</div>`; return; }
  host.classList.add('scrap-cols');
  host.innerHTML = SC_COLS_HTML;
  const CROSS_MIN = 8;   // 누적 = 8개 매체 이상 보도된 것만 쌓음(운영자 260617: 5→8 엄선 — 5~7매체 어중간한 건 컷, 진짜 다매체 큰 것만 누적칼럼). 소수 매체만 다룬 약한 건 노이즈 → 누적서 제외·DB엔 잔존. 조정 가능.
  const _untri = c => { const r = rt[candId(c)] || {}; return !((r.action && r.action !== 'pick') || r.passed); };   // down/pass=양 컬럼서 제외 · PICK=잔류(맨 아래 PICKED 비활성)
  // 픽은 더 이상 가라앉히지 않음(운영자 260617: PICKED도 제자리서 인식 필요) → _pk 정렬키 제거. PICKED 표시·비활성만 유지.
  host.querySelectorAll('.scrap-list[data-col]').forEach(col => {
    const key = col.dataset.col;
    let arr;
    if (key === 'new') {   // 신규 칼럼 = 최신분만. scFast(속보 OR 2+매체 양질) AND 발생 4h 내. 4h 지난 건 신규서 빠져 누적行(거기서 찾음). 정렬 = 핀 → fastScore → 최신순.
      arr = pool.filter(c => _untri(c) && scFast(c) && (Date.now() - scTs(c)) < FAST_MAX_H * 3600000);   // 신규 = scFast AND 발생 <FAST_MAX_H(4h). 4h+ 는 누적行(아래). 오래된 속보가 신규 톱 차지·누적 중복하던 회귀 차단.
      arr.sort((a, b) => (pinFresh(b) - pinFresh(a)) || (fastScore(b) - fastScore(a)) || scTs(b) - scTs(a));   // 최신 속보 핀 → fastScore decay 하강(톱 독차지 방지). 픽은 가라앉히지 않음 — 제자리 유지·PICKED 표시.
    } else {   // 누적 = 9시뉴스감(좌측·넓은 누적). 발생 4h↑(신규서 졸업) AND (cross≥8 OR 긴급[breaking] OR 연속보도 보조진입[followEnters: cross≥4 AND rc≥6 AND grade∉0,1]). 최신(<4h)과 시간 배타. ⚠️ 긴급이었던 건 cross<8이어도 누적 합류(사라지는 구멍 차단·운영자 260617) → 일반 누적 점수(scScore)로 랭킹. 중요도순.
      arr = pool.filter(c => _untri(c) && ((c.cross || 0) >= CROSS_MIN || isBreaking(c) || followEnters(c)) && (Date.now() - scTs(c)) >= FAST_MAX_H * 3600000);
      arr.sort((a, b) => (scScore(b) - scScore(a)) || scTs(b) - scTs(a));   // 순수 scScore 순. 픽은 가라앉히지 않음 — 제자리 유지·PICKED 표시(운영자 인식 필요). ⚠️ 강제핀(pinB) 제거(260617): 오래된 breaking이 최신 고득점 위에 박혀 시간 가속감점을 무력화하던 것 차단(실측: 밀양 28h·score9.5가 최신 score71 위 점유). ⚡이슈 배지는 유지(찾기 가능)·최신 pinFresh(최신속보 핀)는 별개 유지.
    }
    const lim = Math.min(scShown[key], arr.length);
    for (let i = 0; i < lim; i++) {
      const el = makeScItem(arr[i], ratingFor(arr[i]), key);   // 멤버기반 picked 승계로 rep 점프해도 PICKED 유지
      el.style.animationDelay = Math.min(i, 14) * 32 + 'ms';   // 촤르륵 스태거(펼쳐짐)
      col.appendChild(el);
    }
    if (arr.length > lim) {                                             // 나머지는 보관만 — 탭하면 추가 렌더
      const more = document.createElement('button');
      more.className = 'sc-more'; more.type = 'button';
      more.textContent = `더 보기 +${Math.min(SC_PAGE, arr.length - lim)}  ·  남은 ${arr.length - lim}건`;
      more.onclick = () => { scShown[key] += SC_PAGE; renderScrap(); };
      col.appendChild(more);
    }
  });
  pollPicking();   // 픽 후·새로고침 잔존 Picking… 분석완료 폴 시동(가드: 진행중·picking 없으면 즉시 반환)
}
// scTs = 발행시각(정렬·최신성 판정용). ⚠️ 일부 매체가 KST(+09:00)를 +00:00로 오기록 → 발행이 미래/수집(first_seen)보다 뒤로 박혀 '미래 기사'가 신규 최상단을 부당 점유(260618 실측 0.2%). 가드: 발행이 미래거나 수집보다 뒤면(=물리적 불가) first_seen 사용.
const scTs = c => {
  const p = Date.parse(c.published || ''), f = Date.parse(c.first_seen || '');
  if (!isNaN(p) && p <= Date.now() + 60000 && (isNaN(f) || p <= f + 60000)) return p;   // 발행 정상(미래 아님·수집보다 앞) → 발행 우선
  if (!isNaN(f)) return f;                                                               // 발행 오기록(미래·수집보다 뒤) → 수집시각(존재 확인된 상한)
  return isNaN(p) ? 0 : p;
};
// ── 최신 게이트(scFast): 최신한 '속보 OR 양질의 다매체 보도'. = breaking(속보) OR (2+매체 cross≥2 AND 잡음아님 grade∉{0,1}). 보도자료/경미(0/1)만 빼고, 미채점·주목(2)·대형(3)·속보 다 포함. 랭킹에서 연속보도(scFollow)·품질(gradeW)로 양질이 상단. ──
const FAST_MAX_H = 4, FAST_HALF_H = 2;   // ⏱ 신규↔누적 칼럼 경계 = 발생 4h(운영자 정본 260617: 최신=나이<4h=화면 '3시간 전'까지 / 누적=나이≥4h='4시간 전'부터). 자리(칼럼)=신규·누적 / 사건(배지)=긴급=속보[breaking] = 별개 축 — 긴급 사건은 나이 들면 *자리만* 신규→누적로 이동(개념 불변). 이 한 상수가 최신진입·누적진입·속보핀·토스트·배지(🚨긴급↔⚡이슈)를 전부 결정 = 단일출처(드리프트 차단). FAST_HALF_H=하강 반감기. 조정 가능.
const scFast = c => isBreaking(c) || ((c.cross || 0) >= 2 && c.grade !== 0 && c.grade !== 1);
const FOLLOW_W = 0.2;   // 연속보도 가점 가중 — 또 보도될수록↑. 조정 가능.
// 연속보도 가점 = report_count(arts=기사 수 증가 사이클 = '또 보도됨', 같은 매체 1곳이여도 +1). seen_count(12h 윈도우 존재만으로도 올라 결함) 대체. 보도 끊기면 안 오름 → 시간 decay에 밀림(보도자료 자연 침몰).
const scFollow = c => 1 + FOLLOW_W * Math.log2(1 + (c.report_count || 0));
// 누적 '연속보도' 보조진입 — cross<8이어도 계속 또 보도되면(report_count↑) + AI 양질(grade≥2)이면 9시뉴스감 합류. ⚠️ cross≥8 단독선은 *불변*, 이건 rc+grade 동반 *보조* 진입로(§1 "cross 임계 낮추기" 아님 — cross·연속·품질 3중 게이트). §★·§5 '연속보도=제일 무거운 신호'를 진입에도 관철(260618 · cross-only서 rc=14짜리 지속보도 누락 실측·Opus 5인 검증).
const FOLLOW_CROSS_MIN = 4, FOLLOW_RC_MIN = 6;   // 보조진입 임계(보수: 4매체+ AND 6회+ 후속보도 AND 잡음·경미[grade0/1] 제외). 조정 가능.
const followEnters = c => (c.cross || 0) >= FOLLOW_CROSS_MIN && (c.report_count || 0) >= FOLLOW_RC_MIN && c.grade !== 0 && c.grade !== 1;
// AI 경중 게이트 가중 — gate_judge가 grade 0~3 채점(0 비뉴스/보도자료 · 1 경미 · 2 주목 · 3 대형). 구조가 못 가르는 보도자료·잡음 침몰·대형 부상. 미채점(grade 없음)=중립 1(콜드스타트=구조만). docs §2.5.
const GRADE_W = { 0: 0.05, 1: 0.4, 2: 1.0, 3: 1.8 };
const gradeW = c => (c.grade == null ? 1 : (GRADE_W[c.grade] ?? 1));
