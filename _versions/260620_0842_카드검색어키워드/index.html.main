  requestAnimationFrame(() => fitEditLines(wrap));   // 반응형 폭 맞춤
}
function addLineAfter(li) {   // 그 줄 바로 아래 빈 줄 + 커서
  if (edLines.length >= MAX_LINES) return;
  edLines.splice(li + 1, 0, []);
  PENDING_FOCUS = li + 1;
