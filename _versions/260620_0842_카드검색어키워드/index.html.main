}
function dropLine(li) {   // 빈 줄 제거 — 단 마지막 1줄은 빈 채로 유지(저장 게이트가 빈 텍스트 막음)
  if (edLines.length <= 1) { edLines[0] = []; renderEditChips(); return; }
  edLines.splice(li, 1);
  renderEditChips();
