# 파이썬 캐시 (썸네일 스크립트 import 시 생성)
__pycache__/
*.pyc

# 로컬 dev 토큰계측 shard (claude_py — CI는 run-id shard만 커밋, 로컬 run은 추적 안 함)
metrics/usage/local-*.jsonl

# 활성 계정 쿼터 신호(폴오버 SSOT ↔ account_failover.py 승격 공유 파일 · 커밋 대상 아님)
.nomute_active_quota

# Pages 빌드 산출물(빌드 시 생성)
viewer/articles.json
viewer/messages.json
viewer/picks-failed.json
viewer/triage-state.json
viewer/thumb-hist.json
viewer/detail/
viewer/cards/
viewer/assets/

# 에이전트 워크트리(격리 작업 — 추적 금지)
.claude/worktrees/

# 검증 도구 임시 설치(playwright-core 등) — 레포 유입 금지(zero-dependency 유지)
node_modules/

# FX 모델 바이너리(무해시 자동 다운로드 금지 = setup.sh sha256 핀 드롭 or 수동 드롭인 · 레포 커밋 대상 아님)
apps/fx/models/
